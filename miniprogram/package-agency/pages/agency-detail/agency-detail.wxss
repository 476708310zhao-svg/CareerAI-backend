/* pages/agency-detail/agency-detail.wxss — Linear Dark Theme */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ══════════════════════════════════════
   机构信息卡
══════════════════════════════════════ */
.info-card {
  background: var(--bg-panel);
  margin-bottom: 12rpx;
  overflow: hidden;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

/* 头部横幅 */
.info-head {
  background: var(--bg-panel);
  padding: 40rpx 28rpx 28rpx;
  display: flex;
  align-items: flex-end;
  gap: 22rpx;
  border-bottom: 1.5rpx solid rgba(0,0,0,0.05);
}

/* Logo */
.logo-wrap { flex-shrink: 0; }
.logo-img {
  width: 108rpx; height: 108rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(255,255,255,0.12);
}
.logo-placeholder {
  width: 108rpx; height: 108rpx;
  border-radius: 22rpx;
  background: rgba(94,106,210,0.20);
  border: 2rpx solid rgba(94,106,210,0.35);
  display: flex; align-items: center; justify-content: center;
}
.logo-text { font-size: 34rpx; font-weight: 800; color: #6366F1; letter-spacing: 1rpx; }

/* 名称区 */
.info-main { flex: 1; min-width: 0; }
.name-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 12rpx; flex-wrap: wrap;
}
.agency-name { font-size: 34rpx; font-weight: 700; color: var(--text-primary); line-height: 1.3; }
.verified-badge {
  background: rgba(16,185,129,0.15);
  border: 1.5rpx solid rgba(16,185,129,0.35);
  border-radius: 8rpx; padding: 4rpx 14rpx; flex-shrink: 0;
}
.verified-badge text { font-size: 22rpx; color: var(--success); font-weight: 600; }
.unofficial-badge {
  background: rgba(156,163,175,0.15);
  border: 1.5rpx solid rgba(156,163,175,0.35);
  border-radius: 8rpx; padding: 4rpx 14rpx; flex-shrink: 0;
}
.unofficial-badge text { font-size: 22rpx; color: var(--text-muted); font-weight: 500; }
.meta-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.type-tag {
  font-size: 23rpx; color: #6366F1;
  background: #EEF2FF;
  padding: 5rpx 16rpx; border-radius: 8rpx; font-weight: 500;
  border: 1rpx solid rgba(94,106,210,0.30);
}
.city { font-size: 24rpx; color: var(--text-muted); }
.website-txt { font-size: 24rpx; color: var(--text-muted); }

/* 信息主体区 */
.info-body { padding: 24rpx 28rpx 4rpx; }

/* 简介 */
.desc-text {
  font-size: 28rpx; color: var(--text-muted);
  line-height: 1.75; display: block;
  margin-bottom: 20rpx;
}

/* 价格标签行 */
.price-tag-row {
  display: flex; align-items: flex-start;
  gap: 14rpx; margin-bottom: 18rpx;
}
.price-row-label {
  font-size: 24rpx; color: var(--text-muted);
  flex-shrink: 0; padding-top: 10rpx;
}
.price-pills { display: flex; flex-wrap: wrap; gap: 10rpx; }
.price-pill {
  display: flex; align-items: center; gap: 6rpx;
  background: rgba(255,255,255,0.04);
  border: 1.5rpx solid rgba(0,0,0,0.06);
  border-radius: 10rpx; padding: 8rpx 16rpx;
}
.price-pill-region { font-size: 22rpx; color: var(--text-muted); }
.price-pill-val { font-size: 24rpx; font-weight: 600; color: var(--text-secondary); }

/* 四维评分 */
.score-section {
  background: rgba(255,255,255,0.03);
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
}
.score-empty { padding: 16rpx 0 20rpx; }
.score-overview {
  display: flex; align-items: center;
  gap: 24rpx; margin-bottom: 22rpx;
}
.score-big { font-size: 72rpx; font-weight: 900; color: var(--warning); line-height: 1; }
.score-right { display: flex; flex-direction: column; gap: 8rpx; }
.stars-row { display: flex; gap: 4rpx; }
.star { font-size: 30rpx; }
.star.full  { color: var(--warning); }
.star.half  { color: var(--warning); opacity: 0.5; }
.star.empty { color: var(--bg-raised); }
.review-count { font-size: 24rpx; color: var(--text-muted); }
.dim-bars { display: flex; flex-direction: column; gap: 14rpx; }
.dim-row { display: flex; align-items: center; gap: 14rpx; }
.dim-label { font-size: 24rpx; color: var(--text-muted); width: 90rpx; flex-shrink: 0; }
.bar-track {
  flex: 1; height: 8rpx;
  background: rgba(0,0,0,0.06); border-radius: 4rpx; overflow: hidden;
}
.bar-fill {
  height: 100%;
  background: var(--brand);
  border-radius: 4rpx;
}
.dim-val { font-size: 24rpx; color: var(--text-secondary); font-weight: 600; width: 44rpx; text-align: right; flex-shrink: 0; }
.score-empty-txt { font-size: 26rpx; color: var(--text-muted); }

/* 专长标签 */
.spec-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 20rpx; }
.spec-tag {
  font-size: 24rpx; color: var(--text-muted);
  background: rgba(0,0,0,0.04);
  padding: 8rpx 18rpx; border-radius: 10rpx;
  border: 1.5rpx solid rgba(0,0,0,0.06);
}

/* ══════════════════════════════════════
   Tab 栏
══════════════════════════════════════ */
.tab-bar {
  display: flex; position: relative;
  background: var(--bg-panel);
  border-bottom: 1.5rpx solid rgba(0,0,0,0.04);
  margin-bottom: 12rpx;
}
.tab {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 8rpx; padding: 26rpx 0;
  font-size: 28rpx; color: var(--text-muted); font-weight: 500;
}
.tab.active { color: var(--text-primary); font-weight: 700; }
.tab-dot { width: 14rpx; height: 14rpx; background: var(--success); border-radius: 50%; }
.tab-badge {
  font-size: 20rpx;
  background: #EEF2FF;
  color: var(--brand);
  border-radius: var(--r-lg); padding: 2rpx 12rpx; font-weight: 500;
}
.tab-indicator {
  position: absolute; bottom: 0; width: 50%; height: 3rpx;
  background: var(--brand);
  border-radius: 4rpx 4rpx 0 0;
  transition: left 0.25s cubic-bezier(0.4,0,0.2,1);
}

/* ══════════════════════════════════════
   AI 测评区
══════════════════════════════════════ */
.ai-trigger-card {
  background: rgba(94,106,210,0.08);
  border: 1.5rpx solid rgba(94,106,210,0.25);
  border-radius: var(--r-lg);
  padding: 28rpx 24rpx;
  margin: 0 16rpx 16rpx;
}
.ai-intro-header {
  display: flex; align-items: center;
  gap: 18rpx; margin-bottom: 20rpx;
}
.ai-intro-badge {
  width: 68rpx; height: 68rpx;
  background: var(--brand);
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 800; color: #FFF; flex-shrink: 0;
}
.ai-intro-info { flex: 1; }
.ai-intro-title { display: block; font-size: 30rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 6rpx; }
.ai-intro-sub   { display: block; font-size: 23rpx; color: var(--text-muted); line-height: 1.55; }
.ai-intro-dims {
  display: flex; flex-wrap: wrap;
  gap: 10rpx; margin-bottom: 24rpx;
}
.ai-dim-pill {
  font-size: 22rpx; color: #6366F1;
  background: #EEF2FF;
  padding: 6rpx 16rpx; border-radius: 9999rpx;
  border: 1rpx solid rgba(94,106,210,0.28);
}
.ai-trigger-btn {
  display: block; text-align: center;
  background: var(--brand);
  color: #FFF; font-size: 28rpx; font-weight: 600;
  padding: 20rpx; border-radius: var(--r-sm);
}

/* 生成中 */
.ai-loading-card {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 24rpx; padding: 80rpx 28rpx;
}
.ai-loading-txt { font-size: 27rpx; color: var(--text-muted); }
.spinner {
  width: 56rpx; height: 56rpx;
  border: 5rpx solid rgba(0,0,0,0.04);
  border-top-color: var(--brand);
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* AI 测评内容 */
.ai-eval-wrap { padding: 0 16rpx 20rpx; }
.eval-meta-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14rpx 0 12rpx;
}
.eval-meta-txt { font-size: 23rpx; color: var(--text-muted); }
.regen-btn {
  font-size: 24rpx; color: var(--brand); font-weight: 500;
  padding: 6rpx 18rpx;
  background: #EEF2FF;
  border-radius: var(--r-lg);
  border: 1rpx solid rgba(94,106,210,0.25);
}

/* 总体评分卡 */
.eval-score-card {
  background: var(--bg-panel); border-radius: 18rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  padding: 28rpx; margin-bottom: 0;
  display: flex; align-items: center; justify-content: space-between;
}
.eval-score-left { display: flex; align-items: baseline; gap: 6rpx; flex-wrap: wrap; }
.eval-score-num { font-size: 80rpx; font-weight: 900; color: var(--warning); line-height: 1; }
.eval-score-sub { font-size: 32rpx; color: var(--text-muted); }
.eval-score-label { font-size: 24rpx; color: var(--text-muted); width: 100%; margin-top: 4rpx; }
.eval-recommend {
  display: flex; flex-direction: column;
  align-items: center; gap: 8rpx;
  padding: 20rpx 32rpx; border-radius: var(--r-md);
}
.eval-recommend.yes { background: rgba(16,185,129,0.12); border: 1rpx solid rgba(16,185,129,0.25); }
.eval-recommend.no  { background: rgba(239,68,68,0.12);  border: 1rpx solid rgba(239,68,68,0.25); }
.recommend-icon { font-size: 44rpx; }
.recommend-txt  { font-size: 26rpx; font-weight: 700; }
.eval-recommend.yes .recommend-txt { color: var(--success); }
.eval-recommend.no  .recommend-txt { color: var(--danger); }
.eval-recommend-reason {
  background: rgba(245,158,11,0.10);
  border: 1.5rpx solid rgba(245,158,11,0.25);
  border-radius: 14rpx; padding: 20rpx 24rpx; margin-top: 12rpx;
}
.reason-label { display: block; font-size: 24rpx; color: var(--warning); font-weight: 600; margin-bottom: 8rpx; }
.reason-txt   { font-size: 26rpx; color: var(--text-secondary); line-height: 1.65; }

/* 各章节 */
.eval-section {
  background: var(--bg-panel); border-radius: 18rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  padding: 24rpx; margin-top: 12rpx;
}
.eval-section-title {
  display: flex; align-items: center; gap: 14rpx; margin-bottom: 18rpx;
}
.section-num {
  font-size: 21rpx; font-weight: 800; color: var(--brand);
  background: #EEF2FF;
  padding: 4rpx 14rpx; border-radius: 8rpx;
  border: 1rpx solid rgba(94,106,210,0.25);
}
.section-name { font-size: 30rpx; font-weight: 700; color: var(--text-primary); }

/* KV 列表 */
.eval-kv-list { display: flex; flex-direction: column; gap: 14rpx; }
.kv-row { display: flex; gap: 16rpx; align-items: flex-start; }
.kv-key { font-size: 25rpx; color: var(--text-muted); flex-shrink: 0; width: 90rpx; padding-top: 2rpx; }
.kv-val { font-size: 26rpx; color: var(--text-secondary); flex: 1; line-height: 1.65; }

/* 服务标签 */
.service-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 16rpx; }
.service-tag {
  font-size: 24rpx; color: var(--brand);
  background: #EEF2FF;
  padding: 8rpx 18rpx; border-radius: 10rpx;
  border: 1rpx solid rgba(94,106,210,0.25);
}

/* 价格表格 */
.price-grid { display: flex; gap: 12rpx; }
.price-item {
  flex: 1; background: rgba(255,255,255,0.03); border-radius: 14rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05); padding: 18rpx 12rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.price-region { font-size: 23rpx; color: var(--text-muted); }
.price-val { font-size: 23rpx; font-weight: 600; color: var(--text-secondary); text-align: center; line-height: 1.4; }

/* 适用人群 */
.user-tags { display: flex; flex-wrap: wrap; gap: 10rpx; }
.user-tag {
  font-size: 26rpx; color: #6366F1;
  background: #EEF2FF;
  padding: 8rpx 20rpx; border-radius: 10rpx;
  border: 1.5rpx solid rgba(94,106,210,0.25);
}

/* 优劣点 */
.point-list { display: flex; flex-direction: column; gap: 12rpx; }
.point-item {
  display: flex; align-items: flex-start;
  gap: 12rpx; padding: 14rpx 16rpx; border-radius: 14rpx;
}
.point-item.green { background: rgba(16,185,129,0.10); border: 1rpx solid rgba(16,185,129,0.20); }
.point-item.red   { background: rgba(239,68,68,0.10);  border: 1rpx solid rgba(239,68,68,0.20); }
.point-icon {
  font-size: 22rpx; font-weight: 800; flex-shrink: 0;
  width: 36rpx; height: 36rpx; border-radius: 50%;
  line-height: 36rpx; text-align: center;
}
.point-item.green .point-icon { color: var(--success); background: rgba(16,185,129,0.20); }
.point-item.red   .point-icon { color: var(--danger); background: rgba(239,68,68,0.20); }
.point-txt { font-size: 26rpx; line-height: 1.65; flex: 1; }
.point-item.green .point-txt { color: #6ee7b7; }
.point-item.red   .point-txt { color: #fca5a5; }

/* 对比列表 */
.compare-list { display: flex; flex-direction: column; gap: 12rpx; }
.compare-item {
  background: rgba(255,255,255,0.03); border-radius: 14rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05); padding: 16rpx 20rpx;
}
.compare-name { display: block; font-size: 28rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 6rpx; }
.compare-diff { font-size: 26rpx; color: var(--text-muted); line-height: 1.55; }
.plain-text { font-size: 28rpx; color: var(--text-secondary); line-height: 1.75; display: block; }

/* 免责声明横幅 */
.legal-banner {
  background: #FFFBEB;
  border: 1.5rpx solid #FDE68A;
  border-radius: var(--r-md);
  margin: 0 0 12rpx;
  padding: 20rpx 24rpx;
}
.legal-banner-main {
  display: flex; align-items: flex-start; gap: 12rpx; margin-bottom: 14rpx;
}
.legal-icon { font-size: 28rpx; flex-shrink: 0; line-height: 1.6; }
.legal-txt { font-size: 24rpx; color: #92400E; line-height: 1.65; flex: 1; }
.legal-claim-btn {
  background: #FEF3C7;
  border: 1.5rpx solid #FCD34D;
  border-radius: 10rpx;
  padding: 12rpx 20rpx;
  text-align: center;
}
.legal-claim-txt { font-size: 25rpx; color: #B45309; font-weight: 600; }

/* 免责声明（AI测评区） */
.disclaimer {
  margin-top: 20rpx; padding: 20rpx 22rpx;
  background: rgba(245,158,11,0.08);
  border-radius: 14rpx;
  border: 1.5rpx solid rgba(245,158,11,0.20);
}
.disclaimer-title {
  display: block; font-size: 23rpx; color: #d97706;
  font-weight: 700; margin-bottom: 8rpx;
}
.disclaimer-body { font-size: 22rpx; color: #d97706; line-height: 1.7; display: block; }

/* 评测用户须知 */
.review-notice {
  margin: 8rpx 28rpx 0;
  padding: 16rpx 20rpx;
  background: #F9FAFB;
  border-radius: 10rpx;
  border: 1rpx solid var(--border-light);
}
.review-notice text { font-size: 22rpx; color: var(--text-muted); line-height: 1.65; }

/* ══════════════════════════════════════
   用户评测列表
══════════════════════════════════════ */
.review-list { padding: 0 16rpx 20rpx; }
.review-card {
  background: var(--bg-panel); border-radius: 18rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  padding: 24rpx; margin-bottom: 14rpx;
}
.review-head {
  display: flex; align-items: flex-start;
  justify-content: space-between; margin-bottom: 14rpx;
}
.reviewer-info { display: flex; align-items: center; gap: 14rpx; }
.avatar-img { width: 72rpx; height: 72rpx; border-radius: 50%; }
.avatar-placeholder {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(94,106,210,0.20);
  border: 1.5rpx solid rgba(94,106,210,0.30);
  display: flex; align-items: center; justify-content: center;
}
.avatar-placeholder text { font-size: 30rpx; font-weight: 700; color: #6366F1; }
.reviewer-name { display: block; font-size: 28rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 4rpx; }
.review-time   { font-size: 22rpx; color: var(--text-muted); }
.review-rating { display: flex; align-items: center; gap: 4rpx; }
.star.full  { color: var(--warning); }
.star.empty { color: var(--bg-raised); }
.rating-num-sm { font-size: 26rpx; font-weight: 700; color: var(--warning); margin-left: 4rpx; }
.dim-tags { display: flex; gap: 8rpx; margin-bottom: 14rpx; flex-wrap: wrap; }
.dim-tag {
  font-size: 22rpx; color: var(--text-muted);
  background: rgba(0,0,0,0.04);
  padding: 4rpx 14rpx; border-radius: 8rpx;
  border: 1rpx solid rgba(0,0,0,0.05);
}
.review-title { display: block; font-size: 30rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 10rpx; }
.review-content { display: block; font-size: 27rpx; color: var(--text-secondary); line-height: 1.75; margin-bottom: 14rpx; }
.pros-cons { display: flex; flex-direction: column; gap: 10rpx; margin-bottom: 14rpx; }
.pros { background: rgba(16,185,129,0.10); border-radius: var(--r-sm); padding: 14rpx 16rpx; border: 1rpx solid rgba(16,185,129,0.20); }
.cons { background: rgba(239,68,68,0.10);  border-radius: var(--r-sm); padding: 14rpx 16rpx; border: 1rpx solid rgba(239,68,68,0.20); }
.pros-label { display: block; font-size: 22rpx; color: var(--success); font-weight: 600; margin-bottom: 6rpx; }
.cons-label { display: block; font-size: 22rpx; color: var(--danger); font-weight: 600; margin-bottom: 6rpx; }
.pros-txt { font-size: 26rpx; color: #6ee7b7; line-height: 1.6; }
.cons-txt { font-size: 26rpx; color: #fca5a5; line-height: 1.6; }
.review-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(0,0,0,0.04);
}
.like-btn { display: flex; align-items: center; gap: 8rpx; }
.like-icon { font-size: 28rpx; }
.like-cnt  { font-size: 26rpx; color: var(--text-muted); }
.delete-btn {
  font-size: 24rpx; color: var(--danger);
  padding: 6rpx 16rpx;
  background: rgba(239,68,68,0.12);
  border-radius: 8rpx;
  border: 1rpx solid rgba(239,68,68,0.25);
}

/* ── 加载/空状态 ── */
.loading-tip {
  display: flex; align-items: center; justify-content: center;
  gap: 16rpx; padding: 40rpx 0; font-size: 26rpx; color: var(--text-muted);
}
.load-more-btn {
  text-align: center; padding: 28rpx 0;
  font-size: 28rpx; color: var(--brand); font-weight: 600;
  background: rgba(94,106,210,0.10);
  border-radius: var(--r-md); margin: 8rpx 0 16rpx;
  border: 1rpx solid rgba(94,106,210,0.25);
}
.no-more { text-align: center; padding: 36rpx 0; color: var(--text-muted); font-size: 24rpx; }
.empty {
  display: flex; flex-direction: column;
  align-items: center; padding: 80rpx 48rpx 40rpx; text-align: center;
}
.empty-emoji { font-size: 80rpx; line-height: 1; margin-bottom: 24rpx; }
.empty-txt   { font-size: 30rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 10rpx; }
.empty-sub   { font-size: 26rpx; color: var(--text-muted); }

/* ══════════════════════════════════════
   底部操作栏
══════════════════════════════════════ */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; width: 100%;
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--bg-panel);
  border-top: 1.5rpx solid rgba(0,0,0,0.06);
  box-sizing: border-box;
}
.collect-btn {
  display: flex; align-items: center; gap: 8rpx;
  padding: 18rpx 28rpx; border-radius: 9999rpx;
  background: rgba(255,255,255,0.04);
  border: 1.5rpx solid rgba(255,255,255,0.10);
}
.collect-btn.collected {
  background: rgba(239,68,68,0.12);
  border-color: rgba(239,68,68,0.30);
}
.collect-icon { font-size: 32rpx; }
.collect-txt  { font-size: 28rpx; color: var(--text-secondary); font-weight: 500; }
.collect-btn.collected .collect-txt { color: var(--danger); }
.write-review-btn {
  flex: 1; text-align: center;
  background: var(--brand);
  color: #FFF; font-size: 30rpx; font-weight: 700;
  padding: 20rpx 0; border-radius: 9999rpx;
}

/* ══════════════════════════════════════
   写评测弹窗
══════════════════════════════════════ */
.modal-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.75); z-index: 200;
}
.review-modal {
  position: fixed; bottom: -100%; left: 0; width: 100%;
  background: var(--bg-panel);
  border-radius: 32rpx 32rpx 0 0;
  border-top: 1.5rpx solid rgba(255,255,255,0.10);
  z-index: 201; max-height: 90vh;
  overflow-y: scroll; padding-bottom: env(safe-area-inset-bottom);
  transition: bottom 0.3s cubic-bezier(0.4,0,0.2,1);
}
.review-modal.show { bottom: 0; }
.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 28rpx 20rpx;
  border-bottom: 1.5rpx solid rgba(0,0,0,0.05);
  position: sticky; top: 0; background: var(--bg-panel); z-index: 1;
}
.modal-title { font-size: 34rpx; font-weight: 700; color: var(--text-primary); }
.modal-close { font-size: 30rpx; color: var(--text-muted); padding: 8rpx 16rpx; }
.modal-section { padding: 16rpx 28rpx 0; }
.modal-label { display: block; font-size: 26rpx; color: var(--text-muted); margin-bottom: 12rpx; font-weight: 500; }
.required { color: var(--danger); }
.star-selector { display: flex; align-items: center; gap: 8rpx; }
.star-sel { font-size: 48rpx; color: var(--bg-raised); }
.star-sel.selected { color: var(--warning); }
.star-sel.sm { font-size: 36rpx; }
.star-hint { font-size: 26rpx; color: var(--text-muted); margin-left: 12rpx; }
.dim-score-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.dim-score-lbl { font-size: 26rpx; color: var(--text-secondary); width: 90rpx; flex-shrink: 0; }
.modal-input {
  width: 100%; height: 80rpx; line-height: 80rpx;
  background: rgba(255,255,255,0.04);
  border-radius: var(--r-sm);
  padding: 0 20rpx; font-size: 28rpx; color: var(--text-primary);
  border: 1.5rpx solid rgba(0,0,0,0.06); box-sizing: border-box;
}
.modal-textarea {
  width: 100%; min-height: 180rpx;
  background: rgba(255,255,255,0.04);
  border-radius: var(--r-sm);
  padding: 16rpx 20rpx; font-size: 28rpx; color: var(--text-primary);
  border: 1.5rpx solid rgba(0,0,0,0.06); box-sizing: border-box; line-height: 1.65;
}
.char-count { display: block; text-align: right; font-size: 22rpx; color: var(--text-muted); margin-top: 6rpx; }
.anon-row { display: flex; align-items: center; justify-content: space-between; padding-bottom: 8rpx; }
.modal-submit {
  margin: 24rpx 28rpx 32rpx;
  background: var(--brand);
  color: #FFF; text-align: center; font-size: 32rpx; font-weight: 700;
  padding: 26rpx 0; border-radius: 9999rpx;
}
.modal-submit.disabled { opacity: 0.4; }
