/* pages/settings/settings.wxss */
page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.settings-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 58%, #ecfffb 100%);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.08);
}

.hero-kicker,
.hero-title,
.hero-sub,
.badge-num,
.badge-label,
.section-title,
.section-sub,
.setting-title,
.setting-desc,
.status-title,
.status-desc {
  display: block;
}

.hero-kicker {
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 8rpx;
  color: #101828;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 950;
}

.hero-sub {
  width: 420rpx;
  max-width: 100%;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.hero-badge {
  width: 126rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(145deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 18rpx 34rpx rgba(37,99,235,0.22);
  flex-shrink: 0;
}

.badge-num {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 950;
}

.badge-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 800;
  opacity: 0.88;
}

.setting-section {
  margin-top: 28rpx;
}

.section-head {
  margin: 0 4rpx 14rpx;
}

.section-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 950;
}

.section-sub {
  margin-top: 8rpx;
  color: #718096;
  font-size: 23rpx;
}

.setting-card {
  border-radius: 28rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
  overflow: hidden;
}

.setting-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 120rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(226,232,240,0.82);
}

.setting-row:last-child {
  border-bottom: 0;
}

.setting-row.link:active {
  background: #f8fbff;
}

.setting-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef4ff;
  font-size: 31rpx;
  flex-shrink: 0;
}

.setting-main {
  flex: 1;
  min-width: 0;
}

.setting-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.setting-desc {
  margin-top: 8rpx;
  color: #718096;
  font-size: 23rpx;
  line-height: 1.42;
}

.row-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.cache-size {
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 900;
}

.arrow {
  color: #98a2b3;
  font-size: 42rpx;
  line-height: 1;
  flex-shrink: 0;
}

switch {
  transform: scale(0.82);
  transform-origin: right center;
  flex-shrink: 0;
}

.status-card {
  margin-top: 28rpx;
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.88);
  border: 1rpx solid rgba(220,229,240,0.96);
}

.status-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
  text-align: center;
}

.status-desc {
  margin-top: 10rpx;
  color: #718096;
  font-size: 23rpx;
  line-height: 1.5;
  text-align: center;
}
