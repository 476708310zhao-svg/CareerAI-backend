/* pages/favorites/favorites.wxss — White-based premium redesign */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ─── Tab Bar ─────────────────────────────────────────────────── */
.tab-bar {
  display: flex;
  background: var(--bg-panel);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1.5rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 27rpx;
  color: var(--text-muted);
  position: relative;
  font-weight: 500;
  white-space: nowrap;
}

.tab-item.active {
  color: var(--brand);
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 44rpx;
  height: 5rpx;
  background: var(--brand);
  border-radius: 3rpx 3rpx 0 0;
}

.tab-count {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-left: 4rpx;
}

.tab-item.active .tab-count {
  color: #93C5FD;
}

/* ─── List Container ──────────────────────────────────────────── */
.fav-list {
  padding: 20rpx 24rpx 48rpx;
}

/* ─── Favorite Card ───────────────────────────────────────────── */
.fav-card {
  display: flex;
  align-items: flex-start;
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  transition: transform 0.12s;
}

.fav-card:active {
  transform: scale(0.984);
  background: #FAFBFF;
}

/* Company logo */
.fav-logo {
  width: 84rpx;
  height: 84rpx;
  border-radius: 18rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  background: var(--bg-page);
}

/* Info column */
.fav-info {
  flex: 1;
  min-width: 0;
}

.fav-info.full {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.fav-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.fav-subtitle {
  font-size: 25rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.fav-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* Right column */
.fav-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 14rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.fav-salary {
  font-size: 28rpx;
  font-weight: 800;
  color: #059669;
}

/* Remove button */
.remove-btn {
  font-size: 22rpx;
  color: #EF4444;
  padding: 6rpx 18rpx;
  border: 1.5rpx solid #FECACA;
  border-radius: var(--r-lg);
  background: #FEF2F2;
  flex-shrink: 0;
}

/* ─── Toolbar ─────────────────────────────────────────────────── */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--bg-panel);
  border-bottom: 1rpx solid #F1F5F9;
}

.sort-group {
  display: flex;
  background: var(--bg-raised);
  border-radius: var(--r-md);
  padding: 4rpx;
  gap: 4rpx;
}

.sort-btn {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 22rpx;
  border-radius: var(--r-sm);
  font-weight: 500;
}

.sort-btn.active {
  background: var(--bg-panel);
  color: var(--brand);
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.batch-btn {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 22rpx;
  border-radius: var(--r-md);
  border: 1.5rpx solid var(--border-light);
}

.batch-btn.on {
  color: #EF4444;
  border-color: #FECACA;
  background: #FEF2F2;
}

/* ─── Batch Bar ───────────────────────────────────────────────── */
.batch-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #EEF2FF;
  gap: 16rpx;
}

.batch-hint {
  flex: 1;
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 600;
}

.select-all-btn {
  font-size: 24rpx;
  color: var(--brand);
  padding: 8rpx 20rpx;
  border: 1.5rpx solid var(--brand);
  border-radius: var(--r-md);
}

.batch-del-btn {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 8rpx 24rpx;
  border-radius: var(--r-md);
  background: var(--border-light);
}

.batch-del-btn.active {
  color: var(--bg-panel);
  background: #EF4444;
}

/* ─── Select Circle ───────────────────────────────────────────── */
.select-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #D1D5DB;
  margin-right: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-panel);
}

.select-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--brand);
}

.fav-card.selected {
  background: #F0F4FF;
  border-color: #BFDBFE;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Profile entry page polish */
.container {
  min-height: 100vh;
}

.tab-bar {
  margin: 18rpx 24rpx 8rpx;
  padding: 8rpx;
  gap: 6rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.tab-item {
  padding: 16rpx 0;
  border-radius: 17rpx;
  color: #64748b;
  font-size: 23rpx;
  font-weight: 850;
}

.tab-item.active {
  color: #1d4ed8;
  background: #eef4ff;
}

.tab-item.active::after {
  display: none;
}

.toolbar,
.batch-bar {
  margin: 14rpx 24rpx 0;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 10rpx 24rpx rgba(32,48,70,0.045);
}

.fav-list {
  padding: 18rpx 24rpx 48rpx;
}

.fav-card {
  border-radius: 24rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.fav-title {
  color: #111827;
  font-weight: 900;
}

.fav-subtitle,
.fav-date {
  color: #667085;
}

.fav-reminder {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  margin-top: 8rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  color: #2563eb;
  background: #eef4ff;
  font-size: 20rpx;
  font-weight: 850;
}

.fav-reminder.urgent {
  color: #b45309;
  background: #fff7ed;
}

.reminder-btn,
.reminder-clear {
  min-width: 72rpx;
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
}

.reminder-btn {
  color: #2563eb;
  background: #eef4ff;
}

.reminder-clear {
  color: #667085;
  background: #f2f4f7;
}

.remove-btn,
.batch-btn,
.sort-btn.active {
  border-radius: 999rpx;
}

/* Favorites center polish */
.container {
  padding-bottom: 44rpx;
}

.favorites-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 22rpx 24rpx 16rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 58%, #ecfffb 100%);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.08);
}

.hero-kicker,
.hero-title,
.hero-sub,
.count-num,
.count-label,
.empty-title,
.empty-desc {
  display: block;
}

.hero-kicker {
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 8rpx;
  color: #101828;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 950;
}

.hero-sub {
  width: 430rpx;
  max-width: 100%;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.hero-count {
  width: 122rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(145deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 18rpx 34rpx rgba(37,99,235,0.22);
  flex-shrink: 0;
}

.count-num {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 950;
}

.count-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 800;
  opacity: 0.88;
}

.tab-count {
  color: #8aa0bd;
  font-size: 18rpx;
  font-weight: 900;
}

.tab-item.active .tab-count {
  color: #2563eb;
}

.fav-card {
  overflow: hidden;
}

.fav-card.selected {
  background: #eef4ff;
  border-color: rgba(37,99,235,0.22);
}

.fav-empty {
  margin: 72rpx 0 0;
  padding: 76rpx 36rpx 38rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.07);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f7ff;
  font-size: 52rpx;
  box-shadow: inset 0 0 0 1rpx rgba(37,99,235,0.08);
}

.empty-title {
  margin-top: 24rpx;
  color: #111827;
  font-size: 31rpx;
  font-weight: 950;
}

.empty-desc {
  width: 540rpx;
  max-width: 100%;
  margin-top: 14rpx;
  color: #718096;
  font-size: 25rpx;
  line-height: 1.62;
  text-align: center;
}

.empty-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 34rpx;
}

.empty-primary,
.empty-secondary {
  min-width: 176rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
}

.empty-primary {
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 12rpx 26rpx rgba(37,99,235,0.22);
}

.empty-secondary {
  color: #2563eb;
  background: #f3f7ff;
  border: 1rpx solid rgba(37,99,235,0.12);
}

.empty-tips {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 34rpx;
}

.tip-item {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #667085;
  background: #f8fbff;
  font-size: 22rpx;
  font-weight: 750;
}
