/* package-user/pages/search/search.wxss */
page {
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 36%),
    linear-gradient(180deg, #f7faff 0%, #ffffff 46%);
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.search-page {
  min-height: 100vh;
  padding: 0 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 36%),
    linear-gradient(180deg, #f7faff 0%, #ffffff 46%);
}

/* Search */
.search-panel {
  position: sticky;
  top: 0;
  z-index: 20;
  padding: 18rpx 0 16rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 36%),
    linear-gradient(180deg, #f7faff 0%, rgba(247, 250, 255, 0.96) 100%);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  min-width: 0;
  height: 82rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(43, 92, 230, 0.08);
  box-sizing: border-box;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 30rpx;
  color: #111827;
}

.search-btn {
  height: 82rpx;
  min-width: 104rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #1f4fd8 0%, #2b6ff2 100%);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(43, 92, 230, 0.22);
  box-sizing: border-box;
}

.search-btn:active,
.job-card:active,
.company-card:active,
.exp-card:active,
.tag:active,
.load-more-btn:active {
  opacity: 0.78;
}

.search-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 4rpx 0;
}

.search-hint-main {
  font-size: 26rpx;
  font-weight: 800;
  color: #111827;
}

.search-hint-sub {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 23rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Search home */
.section {
  padding: 28rpx 0 4rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #111827;
}

.clear-btn {
  font-size: 24rpx;
  color: #6b7280;
  padding: 8rpx 0 8rpx 24rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  max-width: 100%;
  font-size: 25rpx;
  line-height: 34rpx;
  padding: 13rpx 22rpx;
  color: #374151;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
}

.tag.hot {
  color: #075985;
  background: #eef8ff;
  border-color: rgba(14, 165, 233, 0.18);
}

/* Tabs */
.result-tabs {
  display: flex;
  gap: 10rpx;
  padding: 10rpx;
  margin: 4rpx 0 18rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 26rpx;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.result-tab {
  flex: 1;
  min-width: 0;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #6b7280;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.result-tab.active {
  color: #1f4fd8;
  background: #eef4ff;
  box-shadow: inset 0 0 0 1rpx rgba(43, 92, 230, 0.12);
}

.tab-label,
.tab-count {
  display: inline-flex;
  align-items: center;
  line-height: 1;
}

.tab-count {
  min-width: 34rpx;
  height: 34rpx;
  justify-content: center;
  padding: 0 8rpx;
  color: #64748b;
  background: #f1f5f9;
  border-radius: 999rpx;
  font-size: 21rpx;
  box-sizing: border-box;
}

.result-tab.active .tab-count {
  color: #ffffff;
  background: #2b5ce6;
}

/* Results */
.result-list {
  padding: 0 0 18rpx;
}

.job-card,
.company-card,
.exp-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(15, 23, 42, 0.07);
  border-radius: 26rpx;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.job-card-main,
.company-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.job-logo,
.company-logo {
  flex-shrink: 0;
}

.job-info,
.company-info {
  flex: 1;
  min-width: 0;
}

.job-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.job-title,
.company-name,
.exp-title {
  display: block;
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.32;
}

.job-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-arrow,
.company-arrow,
.exp-arrow {
  color: #94a3b8;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
}

.job-company {
  display: block;
  margin-top: 8rpx;
  color: #374151;
  font-size: 27rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-meta,
.company-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.meta-tag,
.company-chip {
  max-width: 100%;
  padding: 7rpx 14rpx;
  color: #64748b;
  background: #f6f8fb;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 1.25;
  box-sizing: border-box;
}

.company-chip.active {
  color: #0f766e;
  background: #ecfdf5;
  border-color: rgba(20, 184, 166, 0.18);
}

.job-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
}

.salary-label {
  color: #94a3b8;
  font-size: 23rpx;
  font-weight: 700;
}

.job-salary {
  flex: 1;
  min-width: 0;
  text-align: right;
  color: #059669;
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Companies */
.company-card {
  padding: 24rpx;
}

.company-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.company-arrow {
  flex-shrink: 0;
}

/* Experiences */
.exp-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.exp-badge {
  padding: 7rpx 16rpx;
  color: #1f4fd8;
  background: #eef4ff;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.exp-likes {
  color: #f59e0b;
  font-size: 23rpx;
  font-weight: 800;
}

.exp-title {
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.exp-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.exp-company {
  flex: 1;
  min-width: 0;
  color: #374151;
  font-size: 25rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exp-arrow {
  font-size: 24rpx;
  color: #1f4fd8;
}

/* States */
.loading {
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #64748b;
  font-size: 27rpx;
}

.loading-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: #2b5ce6;
  box-shadow: 36rpx 0 0 #8fb1ff, -36rpx 0 0 #c9d8ff;
}

.empty {
  margin: 46rpx 0;
  padding: 72rpx 34rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 27rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx dashed rgba(148, 163, 184, 0.38);
  border-radius: 26rpx;
  box-sizing: border-box;
}

.load-more-row {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 8rpx;
}

.load-more-btn {
  min-width: 260rpx;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f4fd8;
  font-size: 26rpx;
  font-weight: 800;
  background: #eef4ff;
  border: 1rpx solid rgba(43, 92, 230, 0.12);
  border-radius: 999rpx;
  box-sizing: border-box;
}

.loading-more-txt {
  padding: 18rpx 0;
  color: #64748b;
  font-size: 26rpx;
}

.no-more-txt {
  padding: 22rpx 0 8rpx;
  text-align: center;
  color: #c4cad4;
  font-size: 22rpx;
}
