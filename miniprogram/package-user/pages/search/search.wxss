/* package-user/pages/search/search.wxss */
page {
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 36%),
    linear-gradient(180deg, #f7faff 0%, #ffffff 46%);
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.search-page {
  min-height: 100vh;
  padding: 0 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 36%),
    linear-gradient(180deg, #f7faff 0%, #ffffff 46%);
}

/* Search */
.search-panel {
  position: sticky;
  top: 0;
  z-index: 20;
  padding: 18rpx 0 16rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 36%),
    linear-gradient(180deg, #f7faff 0%, rgba(247, 250, 255, 0.96) 100%);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  min-width: 0;
  height: 82rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(43, 92, 230, 0.08);
  box-sizing: border-box;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 30rpx;
  color: #111827;
}

.search-btn {
  height: 82rpx;
  min-width: 104rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #1f4fd8 0%, #2b6ff2 100%);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(43, 92, 230, 0.22);
  box-sizing: border-box;
}

.search-btn:active,
.job-card:active,
.company-card:active,
.exp-card:active,
.tag:active,
.load-more-btn:active {
  opacity: 0.78;
}

.search-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 4rpx 0;
}

.search-hint-main {
  font-size: 26rpx;
  font-weight: 800;
  color: #111827;
}

.search-hint-sub {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 23rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Search home */
.section {
  padding: 28rpx 0 4rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #111827;
}

.clear-btn {
  font-size: 24rpx;
  color: #6b7280;
  padding: 8rpx 0 8rpx 24rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  max-width: 100%;
  font-size: 25rpx;
  line-height: 34rpx;
  padding: 13rpx 22rpx;
  color: #374151;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
}

.tag.hot {
  color: #075985;
  background: #eef8ff;
  border-color: rgba(14, 165, 233, 0.18);
}

/* Tabs */
.result-tabs {
  display: flex;
  gap: 10rpx;
  padding: 10rpx;
  margin: 4rpx 0 18rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 26rpx;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.result-tab {
  flex: 1;
  min-width: 0;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #6b7280;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.result-tab.active {
  color: #1f4fd8;
  background: #eef4ff;
  box-shadow: inset 0 0 0 1rpx rgba(43, 92, 230, 0.12);
}

.tab-label,
.tab-count {
  display: inline-flex;
  align-items: center;
  line-height: 1;
}

.tab-count {
  min-width: 34rpx;
  height: 34rpx;
  justify-content: center;
  padding: 0 8rpx;
  color: #64748b;
  background: #f1f5f9;
  border-radius: 999rpx;
  font-size: 21rpx;
  box-sizing: border-box;
}

.result-tab.active .tab-count {
  color: #ffffff;
  background: #2b5ce6;
}

/* Results */
.result-list {
  padding: 0 0 18rpx;
}

.job-card,
.company-card,
.exp-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(15, 23, 42, 0.07);
  border-radius: 26rpx;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.job-card-main,
.company-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.job-logo,
.company-logo {
  flex-shrink: 0;
}

.job-info,
.company-info {
  flex: 1;
  min-width: 0;
}

.job-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.job-title,
.company-name,
.exp-title {
  display: block;
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.32;
}

.job-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-arrow,
.company-arrow,
.exp-arrow {
  color: #94a3b8;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
}

.job-company {
  display: block;
  margin-top: 8rpx;
  color: #374151;
  font-size: 27rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-meta,
.company-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.meta-tag,
.company-chip {
  max-width: 100%;
  padding: 7rpx 14rpx;
  color: #64748b;
  background: #f6f8fb;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 1.25;
  box-sizing: border-box;
}

.company-chip.active {
  color: #0f766e;
  background: #ecfdf5;
  border-color: rgba(20, 184, 166, 0.18);
}

.job-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
}

.salary-label {
  color: #94a3b8;
  font-size: 23rpx;
  font-weight: 700;
}

.job-salary {
  flex: 1;
  min-width: 0;
  text-align: right;
  color: #059669;
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Companies */
.company-card {
  padding: 24rpx;
}

.company-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.company-arrow {
  flex-shrink: 0;
}

/* Experiences */
.exp-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.exp-badge {
  padding: 7rpx 16rpx;
  color: #1f4fd8;
  background: #eef4ff;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.exp-likes {
  color: #f59e0b;
  font-size: 23rpx;
  font-weight: 800;
}

.exp-title {
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.exp-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.exp-company {
  flex: 1;
  min-width: 0;
  color: #374151;
  font-size: 25rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exp-arrow {
  font-size: 24rpx;
  color: #1f4fd8;
}

/* States */
.loading {
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  color: #64748b;
  font-size: 27rpx;
}

.loading-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: #2b5ce6;
  box-shadow: 36rpx 0 0 #8fb1ff, -36rpx 0 0 #c9d8ff;
}

.empty {
  margin: 46rpx 0;
  padding: 72rpx 34rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 27rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx dashed rgba(148, 163, 184, 0.38);
  border-radius: 26rpx;
  box-sizing: border-box;
}

.load-more-row {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 8rpx;
}

.load-more-btn {
  min-width: 260rpx;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f4fd8;
  font-size: 26rpx;
  font-weight: 800;
  background: #eef4ff;
  border: 1rpx solid rgba(43, 92, 230, 0.12);
  border-radius: 999rpx;
  box-sizing: border-box;
}

.loading-more-txt {
  padding: 18rpx 0;
  color: #64748b;
  font-size: 26rpx;
}

.no-more-txt {
  padding: 22rpx 0 8rpx;
  text-align: center;
  color: #c4cad4;
  font-size: 22rpx;
}

/* Reference-inspired soft search result polish */
page {
  background: #f3f6f8;
}

.search-page {
  padding: 0 24rpx 52rpx;
  background:
    linear-gradient(160deg, rgba(255,255,255,0.96) 0%, rgba(241,247,250,0.94) 42%, rgba(249,250,252,1) 100%);
}

.search-panel {
  padding: calc(env(safe-area-inset-top) + 14rpx) 0 14rpx;
  background: rgba(247, 250, 252, 0.92);
  border-bottom: 1rpx solid rgba(220, 228, 236, 0.72);
  box-shadow: 0 16rpx 34rpx rgba(31, 45, 61, 0.045);
}

.search-bar {
  gap: 14rpx;
}

.search-input-wrap {
  height: 76rpx;
  padding: 0 24rpx;
  gap: 14rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fafc 100%);
  border: 1rpx solid rgba(205, 216, 228, 0.82);
  box-shadow:
    0 14rpx 28rpx rgba(31, 45, 61, 0.065),
    inset 0 1rpx 0 rgba(255,255,255,0.96);
}

.search-input {
  height: 74rpx;
  line-height: 74rpx;
  color: #162033;
  font-size: 27rpx;
  font-weight: 500;
}

.search-btn {
  height: 76rpx;
  min-width: 100rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #4bc0ec 0%, #2f74df 100%);
  box-shadow: 0 14rpx 28rpx rgba(47, 116, 223, 0.20);
  font-size: 26rpx;
}

.search-hint {
  padding: 16rpx 4rpx 0;
}

.search-hint-main {
  color: #162033;
}

.search-hint-sub {
  color: #7b8798;
}

.section-title {
  color: #162033;
}

.tag {
  color: #435166;
  background: rgba(255,255,255,0.90);
  border: 1rpx solid rgba(211, 221, 232, 0.78);
  box-shadow: 0 8rpx 20rpx rgba(31, 45, 61, 0.038);
}

.tag.hot {
  color: #2365ca;
  background: #edf6ff;
  border-color: rgba(66, 153, 225, 0.18);
}

.result-tabs {
  padding: 8rpx;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.84);
  border: 1rpx solid rgba(210, 221, 232, 0.78);
  box-shadow: 0 12rpx 28rpx rgba(31, 45, 61, 0.052);
}

.result-tab {
  height: 66rpx;
  border-radius: 24rpx;
  color: #6f7d90;
}

.result-tab.active {
  color: #2365ca;
  background: #ffffff;
  box-shadow:
    0 8rpx 18rpx rgba(31, 45, 61, 0.085),
    inset 0 0 0 1rpx rgba(66, 153, 225, 0.12);
}

.result-tab.active .tab-count {
  background: linear-gradient(135deg, #4bc0ec 0%, #2f74df 100%);
}

.job-card,
.company-card,
.exp-card {
  border-radius: 30rpx !important;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%) !important;
  border: 1rpx solid rgba(210, 221, 232, 0.82) !important;
  box-shadow:
    0 18rpx 40rpx rgba(31, 45, 61, 0.072),
    inset 0 1rpx 0 rgba(255,255,255,0.98) !important;
}

.job-card:active,
.company-card:active,
.exp-card:active {
  transform: translateY(2rpx) scale(0.988);
  opacity: 0.9;
}

.job-card-main {
  align-items: flex-start;
  gap: 18rpx;
}

.job-logo,
.company-logo {
  width: 84rpx;
  height: 84rpx;
  border-radius: 25rpx;
  background: linear-gradient(145deg, #ffffff 0%, #eef5fb 100%) !important;
  border: 1rpx solid rgba(203, 213, 225, 0.82) !important;
  box-shadow:
    0 12rpx 24rpx rgba(31, 45, 61, 0.072),
    inset 0 1rpx 0 rgba(255,255,255,0.96);
}

.job-title,
.company-name,
.exp-title {
  color: #162033;
  font-size: 30rpx;
  letter-spacing: 0;
}

.job-arrow,
.company-arrow {
  width: 46rpx;
  height: 46rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9aa6b5;
  background: #f3f7fa;
  font-size: 34rpx;
}

.job-company {
  position: relative;
  display: inline-block;
  max-width: 100%;
  margin-top: 8rpx;
  padding-right: 22rpx;
  color: #536174;
  font-size: 24rpx;
  font-weight: 750;
}

.job-company::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  width: 10rpx;
  height: 10rpx;
  margin-top: -5rpx;
  border-radius: 50%;
  background: #27c987;
  box-shadow: 0 0 0 4rpx rgba(39, 201, 135, 0.12);
}

.meta-tag,
.company-chip {
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  color: #536174;
  background: #f7fafc;
  border-color: rgba(210, 221, 232, 0.78);
  font-weight: 800;
}

.company-chip.active {
  color: #0b8b68;
  background: #ecfbf5;
  border-color: rgba(39, 201, 135, 0.18);
}

.job-card-foot {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(210, 221, 232, 0.70);
}

.salary-label {
  color: #8a96a8;
}

.job-salary {
  color: #152238;
  font-size: 28rpx;
}

.exp-badge {
  color: #2365ca;
  background: #edf6ff;
  border: 1rpx solid rgba(66, 153, 225, 0.18);
}

.exp-likes {
  color: #b7791f;
  background: #fff7e8;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.load-more-btn {
  color: #2365ca;
  background: #edf6ff;
  border-color: rgba(66, 153, 225, 0.18);
}
