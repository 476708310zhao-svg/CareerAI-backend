/* pages/messages/messages.wxss - White-based premium redesign */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ─── Tab Bar ─────────────────────────────────────────────────── */
.tab-bar {
  display: flex;
  align-items: center;
  background: var(--bg-panel);
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1.5rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  padding: 28rpx 20rpx;
  font-size: 27rpx;
  color: var(--text-muted);
  position: relative;
  white-space: nowrap;
  font-weight: 500;
}

.tab-item.active {
  color: var(--brand);
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 5rpx;
  background: var(--brand);
  border-radius: 3rpx 3rpx 0 0;
}

.read-all-btn {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--brand);
  white-space: nowrap;
  padding: 28rpx 4rpx;
  font-weight: 500;
}

/* ─── Message List ────────────────────────────────────────────── */
.message-list {
  padding: 16rpx 24rpx 48rpx;
}

/* ─── Message Card ────────────────────────────────────────────── */
.message-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  transition: transform 0.12s;
  overflow: hidden;
}

.message-card:active {
  transform: scale(0.984);
  background: #FAFBFF;
}

/* Read state - slightly dimmed */
.message-card.read {
  opacity: 0.65;
}

/* Unread state - blue left accent */
.message-card.unread {
  border-left: 5rpx solid var(--brand);
}

/* Unread red dot */
.unread-dot {
  position: absolute;
  top: 18rpx;
  right: 20rpx;
  width: 16rpx;
  height: 16rpx;
  background: #EF4444;
  border-radius: 50%;
  box-shadow: 0 0 0 3rpx rgba(239, 68, 68, 0.18);
}

/* Icon wrap */
.msg-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #EEF2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.msg-icon-img {
  width: 38rpx;
  height: 38rpx;
}

/* Content column */
.msg-body {
  flex: 1;
  min-width: 0;
}

.msg-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
  gap: 12rpx;
}

.msg-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-time {
  font-size: 22rpx;
  color: var(--text-muted);
  white-space: nowrap;
  flex-shrink: 0;
}

.msg-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Clear all button */
.clear-wrap {
  text-align: center;
  padding: 28rpx 0;
}

.clear-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Empty state */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.25;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Profile entry page polish */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.message-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 22rpx 24rpx 16rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 58%, #ecfffb 100%);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.08);
}

.hero-kicker,
.hero-title,
.hero-sub,
.count-num,
.count-label,
.quick-title,
.quick-desc {
  display: block;
}

.hero-kicker {
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 8rpx;
  color: #101828;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 950;
}

.hero-sub {
  width: 430rpx;
  max-width: 100%;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.hero-count {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(145deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 18rpx 34rpx rgba(37,99,235,0.22);
  flex-shrink: 0;
}

.count-num {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 950;
}

.count-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 800;
  opacity: 0.88;
}

.quick-panel {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin: 0 24rpx 16rpx;
}

.quick-card {
  min-height: 118rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.055);
}

.quick-card:active {
  transform: scale(0.985);
}

.quick-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.quick-desc {
  margin-top: 8rpx;
  color: #718096;
  font-size: 22rpx;
  line-height: 1.42;
}

.tab-bar {
  margin: 18rpx 24rpx 8rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
  top: 0;
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  color: #64748b;
  font-size: 25rpx;
  font-weight: 800;
}

.tab-item.active {
  color: #1d4ed8;
  background: #eef4ff;
}

.tab-item.active::after {
  display: none;
}

.tab-count {
  min-width: 26rpx;
  height: 26rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  color: #8aa0bd;
  background: #f3f7ff;
  font-size: 18rpx;
  line-height: 26rpx;
  text-align: center;
  font-weight: 900;
}

.tab-item.active .tab-count {
  color: #fff;
  background: #2563eb;
}

.read-all-btn {
  align-self: center;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  color: #2563eb;
  background: #f8fbff;
  font-size: 23rpx;
  font-weight: 850;
}

.message-list {
  padding: 16rpx 24rpx 48rpx;
}

.message-card {
  border-radius: 24rpx;
  padding: 24rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.msg-icon-wrap {
  background: #eef4ff;
}

.msg-title {
  color: #111827;
  font-weight: 900;
}

.msg-content,
.msg-time {
  color: #667085;
}

.empty {
  margin: 96rpx 8rpx 0;
  padding: 92rpx 36rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 16rpx 38rpx rgba(32,48,70,0.06);
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  opacity: 0.38;
}

.empty-text {
  margin-top: 6rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-sub {
  width: 520rpx;
  max-width: 100%;
  margin-top: 14rpx;
  color: #718096;
  font-size: 25rpx;
  line-height: 1.6;
  text-align: center;
}

.empty-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 34rpx;
}

.empty-action {
  min-width: 164rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: #f3f7ff;
  color: #2563eb;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
  border: 1rpx solid rgba(37,99,235,0.12);
}

.empty-action.primary {
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 12rpx 26rpx rgba(37,99,235,0.22);
}
