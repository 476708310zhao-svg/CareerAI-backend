<!-- pages/job-detail/job-detail.wxml -->
<view class="page">

<!-- Loading -->
<view wx:if="{{loading}}" class="loading-wrap">
  <view class="spinner"></view>
  <text class="loading-txt">正在加载...</text>
</view>

<!-- 内容 -->
<block wx:elif="{{job}}">

  <!-- 头部卡片 -->
  <view class="head-card">
    <view class="head-top">
      <c-company-logo
        logo="{{job.logoFailed ? '' : job.logo}}"
        name="{{job.company}}"
        fallback="{{job.companyInitial || 'C'}}"
        size="lg"
        custom-class="head-logo-wrap"
        bind:error="onLogoError"
      ></c-company-logo>
      <view class="head-info">
        <text class="head-kicker">Recommended Role</text>
        <text class="head-company">{{job.company}}</text>
        <text class="head-title">{{job.title}}</text>
      </view>
    </view>

    <!-- 薪资 -->
    <view class="salary-row">
      <text class="salary-val">{{job.salary}}</text>
      <text class="salary-unit" wx:if="{{job.salary !== 'Negotiable'}}"> / year</text>
    </view>

    <!-- 标签 -->
    <view class="info-tags">
      <c-tag type="primary">{{job.city}}{{job.state ? ', '+job.state : ''}}</c-tag>
      <c-tag>{{job.type}}</c-tag>
      <c-tag type="info">{{job.postedAt}}</c-tag>
      <c-tag type="success" wx:if="{{job.visaSponsored}}">Visa Sponsor</c-tag>
    </view>

    <!-- 技能图标 -->
    <view class="skill-tags" wx:if="{{job.skillTags && job.skillTags.length > 0}}">
      <view wx:for="{{job.skillTags}}" wx:key="label" class="skill-chip">
        <image class="skill-icon" src="{{item.iconUrl}}" mode="aspectFit" lazy-load></image>
        <text class="skill-name">{{item.label}}</text>
      </view>
    </view>

    <view class="head-conversion-row">
      <view class="conversion-pill">
        <text class="conversion-num">AI</text>
        <text class="conversion-label">面试准备</text>
      </view>
      <view class="conversion-pill">
        <text class="conversion-num">3/6/12</text>
        <text class="conversion-label">月路线</text>
      </view>
      <view class="conversion-pill">
        <text class="conversion-num">1-click</text>
        <text class="conversion-label">投递看板</text>
      </view>
    </view>
  </view>

  <c-ai-disclosure text="本页模拟面试追问与求职路线规划由人工智能生成，仅供求职准备参考，请核验后使用。" />

  <!-- 职位描述 -->
  <view class="desc-card">
    <view class="desc-title">职位描述</view>
    <text class="desc-body" user-select>{{job.description}}</text>
  </view>

  <view class="action-lab">
    <view class="action-lab-head">
      <text class="action-lab-kicker">Next Best Action</text>
      <text class="action-lab-title">读完职位后，马上进入准备流</text>
    </view>
    <view class="action-grid">
      <view class="action-card" bindtap="startAiInterview">
        <text class="action-icon">AI</text>
        <view class="action-copy">
          <text class="action-title">模拟面试</text>
          <text class="action-sub">围绕该岗位生成追问</text>
        </view>
      </view>
      <view class="action-card" bindtap="applyJob">
        <text class="action-icon doc">↗</text>
        <view class="action-copy">
          <text class="action-title">保存投递</text>
          <text class="action-sub">复制投递链接并加入看板</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 求职路线规划入口 -->
  <view class="roadmap-cta" bindtap="viewCareerPath">
    <view class="roadmap-cta-left">
      <text class="roadmap-cta-icon">🗺️</text>
      <view class="roadmap-cta-info">
        <text class="roadmap-cta-title">为该岗位定制求职路线</text>
        <text class="roadmap-cta-sub">AI 生成 3/6/12 个月专属规划 · 含技能/项目/面试路线</text>
      </view>
    </view>
    <text class="roadmap-cta-arrow">›</text>
  </view>

  <view class="detail-safe-tail ux-detail-tail"></view>
</block>

<view wx:else class="detail-empty">
  <text class="detail-empty-title">职位信息暂不可用</text>
  <text class="detail-empty-sub">该职位可能已下线，或当前网络暂时无法获取详情。</text>
  <view class="detail-empty-btn" bindtap="goBack">返回职位列表</view>
</view>

<!-- 底部操作栏 -->
<view class="footer ux-bottom-bar" wx:if="{{job}}">
  <view class="footer-icons ux-bottom-icons">
    <view class="f-icon ux-icon-action {{isSaved ? 'active' : ''}}" bindtap="toggleSave">
      <text class="f-icon-txt">{{isSaved ? '★' : '☆'}}</text>
    </view>
    <button class="f-icon share-btn ux-icon-action" open-type="share">
      <text class="f-icon-txt">↗</text>
    </button>
  </view>

  <view class="f-btn f-btn-ai ux-sub-cta" bindtap="startAiInterview">
    <text class="ai-badge">AI</text>
    <text>面试</text>
  </view>

  <view class="f-btn f-btn-apply ux-main-cta" bindtap="applyJob">保存投递</view>
</view>

<!-- 保存投递弹窗 -->
<view class="apply-mask" wx:if="{{showApplyModal}}" bindtap="hideApplyModal"></view>
<view class="apply-panel {{showApplyModal ? 'show' : ''}}">
  <view class="ap-header">
    <text class="ap-title">保存投递</text>
    <text class="ap-close" bindtap="hideApplyModal">✕</text>
  </view>

  <!-- 职位信息 -->
  <view class="ap-job-row">
    <c-company-logo
      logo="{{job.logoFailed ? '' : job.logo}}"
      name="{{job.company}}"
      fallback="{{job.companyInitial || 'C'}}"
      size="sm"
      custom-class="ap-job-logo-wrap"
      bind:error="onLogoError"
    ></c-company-logo>
    <view class="ap-job-info">
      <text class="ap-job-title">{{job.title}}</text>
      <text class="ap-job-company">{{job.company}} · {{job.city}}</text>
    </view>
  </view>

  <!-- 简历快照 -->
  <view class="ap-resume-card">
    <text class="ap-resume-label">您的简历摘要（将复制到剪贴板）</text>
    <view wx:if="{{resumeSnap.hasData}}">
      <text class="ap-rname">{{resumeSnap.name}}</text>
      <text class="ap-rsub" wx:if="{{resumeSnap.title}}">{{resumeSnap.title}}</text>
      <text class="ap-rcontact" wx:if="{{resumeSnap.phone || resumeSnap.email}}">
        {{resumeSnap.phone}}{{resumeSnap.phone && resumeSnap.email ? '  ·  ' : ''}}{{resumeSnap.email}}</text>
      <text class="ap-rskills" wx:if="{{resumeSnap.skills}}">🔧 {{resumeSnap.skills}}</text>
    </view>
    <view wx:else class="ap-resume-empty">
      <text>简历信息未完善，建议先填写再投递</text>
      <text class="ap-resume-link" bindtap="hideApplyModal">→ 前往完善</text>
    </view>
  </view>

  <view class="ap-btns">
    <view class="ap-btn-cancel" bindtap="hideApplyModal">取消</view>
    <view class="ap-btn-submit" bindtap="doOneClickApply">
      <text>保存并复制</text>
    </view>
  </view>
  <text class="ap-tip">保存后：投递信息已复制 · 记录到看板 · 请在浏览器完成官方投递</text>
</view>

</view>
