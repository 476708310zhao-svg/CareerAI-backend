/* pages/job-detail/job-detail.wxss */
page {
  background: var(--bg-raised);
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

/* ====== 头部卡片 ====== */
.head-card {
  margin: 24rpx;
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 36rpx;
  box-shadow: var(--shadow-md);
}

.head-top {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.head-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--r-lg);
  border: 1.5rpx solid var(--border);
  margin-right: 24rpx;
  background: var(--bg-raised);
  flex-shrink: 0;
}

.head-info { flex: 1; min-width: 0; }

.head-company {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 6rpx;
}

.head-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.35;
  display: block;
}

/* 薪资行 */
.salary-row {
  background: var(--success-bg-solid);
  border-radius: var(--r-sm);
  padding: 22rpx 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: baseline;
  border: 1rpx solid var(--success-bg);
}

.salary-val {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--success-text);
}

.salary-unit {
  font-size: 22rpx;
  color: var(--success-text);
  margin-left: 6rpx;
}

/* 技能图标 */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}
.skill-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #F8FAFF;
  border: 1.5rpx solid #E4EEFF;
  border-radius: 16rpx;
  padding: 8rpx 18rpx 8rpx 10rpx;
}
.skill-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}
.skill-name {
  font-size: 22rpx;
  color: #374151;
  font-weight: 500;
}

/* 信息标签 */
.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

/* ====== 描述卡片 ====== */
.desc-card {
  margin: 0 24rpx 24rpx;
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 36rpx;
  box-shadow: var(--shadow-md);
}

.desc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-left: 18rpx;
  border-left: 8rpx solid var(--brand);
  line-height: 1;
}

.desc-body {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.85;
  white-space: pre-wrap;
  display: block;
}

/* ====== 底部操作栏 ====== */
.footer,
.ux-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 300;
  min-height: calc(112rpx + env(safe-area-inset-bottom));
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 -14rpx 34rpx rgba(15, 23, 42, 0.08);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.footer-icons {
  width: 146rpx;
  max-width: 146rpx;
}

.footer-icons,
.ux-bottom-icons {
  flex: 0 0 144rpx;
  width: 144rpx;
  max-width: 144rpx;
  display: grid;
  grid-template-columns: repeat(2, 64rpx);
  gap: 12rpx;
  align-items: center;
}

.f-icon,
.ux-icon-action,
.share-btn {
  width: 64rpx;
  min-width: 64rpx;
  height: 64rpx;
  padding: 0;
  margin: 0;
  border-radius: 20rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  background: #f8fafc;
  color: #0f172a;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
}

.share-btn::after {
  border: none;
}

.f-icon.active {
  color: #2563eb;
  background: #eef4ff;
  border-color: rgba(37, 99, 235, 0.18);
}

.f-icon-txt {
  display: block;
  color: inherit;
  font-size: 32rpx;
  line-height: 1;
}

.f-btn,
.ux-sub-cta,
.ux-main-cta {
  min-width: 0;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  white-space: nowrap;
}

.f-btn-ai {
  font-size: 25rpx;
}

.ux-sub-cta {
  flex: 0 0 176rpx;
  gap: 8rpx;
  color: #1d4ed8;
  background: #eef4ff;
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  font-size: 25rpx;
  font-weight: 850;
}

.ux-main-cta {
  flex: 1;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.22);
  font-size: 28rpx;
  font-weight: 900;
}

.ai-badge {
  width: 36rpx; height: 36rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, var(--brand), #6366F1);
  color: #fff;
  font-size: 16rpx;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 6rpx;
  flex-shrink: 0;
}

/* ====== Loading ====== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
}

.spinner {
  width: 48rpx; height: 48rpx;
  border: 5rpx solid #F1F3F7;
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

.loading-txt { font-size: 26rpx; color: var(--text-muted); }

@keyframes spin { to { transform: rotate(360deg); } }

/* ====== 一键投递弹窗 ====== */
.apply-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 500;
}

.apply-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--bg-panel);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 501;
  padding: 32rpx 36rpx calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
}

.apply-panel.show {
  transform: translateY(0);
}

.ap-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.ap-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.ap-close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 0 8rpx;
}

.ap-job-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--bg-raised);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.ap-job-logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.ap-job-info { flex: 1; min-width: 0; }

.ap-job-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ap-job-company {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.ap-resume-card {
  background: #f8faff;
  border: 1.5rpx solid #c7d2fe;
  border-radius: 18rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
}

.ap-resume-label {
  display: block;
  font-size: 20rpx;
  color: var(--brand);
  font-weight: 600;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.ap-rname {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.ap-rsub {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.ap-rcontact {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.ap-rskills {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.ap-resume-empty {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.ap-resume-link {
  color: var(--brand);
  font-weight: 600;
}

.ap-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.ap-btn-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  background: var(--bg-raised);
  color: var(--text-secondary);
  border: 1.5rpx solid rgba(0,0,0,0.08);
}

.ap-btn-submit {
  flex: 2;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--brand), #6366F1);
  box-shadow: 0 6rpx 20rpx rgba(37,99,235,0.35);
}

.ap-tip {
  display: block;
  font-size: 20rpx;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.6;
}

/* ── 求职路线规划入口 ── */
.roadmap-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 24rpx 0;
  padding: 24rpx 26rpx;
  background: linear-gradient(135deg, #EEF2FF 0%, #F5F3FF 100%);
  border-radius: var(--r-lg);
  border: 1.5rpx solid #C7D2FE;
  gap: 16rpx;
}
.roadmap-cta:active { opacity: 0.75; }

.roadmap-cta-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}
.roadmap-cta-icon  { font-size: 44rpx; flex-shrink: 0; }
.roadmap-cta-info  { flex: 1; min-width: 0; }
.roadmap-cta-title {
  display: block;
  font-size: 28rpx; font-weight: 700; color: #1e3a8a;
  margin-bottom: 6rpx;
}
.roadmap-cta-sub {
  display: block;
  font-size: 22rpx; color: #4338CA;
  line-height: 1.5;
}
.roadmap-cta-arrow {
  font-size: 40rpx; color: var(--brand);
  flex-shrink: 0;
}

/* Job detail product polish */
page {
  background:
    radial-gradient(circle at 14% 0%, rgba(43, 92, 230, 0.08), transparent 30%),
    linear-gradient(180deg, #f8fbff 0%, #f6f8fc 52%, #ffffff 100%);
}

.page {
  min-height: 100vh;
  overflow-x: hidden;
}

.head-card,
.desc-card,
.roadmap-cta {
  border: 1rpx solid rgba(31, 45, 74, 0.06);
  box-shadow: 0 18rpx 44rpx rgba(31, 45, 74, 0.08);
}

.head-card {
  margin: 20rpx 24rpx;
  padding: 34rpx 32rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(43, 92, 230, 0.09), transparent 34%),
    #ffffff;
}

.head-top {
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.head-logo-wrap {
  width: 108rpx;
  height: 108rpx;
  margin-right: 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(31, 45, 74, 0.08);
  background: linear-gradient(145deg, #ffffff, #f2f6ff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 12rpx 26rpx rgba(31, 45, 74, 0.08);
}

.head-logo {
  width: 88rpx;
  height: 88rpx;
  margin: 0;
  border: none;
  border-radius: 0;
  background: transparent;
}

.head-logo-initial,
.ap-job-logo-initial {
  color: #2b5ce6;
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.head-company {
  margin-bottom: 8rpx;
  color: #667085;
  font-size: 25rpx;
  font-weight: 650;
}

.head-title {
  color: #172033;
  font-size: 38rpx;
  letter-spacing: -0.6rpx;
}

.salary-row {
  margin-bottom: 22rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #e8fbf3 0%, #f0fdf8 100%);
  border-color: rgba(16, 185, 129, 0.16);
}

.salary-val {
  color: #059669;
  font-size: 34rpx;
}

.info-tags {
  gap: 14rpx 12rpx;
}

.desc-card {
  margin: 0 24rpx 22rpx;
  padding: 34rpx 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
}

.desc-title {
  margin-bottom: 22rpx;
  padding-left: 18rpx;
  border-left-width: 7rpx;
  font-size: 31rpx;
}

.desc-body {
  color: #596579;
  line-height: 1.88;
}

.roadmap-cta {
  margin: 0 24rpx 22rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #eef5ff 0%, #f7f3ff 100%);
}

.roadmap-cta-title {
  color: #1d4ed8;
}

.roadmap-cta-sub {
  color: #5865d6;
}

.detail-safe-tail {
  height: calc(112rpx + env(safe-area-inset-bottom));
}

.footer-icons {
  width: 146rpx;
  max-width: 146rpx;
}

.ap-job-logo-wrap {
  width: 78rpx;
  height: 78rpx;
  border-radius: 18rpx;
  background: #eef4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.ap-job-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 0;
  background: transparent;
}

/* Conversion-first detail */
.head-kicker {
  display: block;
  margin-bottom: 6rpx;
  color: #2b5ce6;
  font-size: 21rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
}

.head-conversion-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.conversion-pill {
  min-width: 0;
  padding: 16rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(248, 250, 252, 0.92);
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  text-align: center;
}

.conversion-num {
  display: block;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1.1;
}

.conversion-label {
  display: block;
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 19rpx;
  font-weight: 700;
}

.action-lab {
  margin: 0 24rpx 22rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(43,92,230,0.10), transparent 36%),
    #ffffff;
  border: 1rpx solid rgba(226,232,240,0.9);
  box-shadow: 0 18rpx 44rpx rgba(31,45,74,0.075);
}

.action-lab-head {
  margin-bottom: 20rpx;
}

.action-lab-kicker {
  display: block;
  margin-bottom: 6rpx;
  color: #2b5ce6;
  font-size: 21rpx;
  font-weight: 850;
  letter-spacing: 0.8rpx;
}

.action-lab-title {
  display: block;
  color: #172033;
  font-size: 31rpx;
  font-weight: 900;
  letter-spacing: -0.4rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action-card {
  min-width: 0;
  padding: 20rpx 18rpx;
  border-radius: 26rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(226,232,240,0.9);
  display: flex;
  align-items: center;
  gap: 14rpx;
  transition: transform var(--trans-fast), opacity var(--trans-fast);
}

.action-card:active {
  transform: scale(0.982);
  opacity: 0.82;
}

.action-card.primary {
  background: linear-gradient(135deg, #eef5ff 0%, #f7f3ff 100%);
  border-color: rgba(43,92,230,0.16);
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #2b5ce6;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon.doc {
  background: #0f172a;
  font-size: 26rpx;
}

.action-icon.progress {
  background: #059669;
  font-size: 24rpx;
}

.action-icon.match {
  background: #7c3aed;
  font-size: 24rpx;
}

.match-mask {
  position: fixed;
  inset: 0;
  z-index: 90;
  background: rgba(15, 23, 42, 0.58);
}

.match-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  max-height: 86vh;
  padding: 30rpx 34rpx calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -22rpx 58rpx rgba(15, 23, 42, 0.18);
  box-sizing: border-box;
  overflow-y: auto;
}

.match-header,
.match-score-row,
.match-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.match-kicker,
.match-title,
.score-num,
.score-label,
.score-job,
.score-risk,
.match-section-title,
.match-body,
.match-empty {
  display: block;
}

.match-kicker {
  color: #7c3aed;
  font-size: 20rpx;
  font-weight: 950;
}

.match-title {
  margin-top: 6rpx;
  color: #101828;
  font-size: 36rpx;
  font-weight: 950;
}

.match-close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  color: #344054;
  background: #f2f4f7;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.match-score-row {
  gap: 24rpx;
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #f5f3ff 0%, #eef4ff 100%);
}

.score-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  color: #ffffff;
  background: linear-gradient(145deg, #7c3aed, #2563eb);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.score-num {
  font-size: 40rpx;
  font-weight: 950;
  line-height: 1;
}

.score-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: 850;
  opacity: 0.85;
}

.match-score-copy {
  flex: 1;
  min-width: 0;
}

.score-job {
  color: #101828;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.score-risk {
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
  font-weight: 750;
}

.match-section {
  margin-top: 24rpx;
}

.match-section-title {
  margin-bottom: 14rpx;
  color: #101828;
  font-size: 27rpx;
  font-weight: 900;
}

.match-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.match-chip {
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.match-chip.missing {
  color: #b45309;
  background: #fff7ed;
}

.match-body,
.match-empty {
  color: #475467;
  font-size: 25rpx;
  line-height: 1.55;
}

.match-suggestion {
  display: flex;
  gap: 12rpx;
  padding: 14rpx 0;
  border-top: 1rpx solid #eef2f7;
}

.match-suggestion:first-of-type {
  border-top: 0;
}

.suggestion-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 13rpx;
  border-radius: 50%;
  background: #2563eb;
  flex-shrink: 0;
}

.suggestion-text {
  flex: 1;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.55;
}

.match-actions {
  gap: 16rpx;
  margin-top: 28rpx;
}

.match-action {
  flex: 1;
  height: 84rpx;
  border-radius: 26rpx;
  font-size: 28rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
}

.match-action.secondary {
  color: #344054;
  background: #f2f4f7;
}

.match-action.primary {
  color: #ffffff;
  background: #2563eb;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.24);
}

.action-copy {
  flex: 1;
  min-width: 0;
}

.action-title {
  display: block;
  color: #172033;
  font-size: 25rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-sub {
  display: block;
  margin-top: 5rpx;
  color: #758195;
  font-size: 20rpx;
  line-height: 1.35;
}

.roadmap-cta {
  box-shadow: 0 16rpx 38rpx rgba(43, 92, 230, 0.08);
}

.f-btn-ai {
  color: #1d4ed8;
}

.f-btn-apply {
  font-weight: 800;
}

.apply-panel {
  background:
    radial-gradient(circle at 50% -8%, rgba(43,92,230,0.10), transparent 34%),
    #ffffff;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* 2026 apply sheet polish: explicit colors for subpackage reliability. */
.apply-mask {
  background: rgba(15, 23, 42, 0.58);
  backdrop-filter: blur(8rpx);
}

.apply-panel {
  padding: 34rpx 36rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background:
    radial-gradient(circle at 50% -6%, rgba(37, 99, 235, 0.12), transparent 36%),
    #ffffff;
  box-shadow: 0 -22rpx 58rpx rgba(15, 23, 42, 0.18);
  box-sizing: border-box;
}

.ap-title {
  color: #101828;
  font-size: 36rpx;
  font-weight: 950;
}

.ap-close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  background: #f2f4f7;
  color: #344054;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}

.ap-job-row {
  padding: 22rpx;
  border-radius: 26rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(226, 232, 240, 0.92);
}

.ap-job-title {
  color: #101828;
  font-size: 30rpx;
  font-weight: 950;
}

.ap-job-company {
  color: #667085;
  font-size: 24rpx;
}

.ap-resume-card {
  padding: 26rpx 28rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  background: #f8fbff;
}

.ap-resume-label {
  color: #101828;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.ap-rname {
  color: #101828;
}

.ap-rsub,
.ap-rcontact,
.ap-rskills,
.ap-resume-empty {
  color: #475467;
}

.ap-resume-link {
  color: #101828;
  font-size: 29rpx;
  font-weight: 950;
}

.ap-btns {
  gap: 18rpx;
}

.ap-btn-cancel,
.ap-btn-submit {
  height: 88rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 950;
}

.ap-btn-cancel {
  flex: 0 0 32%;
  color: #101828;
  background: #f8fafc;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: none;
}

.ap-btn-submit {
  flex: 1;
  color: #ffffff;
  background: #2563eb;
  border: 1rpx solid #2563eb;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.24);
}

.ap-btn-submit text {
  color: #ffffff;
  font-weight: 950;
}

.ap-tip {
  color: #667085;
  font-size: 22rpx;
}

/* Remove the dark native/card seam at the top of the detail page. */
.page {
  position: relative;
  padding-top: 18rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%),
    linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
}

.page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 18rpx;
  background: #f8fbff;
  z-index: 20;
  pointer-events: none;
}

.head-card {
  margin-top: 0;
  border-top-color: rgba(31, 45, 74, 0.035);
  box-shadow: 0 18rpx 42rpx rgba(31, 45, 74, 0.07);
}

.detail-empty {
  min-height: calc(100vh - 140rpx);
  padding: 260rpx 56rpx 80rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.detail-empty-title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 950;
  line-height: 1.2;
}

.detail-empty-sub {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
}

.detail-empty-btn {
  margin-top: 34rpx;
  height: 76rpx;
  padding: 0 32rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 26rpx rgba(37, 99, 235, 0.2);
}
