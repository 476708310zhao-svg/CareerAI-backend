<view class="page">
  <view class="progress-hero">
    <view class="hero-copy">
      <text class="hero-kicker">CAREER PIPELINE</text>
      <text class="hero-title">我的求职进度</text>
      <text class="hero-sub">把收藏、投递、网申、面试和 Offer 放在一条清晰的进度线上。</text>
    </view>
    <view class="hero-total">
      <text class="hero-total-num">{{stats.total}}</text>
      <text class="hero-total-label">记录</text>
    </view>
  </view>

  <view class="summary-grid">
    <view class="summary-item">
      <text class="summary-num">{{stats.active}}</text>
      <text class="summary-label">推进中</text>
    </view>
    <view class="summary-item">
      <text class="summary-num amber">{{stats.dueSoon}}</text>
      <text class="summary-label">3天内截止</text>
    </view>
    <view class="summary-item">
      <text class="summary-num blue">{{stats.interviews}}</text>
      <text class="summary-label">面试阶段</text>
    </view>
    <view class="summary-item">
      <text class="summary-num green">{{stats.offer}}</text>
      <text class="summary-label">Offer</text>
    </view>
  </view>

  <view class="brief-card" bindtap="goDailyBrief" hover-class="card-press">
    <view class="brief-left">
      <text class="brief-title">今日求职建议</text>
      <text class="brief-desc">{{dailyAdvice}}</text>
    </view>
    <text class="brief-arrow">›</text>
  </view>

  <view class="search-row">
    <view class="search-box">
      <text class="search-icon">⌕</text>
      <input class="search-input" value="{{keyword}}" bindinput="onSearchInput" placeholder="搜索公司或岗位" placeholder-style="color:#98A2B3" />
      <text wx:if="{{keyword}}" class="search-clear" catchtap="clearSearch">×</text>
    </view>
    <view class="add-btn" bindtap="showAddForm" hover-class="tap-press">＋</view>
  </view>

  <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="status-scroll">
    <view class="status-track">
      <block wx:for="{{statusTabs}}" wx:key="code">
        <view class="status-chip {{activeStatus === item.code ? 'active' : ''}}" bindtap="setFilter" data-status="{{item.code}}">
          <text>{{item.label}}</text>
          <text class="status-count">{{item.count}}</text>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="record-list" wx:if="{{filteredRecords.length}}">
    <block wx:for="{{filteredRecords}}" wx:key="id">
      <view class="record-card" bindtap="openRecordDetail" data-id="{{item.id}}" hover-class="card-press">
        <view class="record-top">
          <view class="company-avatar">{{item.companyInitial}}</view>
          <view class="record-main">
            <text class="record-title">{{item.jobTitle}}</text>
            <text class="record-company">{{item.company}}{{item.city ? ' · ' + item.city : ''}}</text>
          </view>
          <view class="status-badge status-{{item.statusTone}}">{{item.statusText}}</view>
          <view class="record-more" catchtap="openActions" data-id="{{item.id}}">···</view>
        </view>

        <view class="match-strip" wx:if="{{item.hasMatchReport || item.nextAction}}">
          <view wx:if="{{item.hasMatchReport}}" class="match-score {{item.matchScoreTone}}">
            <text class="match-score-num">{{item.matchScore || '--'}}</text>
            <text class="match-score-label">匹配分</text>
          </view>
          <view class="match-main">
            <text class="match-title">{{item.nextAction}}</text>
            <text wx:if="{{item.missingPreview.length}}" class="match-sub">缺失：{{item.missingPreviewText}}</text>
            <text wx:else class="match-sub">{{item.hasMatchReport ? '关键词覆盖较好，注意补充量化结果' : '点击查看详情补充 JD 分析'}}</text>
          </view>
        </view>

        <view class="meta-grid">
          <view class="meta-item">
            <text class="meta-label">投递</text>
            <text class="meta-value">{{item.appliedAt || '待记录'}}</text>
          </view>
          <view class="meta-item {{item.deadlineUrgent ? 'urgent' : ''}}">
            <text class="meta-label">截止</text>
            <text class="meta-value">{{item.deadlineLabel || '待设置'}}</text>
          </view>
          <view class="meta-item">
            <text class="meta-label">面试</text>
            <text class="meta-value">{{item.interviewTime || '待安排'}}</text>
          </view>
        </view>

        <view class="notes-row" wx:if="{{item.notes}}">
          <text class="notes-label">备注</text>
          <text class="notes-text">{{item.notes}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="empty-card" wx:else>
    <view class="empty-mark">进</view>
    <text class="empty-title">{{activeStatus === 'all' ? '还没有求职进度' : '当前状态暂无记录'}}</text>
    <text class="empty-desc">{{activeStatus === 'all' ? '从收藏岗位或手动添加开始，后续投递、面试和 Offer 都能集中管理。' : '切换状态查看其他记录，或者新建一条进度。'}}</text>
    <view class="empty-actions">
      <view class="empty-primary" bindtap="showAddForm">添加进度</view>
      <view class="empty-secondary" bindtap="goToJobs">浏览岗位</view>
    </view>
  </view>

  <view class="bottom-space"></view>

  <view class="modal-mask" wx:if="{{showForm}}" bindtap="hideForm">
    <view class="form-sheet" catchtap="noop">
      <view class="sheet-handle"></view>
      <text class="sheet-title">{{editId ? '编辑求职进度' : '添加求职进度'}}</text>

      <view class="field-row">
        <view class="field half">
          <text class="field-label">公司 <text class="required">*</text></text>
          <input class="field-input" value="{{form.company}}" data-field="company" bindinput="onFormInput" placeholder="如 Google" />
        </view>
        <view class="field half">
          <text class="field-label">岗位 <text class="required">*</text></text>
          <input class="field-input" value="{{form.jobTitle}}" data-field="jobTitle" bindinput="onFormInput" placeholder="如 Data Analyst" />
        </view>
      </view>

      <view class="field-row">
        <view class="field half">
          <text class="field-label">城市</text>
          <input class="field-input" value="{{form.city}}" data-field="city" bindinput="onFormInput" placeholder="可选" />
        </view>
        <view class="field half">
          <text class="field-label">薪资</text>
          <input class="field-input" value="{{form.salary}}" data-field="salary" bindinput="onFormInput" placeholder="可选" />
        </view>
      </view>

      <view class="field">
        <text class="field-label">岗位链接</text>
        <input class="field-input" value="{{form.jobLink}}" data-field="jobLink" bindinput="onFormInput" placeholder="官方投递链接或 JD 链接" />
      </view>

      <view class="status-form-grid">
        <block wx:for="{{statusOptions}}" wx:key="code">
          <view class="status-form-chip {{form.status === item.code ? 'active tone-' + item.tone : ''}}" bindtap="selectFormStatus" data-status="{{item.code}}">{{item.label}}</view>
        </block>
      </view>

      <view class="field-row">
        <view class="field half">
          <text class="field-label">投递时间</text>
          <picker mode="date" value="{{form.appliedAt}}" bindchange="pickDate" data-field="appliedAt">
            <view class="field-input picker-input">{{form.appliedAt || '选择日期'}}</view>
          </picker>
        </view>
        <view class="field half">
          <text class="field-label">截止时间</text>
          <picker mode="date" value="{{form.deadline}}" bindchange="pickDate" data-field="deadline">
            <view class="field-input picker-input">{{form.deadline || '选择日期'}}</view>
          </picker>
        </view>
      </view>

      <view class="field">
        <text class="field-label">面试时间</text>
        <input class="field-input" value="{{form.interviewTime}}" data-field="interviewTime" bindinput="onFormInput" placeholder="如 2026-07-03 10:00" />
      </view>

      <view class="field">
        <text class="field-label">下一步事项</text>
        <input class="field-input" value="{{form.nextAction}}" data-field="nextAction" bindinput="onFormInput" placeholder="如 补关键词后投递 / 准备一面" />
      </view>

      <view class="field">
        <text class="field-label">关联简历版本</text>
        <input class="field-input" value="{{form.resumeVersionId}}" data-field="resumeVersionId" bindinput="onFormInput" placeholder="如 Data v3 / 中文简历" />
      </view>

      <view class="field">
        <text class="field-label">备注</text>
        <textarea class="field-textarea" value="{{form.notes}}" data-field="notes" bindinput="onFormInput" maxlength="300" placeholder="记录 HR 联系方式、面试链接、下一步动作等"></textarea>
      </view>

      <view class="sheet-actions">
        <view class="sheet-btn cancel" bindtap="hideForm">取消</view>
        <view class="sheet-btn save" bindtap="saveRecord">保存</view>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showDetail && selectedRecord}}" bindtap="hideDetail">
    <view class="detail-sheet" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="detail-head">
        <view class="company-avatar detail-avatar">{{selectedRecord.companyInitial}}</view>
        <view class="detail-title-wrap">
          <text class="detail-title">{{selectedRecord.jobTitle}}</text>
          <text class="detail-sub">{{selectedRecord.company}}{{selectedRecord.city ? ' · ' + selectedRecord.city : ''}}</text>
        </view>
        <view class="status-badge status-{{selectedRecord.statusTone}}">{{selectedRecord.statusText}}</view>
      </view>

      <view class="detail-flow">
        <block wx:for="{{statusFlow}}" wx:key="code">
          <view class="flow-item {{selectedRecord.stageLevel >= item.level ? 'done' : ''}} {{selectedRecord.status === item.code ? 'current' : ''}}">
            <view class="flow-dot"></view>
            <text class="flow-label">{{item.short}}</text>
          </view>
        </block>
      </view>

      <view class="detail-panel" wx:if="{{selectedRecord.hasMatchReport}}">
        <view class="detail-panel-head">
          <text class="detail-panel-title">JD 匹配报告</text>
          <text class="detail-score {{selectedRecord.matchScoreTone}}">{{selectedRecord.matchScore}} 分</text>
        </view>
        <text wx:if="{{selectedRecord.aiSuggestion}}" class="detail-advice">{{selectedRecord.aiSuggestion}}</text>
        <view class="keyword-block" wx:if="{{selectedRecord.matchedPreview.length}}">
          <text class="keyword-title">已命中</text>
          <view class="keyword-list">
            <text wx:for="{{selectedRecord.matchedPreview}}" wx:key="*this" class="keyword-chip matched">{{item}}</text>
          </view>
        </view>
        <view class="keyword-block" wx:if="{{selectedRecord.missingPreview.length}}">
          <text class="keyword-title">建议补充</text>
          <view class="keyword-list">
            <text wx:for="{{selectedRecord.missingPreview}}" wx:key="*this" class="keyword-chip missing">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="detail-panel" wx:else>
        <view class="detail-panel-head">
          <text class="detail-panel-title">还未关联 JD 分析</text>
        </view>
        <text class="detail-advice">补一次 JD 快速匹配后，这里会显示匹配分、缺失关键词和简历优化建议。</text>
      </view>

      <view class="detail-panel">
        <view class="detail-row">
          <text class="detail-label">下一步</text>
          <text class="detail-value">{{selectedRecord.nextAction || '待补充'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">投递时间</text>
          <text class="detail-value">{{selectedRecord.appliedAt || '待记录'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">截止时间</text>
          <text class="detail-value">{{selectedRecord.deadlineLabel || '待设置'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">面试时间</text>
          <text class="detail-value">{{selectedRecord.interviewTime || '待安排'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">简历版本</text>
          <text class="detail-value">{{selectedRecord.resumeVersionId || '默认简历'}}</text>
        </view>
      </view>

      <view class="detail-actions">
        <view class="detail-btn primary" bindtap="updateSelectedStatus">更新状态</view>
        <view class="detail-btn" bindtap="editSelectedRecord">编辑记录</view>
      </view>
      <view class="detail-actions">
        <view class="detail-btn" bindtap="goJdMatchFromRecord">{{selectedRecord.hasMatchReport ? '重新匹配 JD' : '补 JD 匹配'}}</view>
        <view class="detail-btn" bindtap="goAtsFromRecord">优化简历</view>
      </view>
    </view>
  </view>
</view>
