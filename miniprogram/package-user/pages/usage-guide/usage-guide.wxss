page {
  background: #f5f7fb;
  color: #172033;
}

.guide-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 56rpx;
}

.guide-hero {
  box-sizing: border-box;
  padding: 36rpx 32rpx 32rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #2558d8 0%, #159a9c 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(31, 85, 170, 0.18);
}

.hero-eyebrow {
  display: block;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 700;
  opacity: 0.9;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 800;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 42rpx;
  color: rgba(255, 255, 255, 0.88);
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
}

.action-button {
  min-width: 148rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 25rpx;
  font-weight: 700;
  color: #ffffff;
}

.guide-card,
.closing-card {
  margin-top: 22rpx;
  padding: 30rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(30, 42, 70, 0.06);
  box-sizing: border-box;
}

.section-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.section-kicker {
  font-size: 23rpx;
  line-height: 32rpx;
  color: #2b6f6d;
  font-weight: 800;
}

.section-title {
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 800;
  color: #172033;
}

.section-summary {
  font-size: 27rpx;
  line-height: 44rpx;
  color: #5d667a;
}

.quick-steps {
  margin-top: 20rpx;
}

.quick-step {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #edf1f7;
}

.quick-step:first-child {
  border-top: 0;
}

.step-index,
.number-index {
  flex: 0 0 auto;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #eaf2ff;
  color: #2558d8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 800;
}

.step-copy {
  min-width: 0;
  flex: 1;
}

.step-title {
  display: block;
  font-size: 29rpx;
  line-height: 40rpx;
  color: #172033;
  font-weight: 800;
}

.step-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 40rpx;
  color: #667085;
}

.guide-tip {
  margin-top: 8rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #fff7e7;
  color: #8a5200;
  font-size: 25rpx;
  line-height: 38rpx;
  box-sizing: border-box;
}

.guide-list {
  margin-top: 18rpx;
}

.guide-list-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 10rpx 0;
}

.guide-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 18rpx;
  border-radius: 50%;
  background: #2b6f6d;
  flex: 0 0 auto;
}

.guide-list-text {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  line-height: 43rpx;
  color: #465166;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.guide-tag {
  padding: 10rpx 16rpx;
  border-radius: 14rpx;
  background: #eef7f6;
  color: #20615f;
  font-size: 24rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.section-steps {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #edf1f7;
}

.sub-title,
.workflow-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  line-height: 38rpx;
  color: #172033;
  font-weight: 800;
}

.number-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 10rpx 0;
}

.number-text {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  line-height: 42rpx;
  color: #465166;
}

.workflow-block {
  padding: 22rpx 0;
  border-top: 1rpx solid #edf1f7;
}

.workflow-block:first-of-type {
  border-top: 0;
}

.compact-row {
  padding: 7rpx 0;
}

.faq-item {
  padding: 22rpx 0;
  border-top: 1rpx solid #edf1f7;
}

.faq-item:first-of-type {
  border-top: 0;
}

.faq-question {
  display: block;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #172033;
  font-weight: 800;
}

.faq-answer {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 42rpx;
  color: #5d667a;
}

.closing-card {
  background: #17324d;
  color: #ffffff;
  box-shadow: 0 16rpx 38rpx rgba(23, 50, 77, 0.14);
}

.closing-title {
  display: block;
  font-size: 25rpx;
  line-height: 34rpx;
  color: #9be2d6;
  font-weight: 800;
}

.closing-text {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 46rpx;
  color: #ffffff;
  font-weight: 700;
}

.tap-soft {
  opacity: 0.78;
}
