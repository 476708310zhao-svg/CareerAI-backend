page {
  background: #f7fbff;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
  -webkit-font-smoothing: antialiased;
}

.vip-page {
  min-height: 100vh;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 84% 8%, rgba(43, 105, 255, 0.13), transparent 30%),
    linear-gradient(180deg, #f6fbff 0%, #ffffff 48%, #f8fbff 100%);
}

.page-shell {
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 38rpx 34rpx 26rpx;
  border-radius: 24rpx 24rpx 18rpx 18rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(239, 247, 255, 0.96));
  border: 1rpx solid rgba(49, 102, 210, 0.12);
  box-shadow: 0 24rpx 60rpx rgba(35, 90, 170, 0.10);
}

.hero::after {
  content: "";
  position: absolute;
  right: -16rpx;
  top: 178rpx;
  width: 300rpx;
  height: 240rpx;
  opacity: 0.52;
  background-image:
    linear-gradient(rgba(46, 115, 235, 0.10) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(46, 115, 235, 0.10) 1rpx, transparent 1rpx);
  background-size: 28rpx 28rpx;
}

.hero-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-kicker {
  color: #075bea;
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 950;
  letter-spacing: 5rpx;
}

.hero-badge {
  flex-shrink: 0;
  height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #075bea;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(7, 91, 234, 0.55);
  font-size: 22rpx;
  font-weight: 900;
}

.hero-title {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 24rpx;
  color: #05070d;
  font-size: 64rpx;
  line-height: 1.08;
  font-weight: 950;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  display: block;
  width: 620rpx;
  max-width: 100%;
  margin-top: 18rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.48;
  font-weight: 560;
}

.workflow-visual {
  position: relative;
  z-index: 1;
  height: 276rpx;
  margin-top: 26rpx;
}

.resume-card,
.interview-card,
.check-card {
  position: absolute;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(39, 103, 219, 0.13);
  box-shadow: 0 18rpx 44rpx rgba(38, 98, 220, 0.16);
}

.resume-card {
  left: 142rpx;
  top: 24rpx;
  width: 210rpx;
  height: 160rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.mini-label {
  display: block;
  color: #8db5ff;
  font-size: 18rpx;
  font-weight: 950;
}

.mini-label.blue {
  color: #075bea;
}

.avatar-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
}

.avatar-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at 50% 32%, #6aa4ff 0 12rpx, transparent 13rpx),
    radial-gradient(circle at 50% 78%, #2b74f8 0 20rpx, transparent 21rpx),
    #d9e9ff;
}

.line-stack {
  flex: 1;
}

.line-stack view,
.resume-row {
  height: 8rpx;
  border-radius: 999rpx;
  background: #dce9ff;
}

.line-stack view + view {
  margin-top: 12rpx;
}

.resume-row {
  margin-top: 18rpx;
}

.resume-row.short {
  width: 68%;
}

.match-lens {
  position: absolute;
  left: 56rpx;
  top: 94rpx;
  width: 118rpx;
  height: 118rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #075bea;
  background: rgba(255, 255, 255, 0.72);
  border: 4rpx solid rgba(57, 122, 255, 0.72);
  box-shadow: 0 18rpx 36rpx rgba(43, 105, 255, 0.16);
  font-size: 21rpx;
  font-weight: 900;
}

.match-lens::after {
  content: "";
  position: absolute;
  left: -32rpx;
  bottom: -30rpx;
  width: 58rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1b6cff, #69a9ff);
  transform: rotate(-47deg);
}

.interview-card {
  right: 150rpx;
  top: 6rpx;
  width: 230rpx;
  height: 142rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
}

.bubble {
  position: relative;
  width: 112rpx;
  height: 62rpx;
  margin: 22rpx auto 0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #3a7bf7;
  background: linear-gradient(180deg, #cfe2ff, #f5f9ff);
  box-shadow: 0 12rpx 24rpx rgba(43, 105, 255, 0.18);
}

.bubble::after {
  content: "";
  position: absolute;
  right: 20rpx;
  bottom: -18rpx;
  border-width: 18rpx 0 0 22rpx;
  border-style: solid;
  border-color: transparent transparent transparent #dceaff;
}

.bubble text {
  font-size: 34rpx;
  letter-spacing: 6rpx;
  line-height: 1;
  font-weight: 900;
}

.check-card {
  right: 34rpx;
  top: 62rpx;
  width: 108rpx;
  height: 124rpx;
  padding: 20rpx 18rpx;
  border-radius: 14rpx;
  box-sizing: border-box;
}

.check-card > view {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.check-card > view + view {
  margin-top: 16rpx;
}

.check-card text {
  width: 22rpx;
  height: 22rpx;
  border-radius: 5rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: #3b82f6;
  font-size: 18rpx;
  font-weight: 950;
}

.check-card view view {
  width: 44rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #d8e6ff;
}

.flow-line {
  position: absolute;
  left: 126rpx;
  right: 82rpx;
  bottom: 20rpx;
  height: 74rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.flow-line::before {
  content: "";
  position: absolute;
  left: 24rpx;
  right: 68rpx;
  top: 14rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #91bdff, #1c63f2);
}

.step {
  position: relative;
  z-index: 1;
  min-width: 72rpx;
  display: flex;
  justify-content: center;
  color: #0649bd;
  font-size: 22rpx;
  font-weight: 900;
}

.step::before {
  content: "";
  position: absolute;
  top: -56rpx;
  left: 50%;
  width: 24rpx;
  height: 24rpx;
  margin-left: -12rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 6rpx solid #2f75ff;
  box-sizing: border-box;
}

.step.active text {
  padding: 8rpx 18rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47, 117, 255, 0.36);
}

.done-check {
  position: relative;
  z-index: 1;
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, #418bff, #0053d9);
  box-shadow: 0 16rpx 30rpx rgba(20, 91, 225, 0.24);
  font-size: 40rpx;
  font-weight: 950;
}

.benefits-panel {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(31, 95, 210, 0.11);
  box-shadow: 0 20rpx 54rpx rgba(35, 90, 170, 0.10);
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-title-row.small {
  gap: 14rpx;
}

.spark {
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
  position: relative;
}

.spark::before,
.spark::after {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 0;
  width: 10rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: #0b63ff;
}

.spark::after {
  transform: rotate(90deg);
}

.section-title,
.compare-title,
.audience-title {
  color: #05070d;
  font-size: 34rpx;
  line-height: 1.18;
  font-weight: 950;
}

.section-subtitle {
  display: block;
  margin-top: 16rpx;
  color: #435066;
  font-size: 24rpx;
  line-height: 1.45;
}

.benefit-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 26rpx;
}

.benefit-card {
  position: relative;
  min-height: 162rpx;
  padding: 22rpx 18rpx 20rpx 120rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(22, 78, 160, 0.12);
  box-shadow: 0 8rpx 24rpx rgba(30, 88, 170, 0.06);
  box-sizing: border-box;
}

.benefit-num {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  min-width: 52rpx;
  height: 52rpx;
  padding: 0 8rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0649bd;
  background: #eaf3ff;
  font-size: 25rpx;
  font-weight: 950;
  box-sizing: border-box;
}

.benefit-icon {
  position: absolute;
  left: 36rpx;
  top: 86rpx;
  width: 62rpx;
  height: 62rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0b63ff;
  background: linear-gradient(145deg, #eaf3ff, #ffffff);
  box-shadow: 0 10rpx 22rpx rgba(37, 99, 235, 0.14);
  font-size: 22rpx;
  font-weight: 950;
}

.benefit-icon.dots {
  border-radius: 50%;
  color: #ffffff;
  background: linear-gradient(135deg, #45a0ff, #0057df);
  font-size: 26rpx;
  letter-spacing: 3rpx;
}

.benefit-icon.calendar,
.benefit-icon.layers,
.benefit-icon.doc {
  font-size: 25rpx;
}

.benefit-icon.balance,
.benefit-icon.agent {
  width: 72rpx;
  font-size: 18rpx;
}

.benefit-copy {
  min-width: 0;
}

.benefit-title,
.benefit-desc,
.plan-title,
.plan-item {
  display: block;
}

.benefit-title {
  color: #05070d;
  font-size: 27rpx;
  line-height: 1.25;
  font-weight: 950;
}

.benefit-desc {
  margin-top: 10rpx;
  color: #435066;
  font-size: 22rpx;
  line-height: 1.48;
}

.compare-section {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(17, 24, 39, 0.08);
}

.bars {
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: flex-end;
  gap: 5rpx;
}

.bars view {
  width: 7rpx;
  border-radius: 999rpx;
  background: #075bea;
}

.bars view:nth-child(1) { height: 15rpx; }
.bars view:nth-child(2) { height: 25rpx; }
.bars view:nth-child(3) { height: 34rpx; }

.compare-cards {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 44rpx;
  margin-top: 22rpx;
}

.free-card,
.member-card {
  min-height: 188rpx;
  padding: 28rpx 30rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.free-card {
  background: #f8fafc;
  border: 1rpx solid rgba(15, 23, 42, 0.10);
}

.member-card {
  color: #ffffff;
  background: linear-gradient(135deg, #1374ff 0%, #0058e8 48%, #0041bd 100%);
  box-shadow: 0 14rpx 34rpx rgba(0, 81, 210, 0.20);
}

.vs-badge {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 1;
  width: 68rpx;
  height: 68rpx;
  margin-left: -34rpx;
  margin-top: -34rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, #2181ff, #004bd6);
  border: 4rpx solid #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(0, 75, 214, 0.20);
  font-size: 23rpx;
  font-weight: 950;
}

.plan-title {
  margin-bottom: 18rpx;
  color: #1e2a44;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 950;
}

.plan-title.light {
  color: #ffffff;
}

.plan-item {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.95);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 760;
}

.plan-item.muted {
  color: #5b6475;
  font-weight: 650;
}

.audience-section {
  margin-top: 30rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(17, 24, 39, 0.08);
}

.people-icon {
  width: 38rpx;
  height: 28rpx;
  position: relative;
}

.people-icon::before,
.people-icon::after {
  content: "";
  position: absolute;
  bottom: 0;
  border-radius: 999rpx 999rpx 8rpx 8rpx;
  background: #075bea;
}

.people-icon::before {
  left: 0;
  width: 22rpx;
  height: 22rpx;
}

.people-icon::after {
  right: 0;
  width: 26rpx;
  height: 28rpx;
}

.audience-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.audience-chip {
  min-height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0752d7;
  background: #f4f8ff;
  border: 1rpx solid rgba(7, 91, 234, 0.22);
  font-size: 23rpx;
  font-weight: 850;
}

.bottom-safe-space {
  height: calc(142rpx + env(safe-area-inset-bottom));
}

.member-footer {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  z-index: 99;
  height: 92rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  background:
    linear-gradient(95deg, #0632a3 0%, #0752e8 58%, #1678ff 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 18rpx;
  box-shadow:
    0 18rpx 42rpx rgba(0, 42, 145, 0.24),
    0 4rpx 10rpx rgba(0, 60, 180, 0.14);
  overflow: hidden;
}

.member-footer::before,
.member-footer::after {
  content: "";
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border-radius: 1rpx;
  background: rgba(255, 255, 255, 0.80);
  transform: rotate(45deg);
  box-shadow:
    26rpx -8rpx 0 rgba(255, 255, 255, 0.30),
    52rpx 14rpx 0 rgba(255, 255, 255, 0.24);
  pointer-events: none;
}

.member-footer::before {
  right: 18rpx;
  top: 14rpx;
}

.member-footer::after {
  right: 76rpx;
  bottom: 16rpx;
  opacity: 0.62;
}

.footer-main {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.member-card-icon {
  width: 56rpx;
  height: 52rpx;
  flex-shrink: 0;
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.76);
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.03));
  box-shadow:
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.14),
    0 8rpx 18rpx rgba(0, 33, 120, 0.18);
}

.member-card-crown {
  color: #ffeeb3;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 950;
}

.footer-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.footer-title,
.footer-subtitle {
  display: block;
  color: #ffffff;
  white-space: nowrap;
}

.footer-title {
  font-size: 28rpx;
  line-height: 1.12;
  font-weight: 950;
}

.footer-subtitle {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 18rpx;
  line-height: 1.15;
  font-weight: 600;
}

.benefit-pill {
  position: relative;
  z-index: 1;
  width: 214rpx;
  height: 56rpx;
  flex-shrink: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #073eaf;
  background: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  box-shadow:
    0 8rpx 20rpx rgba(0, 25, 92, 0.18),
    inset 0 -2rpx 0 rgba(7, 62, 175, 0.05);
}

.pill-arrow {
  font-size: 26rpx;
  line-height: 1;
  font-weight: 950;
}

.footer-press,
.pill-press {
  opacity: 0.82;
}

@media (max-width: 360px) {
  .hero-title {
    font-size: 56rpx;
  }

  .benefit-grid,
  .compare-cards {
    grid-template-columns: 1fr;
  }

  .compare-cards {
    gap: 18rpx;
  }

  .vs-badge {
    top: 50%;
  }
}
