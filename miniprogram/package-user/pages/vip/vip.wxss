page {
  background: #f4f8fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
  -webkit-font-smoothing: antialiased;
}

.vip-page {
  min-height: 100vh;
  overflow-x: hidden;
  background:
    linear-gradient(180deg, #eef6ff 0%, #ffffff 44%, #f6faf8 100%);
}

.page-shell {
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.hero,
.pricing-panel,
.usage-panel,
.benefits-panel,
.use-panel {
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(24, 72, 132, 0.10);
  box-shadow: 0 18rpx 46rpx rgba(30, 82, 145, 0.09);
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 32rpx 30rpx;
  background:
    linear-gradient(135deg, #ffffff 0%, #f3f8ff 58%, #eef8f3 100%);
}

.hero::after {
  content: "";
  position: absolute;
  right: -24rpx;
  bottom: -28rpx;
  width: 300rpx;
  height: 220rpx;
  opacity: 0.46;
  background-image:
    linear-gradient(rgba(34, 109, 210, 0.10) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(34, 109, 210, 0.10) 1rpx, transparent 1rpx);
  background-size: 28rpx 28rpx;
  pointer-events: none;
}

.hero-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-kicker {
  color: #1d66d2;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.hero-badge {
  flex-shrink: 0;
  min-height: 50rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f5fbd;
  background: #ffffff;
  border: 2rpx solid rgba(37, 99, 235, 0.26);
  font-size: 22rpx;
  font-weight: 850;
}

.hero-title {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 28rpx;
  color: #0b1220;
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 950;
  letter-spacing: 0;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 16rpx;
  color: #40526a;
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 560;
}

.hero-flow {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  margin-top: 34rpx;
}

.flow-node {
  width: 144rpx;
  min-height: 116rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  box-shadow: 0 10rpx 24rpx rgba(40, 93, 166, 0.08);
}

.flow-node.active {
  border-color: rgba(19, 159, 110, 0.36);
  background: #f7fffb;
}

.flow-icon {
  width: 46rpx;
  height: 46rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #139f6e);
  font-size: 24rpx;
  line-height: 1;
  font-weight: 950;
}

.flow-title {
  display: block;
  margin-top: 12rpx;
  color: #17345c;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 850;
}

.flow-line {
  flex: 1;
  height: 3rpx;
  margin: 0 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(37, 99, 235, 0.14), rgba(19, 159, 110, 0.42));
}

.pricing-panel,
.usage-panel,
.benefits-panel,
.use-panel {
  margin-top: 22rpx;
  padding: 26rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.section-head.compact {
  align-items: center;
}

.section-icon {
  width: 46rpx;
  height: 46rpx;
  flex-shrink: 0;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 950;
}

.price-icon {
  background: linear-gradient(135deg, #139f6e, #0f6fbc);
}

.benefit-icon {
  background: linear-gradient(135deg, #2563eb, #0f6fbc);
}

.use-icon {
  background: linear-gradient(135deg, #d89523, #139f6e);
}

.usage-icon {
  background: linear-gradient(135deg, #0f6fbc, #139f6e);
  font-size: 20rpx;
}

.section-copy {
  min-width: 0;
  flex: 1;
}

.section-title,
.section-subtitle {
  display: block;
}

.section-title {
  color: #0b1220;
  font-size: 32rpx;
  line-height: 1.18;
  font-weight: 950;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.42;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.price-card {
  min-height: 204rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: #fbfdff;
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
  transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
}

.price-card.active {
  background: linear-gradient(180deg, #f8fffb 0%, #eff8ff 100%);
  border-color: #139f6e;
  box-shadow: 0 12rpx 28rpx rgba(19, 159, 110, 0.14);
}

.price-card.disabled {
  background: #f7f9fb;
  border-color: rgba(100, 116, 139, 0.18);
  box-shadow: none;
  opacity: 0.76;
}

.price-card.disabled .price-main {
  color: #64748b;
}

.price-card.disabled .price-unit,
.price-card.disabled .price-desc {
  color: #8794a6;
}

.price-card-press {
  transform: scale(0.98);
}

.price-card-head {
  min-height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.price-name,
.price-tag,
.price-unit,
.price-desc {
  display: block;
}

.price-name {
  min-width: 0;
  color: #0f172a;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 900;
}

.price-tag {
  flex-shrink: 0;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a4b00;
  background: #fff2c7;
  font-size: 18rpx;
  font-weight: 900;
}

.price-tag.muted {
  color: #475569;
  background: #e8eef5;
}

.price-main {
  display: flex;
  align-items: baseline;
  margin-top: 18rpx;
  color: #0b3d78;
}

.price-symbol {
  font-size: 23rpx;
  font-weight: 900;
}

.price-value {
  margin-left: 4rpx;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 950;
}

.price-unit {
  margin-top: 10rpx;
  color: #139f6e;
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 900;
}

.price-desc {
  margin-top: 14rpx;
  color: #526175;
  font-size: 21rpx;
  line-height: 1.35;
  font-weight: 650;
}

.quota-date {
  flex-shrink: 0;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  color: #0f5fbd;
  background: #eef6ff;
  font-size: 20rpx;
  font-weight: 850;
}

.quota-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quota-row {
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fbfdff;
  border: 1rpx solid rgba(22, 78, 160, 0.10);
}

.quota-row.exhausted {
  background: #fff8f3;
  border-color: rgba(217, 119, 6, 0.18);
}

.quota-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.quota-name {
  min-width: 0;
  color: #0f172a;
  font-size: 25rpx;
  line-height: 1.25;
  font-weight: 900;
}

.quota-count {
  flex-shrink: 0;
  color: #0f5fbd;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 900;
}

.quota-track {
  position: relative;
  height: 12rpx;
  margin-top: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eaf0f7;
}

.quota-fill {
  height: 12rpx;
  min-width: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #139f6e, #0f6fbc);
}

.quota-fill.warning {
  background: linear-gradient(90deg, #d97706, #ef4444);
}

.quota-remain {
  display: block;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 21rpx;
  line-height: 1.3;
  font-weight: 700;
}

.quota-empty {
  min-height: 86rpx;
  margin-top: 22rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  background: #f7fbff;
  border: 1rpx dashed rgba(37, 99, 235, 0.18);
  font-size: 24rpx;
  font-weight: 700;
}

.benefit-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.benefit-card {
  min-height: 150rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fbfdff;
  border: 1rpx solid rgba(22, 78, 160, 0.10);
  box-sizing: border-box;
}

.benefit-num,
.benefit-title,
.benefit-desc {
  display: block;
}

.benefit-num {
  width: 48rpx;
  height: 34rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f5fbd;
  background: #eaf3ff;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 950;
}

.benefit-title {
  margin-top: 14rpx;
  color: #0f172a;
  font-size: 26rpx;
  line-height: 1.22;
  font-weight: 900;
}

.benefit-desc {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.38;
}

.audience-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.audience-chip {
  min-height: 50rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f5fbd;
  background: #f4f8ff;
  border: 1rpx solid rgba(37, 99, 235, 0.18);
  font-size: 22rpx;
  font-weight: 800;
}

.bottom-safe-space {
  height: calc(144rpx + env(safe-area-inset-bottom));
}

.member-footer {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  z-index: 99;
  min-height: 94rpx;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  background: linear-gradient(95deg, #07358f 0%, #0752e8 56%, #139f6e 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 20rpx;
  box-shadow:
    0 18rpx 42rpx rgba(0, 42, 145, 0.24),
    0 4rpx 10rpx rgba(0, 60, 180, 0.14);
}

.footer-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.vip-mark {
  width: 62rpx;
  height: 62rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f317a;
  background: linear-gradient(135deg, #fff5cc, #ffffff 58%, #dff7ec);
  border: 2rpx solid rgba(255, 255, 255, 0.74);
  box-shadow:
    inset 0 -3rpx 0 rgba(15, 49, 122, 0.08),
    0 8rpx 18rpx rgba(0, 33, 120, 0.18);
}

.vip-mark text {
  font-size: 21rpx;
  line-height: 1;
  font-weight: 950;
}

.footer-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.footer-title,
.footer-subtitle {
  display: block;
  color: #ffffff;
  white-space: nowrap;
}

.footer-title {
  font-size: 27rpx;
  line-height: 1.14;
  font-weight: 950;
}

.footer-subtitle {
  max-width: 360rpx;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 19rpx;
  line-height: 1.16;
  font-weight: 650;
  overflow: hidden;
  text-overflow: ellipsis;
}

.benefit-pill {
  width: 178rpx;
  height: 58rpx;
  flex-shrink: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #073eaf;
  background: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
  box-shadow:
    0 8rpx 20rpx rgba(0, 25, 92, 0.18),
    inset 0 -2rpx 0 rgba(7, 62, 175, 0.05);
}

.pill-arrow {
  font-size: 26rpx;
  line-height: 1;
  font-weight: 950;
}

.footer-press,
.pill-press {
  opacity: 0.82;
}

@media (max-width: 360px) {
  .hero-title {
    font-size: 42rpx;
  }

  .hero-flow,
  .pricing-grid,
  .benefit-grid {
    grid-template-columns: 1fr;
  }

  .flow-node {
    width: 128rpx;
  }

  .benefit-pill {
    width: 160rpx;
  }
}
