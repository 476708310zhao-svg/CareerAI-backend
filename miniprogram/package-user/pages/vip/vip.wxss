/* pages/vip/vip.wxss */
page {
  --vip-bg: #f7f4ee;
  --vip-ink: #0b1220;
  --vip-body: #455164;
  --vip-muted: #8a94a6;
  --vip-line: rgba(24, 32, 48, 0.10);
  --vip-card: rgba(255, 255, 255, 0.78);
  --vip-blue: #102a56;
  --vip-blue-2: #1f5eff;
  --vip-cyan: #10b8b0;
  --vip-cream: #f7f4ee;
  background:
    radial-gradient(circle at 78% 0%, rgba(31,94,255,0.12), transparent 28%),
    linear-gradient(180deg, #f7f4ee 0%, #fbfaf7 46%, #ffffff 100%);
  color: var(--vip-ink);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.vip-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 0;
  box-sizing: border-box;
}

.hero-section,
.plans-panel,
.section-block,
.final-cta,
.vip-active-card {
  border: 1rpx solid var(--vip-line);
  box-shadow: 0 22rpx 60rpx rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(24rpx);
}

.hero-section {
  position: relative;
  overflow: hidden;
  padding: 32rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 98% 8%, rgba(16,184,176,0.18), transparent 32%),
    linear-gradient(135deg, rgba(255,255,255,0.82), rgba(238,244,255,0.72));
}

.hero-section::before {
  content: '';
  position: absolute;
  right: -90rpx;
  top: -80rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(31,94,255,0.20), transparent 64%);
}

.hero-copy {
  position: relative;
  z-index: 1;
}

.eyebrow-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.eyebrow,
.section-kicker,
.final-kicker {
  color: var(--vip-blue-2);
  font-size: 19rpx;
  font-weight: 950;
  letter-spacing: 1.8rpx;
  text-transform: uppercase;
}

.hero-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #5d687a;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(255,255,255,0.9);
  font-size: 21rpx;
  font-weight: 850;
}

.hero-status.active {
  color: #05756f;
  background: rgba(236,253,245,0.86);
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  color: var(--vip-ink);
  font-size: 58rpx;
  line-height: 1.04;
  font-weight: 950;
  letter-spacing: -1.4rpx;
}

.hero-subtitle {
  display: block;
  width: 600rpx;
  max-width: 100%;
  margin-top: 20rpx;
  color: var(--vip-body);
  font-size: 27rpx;
  line-height: 1.58;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.primary-cta,
.secondary-cta,
.final-button {
  height: 74rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 950;
  box-sizing: border-box;
}

.primary-cta,
.final-button {
  color: #fff;
  background: linear-gradient(135deg, #0b1220 0%, #102a56 54%, #1f5eff 100%);
  box-shadow: 0 18rpx 36rpx rgba(16, 42, 86, 0.22);
}

.secondary-cta {
  color: var(--vip-blue);
  background: rgba(255,255,255,0.70);
  border: 1rpx solid rgba(16,42,86,0.12);
}

.agent-dashboard {
  position: relative;
  z-index: 1;
  margin-top: 34rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background:
    linear-gradient(180deg, rgba(11,18,32,0.94), rgba(16,42,86,0.92));
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.14), 0 24rpx 48rpx rgba(16,42,86,0.24);
}

.dash-top,
.benefit-top,
.section-head,
.compare-row,
.task-row,
.flow-row,
.footer-bar {
  display: flex;
  align-items: center;
}

.dash-top {
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.dash-label {
  color: rgba(255,255,255,0.72);
  font-size: 22rpx;
  font-weight: 850;
}

.dash-live {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #b8fff8;
  background: rgba(16,184,176,0.16);
  border: 1rpx solid rgba(16,184,176,0.24);
  font-size: 19rpx;
  font-weight: 900;
}

.prompt-card,
.chat-bubble,
.metric-card {
  border: 1rpx solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.08);
}

.prompt-card {
  padding: 20rpx;
  border-radius: 22rpx;
}

.prompt-user {
  display: block;
  color: rgba(255,255,255,0.48);
  font-size: 20rpx;
  font-weight: 850;
}

.prompt-text {
  display: block;
  margin-top: 8rpx;
  color: #fff;
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 800;
}

.agent-flow {
  margin-top: 18rpx;
}

.flow-row {
  min-height: 78rpx;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.flow-row:last-child {
  border-bottom: 0;
}

.flow-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.36);
  flex-shrink: 0;
}

.flow-row.running .flow-dot {
  background: var(--vip-cyan);
  box-shadow: 0 0 0 8rpx rgba(16,184,176,0.14);
}

.flow-main {
  flex: 1;
  min-width: 0;
}

.flow-title,
.flow-desc,
.flow-status,
.metric-num,
.metric-label,
.section-title,
.section-subtitle,
.section-note,
.benefit-title,
.benefit-desc,
.task-title,
.task-desc,
.task-status,
.audience-title,
.audience-desc,
.final-title,
.final-subtitle,
.active-title,
.active-sub,
.active-hint {
  display: block;
}

.flow-title {
  color: rgba(255,255,255,0.92);
  font-size: 24rpx;
  font-weight: 900;
}

.flow-desc {
  margin-top: 5rpx;
  color: rgba(255,255,255,0.48);
  font-size: 20rpx;
}

.flow-status {
  color: rgba(255,255,255,0.62);
  font-size: 20rpx;
  font-weight: 850;
  flex-shrink: 0;
}

.dash-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.metric-card {
  padding: 18rpx;
  border-radius: 20rpx;
}

.metric-num {
  color: #fff;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 950;
}

.metric-label {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.54);
  font-size: 20rpx;
}

.plans-panel,
.section-block,
.final-cta,
.vip-active-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: var(--vip-card);
}

.section-head {
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 8rpx;
  margin-bottom: 22rpx;
}

.section-head.compact {
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.section-head.compact > view {
  flex: 1;
  min-width: 0;
}

.section-title {
  margin-top: 8rpx;
  width: 100%;
  color: var(--vip-ink);
  font-size: 34rpx;
  line-height: 1.24;
  font-weight: 950;
  word-break: break-word;
}

.section-subtitle,
.section-note {
  margin-top: 8rpx;
  width: 100%;
  color: var(--vip-body);
  font-size: 24rpx;
  line-height: 1.48;
  word-break: break-word;
}

.section-note {
  width: 210rpx;
  text-align: right;
  color: var(--vip-muted);
  flex-shrink: 0;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.plan-card {
  position: relative;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid var(--vip-line);
  box-sizing: border-box;
}

.plan-card.selected {
  background: rgba(255,255,255,0.95);
  border-color: rgba(31,94,255,0.48);
  box-shadow: 0 18rpx 42rpx rgba(31,94,255,0.12);
}

.plan-ribbon {
  position: absolute;
  top: 0;
  left: 0;
  padding: 6rpx 16rpx;
  border-radius: 24rpx 0 16rpx 0;
  color: #fff;
  background: #102a56;
  font-size: 19rpx;
  font-weight: 900;
}

.plan-info {
  flex: 1;
  min-width: 0;
  padding-top: 8rpx;
}

.plan-name {
  display: block;
  color: var(--vip-ink);
  font-size: 29rpx;
  font-weight: 950;
}

.plan-sub {
  display: block;
  margin-top: 8rpx;
  color: var(--vip-body);
  font-size: 22rpx;
}

.plan-price {
  text-align: right;
  flex-shrink: 0;
}

.price-now {
  display: block;
  color: var(--vip-blue-2);
  font-size: 42rpx;
  line-height: 1;
  font-weight: 950;
}

.price-old {
  display: block;
  margin-top: 8rpx;
  color: #aeb6c4;
  font-size: 21rpx;
  text-decoration: line-through;
}

.plan-check {
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  color: #fff;
  background: var(--vip-blue-2);
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 950;
}

.benefit-grid,
.audience-grid,
.feature-entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.benefit-card,
.audience-card,
.feature-entry-card {
  min-height: 214rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,0.70);
  border: 1rpx solid var(--vip-line);
  box-sizing: border-box;
}

.benefit-card:active,
.audience-card:active,
.feature-entry-card:active,
.plan-card:active {
  transform: scale(0.986);
}

.feature-entry-section {
  background:
    radial-gradient(circle at 100% 0%, rgba(31,94,255,0.08), transparent 32%),
    rgba(255,255,255,0.76);
}

.feature-entry-card {
  min-height: 196rpx;
}

.feature-entry-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.feature-entry-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--vip-blue);
  background: rgba(31,94,255,0.08);
  font-size: 28rpx;
  font-weight: 950;
}

.feature-entry-badge {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: var(--vip-blue-2);
  font-size: 18rpx;
  font-weight: 900;
}

.feature-entry-name {
  display: block;
  margin-top: 18rpx;
  color: var(--vip-ink);
  font-size: 26rpx;
  line-height: 1.28;
  font-weight: 950;
}

.feature-entry-desc {
  display: block;
  margin-top: 9rpx;
  color: var(--vip-body);
  font-size: 21rpx;
  line-height: 1.45;
}

.feature-entry-press {
  opacity: 0.78;
}

.benefit-top {
  justify-content: space-between;
}

.benefit-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--vip-blue);
  background: rgba(16,42,86,0.08);
  font-size: 22rpx;
  font-weight: 950;
}

.benefit-tag {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  color: var(--vip-blue-2);
  background: rgba(31,94,255,0.08);
  font-size: 18rpx;
  font-weight: 900;
}

.benefit-title {
  margin-top: 20rpx;
  color: var(--vip-ink);
  font-size: 27rpx;
  line-height: 1.28;
  font-weight: 950;
}

.benefit-desc {
  margin-top: 10rpx;
  color: var(--vip-body);
  font-size: 22rpx;
  line-height: 1.48;
}

.workflow-section {
  background:
    radial-gradient(circle at 100% 0%, rgba(16,184,176,0.10), transparent 30%),
    rgba(255,255,255,0.72);
}

.workflow-shell {
  border-radius: 28rpx;
  padding: 20rpx;
  background: rgba(11,18,32,0.94);
  overflow: hidden;
}

.chat-panel {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.chat-bubble {
  width: 82%;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  color: rgba(255,255,255,0.92);
  font-size: 23rpx;
  line-height: 1.45;
}

.chat-bubble.user {
  align-self: flex-end;
  color: #fff;
  background: rgba(31,94,255,0.34);
  border-color: rgba(31,94,255,0.40);
}

.chat-bubble.ai {
  align-self: flex-start;
}

.task-stream {
  margin-top: 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.10);
}

.task-row {
  min-height: 96rpx;
  gap: 16rpx;
  padding: 18rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.task-row:last-child {
  border-bottom: 0;
}

.task-index {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: rgba(255,255,255,0.72);
  background: rgba(255,255,255,0.10);
  line-height: 42rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.task-row.done .task-index,
.task-row.active .task-index {
  color: #fff;
  background: var(--vip-cyan);
}

.task-copy {
  flex: 1;
  min-width: 0;
}

.task-title {
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
}

.task-desc {
  margin-top: 5rpx;
  color: rgba(255,255,255,0.48);
  font-size: 20rpx;
}

.task-status {
  color: rgba(255,255,255,0.58);
  font-size: 20rpx;
  font-weight: 850;
  flex-shrink: 0;
}

.task-row.active .task-status {
  color: #b8fff8;
}

.compare-table {
  overflow: hidden;
  border-radius: 26rpx;
  border: 1rpx solid var(--vip-line);
  background: rgba(255,255,255,0.64);
}

.compare-row {
  display: grid;
  grid-template-columns: 1.1fr 1fr 1.2fr;
  gap: 12rpx;
  min-height: 86rpx;
  padding: 18rpx;
  border-bottom: 1rpx solid rgba(24,32,48,0.08);
  color: var(--vip-body);
  font-size: 21rpx;
  line-height: 1.35;
}

.compare-row:last-child {
  border-bottom: 0;
}

.compare-head {
  color: var(--vip-ink);
  background: rgba(247,244,238,0.74);
  font-weight: 950;
}

.vip-col,
.vip-value {
  color: var(--vip-blue-2);
  font-weight: 950;
}

.feature-name {
  color: var(--vip-ink);
  font-weight: 850;
}

.free-value {
  color: var(--vip-muted);
}

.audience-grid {
  grid-template-columns: 1fr;
}

.audience-card {
  min-height: 132rpx;
}

.audience-title {
  color: var(--vip-ink);
  font-size: 28rpx;
  font-weight: 950;
}

.audience-desc {
  margin-top: 10rpx;
  color: var(--vip-body);
  font-size: 23rpx;
  line-height: 1.52;
}

.final-cta {
  position: relative;
  overflow: hidden;
  padding: 38rpx 30rpx;
  color: #fff;
  background:
    radial-gradient(circle at 100% 0%, rgba(16,184,176,0.24), transparent 34%),
    linear-gradient(135deg, #0b1220 0%, #102a56 66%, #1f5eff 100%);
}

.final-title {
  margin-top: 12rpx;
  color: #fff;
  font-size: 40rpx;
  line-height: 1.18;
  font-weight: 950;
}

.final-subtitle {
  margin-top: 14rpx;
  color: rgba(255,255,255,0.72);
  font-size: 24rpx;
  line-height: 1.55;
}

.final-button {
  width: 260rpx;
  margin-top: 28rpx;
  background: #fff;
  color: #0b1220;
  box-shadow: 0 18rpx 36rpx rgba(0,0,0,0.20);
}

.vip-active-card {
  color: #fff;
  background: linear-gradient(135deg, #102a56, #10b8b0);
}

.active-title {
  font-size: 32rpx;
  font-weight: 950;
}

.active-sub,
.active-hint {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.78);
  font-size: 24rpx;
  line-height: 1.5;
}

.restore-link {
  padding: 28rpx 0 10rpx;
  color: var(--vip-body);
  text-align: center;
  font-size: 24rpx;
}

.disclaimer {
  padding: 16rpx 18rpx 0;
  color: var(--vip-muted);
  text-align: center;
  font-size: 21rpx;
  line-height: 1.5;
}

.bottom-space {
  height: calc(164rpx + env(safe-area-inset-bottom));
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  gap: 20rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.86);
  border-top: 1rpx solid var(--vip-line);
  box-shadow: 0 -18rpx 42rpx rgba(15,23,42,0.10);
  backdrop-filter: blur(24rpx);
}

.footer-price {
  width: 162rpx;
  flex-shrink: 0;
}

.fp-label {
  display: block;
  color: var(--vip-muted);
  font-size: 20rpx;
}

.fp-plan {
  display: block;
  margin-top: 6rpx;
  color: var(--vip-ink);
  font-size: 26rpx;
  font-weight: 950;
}

.pay-btn {
  flex: 1;
  min-width: 0;
  min-height: 86rpx;
  border-radius: 999rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(135deg, #0b1220 0%, #102a56 54%, #1f5eff 100%);
  box-shadow: 0 16rpx 34rpx rgba(16,42,86,0.22);
}

.pay-btn.paying {
  opacity: 0.72;
}

.pay-main {
  font-size: 28rpx;
  line-height: 1.1;
  font-weight: 950;
}

.pay-sub {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.78);
  font-size: 19rpx;
  font-weight: 750;
}
