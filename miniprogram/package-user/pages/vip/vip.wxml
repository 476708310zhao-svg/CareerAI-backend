<view wx:if="{{membershipEnabled}}" class="vip-page">
  <view class="page-shell">
    <view class="hero">
      <view class="hero-head">
        <text class="hero-kicker">CAREER PRO</text>
        <text class="hero-badge">留学生求职会员</text>
      </view>
      <text class="hero-title">把求职准备做成一套流程</text>
      <text class="hero-subtitle">简历、面试、项目经历与 Offer 分析统一提效，适合集中投递和面试冲刺。</text>

      <view class="hero-flow">
        <view class="flow-node active">
          <text class="flow-icon">简</text>
          <text class="flow-title">简历优化</text>
        </view>
        <view class="flow-line"></view>
        <view class="flow-node">
          <text class="flow-icon">面</text>
          <text class="flow-title">模拟面试</text>
        </view>
        <view class="flow-line"></view>
        <view class="flow-node">
          <text class="flow-icon">策</text>
          <text class="flow-title">Offer 决策</text>
        </view>
      </view>
    </view>

    <c-ai-disclosure text="会员权益中的 AI 内容仅供求职参考，关键信息请结合自身情况核验。" />

    <view class="pricing-panel">
      <view class="section-head">
        <view class="section-icon price-icon">¥</view>
        <view class="section-copy">
          <text class="section-title">选择会员套餐</text>
          <text class="section-subtitle">支付后自动开通，权益状态可在服务端校验。</text>
        </view>
      </view>

      <view class="pricing-grid">
        <view
          wx:for="{{plans}}"
          wx:key="id"
          class="price-card {{selectedPlanId === item.id ? 'active' : ''}} {{item.disabled ? 'disabled' : ''}}"
          data-plan-id="{{item.id}}"
          bindtap="selectPlan"
          hover-class="price-card-press"
        >
          <view class="price-card-head">
            <text class="price-name">{{item.name}}</text>
            <text wx:if="{{item.badgeText}}" class="price-tag {{item.disabled ? 'muted' : ''}}">{{item.badgeText}}</text>
          </view>
          <view class="price-main">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.price}}</text>
          </view>
          <text class="price-unit">{{item.unit}}</text>
          <text class="price-desc">{{item.displayDesc}}</text>
        </view>
      </view>
    </view>

    <view class="benefits-panel">
      <view class="section-head">
        <view class="section-icon benefit-icon">+</view>
        <view class="section-copy">
          <text class="section-title">会员权益</text>
          <text class="section-subtitle">少解释，多帮你把求职动作往前推。</text>
        </view>
      </view>

      <view class="benefit-grid">
        <view class="benefit-card">
          <text class="benefit-num">01</text>
          <text class="benefit-title">AI 面试训练</text>
          <text class="benefit-desc">按目标岗位练习追问与复盘。</text>
        </view>
        <view class="benefit-card">
          <text class="benefit-num">02</text>
          <text class="benefit-title">JD 定制简历</text>
          <text class="benefit-desc">突出匹配点、量化成果。</text>
        </view>
        <view class="benefit-card">
          <text class="benefit-num">03</text>
          <text class="benefit-title">求职节奏规划</text>
          <text class="benefit-desc">拆出 30/60/90 天行动表。</text>
        </view>
        <view class="benefit-card">
          <text class="benefit-num">04</text>
          <text class="benefit-title">项目经历优化</text>
          <text class="benefit-desc">把经历包装成可讲故事。</text>
        </view>
        <view class="benefit-card">
          <text class="benefit-num">05</text>
          <text class="benefit-title">Offer 分析</text>
          <text class="benefit-desc">对比薪资、成长和风险。</text>
        </view>
        <view class="benefit-card">
          <text class="benefit-num">06</text>
          <text class="benefit-title">Agent 工作流</text>
          <text class="benefit-desc">串联找岗、优化、面试准备。</text>
        </view>
      </view>
    </view>

    <view class="use-panel">
      <view class="section-head compact">
        <view class="section-icon use-icon">✓</view>
        <view class="section-copy">
          <text class="section-title">适合这些阶段</text>
        </view>
      </view>
      <view class="audience-chips">
        <view class="audience-chip">集中投递</view>
        <view class="audience-chip">面试准备</view>
        <view class="audience-chip">简历重写</view>
        <view class="audience-chip">Offer 选择</view>
      </view>
    </view>
  </view>

  <view class="bottom-safe-space"></view>

  <view class="member-footer">
    <view class="footer-main" bindtap="handlePay" hover-class="footer-press">
      <view class="vip-mark">
        <text>VIP</text>
      </view>
      <view class="footer-copy">
        <text class="footer-title">{{paying ? '正在开通...' : '解锁会员权益'}}</text>
        <text class="footer-subtitle">{{paymentAvailable ? selectedPlanName + ' ¥' + selectedPlanPrice + ' · 支付后生效' : paymentReason}}</text>
      </view>
    </view>

    <view class="benefit-pill" catchtap="handlePay" hover-class="pill-press">
      <text>{{paying ? '请稍候' : '确认开通'}}</text>
      <text class="pill-arrow">›</text>
    </view>
  </view>
</view>
