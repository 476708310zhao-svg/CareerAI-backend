/* pages/profile-edit/profile-edit.wxss */
page {
  background: var(--bg-raised);
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.container { padding: 0 24rpx 100rpx; }

/* ── Hero Card: 头像 + 进度 ── */
.hero-card {
  background: linear-gradient(135deg, var(--brand) 0%, #4F7CF7 100%);
  border-radius: var(--r-lg);
  padding: 32rpx 28rpx 28rpx;
  margin: 24rpx 0 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(43,92,230,0.25);
}

.hero-avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.6);
}
.camera-badge {
  position: absolute;
  bottom: 0; right: 0;
  background: rgba(0,0,0,0.45);
  width: 42rpx; height: 42rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 42rpx;
  font-size: 20rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
}

.hero-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.hero-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.hero-school {
  font-size: 24rpx;
  color: rgba(255,255,255,0.72);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 进度条区域 */
.progress-wrap { display: flex; flex-direction: column; gap: 12rpx; }
.progress-label { font-size: 24rpx; color: rgba(255,255,255,0.85); font-weight: 600; }
.progress-tip   { font-size: 22rpx; color: rgba(255,255,255,0.6); }
.profile-progress {
  width: 100%;
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dbe7f8;
}
.profile-progress-fill {
  height: 100%;
  min-width: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2563eb, #22c55e);
}

/* ── 分区标题 ── */
.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 27rpx;
  font-weight: 700;
  color: #1F2937;
  padding: 32rpx 4rpx 14rpx;
}
.section-accent {
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--brand), #7BA4F8);
  border-radius: 4rpx;
  flex-shrink: 0;
}
.section-note {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 400;
}

/* ── 表单卡片 ── */
.form-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
}
.form-card.pad { padding: 24rpx 28rpx; }

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  gap: 16rpx;
}
.form-divider {
  height: 1rpx;
  background: var(--bg-raised);
  margin: 0 28rpx;
}
.label-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  width: 110rpx;
  flex-shrink: 0;
}
.label-icon { font-size: 28rpx; }
.label {
  font-size: 28rpx;
  color: var(--text-body);
  font-weight: 600;
}
.input {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
  text-align: right;
  height: 48rpx;
  line-height: 48rpx;
}

/* ── 子标题 ── */
.sub-label {
  display: block;
  font-size: 23rpx;
  color: var(--text-muted);
  font-weight: 600;
  margin-bottom: 14rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}
.sub-label.mt { margin-top: 28rpx; }

/* ── 通用 Chip ── */
.chip-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 12rpx;
  overflow-x: auto;
}
.chip-row.wrap {
  flex-wrap: wrap;
  overflow-x: visible;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 26rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: #F3F4F6;
  border: 2rpx solid transparent;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.15s;
}
.chip-active {
  background: #EEF4FD;
  color: var(--brand);
  border-color: #BFDBFE;
  font-weight: 600;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.14);
}

.chip-active::before {
  content: "✓";
  margin-right: 6rpx;
  font-size: 22rpx;
  font-weight: 900;
}

/* ── 已选标签 ── */
.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 4rpx;
}
.selected-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #EEF4FD;
  color: var(--brand);
  border: 2rpx solid #BFDBFE;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 16rpx 8rpx 20rpx;
}
.tag-remove {
  font-size: 28rpx;
  color: #93C5FD;
  line-height: 1;
  padding: 0 2rpx;
}

/* ── 自定义输入行 ── */
.custom-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  background: #F9FAFB;
  border-radius: var(--r-md);
  padding: 10rpx 16rpx 10rpx 20rpx;
  border: 1rpx solid var(--border-light);
}
.custom-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  height: 48rpx;
  line-height: 48rpx;
}
.custom-add-btn {
  font-size: 24rpx;
  color: var(--brand);
  font-weight: 700;
  padding: 8rpx 24rpx;
  background: #EEF4FD;
  border-radius: var(--r-lg);
  white-space: nowrap;
}

.select-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 72rpx;
  margin-bottom: 20rpx;
  padding: 0 22rpx;
  border-radius: var(--r-md);
  border: 1rpx solid #D0D5DD;
  background: #FFFFFF;
  color: #667085;
  font-size: 26rpx;
  font-weight: 600;
}
.select-trigger.has-value {
  color: #1D4ED8;
  background: #F5F8FF;
  border-color: #B2CCFF;
}
.select-trigger-icon {
  flex-shrink: 0;
  color: #2563EB;
  font-size: 24rpx;
  font-weight: 800;
}

.selector-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(15, 23, 42, 0.36);
}
.selector-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 201;
  max-height: 78vh;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #FFFFFF;
  box-shadow: 0 -18rpx 44rpx rgba(15, 23, 42, 0.18);
}
.selector-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 20rpx;
}
.selector-title {
  display: block;
  color: #101828;
  font-size: 32rpx;
  font-weight: 800;
}
.selector-count {
  display: block;
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
  font-weight: 600;
}
.selector-close {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50%;
  color: #475467;
  background: #F2F4F7;
  font-size: 40rpx;
  font-weight: 500;
}
.selector-search {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 76rpx;
  padding: 0 22rpx;
  border-radius: var(--r-md);
  border: 1rpx solid #D0D5DD;
  background: #F9FAFB;
}
.selector-search-icon {
  color: #2563EB;
  font-size: 24rpx;
  font-weight: 800;
}
.selector-search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  color: #101828;
  font-size: 28rpx;
}
.selector-selected {
  margin-top: 18rpx;
  margin-bottom: 0;
}
.selector-options {
  height: 520rpx;
  max-height: 44vh;
  margin-top: 18rpx;
}
.selector-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 78rpx;
  padding: 0 18rpx;
  border-bottom: 1rpx solid #F2F4F7;
  color: #1F2937;
  font-size: 28rpx;
  font-weight: 600;
}
.selector-option-active {
  color: #1D4ED8;
  background: #F5F8FF;
}
.selector-check {
  color: #2563EB;
  font-size: 26rpx;
  font-weight: 900;
}
.selector-empty {
  padding: 56rpx 0 40rpx;
  color: #98A2B3;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
}
.selector-custom-add {
  margin-top: 18rpx;
  min-height: 72rpx;
  line-height: 72rpx;
  border-radius: var(--r-md);
  color: #1D4ED8;
  background: #EEF4FD;
  text-align: center;
  font-size: 27rpx;
  font-weight: 800;
}
.selector-actions {
  padding-top: 20rpx;
}
.selector-done {
  min-height: 82rpx;
  line-height: 82rpx;
  border-radius: var(--r-md);
  color: #FFFFFF;
  background: #2563EB;
  text-align: center;
  font-size: 29rpx;
  font-weight: 800;
}

/* ── 保存按钮 ── */
.save-btn { margin-top: 48rpx; }
.progress-missing { display: block; margin-top: 10rpx; color: #475467; font-size: 22rpx; }
.sponsor-row { display: flex; align-items: center; justify-content: space-between; gap: 24rpx; margin-top: 28rpx; padding: 22rpx; border-radius: 18rpx; background: #F5F8FF; }
.sponsor-title { display: block; color: #1D2939; font-size: 28rpx; font-weight: 700; }
.sponsor-note { display: block; margin-top: 5rpx; color: #667085; font-size: 22rpx; }
.location-inputs { display: flex; gap: 16rpx; margin-top: 20rpx; }
.location-inputs .custom-input { flex: 1; min-width: 0; }
.projects-textarea { width: 100%; min-height: 190rpx; box-sizing: border-box; color: #1D2939; font-size: 27rpx; line-height: 1.7; }
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* ── Profile edit hero readability override ──
   This package can miss global CSS variables, so keep this block self-contained. */
.hero-card {
  background:
    radial-gradient(circle at 88% 0%, rgba(37, 99, 235, 0.14) 0%, rgba(37, 99, 235, 0) 38%),
    linear-gradient(135deg, #f8fbff 0%, #edf4ff 48%, #ffffff 100%) !important;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  box-shadow: 0 14rpx 34rpx rgba(29, 78, 216, 0.12);
}

.hero-name {
  color: #101828 !important;
  font-weight: 800;
}

.hero-school {
  color: #475467 !important;
  font-weight: 650;
}

.progress-label {
  color: #1d2939 !important;
  font-weight: 800;
}

.progress-tip {
  color: #667085 !important;
  font-weight: 600;
}

.avatar {
  border-color: #ffffff;
  background: #edf2f7;
  box-shadow: 0 10rpx 24rpx rgba(16, 24, 40, 0.12);
}

.camera-badge {
  background: #172554;
  color: #ffffff;
  border-color: #ffffff;
}
