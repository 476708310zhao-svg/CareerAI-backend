<!-- pages/profile-edit/profile-edit.wxml -->
<view class="container">

  <!-- Hero: 头像 + 进度 合并为一个卡片 -->
  <view class="hero-card">
    <view class="hero-avatar-row" bindtap="changeAvatar">
      <view class="avatar-wrapper">
        <image class="avatar" src="{{avatarPreview || userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="camera-badge">📷</view>
      </view>
      <view class="hero-text">
        <text class="hero-name">{{userInfo.nickName || '点击设置昵称'}}</text>
        <text class="hero-school">{{userInfo.school || userInfo.major || '完善信息，提升匹配度'}}</text>
      </view>
    </view>
    <view class="progress-wrap">
      <text class="progress-label">资料完整度</text>
      <view class="profile-progress">
        <view class="profile-progress-fill" style="width: {{completeness}}%;"></view>
      </view>
      <text class="progress-tip">资料越完整，匹配的岗位和题目越精准</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section-title">
    <view class="section-accent"></view>
    <text>基本信息</text>
  </view>
  <view class="form-card">
    <view class="form-item">
      <view class="label-wrap">
        <text class="label-icon">👤</text>
        <text class="label">昵称</text>
      </view>
      <input class="input" type="nickname" value="{{userInfo.nickName}}" placeholder="点击可使用微信昵称" placeholder-style="color:#C4C9D4;" maxlength="20" data-field="nickName" bindinput="onInput" bindblur="onInput"/>
    </view>
    <view class="form-divider"></view>
    <view class="form-item">
      <view class="label-wrap">
        <text class="label-icon">🏫</text>
        <text class="label">学校</text>
      </view>
      <input class="input" value="{{userInfo.school}}" placeholder="请输入学校名称" placeholder-style="color:#C4C9D4;" maxlength="40" data-field="school" bindinput="onInput"/>
    </view>
    <view class="form-divider"></view>
    <view class="form-item">
      <view class="label-wrap">
        <text class="label-icon">📚</text>
        <text class="label">专业</text>
      </view>
      <input class="input" value="{{userInfo.major}}" placeholder="如：计算机科学 · 硕士" placeholder-style="color:#C4C9D4;" maxlength="40" data-field="major" bindinput="onInput"/>
    </view>
  </view>

  <!-- 求职状态 -->
  <view class="section-title">
    <view class="section-accent"></view>
    <text>学历与状态</text>
  </view>
  <view class="form-card pad">
    <text class="sub-label">最高学历</text>
    <view class="chip-row wrap">
      <block wx:for="{{degreeOptions}}" wx:key="value">
        <view
          class="chip {{userInfo.degree === item.value ? 'chip-active' : ''}}"
          bindtap="selectSingle"
          data-field="degree"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </block>
    </view>

    <text class="sub-label mt">当前状态</text>
    <view class="chip-row wrap">
      <block wx:for="{{statusOptions}}" wx:key="value">
        <view
          class="chip {{userInfo.status === item.value ? 'chip-active' : ''}}"
          bindtap="selectSingle"
          data-field="status"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </block>
    </view>

    <text class="sub-label mt">预计毕业年份</text>
    <view class="chip-row wrap">
      <block wx:for="{{gradYearOptions}}" wx:key="*this">
        <view
          class="chip {{userInfo.gradYear === item ? 'chip-active' : ''}}"
          bindtap="selectSingle"
          data-field="gradYear"
          data-value="{{item}}"
        >{{item}}</view>
      </block>
    </view>
  </view>

  <!-- 目标地区 -->
  <view class="section-title">
    <view class="section-accent"></view>
    <text>目标地区</text>
    <text class="section-note">可多选</text>
  </view>
  <view class="form-card pad">
    <view class="selected-tags" wx:if="{{userInfo.targetLocation.length > 0}}">
      <view class="selected-tag" wx:for="{{userInfo.targetLocation}}" wx:key="*this">
        <text>{{item}}</text>
        <text class="tag-remove" catchtap="removeMultiValue" data-field="targetLocation" data-value="{{item}}">×</text>
      </view>
    </view>

    <view class="select-trigger {{userInfo.targetLocation.length > 0 ? 'has-value' : ''}}" bindtap="openMultiSelector" data-field="targetLocation">
      <text>{{userInfo.targetLocation.length > 0 ? '继续搜索添加地区' : '搜索并选择目标地区'}}</text>
      <text class="select-trigger-icon">⌕</text>
    </view>

    <text class="sub-label mt">常见地区</text>
    <view class="chip-row wrap">
      <block wx:for="{{locationOptions}}" wx:key="label">
        <view
          class="chip {{item.selected ? 'chip-active' : ''}}"
          bindtap="toggleLocation"
          data-value="{{item.label}}"
        >{{item.label}}</view>
      </block>
    </view>
  </view>

  <!-- 目标行业 -->
  <view class="section-title">
    <view class="section-accent"></view>
    <text>目标行业</text>
    <text class="section-note">可多选</text>
  </view>
  <view class="form-card pad">
    <view class="selected-tags" wx:if="{{userInfo.targetIndustries.length > 0}}">
      <view class="selected-tag" wx:for="{{userInfo.targetIndustries}}" wx:key="*this">
        <text>{{item}}</text>
        <text class="tag-remove" catchtap="removeMultiValue" data-field="targetIndustries" data-value="{{item}}">×</text>
      </view>
    </view>

    <view class="select-trigger {{userInfo.targetIndustries.length > 0 ? 'has-value' : ''}}" bindtap="openMultiSelector" data-field="targetIndustries">
      <text>{{userInfo.targetIndustries.length > 0 ? '继续搜索添加行业' : '搜索并选择目标行业'}}</text>
      <text class="select-trigger-icon">⌕</text>
    </view>

    <text class="sub-label mt">常见行业</text>
    <view class="chip-row wrap">
      <block wx:for="{{industryOptions}}" wx:key="label">
        <view
          class="chip {{item.selected ? 'chip-active' : ''}}"
          bindtap="toggleIndustry"
          data-value="{{item.label}}"
        >{{item.label}}</view>
      </block>
    </view>
  </view>

  <!-- 求职类型 -->
  <view class="section-title">
    <view class="section-accent"></view>
    <text>求职类型</text>
    <text class="section-note">可多选</text>
  </view>
  <view class="form-card pad">
    <view class="chip-row wrap">
      <block wx:for="{{jobTypeOptions}}" wx:key="value">
        <view
          class="chip {{item.selected ? 'chip-active' : ''}}"
          bindtap="toggleJobType"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </block>
    </view>

    <text class="sub-label mt">工作授权</text>
    <view class="chip-row wrap">
      <block wx:for="{{workAuthOptions}}" wx:key="value">
        <view
          class="chip {{userInfo.workAuthorization === item.value ? 'chip-active' : ''}}"
          bindtap="selectSingle"
          data-field="workAuthorization"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </block>
    </view>

    <view class="custom-input-row">
      <input
        class="custom-input"
        value="{{userInfo.expectedSalaryRange}}"
        placeholder="期望薪资，如：30k-50k"
        placeholder-style="color:#C4C9D4;"
        data-field="expectedSalaryRange"
        bindinput="onInput"
        maxlength="30"
      />
    </view>
  </view>

  <!-- 目标岗位 -->
  <view class="section-title">
    <view class="section-accent"></view>
    <text>目标岗位</text>
    <text class="section-note">最多5个</text>
  </view>
  <view class="form-card pad">
    <!-- 已选岗位 -->
    <view class="selected-tags" wx:if="{{userInfo.targetRoles.length > 0}}">
      <view class="selected-tag" wx:for="{{userInfo.targetRoles}}" wx:key="*this">
        <text>{{item}}</text>
        <text class="tag-remove" catchtap="removeRole" data-value="{{item}}">×</text>
      </view>
    </view>

    <view class="select-trigger {{userInfo.targetRoles.length > 0 ? 'has-value' : ''}}" bindtap="openMultiSelector" data-field="targetRoles">
      <text>{{userInfo.targetRoles.length > 0 ? '搜索并继续添加岗位' : '搜索标准岗位，未命中可补充'}}</text>
      <text class="select-trigger-icon">⌕</text>
    </view>

    <text class="sub-label mt">常见岗位</text>
    <view class="chip-row wrap">
      <block wx:for="{{roleOptions}}" wx:key="label">
        <view
          class="chip {{item.selected ? 'chip-active' : ''}}"
          bindtap="toggleRole"
          data-value="{{item.label}}"
        >{{item.label}}</view>
      </block>
    </view>
  </view>

  <!-- 技能标签 -->
  <view class="section-title">
    <view class="section-accent"></view>
    <text>技能标签</text>
    <text class="section-note">最多20个</text>
  </view>
  <view class="form-card pad">
    <!-- 已选技能 -->
    <view class="selected-tags" wx:if="{{userInfo.skills.length > 0}}">
      <view class="selected-tag" wx:for="{{userInfo.skills}}" wx:key="*this">
        <text>{{item}}</text>
        <text class="tag-remove" catchtap="removeSkill" data-value="{{item}}">×</text>
      </view>
    </view>

    <view class="select-trigger {{userInfo.skills.length > 0 ? 'has-value' : ''}}" bindtap="openMultiSelector" data-field="skills">
      <text>{{userInfo.skills.length > 0 ? '搜索并继续添加技能' : '搜索标准技能，未命中可补充'}}</text>
      <text class="select-trigger-icon">⌕</text>
    </view>

    <text class="sub-label mt">常用技能</text>
    <view class="chip-row wrap">
      <block wx:for="{{skillOptions}}" wx:key="label">
        <view
          class="chip {{item.selected ? 'chip-active' : ''}}"
          bindtap="toggleSkill"
          data-value="{{item.label}}"
        >{{item.label}}</view>
      </block>
    </view>
  </view>

  <!-- 保存按钮 -->
  <c-button class="save-btn" bindtap="handleSave">保存并应用匹配</c-button>

  <view wx:if="{{selector.visible}}" class="selector-mask" catchtap="closeSelector"></view>
  <view wx:if="{{selector.visible}}" class="selector-sheet">
    <view class="selector-header">
      <view>
        <text class="selector-title">{{selector.title}}</text>
        <text class="selector-count">已选 {{selector.selected.length}} / {{selector.max}}</text>
      </view>
      <view class="selector-close" catchtap="closeSelector">×</view>
    </view>

    <view class="selector-search">
      <text class="selector-search-icon">⌕</text>
      <input
        class="selector-search-input"
        value="{{selector.query}}"
        placeholder="{{selector.placeholder}}"
        placeholder-style="color:#98A2B3;"
        bindinput="onSelectorSearch"
        focus="{{selector.visible}}"
      />
    </view>

    <view class="selected-tags selector-selected" wx:if="{{selector.selected.length > 0}}">
      <view class="selected-tag" wx:for="{{selector.selected}}" wx:key="*this">
        <text>{{item}}</text>
        <text class="tag-remove" catchtap="removeSelectorValue" data-value="{{item}}">×</text>
      </view>
    </view>

    <scroll-view class="selector-options" scroll-y>
      <block wx:if="{{selector.filteredOptions.length > 0}}">
        <view
          class="selector-option {{item.selected ? 'selector-option-active' : ''}}"
          wx:for="{{selector.filteredOptions}}"
          wx:key="value"
          bindtap="toggleSelectorOption"
          data-value="{{item.value}}"
        >
          <text>{{item.label}}</text>
          <text class="selector-check" wx:if="{{item.selected}}">✓</text>
        </view>
      </block>
      <view wx:else class="selector-empty">没有匹配的标准选项</view>
    </scroll-view>

    <view
      wx:if="{{selector.allowCustom && selector.query}}"
      class="selector-custom-add"
      bindtap="addSelectorCustom"
    >添加“{{selector.query}}”</view>

    <view class="selector-actions">
      <view class="selector-done" bindtap="closeSelector">完成</view>
    </view>
  </view>

</view>
