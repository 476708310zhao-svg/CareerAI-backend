/* pages/company-detail/company-detail.wxss */
page { background: var(--bg-raised); }

/* 公司头部 */
.company-header {
  background: var(--bg-panel);
  padding: 40rpx 30rpx;
  display: flex;
  align-items: flex-start;
}

.company-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--r-lg);
  border: 1rpx solid #f0f0f0;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: var(--bg-panel);
}

.header-info { flex: 1; }

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.company-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.rating-badge {
  background: #ff9500;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.company-meta {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
  display: block;
}

.tag-row { display: flex; flex-wrap: wrap; gap: 12rpx; }

/* 公司简介卡片 */
.section-card {
  margin: 24rpx 30rpx;
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  border-left: 8rpx solid var(--brand);
  padding-left: 16rpx;
}

.desc-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 20rpx;
  display: block;
}

.info-row {
  display: flex;
  justify-content: space-between;
  background: #F9FAFB;
  border-radius: var(--r-sm);
  padding: 20rpx;
}

.info-item { text-align: center; }
.info-label { font-size: 22rpx; color: var(--text-muted); display: block; margin-bottom: 6rpx; }
.info-value { font-size: 26rpx; color: var(--text-body); font-weight: bold; display: block; }

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: var(--bg-panel);
  margin: 0 30rpx;
  border-radius: var(--r-lg) 20rpx 0 0;
  padding: 0 10rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--brand);
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--brand);
  border-radius: 4rpx;
}

/* Tab 内容 */
.tab-content {
  margin: 0 30rpx;
  background: var(--bg-panel);
  border-radius: 0 0 20rpx 20rpx;
  padding: 20rpx;
}

/* 职位卡片 */
.job-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.job-title { font-size: 28rpx; font-weight: bold; color: var(--text-body); }
.job-salary { font-size: 28rpx; font-weight: bold; color: #059669; }

.job-bottom { display: flex; flex-wrap: wrap; gap: 12rpx; }

/* 面经卡片 */
.exp-title { font-size: 28rpx; font-weight: bold; color: var(--text-body); display: block; margin-bottom: 12rpx; }
.exp-meta { display: flex; gap: 20rpx; font-size: 22rpx; color: var(--text-muted); }
.exp-type { background: #fff7e6; color: #fa8c16; padding: 2rpx 10rpx; border-radius: 6rpx; }

/* 薪资卡片 */
.salary-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.salary-position { font-size: 28rpx; font-weight: bold; color: var(--text-body); }
.salary-avg { font-size: 30rpx; font-weight: bold; color: var(--brand); }

.salary-bar-track {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  margin-bottom: 12rpx;
}

.salary-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #69c0ff, var(--brand));
  border-radius: 6rpx;
}

.salary-bottom {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--text-muted);
}

/* AI面经生成按钮 */
.ai-exp-bar {
  padding: 16rpx 24rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.ai-exp-btn {
  background: linear-gradient(135deg, var(--brand), #6c5ce7);
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  padding: 16rpx 0;
  border-radius: 30rpx;
  text-align: center;
}
.ai-exp-btn.disabled { opacity: 0.6; }

/* AI标记 */
.exp-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.exp-title-row .exp-title { flex: 1; margin-bottom: 0; }
.ai-tag {
  font-size: 20rpx;
  color: #6c5ce7;
  background: #f0e6ff;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: bold;
  border: 1rpx solid #d3adf7;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 加载提示 */
.loading-hint {
  text-align: center;
  color: var(--text-muted);
  font-size: 24rpx;
  padding: 30rpx 0;
}

.empty {
  text-align: center;
  color: #D1D5DB;
  padding: 60rpx 0;
  font-size: 28rpx;
}

.intro-loading {
  padding: 16rpx 0;
}
.intro-loading-text {
  font-size: 26rpx;
  color: #6366f1;
}

/* ══ AI 洞察 ══ */
.insight-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 20rpx;
}
.insight-spin {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.insight-loading-txt { font-size: 26rpx; color: var(--brand); }

.insight-card-header {
  display: flex; align-items: center; gap: 10rpx;
  margin-bottom: 14rpx;
}
.insight-icon { font-size: 28rpx; }
.insight-card-title { font-size: 28rpx; font-weight: bold; color: var(--text-primary); }
.insight-card-body {
  font-size: 26rpx; color: var(--text-secondary);
  line-height: 1.7; display: block;
}
.insight-qlist { display: flex; flex-direction: column; gap: 12rpx; }
.insight-q-item {
  display: flex; align-items: flex-start; gap: 12rpx;
  background: #F9FAFB; border-radius: 12rpx;
  padding: 14rpx 16rpx;
}
.insight-q-num {
  font-size: 20rpx; color: var(--brand); font-weight: bold;
  background: #EEF2FF; padding: 2rpx 10rpx; border-radius: 8rpx;
  flex-shrink: 0; margin-top: 2rpx;
}
.insight-q-txt { font-size: 26rpx; color: var(--text-body); line-height: 1.6; flex: 1; }
.insight-tips { display: flex; flex-direction: column; gap: 12rpx; }
.insight-tip-item { display: flex; align-items: flex-start; gap: 12rpx; }
.insight-tip-check { font-size: 22rpx; color: #059669; font-weight: bold; flex-shrink: 0; margin-top: 4rpx; }
.insight-tip-txt { font-size: 26rpx; color: var(--text-body); line-height: 1.6; flex: 1; }
.insight-refresh-row { text-align: center; padding: 16rpx 0; }
.insight-refresh-txt { font-size: 24rpx; color: var(--text-muted); }

.insight-empty {
  display: flex; flex-direction: column;
  align-items: center; padding: 50rpx 20rpx; gap: 18rpx;
}
.insight-gen-btn {
  background: linear-gradient(135deg, var(--brand), #6c5ce7);
  color: #fff; font-size: 28rpx; font-weight: bold;
  padding: 20rpx 52rpx; border-radius: 40rpx; text-align: center;
}
.insight-empty-sub { font-size: 24rpx; color: var(--text-muted); }

/* Company detail product polish */
page {
  background:
    radial-gradient(circle at 10% 0%, rgba(43, 92, 230, 0.08), transparent 30%),
    linear-gradient(180deg, #f8fbff 0%, #f6f8fc 50%, #ffffff 100%);
}

.container {
  min-height: 100vh;
  overflow-x: hidden;
}

.company-header {
  margin: 18rpx 24rpx 22rpx;
  padding: 34rpx 30rpx;
  border-radius: 34rpx;
  border: 1rpx solid rgba(31, 45, 74, 0.06);
  background:
    radial-gradient(circle at 100% 0%, rgba(43, 92, 230, 0.09), transparent 35%),
    #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(31, 45, 74, 0.08);
}

.company-logo-wrap {
  width: 124rpx;
  height: 124rpx;
  margin-right: 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(31, 45, 74, 0.08);
  background: linear-gradient(145deg, #ffffff, #f2f6ff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 12rpx 26rpx rgba(31, 45, 74, 0.08);
}

.company-logo {
  width: 98rpx;
  height: 98rpx;
  margin: 0;
  border: none;
  border-radius: 0;
  background: transparent;
}

.company-logo-initial {
  color: #2b5ce6;
  font-size: 42rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.company-name {
  color: #172033;
  font-size: 38rpx;
  line-height: 1.25;
  letter-spacing: -0.6rpx;
}

.company-meta {
  color: #667085;
  line-height: 1.55;
}

.section-card,
.tab-bar,
.tab-content {
  margin-left: 24rpx;
  margin-right: 24rpx;
  border: 1rpx solid rgba(31, 45, 74, 0.06);
  background: #ffffff;
  box-shadow: 0 16rpx 38rpx rgba(31, 45, 74, 0.07);
}

.section-card {
  margin-top: 0;
  margin-bottom: 22rpx;
  padding: 32rpx 30rpx;
  border-radius: 32rpx;
}

.section-title {
  font-size: 31rpx;
  border-left-width: 7rpx;
}

.desc-text {
  color: #596579;
  line-height: 1.85;
}

.info-row {
  gap: 10rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #f5f8fd;
}

.info-item {
  flex: 1;
  min-width: 0;
}

.info-value {
  color: #263247;
  font-size: 25rpx;
  line-height: 1.35;
}

.tab-bar {
  border-radius: 28rpx 28rpx 0 0;
  padding: 4rpx 10rpx 0;
  box-shadow: none;
}

.tab-item {
  padding: 24rpx 0 22rpx;
  font-size: 27rpx;
}

.tab-content {
  padding: 18rpx;
  border-top: none;
  border-radius: 0 0 28rpx 28rpx;
  box-shadow: 0 16rpx 38rpx rgba(31, 45, 74, 0.07);
}

.job-top,
.salary-top {
  align-items: flex-start;
  gap: 18rpx;
}

.job-title,
.salary-position {
  flex: 1;
  min-width: 0;
  color: #263247;
  line-height: 1.45;
}

.job-salary,
.salary-avg {
  color: #059669;
  flex-shrink: 0;
}

.ai-exp-btn,
.insight-gen-btn {
  background: linear-gradient(135deg, #2b5ce6 0%, #465ff2 100%);
}

/* Company intelligence conversion */
.company-intel {
  margin: 0 24rpx 22rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  border: 1rpx solid rgba(31,45,74,0.06);
  background:
    radial-gradient(circle at 100% 0%, rgba(43,92,230,0.10), transparent 34%),
    #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(31,45,74,0.075);
}

.intel-head {
  margin-bottom: 22rpx;
}

.intel-kicker {
  display: block;
  margin-bottom: 8rpx;
  color: #2b5ce6;
  font-size: 21rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
}

.intel-title {
  display: block;
  color: #172033;
  font-size: 34rpx;
  font-weight: 950;
  letter-spacing: -0.6rpx;
}

.intel-sub {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}

.intel-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.intel-card {
  min-width: 0;
  padding: 18rpx 10rpx;
  border-radius: 22rpx;
  background: #f7f9fd;
  border: 1rpx solid rgba(226,232,240,0.9);
  text-align: center;
  transition: transform var(--trans-fast), opacity var(--trans-fast);
}

.intel-card:active {
  transform: scale(0.97);
  opacity: 0.82;
}

.intel-card.accent {
  background: linear-gradient(135deg, #eef5ff 0%, #f7f3ff 100%);
  border-color: rgba(43,92,230,0.16);
}

.intel-num {
  display: block;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.1;
}

.intel-label {
  display: block;
  margin-top: 8rpx;
  color: #758195;
  font-size: 20rpx;
  font-weight: 750;
}

.tab-section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 6rpx 6rpx 22rpx;
}

.tab-section-kicker {
  display: block;
  margin-bottom: 6rpx;
  color: #2b5ce6;
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 0.8rpx;
}

.tab-section-title {
  display: block;
  color: #172033;
  font-size: 30rpx;
  font-weight: 900;
  letter-spacing: -0.4rpx;
}

.tab-section-count {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #2b5ce6;
  background: rgba(43,92,230,0.08);
  font-size: 22rpx;
  font-weight: 850;
}

.job-card {
  position: relative;
  overflow: hidden;
}

.job-card::after {
  content: '';
  position: absolute;
  right: -48rpx;
  top: -56rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(43,92,230,0.08), rgba(43,92,230,0));
}

.job-title,
.job-salary,
.job-bottom {
  position: relative;
  z-index: 1;
}

.insight-card {
  background:
    radial-gradient(circle at 100% 0%, rgba(43,92,230,0.06), transparent 30%),
    #fbfdff;
}

.insight-card-header {
  padding-bottom: 4rpx;
}

.insight-q-item,
.insight-tip-item {
  border: 1rpx solid rgba(226,232,240,0.85);
}

.insight-gen-btn {
  box-shadow: 0 14rpx 30rpx rgba(43,92,230,0.24);
}

/* ── Glassdoor ─────────────────────────────────────────────────────────────── */

.gd-header-badge {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-top: 14rpx;
}
.gd-hb-icon {
  width: 34rpx; height: 34rpx;
  background: #0CAA41; color: #fff;
  font-size: 18rpx; font-weight: 900;
  border-radius: 8rpx; text-align: center; line-height: 34rpx;
  flex-shrink: 0;
}
.gd-hb-score {
  font-size: 25rpx; font-weight: bold; color: #0CAA41;
}
.gd-hb-sep, .gd-hb-count {
  font-size: 22rpx; color: var(--text-muted);
}
.gd-hb-arrow {
  font-size: 22rpx; color: var(--brand);
}

.gd-overview-card {
  background: #f7fff9;
  border: 1rpx solid rgba(12,170,65,0.18);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.gd-score-row {
  display: flex; align-items: flex-start; gap: 22rpx;
  padding-bottom: 20rpx; margin-bottom: 18rpx;
  border-bottom: 1rpx solid #eef6ef;
}
.gd-score-main {
  display: flex; align-items: baseline; gap: 6rpx; flex-shrink: 0;
}
.gd-big-score {
  font-size: 72rpx; font-weight: 900; color: #0CAA41; line-height: 1;
}
.gd-score-label {
  font-size: 26rpx; font-weight: bold; color: var(--text-muted);
}
.gd-score-right { flex: 1; min-width: 0; }
.gd-review-count {
  display: block; font-size: 23rpx; color: var(--text-muted); margin-bottom: 14rpx;
}
.gd-pills-row { display: flex; gap: 10rpx; flex-wrap: wrap; }
.gd-pill {
  padding: 6rpx 14rpx; border-radius: 12rpx; text-align: center;
}
.gd-pill-green {
  background: rgba(12,170,65,0.1); border: 1rpx solid rgba(12,170,65,0.25);
}
.gd-pill-blue {
  background: rgba(43,92,230,0.08); border: 1rpx solid rgba(43,92,230,0.2);
}
.gd-pill-val {
  display: block; font-size: 26rpx; font-weight: 900; color: #172033; line-height: 1.2;
}
.gd-pill-label {
  display: block; font-size: 20rpx; color: var(--text-muted); margin-top: 2rpx;
}

.gd-subs { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 16rpx; }
.gd-sub-item { display: flex; align-items: center; gap: 12rpx; }
.gd-sub-lbl {
  font-size: 22rpx; color: var(--text-muted); width: 136rpx; flex-shrink: 0;
}
.gd-sub-track {
  flex: 1; height: 10rpx; background: #eef6ef; border-radius: 5rpx; overflow: hidden;
}
.gd-sub-fill {
  height: 100%;
  background: linear-gradient(90deg, #0CAA41, #52c41a);
  border-radius: 5rpx;
}
.gd-sub-val {
  font-size: 22rpx; font-weight: bold; color: #0CAA41; width: 44rpx; text-align: right; flex-shrink: 0;
}
.gd-source-note {
  display: block; font-size: 20rpx; color: #b8c4bf; text-align: right; margin-top: 6rpx;
}

.gd-reviews-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 6rpx 4rpx 14rpx;
}
.gd-reviews-title { font-size: 28rpx; font-weight: bold; color: var(--text-primary); }
.gd-reviews-total { font-size: 22rpx; color: var(--text-muted); }

.gd-review-card { margin-bottom: 16rpx; }
.gd-rv-header { display: flex; align-items: flex-start; gap: 14rpx; margin-bottom: 14rpx; }
.gd-rv-rating {
  display: flex; align-items: center; gap: 4rpx;
  background: #fff8ee; border: 1rpx solid #ffe7b0;
  border-radius: 10rpx; padding: 6rpx 12rpx; flex-shrink: 0;
}
.gd-rv-star { font-size: 22rpx; color: #fa8c16; }
.gd-rv-score { font-size: 24rpx; font-weight: bold; color: #fa8c16; }
.gd-rv-meta { flex: 1; min-width: 0; }
.gd-rv-title {
  display: block; font-size: 27rpx; font-weight: bold;
  color: var(--text-body); line-height: 1.4; margin-bottom: 6rpx;
}
.gd-rv-sub { font-size: 21rpx; color: var(--text-muted); }
.gd-rv-body { display: flex; flex-direction: column; gap: 10rpx; }
.gd-rv-row { display: flex; align-items: flex-start; gap: 12rpx; }
.gd-rv-badge {
  font-size: 20rpx; font-weight: bold;
  padding: 2rpx 10rpx; border-radius: 8rpx; flex-shrink: 0; margin-top: 3rpx;
}
.gd-rv-pro {
  background: rgba(12,170,65,0.1); color: #0CAA41; border: 1rpx solid rgba(12,170,65,0.25);
}
.gd-rv-con {
  background: rgba(239,68,68,0.08); color: #ef4444; border: 1rpx solid rgba(239,68,68,0.2);
}
.gd-rv-text {
  font-size: 25rpx; color: var(--text-secondary); line-height: 1.65; flex: 1;
}

.gd-load-more {
  text-align: center; padding: 22rpx 0;
  font-size: 26rpx; color: var(--brand);
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* 2026 company detail rebuild: keep this section last to override legacy blocks. */
page {
  background:
    radial-gradient(circle at 12% 0%, rgba(37, 99, 235, 0.10), transparent 32%),
    linear-gradient(180deg, #f7faff 0%, #f5f7fb 48%, #ffffff 100%);
}

.container {
  min-height: 100vh;
  padding: 20rpx 24rpx 0;
  box-sizing: border-box;
  background: transparent;
}

.company-header,
.company-intel,
.section-card,
.tab-bar,
.tab-content {
  margin-left: 0;
  margin-right: 0;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.07);
}

.company-header {
  margin-top: 0;
  margin-bottom: 18rpx;
  padding: 32rpx;
  border-radius: 34rpx;
  align-items: center;
  background:
    radial-gradient(circle at 100% 0%, rgba(37, 99, 235, 0.12), transparent 38%),
    #ffffff;
}

.header-info {
  min-width: 0;
}

.name-row {
  margin-bottom: 10rpx;
}

.company-name {
  color: #101828;
  font-size: 42rpx;
  font-weight: 950;
