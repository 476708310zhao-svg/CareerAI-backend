<!-- pages/about/about.wxml -->
<view class="about-page">

  <view class="brand-hero">
    <view class="hero-top">
      <view class="brand-logo">
        <image class="brand-logo-img" src="/images/home-active.png" mode="aspectFit"></image>
      </view>
      <view class="version-chip">v{{version}}</view>
    </view>
    <text class="hero-kicker">CAREER AI WORKSPACE</text>
    <text class="hero-title">职引</text>
    <text class="hero-desc">面向留学生的 AI 求职工作台，把岗位筛选、简历优化、面试准备和网申跟进整理成清晰的下一步。</text>
    <view class="hero-tags">
      <view class="hero-tag">岗位推荐</view>
      <view class="hero-tag">AI 面试</view>
      <view class="hero-tag">求职规划</view>
    </view>
  </view>

  <c-ai-disclosure text="本小程序涉及 AI 问答、简历优化、模拟面试等功能，相关内容由人工智能生成，仅供参考，请核验后使用。" />

  <view class="stats-row">
    <block wx:for="{{stats}}" wx:key="label">
      <view class="stat-item">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </block>
  </view>

  <view class="mission-section">
    <text class="section-kicker">OUR MISSION</text>
    <text class="mission-title">让求职从信息收集，变成可执行的行动系统。</text>
    <text class="mission-text">我们希望帮助海外留学生更高效地理解岗位、准备面试、跟进网申，并把每一次准备沉淀成可复用的求职资产。</text>
  </view>

  <view class="section-head">
    <text class="section-title">核心功能</text>
    <text class="section-sub">围绕投递、准备、复盘三个阶段设计</text>
  </view>
  <view class="feature-grid">
    <block wx:for="{{features}}" wx:key="title">
      <view class="feature-card">
        <view class="feature-icon-wrap">
          <image class="feature-icon" src="{{item.icon}}" mode="aspectFit" lazy-load></image>
        </view>
        <text class="feature-title">{{item.title}}</text>
        <text class="feature-desc">{{item.desc}}</text>
      </view>
    </block>
  </view>

  <view class="section-head">
    <text class="section-title">使用流程</text>
    <text class="section-sub">把模糊的求职目标拆成连续动作</text>
  </view>
  <view class="process-list">
    <block wx:for="{{processSteps}}" wx:key="title">
      <view class="process-item">
        <view class="process-index">{{index + 1}}</view>
        <view class="process-body">
          <text class="process-title">{{item.title}}</text>
          <text class="process-desc">{{item.desc}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="section-head">
    <text class="section-title">我们在意</text>
    <text class="section-sub">产品会继续围绕这些方向打磨</text>
  </view>
  <view class="value-list">
    <block wx:for="{{values}}" wx:key="title">
      <view class="value-item">
        <view class="value-dot"></view>
        <view class="value-copy">
          <text class="value-title">{{item.title}}</text>
          <text class="value-desc">{{item.desc}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="contact-section">
    <view class="contact-main">
      <text class="contact-label">联系我们</text>
      <text class="contact-title">在线客服与邮箱反馈</text>
      <text class="contact-desc">产品建议、合作沟通或问题反馈都可以通过微信客服或邮箱联系。</text>
    </view>
    <view class="contact-actions">
      <button
        class="customer-button"
        open-type="contact"
        session-from="about"
        show-message-card="true"
        send-message-title="职引客服"
        send-message-path="/pages/index/index"
      >在线客服</button>
      <view class="copy-button" bindtap="copyEmail" hover-class="tap-soft">复制邮箱</view>
    </view>
  </view>

  <view class="copyright">
    <text>Copyright 2026 职引</text>
    <text>All Rights Reserved</text>
  </view>
</view>
