/* pages/about/about.wxss — Premium Redesign */
page {
  background: #F2F4F8;
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container { padding: 0 24rpx 40rpx; }

/* Logo section */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72rpx 0 48rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #0D1B3E, var(--brand));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(43,92,230,0.35);
}

.app-logo {
  width: 96rpx;
  height: 96rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #0F172A;
  margin-bottom: 8rpx;
}

.app-version {
  font-size: 24rpx;
  color: var(--text-muted);
  background: #F3F4F6;
  padding: 5rpx 18rpx;
  border-radius: var(--r-lg);
}

/* Cards */
.intro-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1.5rpx solid #F1F3F7;
}

.intro-text {
  font-size: 27rpx;
  color: var(--text-secondary);
  line-height: 1.75;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
  padding: 0 0 16rpx;
  padding-left: 18rpx;
  border-left: 6rpx solid var(--brand);
  margin-bottom: 16rpx;
}

.feature-list {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 8rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1.5rpx solid #F1F3F7;
  overflow: hidden;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--bg-raised);
}

.feature-item:last-child { border-bottom: none; }

.feature-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  border-radius: var(--r-md);
}

.feature-info { flex: 1; }

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
  display: block;
  margin-bottom: 5rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
}

.contact-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1.5rpx solid #F1F3F7;
}

.contact-label {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.contact-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.contact-value {
  font-size: 28rpx;
  color: var(--brand);
  font-weight: 600;
}

.copy-hint {
  font-size: 22rpx;
  color: #C4C9D4;
}

.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  font-size: 22rpx;
  color: #C4C9D4;
  line-height: 1.9;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Profile entry page polish */
.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.logo-section {
  margin-bottom: 22rpx;
  padding: 46rpx 28rpx 40rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(20,184,166,0.10), transparent 34%),
    linear-gradient(135deg, rgba(255,255,255,0.98), rgba(241,248,255,0.98));
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 16rpx 42rpx rgba(32,48,70,0.07);
}

.app-logo {
  width: 116rpx;
  height: 116rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  box-shadow: 0 16rpx 34rpx rgba(37,99,235,0.18);
  box-sizing: border-box;
}

.app-name {
  margin-top: 20rpx;
  color: #111827;
  font-size: 38rpx;
}

.app-version {
  color: #1d4ed8;
  background: #eef4ff;
}

.intro-card,
.feature-list,
.contact-card {
  border-radius: 24rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.section-title {
  border-left: 0;
  padding-left: 0;
  color: #111827;
  font-size: 30rpx;
  font-weight: 950;
}

.feature-icon {
  border-radius: 18rpx;
  background: #eef4ff;
}

.feature-title {
  color: #111827;
}

.feature-desc,
.intro-text,
.contact-label,
.copyright {
  color: #667085;
}

.copy-hint {
  color: #2563eb;
}

/* About page rebuild */
.about-hero {
  position: relative;
  padding: 34rpx 30rpx 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 58%, #ecfffb 100%);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.08);
  overflow: hidden;
}

.logo-mark {
  width: 112rpx;
  height: 112rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  box-shadow: 0 16rpx 34rpx rgba(37,99,235,0.18);
}

.logo-mark .app-logo {
  width: 70rpx;
  height: 70rpx;
  padding: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.hero-copy {
  margin-top: 24rpx;
}

.hero-kicker,
.app-name,
.hero-sub,
.version-pill,
.stat-value,
.stat-label,
.section-kicker,
.mission-title,
.mission-text,
.section-title,
.section-sub,
.feature-title,
.feature-desc,
.value-title,
.value-desc,
.contact-label,
.contact-title,
.contact-desc {
  display: block;
}

.hero-kicker,
.section-kicker {
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.about-hero .app-name {
  margin-top: 8rpx;
  color: #101828;
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 950;
}

.hero-sub {
  width: 560rpx;
  max-width: 100%;
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.58;
}

.version-pill {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #2563eb;
  background: rgba(238,244,255,0.92);
  font-size: 21rpx;
  font-weight: 900;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin: 18rpx 0;
}

.stat-card {
  min-height: 110rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.055);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-value {
  color: #111827;
  font-size: 32rpx;
  font-weight: 950;
}

.stat-label {
  margin-top: 8rpx;
  color: #718096;
  font-size: 22rpx;
  font-weight: 800;
}

.mission-card {
  padding: 30rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.mission-title {
  margin-top: 10rpx;
  color: #111827;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 950;
}

.mission-text {
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.7;
}

.section-head {
  margin: 30rpx 4rpx 16rpx;
}

.section-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 950;
}

.section-sub {
  margin-top: 8rpx;
  color: #718096;
  font-size: 23rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.feature-grid .feature-item {
  display: block;
  padding: 24rpx;
  min-height: 210rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.055);
}

.feature-grid .feature-icon {
  width: 66rpx;
  height: 66rpx;
  margin: 0 0 18rpx;
  padding: 14rpx;
  box-sizing: border-box;
}

.feature-grid .feature-title {
  font-size: 27rpx;
  font-weight: 950;
}

.feature-grid .feature-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.45;
}

.value-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.value-card {
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 10rpx 26rpx rgba(32,48,70,0.045);
}

.value-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 950;
}

.value-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.58;
}

.contact-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 26rpx;
  padding: 28rpx;
}

.contact-title {
  margin-top: 8rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 950;
}

.contact-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.5;
}

.contact-row {
  flex-shrink: 0;
}

.copy-hint {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 12rpx 26rpx rgba(37,99,235,0.22);
  font-size: 23rpx;
  font-weight: 900;
}
