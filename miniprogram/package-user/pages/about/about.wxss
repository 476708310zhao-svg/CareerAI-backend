/* pages/about/about.wxss */
page {
  --about-bg: #f6f8fc;
  --about-card: #ffffff;
  --about-text: #101828;
  --about-sub: #475467;
  --about-muted: #667085;
  --about-line: rgba(16, 24, 40, 0.08);
  --about-brand: #2563eb;
  --about-teal: #14b8a6;
  overflow-x: hidden;
  background: linear-gradient(180deg, #f8fbff 0%, #f6f8fc 48%, #ffffff 100%);
  color: var(--about-text);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.about-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.tap-soft {
  opacity: 0.78;
  transform: scale(0.99);
}

.brand-hero {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at 100% 0, rgba(20, 184, 166, 0.16), transparent 34%),
    linear-gradient(135deg, #ffffff 0%, #f1f6ff 62%, #effdfa 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  box-shadow: 0 16rpx 36rpx rgba(16, 24, 40, 0.07);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.brand-logo {
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
  background: #111827;
  box-shadow: 0 16rpx 30rpx rgba(17, 24, 39, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.brand-logo-img {
  width: 62rpx;
  height: 62rpx;
}

.version-chip {
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  color: var(--about-brand);
  font-size: 21rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-kicker,
.section-kicker {
  display: block;
  margin-top: 24rpx;
  color: var(--about-brand);
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  color: var(--about-text);
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 950;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  max-width: 610rpx;
  color: var(--about-sub);
  font-size: 26rpx;
  line-height: 1.62;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 24rpx;
}

.hero-tag {
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #175cd3;
  background: #eff6ff;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  font-size: 23rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.stat-item {
  min-height: 104rpx;
  padding: 14rpx 8rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: var(--about-card);
  border: 1rpx solid var(--about-line);
  box-shadow: 0 10rpx 24rpx rgba(16, 24, 40, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.stat-value {
  display: block;
  color: var(--about-text);
  font-size: 32rpx;
  line-height: 1.05;
  font-weight: 950;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: var(--about-muted);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 750;
}

.mission-section,
.contact-section {
  margin-top: 18rpx;
  padding: 26rpx;
  border-radius: 16rpx;
  background: var(--about-card);
  border: 1rpx solid var(--about-line);
  box-shadow: 0 10rpx 24rpx rgba(16, 24, 40, 0.05);
}

.mission-section .section-kicker {
  margin-top: 0;
}

.mission-title {
  display: block;
  margin-top: 10rpx;
  color: var(--about-text);
  font-size: 32rpx;
  line-height: 1.36;
  font-weight: 950;
}

.mission-text {
  display: block;
  margin-top: 14rpx;
  color: var(--about-sub);
  font-size: 25rpx;
  line-height: 1.72;
}

.section-head {
  margin: 30rpx 4rpx 16rpx;
}

.section-title {
  display: block;
  color: var(--about-text);
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 950;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  color: var(--about-muted);
  font-size: 23rpx;
  line-height: 1.45;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.feature-card {
  min-height: 222rpx;
  padding: 22rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: var(--about-card);
  border: 1rpx solid var(--about-line);
  box-shadow: 0 10rpx 24rpx rgba(16, 24, 40, 0.05);
}

.feature-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: #eff6ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-icon {
  width: 38rpx;
  height: 38rpx;
}

.feature-title {
  display: block;
  margin-top: 18rpx;
  color: var(--about-text);
  font-size: 27rpx;
  line-height: 1.28;
  font-weight: 900;
}

.feature-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--about-muted);
  font-size: 22rpx;
  line-height: 1.5;
}

.process-list,
.value-list {
  border-radius: 16rpx;
  background: var(--about-card);
  border: 1rpx solid var(--about-line);
  box-shadow: 0 10rpx 24rpx rgba(16, 24, 40, 0.05);
  overflow: hidden;
}

.process-item,
.value-item {
  display: flex;
  gap: 18rpx;
  padding: 24rpx;
  border-top: 1rpx solid rgba(16, 24, 40, 0.06);
  box-sizing: border-box;
}

.process-item:first-child,
.value-item:first-child {
  border-top: none;
}

.process-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: #111827;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 950;
  flex-shrink: 0;
}

.process-body,
.value-copy {
  flex: 1;
  min-width: 0;
}

.process-title,
.value-title {
  display: block;
  color: var(--about-text);
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 900;
}

.process-desc,
.value-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--about-muted);
  font-size: 24rpx;
  line-height: 1.58;
}

.value-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--about-brand), var(--about-teal));
  flex-shrink: 0;
}

.contact-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin-top: 28rpx;
}

.contact-main {
  flex: 1;
  min-width: 0;
}

.contact-label,
.contact-title,
.contact-desc {
  display: block;
}

.contact-label {
  color: var(--about-brand);
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 900;
}

.contact-title {
  margin-top: 8rpx;
  color: var(--about-text);
  font-size: 29rpx;
  line-height: 1.25;
  font-weight: 950;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-desc {
  margin-top: 10rpx;
  color: var(--about-muted);
  font-size: 23rpx;
  line-height: 1.5;
}

.copy-button {
  height: 58rpx;
  min-width: 94rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: var(--about-brand);
  box-shadow: 0 10rpx 22rpx rgba(37, 99, 235, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 900;
  flex-shrink: 0;
  box-sizing: border-box;
}

.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 34rpx 0 10rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.9;
}
