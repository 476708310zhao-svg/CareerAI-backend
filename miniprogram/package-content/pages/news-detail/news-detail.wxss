/* pages/news-detail/news-detail.wxss */
page {
  --article-ink: #111827;
  --article-body: #374151;
  --article-muted: #8a94a6;
  --article-line: rgba(17, 24, 39, 0.08);
  background: #f5f7fb;
  color: var(--article-ink);
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background:
    radial-gradient(circle at 10% 0%, rgba(37,99,235,0.10), transparent 34%),
    linear-gradient(180deg, #f7fbff 0%, #f5f7fb 44%, #ffffff 100%);
}

.article-hero {
  margin: 24rpx;
  padding: 34rpx 30rpx;
  border-radius: 30rpx;
  color: #fff;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.14);
}

.cat-news { background: linear-gradient(135deg, #f97316, #fb923c); }
.cat-tip { background: linear-gradient(135deg, #2563eb, #4f46e5); }
.cat-data { background: linear-gradient(135deg, #059669, #10b981); }
.cat-policy { background: linear-gradient(135deg, #7c3aed, #a855f7); }

.hero-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 22rpx;
}

.type-badge,
.personal-badge {
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.20);
  color: #fff;
  font-size: 21rpx;
  font-weight: 900;
}

.personal-badge {
  background: rgba(255,255,255,0.92);
  color: #111827;
}

.hero-time {
  margin-left: auto;
  color: rgba(255,255,255,0.78);
  font-size: 22rpx;
}

.article-title {
  display: block;
  color: #fff;
  font-size: 40rpx;
  line-height: 1.32;
  font-weight: 950;
}

.article-desc {
  display: block;
  margin-top: 16rpx;
  color: rgba(255,255,255,0.82);
  font-size: 25rpx;
  line-height: 1.55;
}

.article-card {
  margin: 0 24rpx;
  padding: 34rpx 30rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 1rpx solid var(--article-line);
  box-shadow: 0 16rpx 42rpx rgba(15,23,42,0.07);
}

.article-text {
  display: block;
  white-space: pre-wrap;
  word-break: break-word;
  color: var(--article-body);
  font-size: 29rpx;
  line-height: 1.82;
}

.bottom-space {
  height: calc(130rpx + env(safe-area-inset-bottom));
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.92);
  border-top: 1rpx solid var(--article-line);
  box-shadow: 0 -16rpx 42rpx rgba(15,23,42,0.08);
  backdrop-filter: blur(20rpx);
}

.back-btn,
.copy-btn,
.share-btn,
.empty-btn {
  height: 68rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.back-btn {
  width: 120rpx;
  color: var(--article-body);
  background: #f3f4f6;
}

.copy-btn {
  flex: 1;
  color: #2563eb;
  background: #eef4ff;
}

.share-btn {
  width: 128rpx;
  margin: 0;
  padding: 0;
  color: #fff;
  background: #111827;
  line-height: 68rpx;
}

.share-btn::after {
  border: 0;
}

.empty-page {
  min-height: 100vh;
  padding: 160rpx 44rpx 0;
  text-align: center;
  background: #f5f7fb;
}

.empty-title {
  display: block;
  color: var(--article-ink);
  font-size: 34rpx;
  font-weight: 950;
}

.empty-desc {
  display: block;
  margin-top: 16rpx;
  color: var(--article-body);
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-btn {
  width: 190rpx;
  margin: 32rpx auto 0;
  color: #fff;
  background: #111827;
}
