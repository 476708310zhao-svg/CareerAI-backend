<!-- pages/news-detail/news-detail.wxml -->
<view class="page" wx:if="{{news}}">
  <view class="article-hero cat-{{news.type}}">
    <view class="hero-top">
      <text class="type-badge">{{typeLabel[news.type]}}</text>
      <text class="personal-badge" wx:if="{{news.isPersonal}}">为你推荐</text>
      <text class="hero-time">{{news.time}}</text>
    </view>
    <text class="article-title">{{news.title}}</text>
    <text class="article-desc" wx:if="{{news.desc}}">{{news.desc}}</text>
  </view>

  <view class="article-card">
    <text class="article-text" space="nbsp">{{news.content}}</text>
  </view>

  <view class="bottom-space"></view>

  <view class="bottom-bar">
    <view class="back-btn" bindtap="onBack">返回</view>
    <view class="copy-btn" wx:if="{{news.url}}" bindtap="onCopyLink">复制原文链接</view>
    <button class="share-btn" open-type="share">分享</button>
  </view>
</view>

<view class="empty-page" wx:else>
  <text class="empty-title">内容加载失败</text>
  <text class="empty-desc">请返回快讯列表后重新打开。</text>
  <view class="empty-btn" bindtap="onBack">返回列表</view>
</view>
