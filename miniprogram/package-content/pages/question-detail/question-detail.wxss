/* pages/question-detail/question-detail.wxss */
page {
  background: var(--bg-raised);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
  color: var(--text-primary);
}

.page {
  display: flex;
  flex-direction: column;
  padding: 20rpx 24rpx 0;
}

/* ── 标题卡片 ──────────────────────────────────────────────────── */
.title-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.meta-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.diff-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 18rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.diff-badge.easy  { background: #ECFDF5; color: #059669; }
.diff-badge.mid   { background: #FFF8E6; color: #D97706; }
.diff-badge.hard  { background: #FEF2F2; color: #DC2626; }

.cat-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  background: #EEF2FF;
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 600;
}

.lc-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  background: #FFF7ED;
  color: #EA580C;
  font-size: 22rpx;
  font-weight: 700;
}

.ai-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  background: #F5F3FF;
  color: #7C3AED;
  font-size: 22rpx;
  font-weight: 600;
}

.q-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.5;
}

.q-title-en {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
  line-height: 1.5;
}

/* ── LeetCode 统计 ─────────────────────────────────────────────── */
.lc-stats-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.lc-stat-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.lc-stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.lc-stat-val {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.lc-stat-divider {
  width: 1.5rpx;
  background: #F1F5F9;
  align-self: stretch;
}

.lc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.lc-tag {
  display: inline-block;
  font-size: 20rpx;
  color: var(--text-secondary);
  background: var(--bg-raised);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.lc-tag-empty {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* ── 参考答案 ──────────────────────────────────────────────────── */
.answer-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.answer-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.answer-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #FFFBEB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.answer-icon {
  font-size: 28rpx;
  line-height: 1;
}

.answer-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.answer-text {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.8;
  display: block;
}

/* ── LeetCode 提示 ─────────────────────────────────────────────── */
.lc-hint-card {
  background: #FFF7ED;
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  border: 1.5rpx solid #FED7AA;
}

.lc-hint-icon {
  font-size: 36rpx;
  line-height: 1;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.lc-hint-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.lc-hint-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #C2410C;
}

.lc-hint-desc {
  font-size: 24rpx;
  color: #92400E;
  line-height: 1.6;
}

/* ── 面试要点 ──────────────────────────────────────────────────── */
.tips-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tips-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #EEF2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tips-icon {
  font-size: 28rpx;
  line-height: 1;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.tip-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--brand);
  flex-shrink: 0;
  margin-top: 12rpx;
}

.tip-text {
  font-size: 26rpx;
  color: var(--text-body);
  line-height: 1.6;
  flex: 1;
}

/* ── 底部操作栏 ─────────────────────────────────────────────────── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--bg-panel);
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bottom-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 48rpx;
  padding: 22rpx 0;
}

.bottom-btn.secondary {
  flex: 0 0 160rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-light);
}

.bottom-btn.primary {
  flex: 1;
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
  box-shadow: 0 6rpx 20rpx rgba(43, 92, 230, 0.3);
}

.bottom-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 30rpx;
  line-height: 1;
}

.btn-txt {
  font-size: 28rpx;
  font-weight: 700;
}

.bottom-btn.secondary .btn-txt { color: var(--text-body); }
.bottom-btn.primary   .btn-txt { color: var(--bg-panel); }
.bottom-btn.secondary .btn-icon { font-size: 32rpx; }

/* ── 已做标记按钮 ────────────────────────────────────────────── */
.bottom-btn.secondary {
  flex: 0 0 130rpx;
}

.bottom-btn.done-btn {
  flex: 0 0 170rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-light);
}

.bottom-btn.done-btn.done-on {
  background: #ECFDF5;
  border-color: #059669;
}

.bottom-btn.done-btn .btn-txt { color: var(--text-body); }
.bottom-btn.done-btn.done-on .btn-txt { color: #059669; font-weight: 700; }
.bottom-btn.done-btn.done-on .btn-icon { color: #059669; }

/* ── 已完成角标 ──────────────────────────────────────────────── */
.done-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 6rpx 18rpx;
  background: #ECFDF5;
  color: #059669;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 10rpx;
  border: 1.5rpx solid #A7F3D0;
}
/* Polished question detail experience */
page,
.page,
.container {
  background:
    linear-gradient(180deg, #edf4ff 0%, rgba(237, 244, 255, 0) 420rpx),
    #f6f8fc;
  background-color: #f6f8fc;
  color: #111827;
}

.page {
  min-height: 100vh;
  padding: 20rpx 24rpx 0;
  box-sizing: border-box;
}

.title-card,
.lc-stats-card,
.answer-card,
.tips-card {
  background: #ffffff;
  border-radius: 26rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.06);
}

.title-card {
  position: relative;
  padding: 32rpx 28rpx 34rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(241,247,255,0.94));
  overflow: hidden;
}

.title-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 32rpx;
  bottom: 32rpx;
  width: 6rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: linear-gradient(180deg, #2563eb, #14b8a6);
}

.meta-row {
  gap: 10rpx;
  margin-bottom: 22rpx;
}

.diff-badge,
.cat-badge,
.lc-badge,
.ai-badge {
  border-radius: 999rpx;
  padding: 7rpx 18rpx;
  font-size: 22rpx;
  font-weight: 800;
  border: 1rpx solid transparent;
}

.diff-badge.easy {
  background: #ecfdf5;
  color: #059669;
  border-color: #a7f3d0;
}

.diff-badge.mid {
  background: #fff7ed;
  color: #c2410c;
  border-color: #fed7aa;
}

.diff-badge.hard {
  background: #fef2f2;
  color: #dc2626;
  border-color: #fecaca;
}

.cat-badge {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}

.lc-badge {
  background: #f8fafc;
  color: #475569;
  border-color: #e2e8f0;
}

.ai-badge {
  background: #f0fdfa;
  color: #0f766e;
  border-color: #99f6e4;
}

.q-title {
  position: relative;
  z-index: 1;
  font-size: 38rpx;
  line-height: 1.45;
  font-weight: 800;
  color: #0f172a;
}

.q-title-en {
  color: #64748b;
  font-size: 26rpx;
}

.done-badge {
  border-radius: 999rpx;
  background: #ecfdf5;
  border: 1rpx solid #a7f3d0;
  color: #059669;
}

.lc-stats-card {
  padding: 26rpx;
  margin-bottom: 20rpx;
}

.lc-stat-label,
.lc-tag-empty {
  color: #64748b;
}

.lc-stat-val {
  color: #111827;
}

.lc-stat-divider {
  background: #e2e8f0;
}

.lc-tag {
  background: #f1f5f9;
  color: #334155;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.answer-card,
.tips-card {
  padding: 30rpx 28rpx;
  margin-bottom: 20rpx;
}

.answer-header,
.tips-header {
  margin-bottom: 22rpx;
}

.answer-icon-box,
.tips-icon-box {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
}

.answer-icon-box {
  background: #fffbeb;
  border: 1rpx solid #fde68a;
}

.tips-icon-box {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
}

.answer-title,
.tips-title {
  font-size: 31rpx;
  font-weight: 800;
  color: #111827;
}

.answer-text {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  color: #334155;
  font-size: 29rpx;
  line-height: 1.8;
}

.lc-hint-card {
  border-radius: 24rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.04);
}

.tips-list {
  gap: 14rpx;
}

.tip-item {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e5edf8;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 14rpx;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
}

.tip-text {
  color: #334155;
  font-size: 28rpx;
  line-height: 1.68;
}

.bottom-bar {
  gap: 14rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -12rpx 34rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.bottom-btn {
  height: 88rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.bottom-btn.secondary,
.bottom-btn.done-btn {
  flex: 0 0 148rpx;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
}

.bottom-btn.done-btn {
  flex-basis: 190rpx;
}

.bottom-btn.done-btn.done-on {
  background: #ecfdf5;
  border-color: #a7f3d0;
}

.bottom-btn.primary {
  flex: 1;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.22);
}

.btn-icon {
  font-size: 30rpx;
}

.btn-txt {
  font-size: 28rpx;
  font-weight: 800;
  white-space: nowrap;
}

.bottom-btn.secondary .btn-txt,
.bottom-btn.done-btn .btn-txt {
  color: #334155;
}

.bottom-btn.primary .btn-txt {
  color: #ffffff;
}

.bottom-btn.primary .btn-icon {
  color: #ffffff;
}

.bottom-btn.done-btn.done-on .btn-txt,
.bottom-btn.done-btn.done-on .btn-icon {
  color: #059669;
}

.bottom-spacer {
  height: calc(156rpx + env(safe-area-inset-bottom));
}
