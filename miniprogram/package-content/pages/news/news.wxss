/* pages/news/news.wxss */
page {
  --news-bg: #f5f7fb;
  --news-card: #ffffff;
  --news-ink: #111827;
  --news-body: #4b5563;
  --news-muted: #8a94a6;
  --news-line: rgba(17, 24, 39, 0.08);
  --news-blue: #2563eb;
  --news-orange: #f97316;
  --news-green: #059669;
  --news-purple: #7c3aed;
  background: var(--news-bg);
  color: var(--news-ink);
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background:
    radial-gradient(circle at 8% 0%, rgba(37,99,235,0.10), transparent 34%),
    linear-gradient(180deg, #f7fbff 0%, #f5f7fb 42%, #ffffff 100%);
}

.top-panel {
  padding: 24rpx 28rpx 20rpx;
  background: rgba(255,255,255,0.92);
  border-bottom: 1rpx solid var(--news-line);
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.06);
}

.headline-row,
.meta-row,
.lead-top,
.card-top,
.lead-action,
.news-card,
.loading-strip {
  display: flex;
  align-items: center;
}

.headline-row {
  justify-content: space-between;
  gap: 20rpx;
}

.kicker {
  display: block;
  color: var(--news-blue);
  font-size: 19rpx;
  font-weight: 900;
  letter-spacing: 1.4rpx;
}

.title {
  display: block;
  margin-top: 8rpx;
  color: var(--news-ink);
  font-size: 40rpx;
  line-height: 1.12;
  font-weight: 950;
}

.refresh-pill {
  flex-shrink: 0;
  min-width: 92rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--news-blue);
  background: #eef4ff;
  font-size: 22rpx;
  font-weight: 850;
}

.refresh-pill.spinning {
  color: var(--news-green);
  background: #ecfdf5;
}

.subtitle {
  display: block;
  margin-top: 14rpx;
  color: var(--news-body);
  font-size: 24rpx;
  line-height: 1.52;
}

.search-card {
  height: 76rpx;
  margin-top: 22rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f3f6fb;
  border: 1rpx solid rgba(37,99,235,0.08);
  box-sizing: border-box;
}

.search-icon {
  color: var(--news-blue);
  font-size: 32rpx;
  font-weight: 900;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  color: var(--news-ink);
  font-size: 26rpx;
}

.search-placeholder {
  color: #9ca3af;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  background: #e5e7eb;
  font-size: 30rpx;
  line-height: 1;
}

.meta-row {
  justify-content: space-between;
  margin-top: 14rpx;
  color: var(--news-muted);
  font-size: 21rpx;
}

.filter-panel {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 18rpx 24rpx 14rpx;
  background: rgba(245,247,251,0.96);
  backdrop-filter: blur(20rpx);
}

.segmented {
  height: 68rpx;
  padding: 6rpx;
  border-radius: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 6rpx;
  background: #e9eef7;
  box-sizing: border-box;
}

.seg-item {
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 800;
}

.seg-item.active {
  color: var(--news-ink);
  background: #fff;
  box-shadow: 0 8rpx 18rpx rgba(15,23,42,0.08);
}

.tab-scroll {
  white-space: nowrap;
  margin-top: 16rpx;
}

.tab-row {
  display: inline-flex;
  gap: 12rpx;
}

.tab {
  min-width: 92rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  background: #fff;
  border: 1rpx solid var(--news-line);
  font-size: 24rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.tab.active {
  color: #fff;
  background: var(--news-ink);
  border-color: var(--news-ink);
}

.search-hint {
  margin: 0 24rpx 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  color: var(--news-blue);
  background: #eef4ff;
  font-size: 23rpx;
}

.loading-strip {
  gap: 12rpx;
  margin: 0 24rpx 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  color: var(--news-green);
  background: #ecfdf5;
  font-size: 23rpx;
}

.loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--news-green);
  box-shadow: 0 0 0 8rpx rgba(5,150,105,0.12);
}

.list-wrap {
  padding: 0 24rpx;
  box-sizing: border-box;
}

.lead-card,
.news-card,
.empty-wrap {
  background: var(--news-card);
  border: 1rpx solid var(--news-line);
  box-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.07);
}

.lead-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 18rpx;
  padding: 28rpx;
  border-radius: 28rpx;
}

.lead-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.cat-news::before { background: var(--news-orange); }
.cat-tip::before { background: var(--news-blue); }
.cat-data::before { background: var(--news-green); }
.cat-policy::before { background: var(--news-purple); }

.lead-top {
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.type-badge,
.personal-badge {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.badge-news { color: var(--news-orange); background: #fff7ed; }
.badge-tip { color: var(--news-blue); background: #eef4ff; }
.badge-data { color: var(--news-green); background: #ecfdf5; }
.badge-policy { color: var(--news-purple); background: #f3e8ff; }

.personal-badge {
  color: #fff;
  background: linear-gradient(135deg, #2563eb, #7c3aed);
}

.personal-badge.small {
  padding: 5rpx 12rpx;
  font-size: 19rpx;
}

.lead-time,
.card-time {
  margin-left: auto;
  color: var(--news-muted);
  font-size: 21rpx;
}

.lead-title {
  display: block;
  color: var(--news-ink);
  font-size: 34rpx;
  line-height: 1.34;
  font-weight: 950;
}

.lead-desc {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-top: 14rpx;
  color: var(--news-body);
  font-size: 25rpx;
  line-height: 1.55;
}

.lead-action {
  justify-content: flex-end;
  gap: 8rpx;
  margin-top: 22rpx;
  color: var(--news-blue);
  font-size: 25rpx;
  font-weight: 900;
}

.arrow {
  font-size: 28rpx;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.news-card {
  gap: 18rpx;
  min-height: 168rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.news-card:active,
.lead-card:active {
  transform: scale(0.988);
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-top {
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.card-title {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  color: var(--news-ink);
  font-size: 29rpx;
  line-height: 1.38;
  font-weight: 900;
}

.card-desc {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-top: 8rpx;
  color: var(--news-body);
  font-size: 23rpx;
  line-height: 1.5;
}

.card-action {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--news-blue);
  background: #eef4ff;
  font-size: 28rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.empty-wrap {
  margin-top: 60rpx;
  padding: 56rpx 36rpx;
  border-radius: 28rpx;
  text-align: center;
}

.empty-title {
  display: block;
  color: var(--news-ink);
  font-size: 30rpx;
  font-weight: 950;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  color: var(--news-body);
  font-size: 24rpx;
  line-height: 1.52;
}

.empty-btn {
  width: 190rpx;
  height: 64rpx;
  margin: 26rpx auto 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: var(--news-ink);
  font-size: 24rpx;
  font-weight: 900;
}

.list-end {
  padding: 28rpx 0 42rpx;
  color: var(--news-muted);
  text-align: center;
  font-size: 22rpx;
}
