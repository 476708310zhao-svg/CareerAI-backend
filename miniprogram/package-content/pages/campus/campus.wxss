  color: #ffffff;
  background: linear-gradient(135deg, #10b981, #2f66f4);
  box-shadow: 0 10rpx 22rpx rgba(16, 185, 129, 0.18);
}

.filter-panel {
  margin-top: 16rpx;
  border-radius: 26rpx;
  background: #f8fffc;
  border: 1rpx solid rgba(16, 185, 129, 0.12);
}

.stat-row {
  margin-top: 14rpx;
  padding: 12rpx 4rpx 0;
}

.list {
  padding: 22rpx 24rpx calc(42rpx + env(safe-area-inset-bottom));
}

.card {
  border: 1rpx solid rgba(28, 83, 108, 0.08);
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfffd 100%);
  box-shadow: 0 16rpx 36rpx rgba(21, 49, 74, 0.08);
}

.logo-wrap {
  border-radius: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(16, 185, 129, 0.12);
}

.badge,
.region-chip,
.apply-btn,
.info-item {
  border-radius: 999rpx;
}

.info-grid {
  border-radius: 24rpx;
  background: #f7fbff;
}

.apply-btn {
  background: linear-gradient(135deg, #10b981, #2f66f4);
  box-shadow: 0 10rpx 22rpx rgba(16, 185, 129, 0.2);
}

.tab-pill:active,
.fp:active,
.grad-year-btn:active,
.filter-tag:active,
.card:active,
.apply-btn:active,
.clear-btn:active,
.filter-toggle-btn:active {
  transform: scale(0.965);
  opacity: 0.86;
}

.no-more {
  padding: 20rpx 0 10rpx;
}

