}

.tab-scroll {
  margin-top: 14rpx;
}

.tab-inner {
  gap: 12rpx;
}

.tab-pill,
.fp,
.grad-year-btn,
.filter-tag,
.card,
.apply-btn,
.clear-btn,
.filter-toggle-btn {
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.tab-pill,
.fp {
  border-radius: 999rpx;
  background: #f4f8fb;
  border: 1rpx solid rgba(38, 80, 119, 0.06);
}

.active-recruit,
.active-region,
