/* pages/campus-detail/campus-detail.wxss */
page {
  background: #f6f8fc;
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
  color: #111827;
}

.page {
  min-height: 100vh;
  padding-bottom: 1rpx;
  background:
    linear-gradient(180deg, #edf4ff 0%, rgba(237, 244, 255, 0) 360rpx),
    #f6f8fc;
}

/* 加载 */
.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh; gap: 24rpx;
  background: #f6f8fc;
}
.loading-txt { font-size: 26rpx; color: #6b7280; }
.spinner {
  width: 56rpx; height: 56rpx;
  border: 5rpx solid rgba(37, 99, 235, 0.12);
  border-top-color: #2563eb;
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ════ 头部横幅 ════ */
.hero {
  margin: 20rpx 24rpx 0;
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(241,247,255,0.94));
  border: 1rpx solid rgba(59, 130, 246, 0.12);
  box-shadow: 0 20rpx 54rpx rgba(31, 41, 55, 0.08);
}
.hero-inner { display: flex; align-items: flex-start; gap: 22rpx; }
.logo-wrap { flex-shrink: 0; }
.logo-img {
  width: 112rpx; height: 112rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.24);
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
}
.logo-placeholder {
  width: 112rpx; height: 112rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #e0e7ff, #dbeafe);
  border: 1rpx solid rgba(59, 130, 246, 0.18);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 10rpx 26rpx rgba(37, 99, 235, 0.12);
}
.logo-char { font-size: 36rpx; font-weight: 800; color: #3b5bdb; }
.hero-info { flex: 1; min-width: 0; }
.hero-name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 10rpx; }
.hero-company {
  font-size: 38rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.22;
  flex: 1;
}
.hot-dot {
  font-size: 18rpx; font-weight: 800; color: #fff;
  background: #ef4444;
  padding: 4rpx 10rpx; border-radius: 999rpx; flex-shrink: 0;
}
.hero-position {
  display: block;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.45;
  margin-bottom: 18rpx;
}
.hero-badges { display: flex; flex-wrap: wrap; gap: 10rpx; }
.badge {
  font-size: 22rpx; font-weight: 700;
  padding: 7rpx 16rpx; border-radius: 999rpx;
  border: 1rpx solid transparent;
}
.grad-badge {
  background: #f1f5f9;
  color: #334155;
  border-color: rgba(148, 163, 184, 0.2);
}

/* ════ 关键信息卡 ════ */
.info-card {
  background: #ffffff;
  margin: 20rpx 24rpx 0;
  border-radius: 24rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.05);
}
.kv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
.kv-item {
  display: flex;
  flex-direction: column;
  min-height: 118rpx;
  padding: 22rpx 20rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
}
.kv-item:nth-child(2n + 1) { background: #fbfdff; }
.kv-key { font-size: 22rpx; color: #94a3b8; margin-bottom: 9rpx; }
.kv-val {
  font-size: 29rpx;
  color: #111827;
  font-weight: 700;
  line-height: 1.42;
  word-break: break-word;
}
.kv-val.urgent { color: #dc2626; }

/* ════ 通用卡片 ════ */
.section-card {
  background: #ffffff;
  margin: 20rpx 24rpx 0;
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.05);
}
.section-title {
  display: flex; align-items: center; gap: 10rpx;
  font-size: 31rpx; font-weight: 800; color: #111827;
  margin-bottom: 20rpx;
}
.section-icon { font-size: 31rpx; }
.notes-txt {
  font-size: 29rpx;
  color: #334155;
  line-height: 1.72;
  display: block;
}

/* 投递链接 */
.link-row {
  margin-bottom: 14rpx;
  padding: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #e5edf8;
  border-radius: 18rpx;
}
.link-label {
  display: block;
  font-size: 23rpx;
  color: #64748b;
  margin-bottom: 8rpx;
  font-weight: 700;
}
.link-url {
  display: block; font-size: 24rpx; color: #2563eb;
  word-break: break-all; line-height: 1.5;
}
.copy-btn {
  display: block; text-align: center; margin-top: 18rpx;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  color: #ffffff;
  font-size: 28rpx; font-weight: 600;
  padding: 20rpx; border-radius: 18rpx;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.18);
}
.copy-btn:active { transform: scale(0.99); opacity: 0.92; }

/* 数据来源 */
.source-bar {
  margin: 18rpx 24rpx 0;
  padding: 0 4rpx;
}
.source-txt { font-size: 23rpx; color: #94a3b8; }

/* ════ 截止提醒卡 ════ */
.remind-card {
  display: flex; align-items: center; justify-content: space-between;
  margin: 20rpx 24rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 26rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.05);
  gap: 16rpx;
}
.remind-card:active { opacity: 0.75; }
.remind-left { display: flex; align-items: center; gap: 16rpx; flex: 1; min-width: 0; }
.remind-icon {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #fff7ed;
}
.remind-info { flex: 1; min-width: 0; }
.remind-title { display: block; font-size: 29rpx; font-weight: 800; color: #111827; margin-bottom: 6rpx; }
.remind-sub   { display: block; font-size: 23rpx; color: #64748b; line-height: 1.35; }
.remind-action {
  flex-shrink: 0;
  font-size: 25rpx; font-weight: 800;
  color: #2563eb;
  background: #eff6ff;
  padding: 12rpx 26rpx;
  border-radius: 9999rpx;
  border: 1rpx solid #bfdbfe;
}
.remind-action.subscribed {
  color: #059669;
  background: #ECFDF5;
  border-color: #A7F3D0;
}

/* ════ 底部投递按钮 ════ */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; width: 100%;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  box-sizing: border-box;
  box-shadow: 0 -12rpx 34rpx rgba(15, 23, 42, 0.06);
}
.bottom-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.collect-btn {
  width: 198rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #f1f5f9;
  color: #334155;
  font-size: 29rpx;
  font-weight: 800;
  border-radius: 9999rpx;
  border: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}
.collect-btn.collected {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}
.apply-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  display: block;
  text-align: center;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  border-radius: 9999rpx;
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.22);
}
.collect-btn:active,
.apply-btn:active {
  transform: scale(0.99);
  opacity: 0.9;
}
.bottom-spacer {
  height: calc(156rpx + env(safe-area-inset-bottom));
}
