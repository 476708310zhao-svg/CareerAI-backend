.interview-list {
  padding: 20rpx;
  color: #111827;
}

.similar-tip {
  margin-bottom: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  background: #fff7ed;
  color: #9a3412;
  font-size: 23rpx;
}

.summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 700;
}

.summary-count {
  font-size: 24rpx;
  color: #64748b;
}

.empty,
.interview-card {
  border: 1rpx solid var(--card-border, rgba(190,208,232,0.62));
  border-radius: var(--card-radius, 26rpx);
  background: var(--card-bg, linear-gradient(145deg, #ffffff, #f8fbff));
  box-shadow: var(--card-shadow, 0 14rpx 34rpx rgba(36,58,92,0.07));
}

.empty {
  padding: 28rpx;
}

.empty-title,
.empty-desc {
  display: block;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.interview-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.interview-card-hover {
  background: #f8fafc;
}

.card-head {
  display: flex;
  align-items: center;
  min-width: 0;
}

.company-mark {
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #eef2ff;
  color: #2b5ce6;
  font-size: 22rpx;
  font-weight: 800;
  overflow: hidden;
}

.title-wrap {
  min-width: 0;
  margin-left: 18rpx;
}

.title,
.company {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.title {
  font-size: 29rpx;
  font-weight: 800;
  color: #111827;
}

.company {
  margin-top: 4rpx;
  color: #64748b;
  font-size: 24rpx;
}

.meta-row,
.foot-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.meta-row {
  margin-top: 18rpx;
}

.meta-pill {
  padding: 6rpx 10rpx;
  border-radius: 6rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 23rpx;
}

.similar {
  background: #fff7ed;
  color: #9a3412;
}

.summary-text {
  display: block;
  margin-top: 16rpx;
  color: #334155;
  font-size: 24rpx;
  line-height: 1.55;
}

.foot-row {
  margin-top: 18rpx;
  color: #64748b;
  font-size: 23rpx;
}

.detail-link {
  margin-left: auto;
  color: #2b5ce6;
  font-weight: 700;
}

@media (prefers-color-scheme: dark) {
  .interview-list {
    color: #f8fafc;
  }

  .empty,
  .interview-card {
    background: #111827;
    border-color: #334155;
  }

  .interview-card-hover {
    background: #1f2937;
  }

  .title,
  .empty-title {
    color: #f8fafc;
  }

  .summary-count,
  .company,
  .empty-desc,
  .summary-text,
  .foot-row {
    color: #cbd5e1;
  }

  .company-mark,
  .meta-pill {
    background: #1e293b;
  }

  .meta-pill {
    color: #cbd5e1;
  }

  .similar-tip,
  .similar {
    background: #431407;
    color: #fed7aa;
  }
}
