.detail-card {
  margin: 20rpx;
  padding: 28rpx;
  border: 1rpx solid var(--card-border, rgba(190,208,232,0.62));
  border-radius: var(--card-radius, 26rpx);
  background: var(--card-bg, linear-gradient(145deg, #ffffff, #f8fbff));
  box-shadow: var(--card-shadow, 0 14rpx 34rpx rgba(36,58,92,0.07));
  color: #111827;
}

.head {
  display: flex;
  align-items: center;
  min-width: 0;
}

.company-mark {
  width: 80rpx;
  height: 80rpx;
  flex: 0 0 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #eef2ff;
  color: #2b5ce6;
  font-size: 22rpx;
  font-weight: 800;
  overflow: hidden;
}

.title-wrap {
  min-width: 0;
  margin-left: 20rpx;
}

.title,
.company {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.title {
  font-size: 31rpx;
  font-weight: 800;
  color: #111827;
}

.company {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

.meta-row,
.tag-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.meta-row {
  margin-top: 22rpx;
}

.meta-pill {
  padding: 7rpx 12rpx;
  border-radius: 6rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 23rpx;
}

.tag-row {
  margin-top: 16rpx;
}

.tag {
  padding: 5rpx 10rpx;
  border-radius: 6rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 22rpx;
  font-weight: 700;
}

.summary-text {
  display: block;
  margin-top: 22rpx;
  color: #334155;
  font-size: 26rpx;
  line-height: 1.6;
}

.primary-btn {
  margin-top: 26rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 8rpx;
  background: #2b5ce6;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
}

@media (prefers-color-scheme: dark) {
  .detail-card {
    background: #111827;
    border-color: #334155;
    color: #f8fafc;
  }

  .title,
  .empty-title {
    color: #f8fafc;
  }

  .company,
  .summary-text {
    color: #cbd5e1;
  }

  .company-mark,
  .meta-pill {
    background: #1e293b;
  }

  .meta-pill {
    color: #cbd5e1;
  }

  .tag {
    background: #064e3b;
    color: #bbf7d0;
  }
}
