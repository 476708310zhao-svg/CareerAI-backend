.skill-job-list {
  padding: 20rpx;
  color: #111827;
}

.skill-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 700;
}

.summary-count {
  font-size: 24rpx;
  color: #64748b;
}

.empty {
  padding: 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #ffffff;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #64748b;
}

.job-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border: 1rpx solid var(--card-border, rgba(190,208,232,0.62));
  border-radius: var(--card-radius, 26rpx);
  background: var(--card-bg, linear-gradient(145deg, #ffffff, #f8fbff));
  box-shadow: var(--card-shadow, 0 14rpx 34rpx rgba(36,58,92,0.07));
}

.job-card-hover {
  background: #f8fafc;
}

.card-head {
  display: flex;
  align-items: center;
  min-width: 0;
}

.company-logo,
.company-fallback {
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
  border-radius: 8rpx;
  background: #eef2ff;
  overflow: hidden;
}

.company-logo-img {
  width: 72rpx;
  height: 72rpx;
}

.company-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #2b5ce6;
}

.card-title-wrap {
  min-width: 0;
  margin-left: 18rpx;
}

.job-title,
.company-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #111827;
}

.company-name {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #64748b;
}

.meta-row,
.foot-row,
.tag-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.meta-row {
  margin-top: 18rpx;
  color: #475569;
  font-size: 24rpx;
}

.meta-item {
  max-width: 560rpx;
}

.meta-dot {
  margin: 0 8rpx;
  color: #94a3b8;
}

.tag-row {
  gap: 8rpx;
  margin-top: 14rpx;
}

.visa-tag {
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 22rpx;
  font-weight: 600;
}

.foot-row {
  gap: 12rpx;
  margin-top: 18rpx;
  font-size: 23rpx;
  color: #64748b;
}

.salary {
  color: #0f766e;
}

.detail-link {
  margin-left: auto;
  color: #2b5ce6;
  font-weight: 700;
}

@media (prefers-color-scheme: dark) {
  .skill-job-list {
    color: #f8fafc;
  }

  .job-card,
  .empty {
    background: #111827;
    border-color: #334155;
  }

  .job-card-hover {
    background: #1f2937;
  }

  .job-title,
  .empty-title {
    color: #f8fafc;
  }

  .company-name,
  .summary-count,
  .empty-desc,
  .meta-row,
  .foot-row {
    color: #cbd5e1;
  }

  .company-logo,
  .company-fallback {
    background: #1e293b;
  }

  .visa-tag {
    background: #064e3b;
    color: #bbf7d0;
  }
}
