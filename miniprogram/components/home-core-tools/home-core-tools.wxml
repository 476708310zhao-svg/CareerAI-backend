<view class="section">
  <view class="section-head">
    <view>
      <text class="section-title">核心求职工具</text>
      <text class="section-subtitle">从岗位判断到面试准备</text>
    </view>
  </view>

  <view class="tool-grid">
    <view
      class="tool-card {{item.tone}}"
      wx:for="{{tools}}"
      wx:key="id"
      data-index="{{index}}"
      bindtap="onSelect"
      hover-class="tool-hover"
    >
      <view class="tool-icon-wrap">
        <image class="tool-icon" src="{{item.icon}}" mode="aspectFit"></image>
      </view>
      <view class="tool-copy">
        <text class="tool-title">{{item.title}}</text>
        <text class="tool-desc">{{item.desc}}</text>
      </view>
      <text class="tool-arrow">›</text>
    </view>
  </view>
</view>
