<view class="section" wx:if="{{items.length || loading || ready}}">
  <view class="section-head">
    <view class="section-copy">
      <view class="section-title-line">
        <text class="section-title">校招日历</text>
        <text class="section-pill">每日更新</text>
      </view>
      <text class="section-subtitle">{{dateLabel}} · 网申动态与截止提醒</text>
    </view>
    <view class="section-more" bindtap="onMore" hover-class="more-hover">
      <text>全部{{total ? ' ' + total : ''}}</text>
      <text class="more-arrow">›</text>
    </view>
  </view>

  <view class="waterfall skeleton-waterfall" wx:if="{{loading && !items.length}}">
    <view class="waterfall-column" wx:for="{{skeletonColumns}}" wx:key="index">
      <view class="campus-tile skeleton-tile" wx:for="{{item}}" wx:key="*this">
        <view class="skeleton-top">
          <view class="skeleton-logo"></view>
          <view class="skeleton-badge"></view>
        </view>
        <view class="skeleton-line long"></view>
        <view class="skeleton-line"></view>
        <view class="skeleton-line short"></view>
      </view>
    </view>
  </view>

  <view class="waterfall" wx:elif="{{items.length}}">
    <view class="waterfall-column" wx:for="{{columns}}" wx:for-item="column" wx:key="index">
      <view
        class="campus-tile layout-{{card.layout}} {{card.isUrgent ? 'is-urgent' : ''}}"
        wx:for="{{column}}"
        wx:for-item="card"
        wx:key="id"
        data-id="{{card.id}}"
        bindtap="onSelect"
        hover-class="tile-hover"
      >
        <view class="tile-top">
          <c-company-logo
            logo="{{card.companyLogo}}"
            name="{{card.company}}"
            fallback="{{card.companyInitial}}"
            size="sm"
            lazy-load="{{true}}"
            custom-class="campus-logo"
            data-id="{{card.id}}"
            bind:error="onLogoError"
          ></c-company-logo>
          <text class="campus-badge {{card.isUrgent ? 'urgent' : ''}}">{{card.badgeText}}</text>
        </view>
        <text class="campus-title">{{card.title}}</text>
        <text class="campus-sub">{{card.subtitle}}</text>
        <view class="campus-tags">
          <text wx:if="{{card.tagText}}">{{card.tagText}}</text>
          <text wx:if="{{card.updatedText}}">{{card.updatedText}}</text>
        </view>
        <view class="tile-footer">
          <text class="campus-deadline {{card.isUrgent ? 'urgent' : ''}}">{{card.deadlineText}}</text>
          <text class="tile-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:else bindtap="onMore" hover-class="empty-hover">
    <view class="empty-icon">校</view>
    <view class="empty-copy">
      <text class="empty-title">暂无新的校招更新</text>
      <text class="empty-sub">进入校招日历查看全部企业、岗位与截止日期</text>
    </view>
    <text class="empty-arrow">›</text>
  </view>
</view>
