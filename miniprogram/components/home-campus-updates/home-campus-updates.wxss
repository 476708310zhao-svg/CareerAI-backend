:host {
  display: block;
}

.section {
  margin-top: 34rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-copy {
  min-width: 0;
  flex: 1;
}

.section-title-line,
.campus-topline,
.campus-footer,
.campus-tags {
  display: flex;
  align-items: center;
}

.section-title-line {
  gap: 10rpx;
}

.section-title,
.section-subtitle,
.campus-title,
.campus-sub,
.empty-title,
.empty-sub {
  display: block;
}

.section-title {
  color: #101b2e;
  font-size: 31rpx;
  font-weight: 850;
}

.section-pill {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: #2365dc;
  background: #e9f2ff;
  font-size: 15rpx;
  font-weight: 750;
}

.section-subtitle {
  margin-top: 4rpx;
  color: #7f8da2;
  font-size: 18rpx;
}

.section-more {
  min-height: 50rpx;
  display: flex;
  align-items: center;
  gap: 5rpx;
  flex-shrink: 0;
  padding: 0 15rpx;
  border: 1rpx solid #d4e3f7;
  border-radius: 999rpx;
  color: #1769e8;
  background: #f6faff;
  font-size: 19rpx;
  font-weight: 750;
}

.more-arrow {
  font-size: 27rpx;
  line-height: 1;
}

.more-hover {
  opacity: 0.72;
}

.campus-list {
  overflow: hidden;
  border: 1.5rpx solid #dfe8f4;
  border-radius: 25rpx;
  background: #fff;
  box-shadow: 0 11rpx 28rpx rgba(31, 55, 89, 0.052);
}

.campus-row {
  min-height: 154rpx;
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid #e8eef6;
  background: linear-gradient(90deg, #fff 0%, #fbfdff 100%);
}

.campus-row:last-child {
  border-bottom: 0;
}

.campus-row.is-urgent {
  background: linear-gradient(90deg, #fff 0%, #fffaf3 100%);
}

.campus-logo {
  flex-shrink: 0;
  border-radius: 14rpx;
}

.campus-main {
  min-width: 0;
  flex: 1;
}

.campus-topline {
  min-width: 0;
  justify-content: space-between;
  gap: 10rpx;
}

.campus-badge {
  max-width: 150rpx;
  overflow: hidden;
  padding: 3rpx 9rpx;
  border-radius: 999rpx;
  color: #1769e8;
  background: #eaf3ff;
  font-size: 15rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-badge.urgent {
  color: #b45b20;
  background: #ffead5;
}

.campus-updated {
  flex-shrink: 0;
  color: #8492a6;
  font-size: 16rpx;
}

.campus-title {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: #17243a;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.campus-sub {
  margin-top: 6rpx;
  overflow: hidden;
  color: #7c899c;
  font-size: 17rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-footer {
  min-width: 0;
  gap: 9rpx;
  margin-top: 10rpx;
}

.campus-tags {
  min-width: 0;
  flex: 1;
}

.campus-tags text {
  max-width: 220rpx;
  overflow: hidden;
  padding: 3rpx 9rpx;
  border-radius: 999rpx;
  color: #4d6f9f;
  background: #eef4fb;
  font-size: 14rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-deadline {
  max-width: 150rpx;
  flex-shrink: 0;
  overflow: hidden;
  color: #1769e8;
  font-size: 16rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-deadline.urgent {
  color: #df6d25;
}

.row-arrow {
  flex-shrink: 0;
  color: #9aa9bc;
  font-size: 27rpx;
  line-height: 1;
}

.row-hover {
  background: #f5f9ff;
}

.skeleton-row {
  min-height: 146rpx;
  align-items: flex-start;
}

.skeleton-logo {
  width: 54rpx;
  height: 54rpx;
  flex-shrink: 0;
  border-radius: 14rpx;
}

.skeleton-main {
  min-width: 0;
  flex: 1;
}

.skeleton-line,
.skeleton-logo {
  background: linear-gradient(90deg, #edf2f7 25%, #fafbfd 50%, #edf2f7 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}

.skeleton-line {
  width: 62%;
  height: 15rpx;
  margin-top: 12rpx;
  border-radius: 7rpx;
}

.skeleton-line.long {
  width: 92%;
  height: 20rpx;
}

.skeleton-line.short {
  width: 32%;
  margin-top: 1rpx;
}

.empty {
  min-height: 124rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 22rpx;
  box-sizing: border-box;
  border: 1.5rpx solid #dfe7f1;
  border-radius: 24rpx;
  background: #fff;
}

.empty-icon {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  color: #1769e8;
  background: #eaf3ff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 52rpx;
  text-align: center;
}

.empty-copy {
  min-width: 0;
  flex: 1;
}

.empty-title {
  color: #213047;
  font-size: 23rpx;
  font-weight: 750;
}

.empty-sub {
  margin-top: 5rpx;
  color: #8290a4;
  font-size: 18rpx;
  line-height: 1.4;
}

.empty-arrow {
  color: #91a1b5;
  font-size: 31rpx;
}

.empty-hover {
  background: #f7faff;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
