:host {
  display: block;
}

.section {
  margin-top: 34rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-copy {
  min-width: 0;
  flex: 1;
}

.section-title-line,
.tile-top,
.tile-footer,
.campus-tags {
  display: flex;
  align-items: center;
}

.section-title-line {
  gap: 10rpx;
}

.section-title,
.section-subtitle,
.campus-title,
.campus-sub,
.empty-title,
.empty-sub {
  display: block;
}

.section-title {
  color: #101b2e;
  font-size: 31rpx;
  font-weight: 850;
}

.section-pill {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: #2365dc;
  background: #e9f2ff;
  font-size: 15rpx;
  font-weight: 750;
}

.section-subtitle {
  margin-top: 4rpx;
  color: #7f8da2;
  font-size: 18rpx;
}

.section-more {
  min-height: 50rpx;
  display: flex;
  align-items: center;
  gap: 5rpx;
  flex-shrink: 0;
  padding: 0 15rpx;
  border: 1rpx solid #d4e3f7;
  border-radius: 999rpx;
  color: #1769e8;
  background: #f6faff;
  font-size: 19rpx;
  font-weight: 750;
}

.more-arrow {
  font-size: 27rpx;
  line-height: 1;
}

.more-hover {
  opacity: 0.72;
}

.waterfall {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.waterfall-column {
  width: calc((100% - 14rpx) / 2);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.campus-tile {
  position: relative;
  overflow: hidden;
  padding: 18rpx;
  box-sizing: border-box;
  border: 1.5rpx solid #dfe8f4;
  border-radius: 24rpx;
  background: linear-gradient(155deg, #ffffff 0%, #f8fbff 100%);
  box-shadow: 0 10rpx 26rpx rgba(31, 55, 89, 0.055);
}

.campus-tile.layout-1,
.campus-tile.layout-3 {
  padding-top: 22rpx;
  padding-bottom: 22rpx;
}

.campus-tile.is-urgent {
  border-color: #f5d9bc;
  background: linear-gradient(155deg, #fffdf9 0%, #fff7ed 100%);
}

.tile-top {
  justify-content: space-between;
  gap: 8rpx;
}

.campus-logo {
  flex-shrink: 0;
  border-radius: 14rpx;
}

.campus-badge {
  max-width: 105rpx;
  overflow: hidden;
  padding: 4rpx 9rpx;
  border-radius: 999rpx;
  color: #1769e8;
  background: #eaf3ff;
  font-size: 15rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-badge.urgent {
  color: #b45b20;
  background: #ffead5;
}

.campus-title {
  display: -webkit-box;
  margin-top: 15rpx;
  overflow: hidden;
  color: #17243a;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.layout-1 .campus-title,
.layout-3 .campus-title {
  -webkit-line-clamp: 3;
}

.campus-sub {
  margin-top: 8rpx;
  overflow: hidden;
  color: #7c899c;
  font-size: 17rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-tags {
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 11rpx;
}

.campus-tags text {
  max-width: 124rpx;
  overflow: hidden;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  color: #4d6f9f;
  background: #eef4fb;
  font-size: 14rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tile-footer {
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 15rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #e7edf5;
}

.campus-deadline {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: #1769e8;
  font-size: 17rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-deadline.urgent {
  color: #df6d25;
}

.tile-arrow {
  color: #9aa9bc;
  font-size: 27rpx;
  line-height: 1;
}

.tile-hover {
  opacity: 0.78;
  transform: scale(0.985);
}

.skeleton-tile {
  min-height: 240rpx;
}

.skeleton-tile:nth-child(2n) {
  min-height: 276rpx;
}

.skeleton-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.skeleton-logo {
  width: 50rpx;
  height: 50rpx;
  border-radius: 14rpx;
}

.skeleton-badge {
  width: 70rpx;
  height: 25rpx;
  border-radius: 999rpx;
}

.skeleton-line,
.skeleton-logo,
.skeleton-badge {
  background: linear-gradient(90deg, #edf2f7 25%, #fafbfd 50%, #edf2f7 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}

.skeleton-line {
  width: 72%;
  height: 15rpx;
  margin-top: 14rpx;
  border-radius: 7rpx;
}

.skeleton-line.long {
  width: 92%;
  height: 20rpx;
  margin-top: 21rpx;
}

.skeleton-line.short {
  width: 48%;
}

.empty {
  min-height: 124rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 22rpx;
  box-sizing: border-box;
  border: 1.5rpx solid #dfe7f1;
  border-radius: 24rpx;
  background: #fff;
}

.empty-icon {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  color: #1769e8;
  background: #eaf3ff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 52rpx;
  text-align: center;
}

.empty-copy {
  min-width: 0;
  flex: 1;
}

.empty-title {
  color: #213047;
  font-size: 23rpx;
  font-weight: 750;
}

.empty-sub {
  margin-top: 5rpx;
  color: #8290a4;
  font-size: 18rpx;
  line-height: 1.4;
}

.empty-arrow {
  color: #91a1b5;
  font-size: 31rpx;
}

.empty-hover {
  background: #f7faff;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
