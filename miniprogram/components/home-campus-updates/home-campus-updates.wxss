:host {
  display: block;
}

.section {
  margin-top: 34rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.section-copy {
  min-width: 0;
  flex: 1;
}

.section-title,
.section-subtitle,
.campus-title,
.campus-sub,
.campus-deadline,
.campus-side-tag,
.empty-title,
.empty-sub {
  display: block;
}

.section-title {
  color: #101b2e;
  font-size: 31rpx;
  font-weight: 850;
}

.section-subtitle {
  margin-top: 4rpx;
  overflow: hidden;
  color: #7f8da2;
  font-size: 18rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-more {
  min-height: 50rpx;
  display: flex;
  align-items: center;
  gap: 7rpx;
  flex-shrink: 0;
  padding: 0 15rpx;
  border: 1rpx solid #d4e3f7;
  border-radius: 999rpx;
  color: #1769e8;
  background: #f6faff;
  font-size: 19rpx;
  font-weight: 750;
}

.calendar-icon {
  font-size: 20rpx;
}

.campus-card {
  overflow: hidden;
  border: 1.5rpx solid #dfe7f1;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 12rpx 28rpx rgba(31, 55, 89, 0.045);
}

.campus-row {
  min-height: 105rpx;
  display: flex;
  align-items: center;
  gap: 13rpx;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid #e6edf5;
}

.campus-row:last-child {
  border-bottom: 0;
}

.featured-row {
  min-height: 130rpx;
  align-items: flex-start;
  padding-top: 16rpx;
  padding-bottom: 16rpx;
  background: linear-gradient(90deg, #ffffff 0%, #f8fbff 100%);
}

.campus-logo {
  flex-shrink: 0;
  border-radius: 14rpx;
}

.campus-main {
  min-width: 0;
  flex: 1;
}

.campus-topline {
  display: flex;
  align-items: center;
  gap: 9rpx;
  min-width: 0;
}

.campus-badge {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: #1769e8;
  background: #eaf3ff;
  font-size: 16rpx;
  font-weight: 800;
}

.campus-badge.urgent {
  color: #b45b20;
  background: #fff1e2;
}

.campus-title {
  overflow: hidden;
  color: #182338;
  font-size: 21rpx;
  font-weight: 750;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-sub {
  margin-top: 7rpx;
  overflow: hidden;
  color: #748299;
  font-size: 18rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-tags {
  display: flex;
  align-items: center;
  gap: 7rpx;
  margin-top: 8rpx;
}

.campus-tags text {
  padding: 3rpx 9rpx;
  border-radius: 999rpx;
  color: #3270d1;
  background: #eef5ff;
  font-size: 15rpx;
}

.campus-side {
  width: 100rpx;
  flex-shrink: 0;
  text-align: right;
}

.campus-deadline {
  max-width: 108rpx;
  flex-shrink: 0;
  overflow: hidden;
  color: #1769e8;
  font-size: 18rpx;
  font-weight: 800;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-deadline.urgent {
  color: #e06b22;
}

.campus-side-tag {
  margin-top: 6rpx;
  overflow: hidden;
  color: #8290a4;
  font-size: 16rpx;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-hover {
  background: #f5f9ff;
}

.skeleton-card {
  min-height: 270rpx;
}

.skeleton-logo {
  width: 50rpx;
  height: 50rpx;
  flex-shrink: 0;
  border-radius: 14rpx;
}

.skeleton-main {
  min-width: 0;
  flex: 1;
}

.skeleton-line,
.skeleton-logo {
  background: linear-gradient(90deg, #edf2f7 25%, #fafbfd 50%, #edf2f7 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}

.skeleton-line {
  width: 65%;
  height: 16rpx;
  margin-top: 11rpx;
  border-radius: 7rpx;
}

.skeleton-line.long {
  width: 88%;
  height: 19rpx;
  margin-top: 0;
}

.empty {
  min-height: 118rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

.empty-icon {
  width: 50rpx;
  height: 50rpx;
  flex-shrink: 0;
  border-radius: 15rpx;
  color: #1769e8;
  background: #eaf3ff;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 50rpx;
  text-align: center;
}

.empty-copy {
  min-width: 0;
  flex: 1;
}

.empty-title {
  color: #213047;
  font-size: 23rpx;
  font-weight: 750;
}

.empty-sub {
  margin-top: 5rpx;
  color: #8290a4;
  font-size: 18rpx;
  line-height: 1.4;
}

.empty-arrow {
  color: #91a1b5;
  font-size: 31rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
