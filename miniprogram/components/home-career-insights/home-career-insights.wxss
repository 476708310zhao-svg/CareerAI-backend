:host {
  display: block;
}

.section {
  margin-top: 31rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 13rpx;
}

.section-title,
.insight-title,
.insight-meta,
.insight-time,
.state-title,
.state-desc {
  display: block;
}

.section-title {
  color: #101b2e;
  font-size: 31rpx;
  font-weight: 850;
}

.section-more {
  flex-shrink: 0;
  color: #1769e8;
  font-size: 20rpx;
  font-weight: 750;
}

.insight-list {
  overflow: hidden;
  border: 1.5rpx solid #dfe7f1;
  border-radius: 23rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 11rpx 26rpx rgba(31, 55, 89, 0.04);
}

.insight-row {
  min-height: 83rpx;
  display: flex;
  align-items: center;
  gap: 13rpx;
  padding: 12rpx 16rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid #e6edf5;
}

.insight-row:last-child {
  border-bottom: 0;
}

.insight-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  border-radius: 11rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #2879f0 0%, #1762d5 100%);
  box-shadow: 0 6rpx 13rpx rgba(33, 105, 220, 0.18);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 40rpx;
  text-align: center;
}

.insight-icon.data {
  background: linear-gradient(145deg, #27c887 0%, #11a66b 100%);
}

.insight-icon.policy {
  background: linear-gradient(145deg, #f4a64f 0%, #df7b25 100%);
}

.insight-icon.tip {
  background: linear-gradient(145deg, #8b72e9 0%, #6d55cb 100%);
}

.insight-copy {
  min-width: 0;
  flex: 1;
}

.insight-title {
  overflow: hidden;
  color: #182338;
  font-size: 21rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.insight-meta {
  margin-top: 5rpx;
  overflow: hidden;
  color: #8996a8;
  font-size: 16rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.insight-time {
  width: 86rpx;
  flex-shrink: 0;
  overflow: hidden;
  color: #7c899d;
  font-size: 17rpx;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-hover {
  background: #f5f9ff;
}

.state-card {
  padding: 29rpx 26rpx;
  border: 1.5rpx solid #dfe7f1;
  border-radius: 23rpx;
  background: #ffffff;
  box-shadow: 0 11rpx 26rpx rgba(31, 55, 89, 0.04);
  text-align: center;
}

.state-card.error {
  border-color: #efd9d7;
  background: #fffafa;
}

.state-title {
  color: #26354b;
  font-size: 23rpx;
  font-weight: 800;
}

.state-desc {
  margin-top: 7rpx;
  color: #8591a2;
  font-size: 18rpx;
}

.retry {
  min-height: 52rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  padding: 0 21rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1766ec 0%, #3d8cff 100%);
  font-size: 20rpx;
  font-weight: 750;
}

.retry.secondary {
  color: #40516a;
  background: #edf2f7;
}

.skeleton-icon,
.skeleton-line {
  background: linear-gradient(90deg, #edf2f7 25%, #fafbfd 50%, #edf2f7 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}

.skeleton-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  border-radius: 11rpx;
}

.skeleton-copy {
  min-width: 0;
  flex: 1;
}

.skeleton-line {
  height: 17rpx;
  border-radius: 7rpx;
}

.skeleton-line.long {
  width: 86%;
}

.skeleton-line.medium {
  width: 52%;
  height: 14rpx;
  margin-top: 9rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
