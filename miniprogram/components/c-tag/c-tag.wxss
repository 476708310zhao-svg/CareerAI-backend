/* ══ c-tag 标签/徽章组件 ════════════════════════════════════════════
 *
 * 用法：
 *   <c-tag type="primary">全职</c-tag>
 *   <c-tag type="success" size="small">已通过</c-tag>
 *
 * type: default | primary | success | warning | danger | info
 * size: default | small | large
 *
 * ★ 所有视觉值来自 app.wxss 设计令牌
 *   改主色标签 → --brand
 *   改文字颜色 → 对应 --text-* 变量
 * ════════════════════════════════════════════════════════════════════ */

.ct {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: var(--r-xs);
  line-height: 1;
  white-space: nowrap;
}

/* ── 类型 ────────────────────────────────────────────────────────── */

.ct--default {
  background: var(--bg-raised);
  color: var(--text-secondary);
  border: 1rpx solid var(--border-light);
}

.ct--primary {
  background: rgba(43, 92, 230, 0.10);
  color: var(--brand);
  border: 1rpx solid rgba(43, 92, 230, 0.20);
}

.ct--success {
  background: rgba(16, 185, 129, 0.10);
  color: var(--success);
  border: 1rpx solid rgba(16, 185, 129, 0.22);
}

.ct--warning {
  background: rgba(245, 158, 11, 0.10);
  color: var(--warning);
  border: 1rpx solid rgba(245, 158, 11, 0.22);
}

.ct--danger {
  background: rgba(239, 68, 68, 0.10);
  color: var(--danger);
  border: 1rpx solid rgba(239, 68, 68, 0.22);
}

.ct--info {
  background: rgba(43, 92, 230, 0.06);
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
}

/* ── 尺寸 ────────────────────────────────────────────────────────── */

.ct--small {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.ct--large {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--r-sm);
}

/* 2026 product component polish */
.ct {
  min-height: 38rpx;
  border-radius: var(--radius-full, 999rpx);
  font-weight: 680;
  letter-spacing: 0;
}

.ct--default {
  background: var(--color-bg-soft, #f7f8fb);
  color: var(--color-ink-3, #667085);
  border-color: var(--color-line-soft, rgba(16, 24, 40, 0.05));
}

.ct--primary {
  background: var(--color-brand-soft, #eff6ff);
  color: var(--color-brand, #2563eb);
  border-color: rgba(37, 99, 235, 0.16);
}

.ct--success {
  background: var(--color-success-soft, #ecfdf3);
  color: var(--color-success, #059669);
  border-color: rgba(5, 150, 105, 0.14);
}

.ct--warning {
  background: var(--color-warning-soft, #fffbeb);
  color: var(--color-warning, #d97706);
  border-color: rgba(217, 119, 6, 0.14);
}

.ct--danger {
  background: var(--color-danger-soft, #fef2f2);
  color: var(--color-danger, #dc2626);
  border-color: rgba(220, 38, 38, 0.14);
}
