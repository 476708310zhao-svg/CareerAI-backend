.search-bar {
  padding: 16rpx 32rpx;
}
.search-wrap {
  display: flex;
  align-items: center;
  background: var(--bg-raised, #F4F6F9);
  border-radius: var(--r-pill, 9999rpx);
  padding: 0 24rpx;
  height: 72rpx;
  border: 1rpx solid var(--border-subtle, rgba(0,0,0,0.04));
}
.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary, #111827);
  height: 72rpx;
}
.search-clear {
  font-size: 28rpx;
  color: var(--text-muted, #9CA3AF);
  padding: 8rpx 4rpx 8rpx 12rpx;
  flex-shrink: 0;
}

/* 2026 product component polish */
.search-bar {
  padding: 14rpx 24rpx;
}

.search-wrap {
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: var(--color-bg-soft, #f7f8fb);
  border: 1rpx solid transparent;
}

.search-wrap:active {
  background: #ffffff;
  border-color: rgba(37, 99, 235, 0.16);
}

.search-input {
  height: 76rpx;
  font-size: 27rpx;
}

.search-icon,
.search-clear {
  color: var(--color-ink-4, #98a2b3);
}

/* Soft raised search bar */
.search-bar {
  padding: 14rpx 28rpx;
}

.search-wrap {
  height: 76rpx;
  padding: 0 24rpx;
  gap: 14rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fafc 100%);
  border: 1rpx solid rgba(205, 216, 228, 0.82);
  box-shadow:
    0 14rpx 28rpx rgba(31, 45, 61, 0.065),
    inset 0 1rpx 0 rgba(255,255,255,0.96);
}

.search-wrap:active {
  background: #ffffff;
  border-color: rgba(66, 153, 225, 0.22);
}

.search-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 0;
}

.search-input {
  height: 76rpx;
  line-height: 76rpx;
  color: #162033;
  font-size: 27rpx;
  font-weight: 500;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  padding: 0;
  border-radius: 50%;
  color: #7b8798;
  background: #edf2f7;
  border: 1rpx solid rgba(203, 213, 225, 0.86);
  font-size: 24rpx;
  line-height: 38rpx;
  text-align: center;
}
