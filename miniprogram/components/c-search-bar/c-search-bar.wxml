<view class="search-bar">
  <view class="search-wrap">
    <icon class="search-icon" type="search" size="15" color="#94A3B8"></icon>
    <input
      class="search-input"
      placeholder="{{placeholder}}"
      value="{{value}}"
      confirm-type="search"
      bindinput="onInput"
      bindconfirm="onConfirm"
    />
    <view class="search-clear" wx:if="{{value}}" catchtap="onClear">✕</view>
  </view>
</view>
