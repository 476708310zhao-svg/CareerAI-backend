<!-- components/c-login-popup/c-login-popup.wxml -->
<view class="popup-root" wx:if="{{show}}">

  <!-- 遮罩层 -->
  <view class="backdrop" bindtap="onBackdropTap"></view>

  <!-- 底部卡片 -->
  <view class="sheet" catchtap="onSheetTap">

    <!-- 顶部拖拽条 -->
    <view class="handle-bar"></view>

    <!-- 品牌标题 -->
    <view class="sheet-header">
      <view class="logo-wrap">
        <image class="logo-img" src="/images/home-active.png" mode="aspectFit" />
      </view>
      <text class="sheet-title">登录职引</text>
      <text class="sheet-subtitle">{{subtitle}}</text>
    </view>

    <!-- 微信一键登录 -->
    <view class="btn-area" catchtap="onUnagreedTap">
      <button
        class="btn btn-wechat {{(!agreed || !wechatPrivacyReady || loadingWechat || loadingPhone) ? 'is-disabled' : ''}}"
        bindtap="onWechatLogin"
        loading="{{loadingWechat}}"
        disabled="{{!agreed || !wechatPrivacyReady || loadingWechat || loadingPhone}}"
      >
        <text class="btn-icon">💬</text>
        <text class="btn-text">微信一键登录</text>
      </button>
    </view>

    <!-- 手机号快速验证 -->
    <view class="btn-area" catchtap="onUnagreedTap">
      <button
        class="btn btn-phone {{(!agreed || !wechatPrivacyReady || loadingWechat || loadingPhone) ? 'is-disabled' : ''}}"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
        loading="{{loadingPhone}}"
        disabled="{{!agreed || !wechatPrivacyReady || loadingWechat || loadingPhone}}"
      >
        <text class="btn-icon">📱</text>
        <text class="btn-text">手机号快速验证</text>
      </button>
    </view>

    <!-- 隐私协议 -->
    <view class="privacy-row" bindtap="toggleAgree">
      <view class="checkbox {{agreed ? 'checked' : ''}}">
        <text wx:if="{{agreed}}" class="check-mark">✓</text>
      </view>
      <view class="privacy-desc">
        <text class="privacy-text">我已阅读并同意</text>
        <text class="privacy-link" catchtap="onPrivacyTap">《用户协议与隐私政策》</text>
      </view>
    </view>

    <view class="wechat-privacy-card" wx:if="{{!wechatPrivacyReady}}">
      <text class="wechat-privacy-text">继续使用登录、手机号等能力前，请先阅读并同意{{privacyContractName}}。</text>
      <view class="wechat-privacy-actions">
        <button class="privacy-link-btn" bindtap="onOpenWechatPrivacy">查看指引</button>
        <button
          class="privacy-agree-btn"
          open-type="agreePrivacyAuthorization"
          bindagreeprivacyauthorization="onAgreeWechatPrivacy"
        >同意并继续</button>
      </view>
    </view>

  </view>
</view>
