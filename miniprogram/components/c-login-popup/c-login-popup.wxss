/* components/c-login-popup/c-login-popup.wxss */

/* ── 根层：铺满全屏 ── */
.popup-root {
  position: fixed;
  inset: 0;
  z-index: 1000;
}

/* ── 遮罩 ── */
.backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  animation: fadeIn 0.25s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ── 底部卡片 ── */
.sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 48rpx calc(env(safe-area-inset-bottom) + 48rpx);
  animation: slideUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

/* ── 顶部拖拽条 ── */
.handle-bar {
  width: 80rpx;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  margin: 20rpx auto 32rpx;
}

/* ── 标题 ── */
.sheet-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.sheet-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1D27;
  margin-bottom: 10rpx;
}

.sheet-subtitle {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* ── 头像区 ── */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  position: relative;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #EEF2FF;
  display: block;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  background: #2B5CE6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #ffffff;
}

.edit-icon {
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
}

.avatar-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ── 昵称输入 ── */
.input-row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #F3F4F6;
  padding: 16rpx 0;
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  width: 80rpx;
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1D27;
  height: 64rpx;
  padding-left: 16rpx;
}

.input-placeholder {
  color: #C4C9D4;
  font-size: 26rpx;
}

/* ── 确认按钮 ── */
.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3B6EF8, #2B5CE6);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(43, 92, 230, 0.3);
  letter-spacing: 2rpx;
  margin-bottom: 28rpx;
}

.confirm-btn[disabled] {
  opacity: 0.65;
}

/* ── 隐私协议 ── */
.privacy-row {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
}

.privacy-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

.privacy-link {
  font-size: 22rpx;
  color: #2B5CE6;
}
