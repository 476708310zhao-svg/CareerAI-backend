/* components/c-login-popup/c-login-popup.wxss */

/* ── 根层：铺满全屏 ── */
.popup-root {
  position: fixed;
  inset: 0;
  z-index: 20000;
}

/* ── 遮罩 ── */
.backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.48);
  animation: fadeIn 0.22s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ── 底部卡片 ── */
.sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 36rpx 36rpx 0 0;
  padding: 0 48rpx calc(env(safe-area-inset-bottom) + 56rpx);
  max-height: calc(100vh - 24rpx);
  overflow-y: auto;
  box-sizing: border-box;
  animation: slideUp 0.28s cubic-bezier(0.34, 1.4, 0.64, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

/* ── 顶部拖拽条 ── */
.handle-bar {
  width: 72rpx;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  margin: 20rpx auto 36rpx;
}

/* ── 品牌标题 ── */
.sheet-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.logo-wrap {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #3B6EF8, #2B5CE6);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(43, 92, 230, 0.28);
}

.logo-img {
  width: 52rpx;
  height: 52rpx;
  filter: brightness(10);
}

.sheet-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1A1D27;
  margin-bottom: 10rpx;
}

.sheet-subtitle {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* ── 按钮区域 ── */
.btn-area {
  width: 100%;
  margin-bottom: 20rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 1rpx;
}

.btn::after {
  border: none;
}

.btn.is-disabled {
  opacity: 0.42;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 14rpx;
  line-height: 1;
}

.btn-text {
  line-height: 1;
}

.btn-wechat {
  background: linear-gradient(135deg, #2DC100, #1AAD19);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(26, 173, 25, 0.28);
  margin-bottom: 0;
}

.btn-phone {
  background: linear-gradient(135deg, #3B6EF8, #2B5CE6);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(43, 92, 230, 0.28);
}

/* ── 隐私协议 ── */
.privacy-row {
  display: flex;
  align-items: center;
  margin: 0 0 28rpx;
  padding: 4rpx 0;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid #D1D5DB;
  background: #F9FAFB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 14rpx;
}

.checkbox.checked {
  background: #2B5CE6;
  border-color: #2B5CE6;
}

.check-mark {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.privacy-desc {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  flex: 1;
}

.privacy-text {
  font-size: 24rpx;
  color: #9CA3AF;
  line-height: 1.5;
}

.privacy-link {
  font-size: 24rpx;
  color: #2B5CE6;
  line-height: 1.5;
}

.wechat-privacy-card {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: var(--card-radius, 26rpx);
  background: var(--card-bg, linear-gradient(145deg, #ffffff, #f6f9ff));
  border: 1rpx solid var(--card-border, #dbeafe);
  box-shadow: var(--card-shadow, 0 14rpx 34rpx rgba(36,58,92,0.07));
}

.wechat-privacy-text {
  display: block;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.55;
}

.wechat-privacy-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.privacy-link-btn,
.privacy-agree-btn {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.privacy-link-btn {
  color: #2563eb;
  background: #ffffff;
}

.privacy-agree-btn {
  color: #ffffff;
  background: #2563eb;
}

.privacy-link-btn::after,
.privacy-agree-btn::after {
  border: 0;
}
