:host {
  display: block;
}

.section {
  margin-top: 34rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.section-copy {
  min-width: 0;
  flex: 1;
}

.section-title,
.section-subtitle,
.job-company,
.job-title,
.match-label,
.match-value,
.state-title,
.state-desc {
  display: block;
}

.section-title {
  color: #101b2e;
  font-size: 31rpx;
  font-weight: 850;
}

.section-subtitle {
  display: none;
}

.section-more {
  flex-shrink: 0;
  color: #1769e8;
  font-size: 20rpx;
  font-weight: 750;
}

.job-list {
  overflow: hidden;
  border: 1.5rpx solid #dfe7f1;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 12rpx 28rpx rgba(31, 55, 89, 0.045);
}

.job-row {
  min-height: 108rpx;
  display: flex;
  align-items: center;
  gap: 13rpx;
  padding: 14rpx 17rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid #e7edf4;
}

.job-row:last-child {
  border-bottom: 0;
}

.company-cell {
  width: 145rpx;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.job-logo {
  flex-shrink: 0;
  border-radius: 13rpx;
}

.job-company {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: #172136;
  font-size: 19rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-divider {
  width: 1rpx;
  height: 55rpx;
  flex-shrink: 0;
  background: #e2e9f2;
}

.job-main {
  min-width: 0;
  flex: 1;
}

.job-title {
  overflow: hidden;
  color: #172136;
  font-size: 22rpx;
  font-weight: 750;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  overflow: hidden;
  color: #7f8da2;
  font-size: 17rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-pin {
  margin-right: 7rpx;
  color: #71839c;
  font-size: 12rpx;
}

.match-cell {
  width: 76rpx;
  flex-shrink: 0;
  padding-left: 10rpx;
  border-left: 1rpx solid #edf1f6;
  text-align: center;
}

.match-label {
  color: #7d8b9e;
  font-size: 16rpx;
  white-space: nowrap;
}

.match-value {
  margin-top: 3rpx;
  color: #08a65d;
  font-size: 29rpx;
  font-weight: 850;
  line-height: 1.05;
}

.match-unit {
  font-size: 17rpx;
}

.match-value.neutral {
  color: #2f71d9;
  font-size: 19rpx;
  line-height: 1.45;
}

.row-hover {
  background: #f5f9ff;
}

.state-card {
  padding: 31rpx 27rpx;
  border: 1.5rpx solid #dfe7f1;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(31, 55, 89, 0.045);
  text-align: center;
}

.state-card.error {
  border-color: #efd9d7;
  background: #fffafa;
}

.state-mark {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto;
  border-radius: 15rpx;
  color: #c6534d;
  background: #fdeeed;
  font-size: 25rpx;
  font-weight: 850;
  line-height: 48rpx;
}

.state-mark.calm {
  color: #226ed8;
  background: #eaf4ff;
}

.state-title {
  margin-top: 13rpx;
  color: #213047;
  font-size: 24rpx;
  font-weight: 800;
}

.state-desc {
  margin-top: 7rpx;
  color: #8591a2;
  font-size: 19rpx;
}

.empty-actions {
  display: flex;
  justify-content: center;
  gap: 11rpx;
  margin-top: 17rpx;
}

.state-action {
  min-height: 54rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 17rpx;
  padding: 0 21rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1766ec 0%, #3d8cff 100%);
  font-size: 20rpx;
  font-weight: 750;
}

.empty-actions .state-action {
  margin-top: 0;
}

.state-action.secondary {
  color: #40516a;
  background: #edf2f7;
}

.skeleton-logo,
.skeleton-company,
.skeleton-line,
.skeleton-score {
  background: linear-gradient(90deg, #edf2f7 25%, #fafbfd 50%, #edf2f7 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}

.skeleton-logo {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  border-radius: 13rpx;
}

.skeleton-company {
  width: 74rpx;
  height: 18rpx;
  flex-shrink: 0;
  border-radius: 7rpx;
}

.skeleton-copy {
  min-width: 0;
  flex: 1;
}

.skeleton-line {
  height: 19rpx;
  border-radius: 7rpx;
}

.skeleton-line.long {
  width: 82%;
}

.skeleton-line.medium {
  width: 60%;
  height: 15rpx;
  margin-top: 11rpx;
}

.skeleton-score {
  width: 58rpx;
  height: 35rpx;
  border-radius: 9rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
