.ai-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}
.ai-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid var(--border-subtle, rgba(0,0,0,0.04));
  border-top-color: var(--brand, #2B5CE6);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 32rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.ai-loading-dots {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--border-light, #E5E7EB);
  transition: background 0.3s;
}
.dot.active {
  background: var(--brand, #2B5CE6);
}
.ai-loading-tip {
  font-size: 28rpx;
  color: var(--text-secondary, #6B7280);
  text-align: center;
  transition: opacity 0.3s;
}
