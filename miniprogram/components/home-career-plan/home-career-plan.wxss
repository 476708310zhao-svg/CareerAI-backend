:host {
  display: block;
}

.plan-card {
  position: relative;
  overflow: hidden;
  padding: 26rpx;
  border: 1.5rpx solid #d9e5f4;
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(73, 139, 255, 0.08), transparent 34%),
    linear-gradient(145deg, #ffffff 0%, #f6faff 100%);
  box-shadow: 0 14rpx 34rpx rgba(38, 77, 132, 0.07);
}

.plan-kicker,
.plan-title,
.plan-subtitle,
.metric-label,
.metric-value,
.suggestion-label,
.suggestion-title,
.suggestion-desc {
  display: block;
}

.plan-kicker {
  color: #1769e8;
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 0.5rpx;
}

.plan-title {
  margin-top: 7rpx;
  color: #101a2d;
  font-size: 34rpx;
  font-weight: 850;
  line-height: 1.3;
}

.plan-subtitle {
  margin-top: 7rpx;
  overflow: hidden;
  color: #728198;
  font-size: 20rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 11rpx;
  margin-top: 22rpx;
}

.metric {
  min-width: 0;
  min-height: 112rpx;
  padding: 15rpx 12rpx 13rpx;
  box-sizing: border-box;
  border: 1rpx solid #dce8f6;
  border-radius: 19rpx;
  background: rgba(248, 251, 255, 0.96);
}

.metric.good {
  border-color: #d2ecdf;
  background: #f4fbf7;
}

.metric.amber,
.metric.warn {
  border-color: #f0dfc8;
  background: #fff9f1;
}

.metric.blue {
  border-color: #d4e4f8;
  background: #f4f8ff;
}

.metric-head {
  display: flex;
  align-items: center;
  gap: 7rpx;
  min-width: 0;
}

.metric-icon-wrap {
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 9rpx;
  background: #e5f0ff;
}

.metric.good .metric-icon-wrap {
  background: #e1f5ea;
}

.metric.amber .metric-icon-wrap,
.metric.warn .metric-icon-wrap {
  background: #fff0dc;
}

.metric-icon {
  width: 21rpx;
  height: 21rpx;
}

.metric-label {
  overflow: hidden;
  color: #4b5b73;
  font-size: 18rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-value {
  margin-top: 10rpx;
  color: #101b2f;
  font-size: 33rpx;
  font-weight: 850;
  line-height: 1;
}

.metric-suffix {
  margin-left: 2rpx;
  color: #6f7e92;
  font-size: 17rpx;
  font-weight: 650;
}

.suggestion {
  min-height: 78rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 17rpx;
  padding: 13rpx 13rpx 13rpx 15rpx;
  box-sizing: border-box;
  border: 1rpx solid #dce6f2;
  border-radius: 19rpx;
  background: rgba(255, 255, 255, 0.9);
}

.suggestion-mark {
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  color: #14a666;
  background: #e7f8ef;
  font-size: 24rpx;
  font-weight: 850;
  line-height: 42rpx;
  text-align: center;
}

.suggestion-copy {
  min-width: 0;
  flex: 1;
}

.suggestion-title-row {
  display: flex;
  align-items: center;
  gap: 11rpx;
  min-width: 0;
}

.suggestion-label {
  flex-shrink: 0;
  color: #25344b;
  font-size: 19rpx;
  font-weight: 800;
}

.suggestion-title {
  overflow: hidden;
  color: #172136;
  font-size: 21rpx;
  font-weight: 750;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.suggestion-desc {
  margin-top: 5rpx;
  overflow: hidden;
  color: #7f8da2;
  font-size: 18rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.suggestion-action {
  min-height: 52rpx;
  display: flex;
  align-items: center;
  gap: 5rpx;
  flex-shrink: 0;
  padding: 0 17rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1766ec 0%, #3d8cff 100%);
  box-shadow: 0 8rpx 18rpx rgba(30, 105, 232, 0.2);
  font-size: 19rpx;
  font-weight: 800;
}

.suggestion-action-arrow {
  font-size: 25rpx;
}

.card-hover {
  opacity: 0.82;
}
