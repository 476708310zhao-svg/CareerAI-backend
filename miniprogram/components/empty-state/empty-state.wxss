/* ══ empty-state 空状态组件 ══════════════════════════════════════════
 *   改颜色 → 修改 app.wxss 中 --brand / --text-muted
 * ════════════════════════════════════════════════════════════════════ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx 60rpx;
  text-align: center;
}

.es-emoji {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 28rpx;
}

.es-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.es-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.es-btn {
  background: var(--brand);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 56rpx;
  height: var(--btn-height);
  line-height: var(--btn-height);
  border-radius: var(--r-pill);
  box-shadow: 0 6rpx 20rpx var(--brand-shadow);
}

.es-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* 2026 product component polish */
.empty-state {
  padding: 96rpx 48rpx 72rpx;
}

.es-emoji {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-soft, #f7f8fb);
  font-size: 58rpx;
  margin-bottom: 26rpx;
}

.es-title {
  color: var(--color-ink, #101828);
  font-size: 31rpx;
  font-weight: 820;
  letter-spacing: -0.3rpx;
}

.es-desc {
  max-width: 520rpx;
  color: var(--color-ink-3, #667085);
  font-size: 25rpx;
}

.es-btn {
  height: 78rpx;
  line-height: 78rpx;
  padding: 0 42rpx;
  background: var(--color-brand, #2563eb);
  box-shadow: var(--shadow-action, 0 12rpx 26rpx rgba(37, 99, 235, 0.18));
}
