/* ══ empty-state 空状态组件 ══════════════════════════════════════════
 *   改颜色 → 修改 app.wxss 中 --brand / --text-muted
 * ════════════════════════════════════════════════════════════════════ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx 60rpx;
  text-align: center;
}

.es-emoji {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 28rpx;
}

.es-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.es-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.es-btn {
  background: var(--brand);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 56rpx;
  height: var(--btn-height);
  line-height: var(--btn-height);
  border-radius: var(--r-pill);
  box-shadow: 0 6rpx 20rpx var(--brand-shadow);
}

.es-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}
