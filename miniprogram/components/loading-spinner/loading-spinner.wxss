/* ══ loading-spinner 加载组件 ════════════════════════════════════════
 *   改颜色 → 修改 app.wxss 中 --brand / --border / --text-muted
 * ════════════════════════════════════════════════════════════════════ */
.ls-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 20rpx;
}

.ls-ring {
  width: 48rpx;
  height: 48rpx;
  border: 5rpx solid var(--border);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: ls-spin 0.8s linear infinite;
}

@keyframes ls-spin {
  to { transform: rotate(360deg); }
}

.ls-text {
  font-size: 26rpx;
  color: var(--text-muted);
}
