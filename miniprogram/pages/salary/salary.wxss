/* pages/salary/salary.wxss */
page {
  background:
    radial-gradient(circle at 18% 0%, rgba(47, 102, 244, 0.14), transparent 34%),
    linear-gradient(180deg, #f7fbff 0%, #f5f7fb 54%, #ffffff 100%);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
  color: var(--text-primary);
  overflow-x: hidden;
}

.container {
  overflow-x: hidden;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 鈹€鈹€ Hero 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.hero {
  position: relative;
  margin: 18rpx 24rpx 0;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 20rpx;
  border: 0;
  border-radius: 34rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #10296d 0%, #2f66f4 56%, #13bfa6 100%);
  box-shadow: 0 22rpx 44rpx rgba(47, 102, 244, 0.22);
}

.hero::after {
  content: '';
  position: absolute;
  width: 260rpx;
  height: 260rpx;
  right: -94rpx;
  top: -94rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.hero-text {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -0.8rpx;
}

.hero-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.76);
}

/* 鍦板尯鍒囨崲 */
.region-toggle {
  display: flex;
  position: relative;
  z-index: 1;
  align-self: center;
  min-width: 214rpx;
  padding: 7rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
  gap: 4rpx;
  flex-shrink: 0;
}

.region-btn {
  min-width: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  transition: transform 0.16s ease, background 0.16s ease, opacity 0.16s ease;
}

.region-btn.active {
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(14, 37, 105, 0.2);
}

.region-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.region-btn.active .region-text {
  color: #1d4ed8;
  font-weight: 800;
  text-shadow: none;
}

/* 鈹€鈹€ Tab 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.tab-header {
  display: flex;
  margin: 18rpx 24rpx 0;
  padding: 7rpx;
  border-radius: 28rpx;
  border: 0;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 30rpx rgba(23, 42, 80, 0.07);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  padding: 18rpx 0;
  border-radius: 20rpx;
  color: #6b778c;
  font-size: 25rpx;
  font-weight: 700;
}

.tab-item.active {
  color: #ffffff;
  background: linear-gradient(135deg, #1d6df2 0%, #16b8a7 100%);
  box-shadow: 0 10rpx 24rpx rgba(47, 102, 244, 0.22);
}

.tab-item.active::after {
  display: none;
}

/* 鈹€鈹€ 鎼滅储琛ㄥ崟 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.form-card {
  background: var(--bg-panel);
  border-radius: 30rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1.5rpx solid rgba(0, 0, 0, 0.05);
  margin: 18rpx 24rpx 0;
}

.input-group {
  display: flex;
  align-items: center;
  background: #f8fbff;
  border-radius: 22rpx;
  padding: 0 20rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(47, 102, 244, 0.14);
  height: 82rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.input-icon-box {
  width: 46rpx;
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 14rpx;
  border-radius: 15rpx;
  background: #edf4ff;
}

.input-icon-txt {
  font-size: 32rpx;
  color: #2f66f4;
  line-height: 1;
}

.form-input {
  flex: 1;
  font-size: 27rpx;
  font-weight: 650;
  color: #16233a;
  height: 88rpx;
  line-height: 88rpx;
}

.ph {
  color: #9aa8bb;
  font-size: 28rpx;
  font-weight: 500;
}

.search-btn {
  --brand: var(--color-brand);
  --brand-dark: #173bd1;
  --brand-shadow: rgba(37, 99, 235, 0.28);
  --btn-height: 84rpx;
  --btn-font-size: 28rpx;
  margin-top: 6rpx;
  color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(47, 102, 244, 0.22);
}

/* 鈹€鈹€ 鍘嗗彶鏌ヨ璁板綍 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.history-section {
  padding: 24rpx 24rpx 0;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.history-clear {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 4rpx 8rpx;
}

.history-scroll {
  width: 100%;
  white-space: nowrap;
}

.history-list {
  display: flex;
  gap: 14rpx;
  padding-bottom: 4rpx;
}

.history-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: var(--bg-panel);
  border: 1.5rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 40rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.history-chip:active {
  background: #F0F4FF;
  border-color: #BFDBFE;
}

.history-tag {
  font-size: 20rpx;
  color: var(--bg-panel);
  background: var(--brand);
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.history-main {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-loc {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 鈹€鈹€ 鐑棬蹇煡 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.preset-section {
  margin-top: 18rpx;
  padding: 24rpx 22rpx 26rpx;
}

.section-label {
  display: block;
  color: #172033;
  font-size: 29rpx;
  font-weight: 850;
  margin-bottom: 20rpx;
}

/* 宀椾綅鍗＄墖 2鍒?*/
.role-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.role-card {
  min-height: 126rpx;
  padding: 20rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(37, 99, 235, 0.08);
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  box-shadow: 0 12rpx 26rpx rgba(19, 34, 64, 0.07);
}

.role-card:active {
  transform: scale(0.97);
  background: #FAFBFF;
}

.role-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.role-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.role-range {
  font-size: 21rpx;
  color: var(--color-success-text);
  font-weight: 700;
  background: var(--color-success-tint);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.role-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}

/* 鍏徃鏍囩 */
.tag-container {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.company-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--brand);
  background: var(--color-brand-tint-legacy);
  padding: 12rpx 28rpx;
  border-radius: 22rpx;
  border: 1.5rpx solid #BFDBFE;
  font-weight: 500;
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.company-tag:active {
  background: #E0E7FF;
  transform: scale(0.96);
  opacity: 0.86;
}

/* 鈹€鈹€ 缁撴灉鍗＄墖 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.result-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.07);
  border: 1.5rpx solid rgba(0, 0, 0, 0.05);
  margin: 24rpx 24rpx 0;
  animation: fadeUp 0.3s ease-out;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 缁撴灉澶撮儴 */
.result-header {
  margin-bottom: 28rpx;
}

.res-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.res-loc-row {
  display: flex;
  align-items: center;
}

.res-loc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 钖祫澶ф暟瀛楀尯鍩?*/
.salary-hero {
  background: linear-gradient(135deg, var(--color-brand-tint-legacy), #F0F4FF);
  border-radius: var(--r-lg);
  padding: 32rpx 28rpx;
  margin-bottom: 32rpx;
  border: 1.5rpx solid #C7D2FE;
}

.salary-label {
  display: block;
  font-size: 22rpx;
  color: var(--brand);
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  text-transform: uppercase;
}

.salary-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  margin-bottom: 28rpx;
}

.salary-val {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
}

.salary-unit {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

/* 钖祫鑼冨洿鏉?*/
.salary-range-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.salary-min, .salary-max {
  font-size: 22rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  flex-shrink: 0;
}

.salary-range-bar {
  flex: 1;
  height: 10rpx;
  background: linear-gradient(90deg, #BFDBFE, var(--brand), #BFDBFE);
  border-radius: 5rpx;
  position: relative;
}

.salary-range-fill {
  position: absolute;
  inset: 0;
  border-radius: 5rpx;
}

.salary-dot {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 22rpx;
  height: 22rpx;
  background: var(--bg-panel);
  border: 4rpx solid var(--brand);
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(43, 92, 230, 0.4);
}

/* 鈹€鈹€ section 鏍囬 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-body);
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 5rpx solid var(--brand);
}

/* 鈹€鈹€ 鍒嗕綅鐐?鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.percentile-section {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1.5rpx solid var(--color-surface-muted);
}

.pct-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.pct-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.pct-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.pct-val {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-body);
}

.pct-mid .pct-label { color: var(--brand); font-weight: 700; }
.pct-mid .pct-val   { color: var(--brand); font-size: 28rpx; }

.pct-track {
  position: relative;
  height: 10rpx;
  background: var(--color-surface-muted);
  border-radius: 5rpx;
  margin: 10rpx 0;
}

.pct-fill {
  position: absolute;
  top: 0;
  height: 100%;
  background: var(--color-brand-tint-legacy);
  border-radius: 5rpx;
}

.pct-dot-node {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 14rpx;
  height: 14rpx;
  background: var(--bg-panel);
  border: 3rpx solid #BFDBFE;
  border-radius: 50%;
}

.pct-dot-mid {
  width: 20rpx;
  height: 20rpx;
  border-color: var(--brand);
  box-shadow: 0 0 6rpx rgba(43, 92, 230, 0.3);
}

/* 鈹€鈹€ 鏌辩姸鍥?鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.chart-section {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1.5rpx solid var(--color-surface-muted);
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 160rpx;
  padding: 0 4rpx;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 3rpx;
}

.bar-fill {
  width: 100%;
  background: var(--color-brand-tint-legacy);
  border-radius: 6rpx 6rpx 0 0;
  min-height: 10rpx;
}

.bar-fill.bar-hl {
  background: var(--brand);
}

.bar-label {
  font-size: 18rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  white-space: nowrap;
}

/* 鈹€鈹€ TC 鎬诲寘 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.tc-section {
  margin-bottom: 28rpx;
  padding-bottom: 28rpx;
  border-bottom: 1.5rpx solid var(--color-surface-muted);
}

.tc-bar-wrap {
  display: flex;
  height: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  gap: 3rpx;
  margin-bottom: 18rpx;
}

.tc-seg { border-radius: 4rpx; height: 100%; }
.seg-base   { background: var(--brand); }
.seg-bonus  { background: var(--color-warning-strong); }
.seg-equity { background: #8B5CF6; }

.tc-legend {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.tc-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tc-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-base   { background: var(--brand); }
.dot-bonus  { background: var(--color-warning-strong); }
.dot-eq     { background: #8B5CF6; }

.tc-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 鈹€鈹€ 甯傚満涓绘祦鍖洪棿 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.market-ref {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  background: var(--color-form-bg);
  border-radius: 14rpx;
  border: 1.5rpx solid rgba(0, 0, 0, 0.05);
}

.ref-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.ref-val {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-success-text);
}

/* 鈹€鈹€ Mock 鎻愮ず 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.mock-banner {
  margin: 0 0 16rpx;
  padding: 14rpx 20rpx;
  background: var(--color-warning-soft);
  border: 1.5rpx solid #FCD34D;
  border-radius: var(--r-sm);
  font-size: 24rpx;
  color: #92400E;
  text-align: center;
}

/* 鈹€鈹€ 閲嶆柊鏌ヨ 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.reset-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  color: var(--brand);
  font-weight: 600;
  background: var(--color-brand-tint-legacy);
  border-radius: 48rpx;
}

/* 鈹€鈹€ 鏁版嵁鏉ユ簮鏍囨敞 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.data-source-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: -16rpx 0 24rpx;
}

.source-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--r-lg);
  font-size: 22rpx;
}

.source-api {
  background: var(--color-success-tint);
  color: #065F46;
}

.source-ref {
  background: var(--color-warning-soft);
  color: #92400E;
}

.source-ai {
  background: #EEF0FF;
  color: #4338CA;
}

.source-community {
  background: #F0FDF4;
  color: #166534;
}

.market-note {
  background: #FAFAFA;
  border-left: 4rpx solid #A5B4FC;
  border-radius: 8rpx;
  padding: 14rpx 20rpx;
  margin: -8rpx 0 24rpx;
}

.market-note-txt {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}

.source-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}

.source-txt {
  font-size: 22rpx;
  font-weight: 500;
}

.share-link {
  padding: 6rpx 16rpx;
}

.share-link-txt {
  font-size: 24rpx;
  color: var(--brand);
  font-weight: 500;
}

/* 鈹€鈹€ 鐢ㄦ埛鍏变韩鏁版嵁鍗＄墖 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.user-stats-card {
  background: linear-gradient(135deg, #F0F9FF, #E0F2FE);
  border: 1.5rpx solid #BAE6FD;
  border-radius: 18rpx;
  padding: 24rpx 24rpx 18rpx;
  margin-bottom: 28rpx;
}

.user-stats-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.user-stats-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #0369A1;
}

.user-stats-count {
  font-size: 22rpx;
  color: #0EA5E9;
  background: #E0F2FE;
  padding: 4rpx 14rpx;
  border-radius: var(--r-lg);
}

.user-stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 16rpx;
}

.user-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.user-stat-divider {
  width: 1.5rpx;
  height: 48rpx;
  background: rgba(3, 105, 161, 0.2);
}

.ust-label {
  font-size: 22rpx;
  color: var(--color-neutral);
}

.ust-val {
  font-size: 28rpx;
  font-weight: 700;
}

.ust-low  { color: #DC2626; }
.ust-avg  { color: #0369A1; }
.ust-high { color: var(--color-success-text); }

.user-stats-note {
  display: block;
  font-size: 20rpx;
  color: var(--color-neutral-muted);
  text-align: center;
}

/* 鐪熷疄鍒嗕綅鐐硅锛圱-7淇锛?*/
.user-pct-row {
  display: flex;
  justify-content: space-around;
  margin: 16rpx 0 8rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid var(--color-surface-muted);
  border-bottom: 1rpx solid var(--color-surface-muted);
}
.user-pct-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.upct-label {
  font-size: 20rpx;
  color: var(--color-neutral-muted);
}
.upct-val {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
}
.upct-highlight {
  color: var(--color-brand);
}

/* 鈹€鈹€ 閭€璇峰垎浜叆鍙?鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.invite-share-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg-panel);
  border: 1.5rpx dashed #BFDBFE;
  border-radius: var(--r-md);
  padding: 20rpx 24rpx;
  margin-top: 20rpx;
}

.invite-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.invite-txt {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-body);
}

.invite-arrow {
  font-size: 28rpx;
  color: var(--brand);
}

/* 鈹€鈹€ 鍒嗕韩钖祫寮圭獥 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 900;
}

.share-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-panel);
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 32rpx 60rpx;
  z-index: 901;
  max-height: 88vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 4rpx 12rpx;
}

.modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 28rpx;
}

.share-form {
  display: flex;
  flex-direction: column;
  gap: 0rpx;
}

.sf-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.sf-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-body);
}

.sf-unit {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 400;
}

.sf-input {
  background: var(--bg-raised);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  border: 1.5rpx solid var(--border);
  height: 88rpx;
  box-sizing: border-box;
}

.modal-notice {
  margin: 4rpx 0 20rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
  background: var(--color-form-bg);
  border-radius: var(--r-sm);
  padding: 14rpx 18rpx;
}

/* modal-submit-btn 鐢?c-button 鎻愪緵鏍峰紡 */

/* 鈹€鈹€ 钖祫娑ㄥ箙瓒嬪娍鍥?鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.trend-section {
  margin-bottom: 28rpx;
  padding-bottom: 28rpx;
  border-bottom: 1.5rpx solid var(--color-surface-muted);
}

.trend-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.trend-summary-badge {
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: var(--r-lg);
}

.badge-up {
  background: var(--color-success-tint);
  color: #065F46;
}

.badge-dn {
  background: var(--color-danger-tint);
  color: #991B1B;
}

.trend-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 4rpx;
}

.trend-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  margin: 0 4rpx;
}

.trend-yoy {
  font-size: 19rpx;
  font-weight: 700;
  min-height: 28rpx;
  line-height: 28rpx;
}

.yoy-up { color: var(--color-success-text); }
.yoy-dn { color: #DC2626; }

.trend-val {
  font-size: 20rpx;
  color: var(--text-secondary);
  font-weight: 500;
  white-space: nowrap;
}

.trend-val-cur {
  color: var(--brand);
  font-weight: 700;
}

.trend-bar-wrap {
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.trend-bar {
  width: 88%;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 12rpx;
}

.tbar-up  { background: linear-gradient(180deg, #60A5FA, #3B82F6); }
.tbar-dn  { background: linear-gradient(180deg, #FCA5A5, #EF4444); }
.tbar-cur { background: linear-gradient(180deg, #818CF8, var(--brand)); box-shadow: 0 4rpx 12rpx rgba(43,92,230,0.35); }

.trend-year {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.trend-year-cur {
  color: var(--brand);
  font-weight: 700;
}

.trend-note {
  display: block;
  font-size: 20rpx;
  color: #C4C9D4;
  margin-top: 16rpx;
  text-align: center;
}

/* 鈹€鈹€ 鍏徃妯悜瀵规瘮闈㈡澘 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.cmp-panel {
  padding: 0 24rpx;
}

/* 杈撳叆鍖哄崱鐗?*/
.cmp-form-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 20rpx 24rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  border: 1.5rpx solid rgba(0,0,0,0.05);
  margin-top: 16rpx;
}

.cmp-row {
  display: flex;
  align-items: center;
  background: #f7faff;
  border-radius: 22rpx;
  padding: 0 16rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(47, 102, 244, 0.1);
  height: 88rpx;
}

.cmp-add-btn {
  flex-shrink: 0;
  background: var(--brand);
  border-radius: var(--r-sm);
  padding: 10rpx 22rpx;
  margin-left: 12rpx;
}

.cmp-add-txt {
  font-size: 26rpx;
  color: var(--bg-panel);
  font-weight: 600;
}

/* 蹇嵎鍏徃鏍囩 */
.cmp-quick-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-top: 4rpx;
}

.cmp-quick-tag {
  font-size: 24rpx;
  color: var(--brand);
  background: var(--color-brand-tint-legacy);
  border: 1.5rpx solid #C7D2FE;
  border-radius: 22rpx;
  padding: 8rpx 20rpx;
  font-weight: 500;
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.cmp-quick-tag:active {
  background: #E0E7FF;
  transform: scale(0.96);
  opacity: 0.86;
}

.cmp-quick-disabled {
  color: var(--text-muted);
  background: var(--bg-raised);
  border-color: var(--border-light);
  pointer-events: none;
}

/* 缁撴灉鍗＄墖 */
.cmp-result-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
  border: 1.5rpx solid rgba(0,0,0,0.05);
  margin-top: 16rpx;
}

.cmp-result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.cmp-clear-btn {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 4rpx 10rpx;
}

/* 姣忓鍏徃涓€琛?*/
.cmp-chart {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cmp-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cmp-label-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.cmp-rank {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--color-surface-muted);
  color: var(--text-secondary);
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cmp-rank-top {
  background: var(--brand);
  color: var(--bg-panel);
}

.cmp-company-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-body);
  flex: 1;
}

.cmp-name-top {
  color: var(--brand);
}

.cmp-estimated-tag {
  font-size: 20rpx;
  color: #D97706;
  background: #FEF3C7;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.cmp-remove {
  font-size: 28rpx;
  color: var(--color-divider-strong);
  padding: 0 4rpx;
}

/* 鏉″舰鍥捐建閬?*/
.cmp-bar-track {
  position: relative;
  height: 16rpx;
  background: #eef3fb;
  border-radius: 999rpx;
  overflow: hidden;
}

/* 钖祫鑼冨洿锛堝崐閫忔槑搴曡壊锛?*/
.cmp-range-bar {
  position: absolute;
  top: 0;
  height: 100%;
  background: rgba(43,92,230,0.12);
  border-radius: var(--r-sm);
}

/* 涓綅鏁版潯锛堝疄鑹诧紝鍙犲湪涓婂眰锛?*/
.cmp-median-bar {
  position: absolute;
  top: 4rpx;
  height: 16rpx;
  background: linear-gradient(90deg, #2f66f4, #17b7a6);
  border-radius: 999rpx;
}

.cmp-bar-top {
  background: linear-gradient(90deg, #818CF8, var(--brand));
  box-shadow: 0 2rpx 8rpx rgba(43,92,230,0.3);
}

/* 鏁板€艰 */
.cmp-val-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cmp-range-txt {
  font-size: 21rpx;
  color: var(--text-muted);
}

.cmp-median-txt {
  font-size: 23rpx;
  font-weight: 700;
  color: var(--text-body);
}

.cmp-median-top {
  color: var(--brand);
}

/* 鍥句緥 */
.cmp-legend {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1.5rpx solid var(--color-surface-muted);
}

.cmp-legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.cmp-legend-dot {
  width: 20rpx;
  height: 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.cmp-dot-range  { background: rgba(43,92,230,0.18); }
.cmp-dot-median { background: linear-gradient(90deg, #818CF8, var(--brand)); }

.cmp-legend-txt {
  font-size: 22rpx;
  color: var(--text-muted);
}

.cmp-unit-note {
  font-size: 21rpx;
  color: #C4C9D4;
  margin-left: auto;
}

/* 绌虹姸鎬?*/
.cmp-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 14rpx;
}

.cmp-empty-icon {
  font-size: 72rpx;
}

.cmp-empty-txt {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-body);
}

.cmp-empty-sub {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 鍔犺浇涓?*/
.cmp-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 鈹€鈹€ VIP 瑙ｉ攣妯爮 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.vip-lock-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, var(--color-warning-soft), #fef3c7);
  border: 1.5rpx solid var(--color-warning-strong);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-top: 16rpx;
}

.vlb-icon {
  font-size: 30rpx;
  flex-shrink: 0;
}

.vlb-txt {
  flex: 1;
  font-size: 24rpx;
  color: #92400e;
  line-height: 1.4;
}

.vlb-btn {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  background: var(--color-warning-strong);
  padding: 8rpx 22rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 鍒嗕綅鐐归攣瀹氭€?*/
.pct-locked {
  opacity: 0.4;
}

.pct-blur {
  letter-spacing: 4rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.form-card,
.cmp-form-card,
.cmp-result-card,
.history-section,
.preset-section,
.result-card,
.percentile-card,
.compare-card {
  margin-left: 24rpx;
  margin-right: 24rpx;
  border: 1rpx solid rgba(37, 72, 133, 0.08);
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  box-shadow: 0 16rpx 38rpx rgba(21, 34, 65, 0.08);
}

.role-card,
.cmp-item,
.history-chip,
.tag-item {
  border-radius: 22rpx;
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.role-card:active,
.cmp-item:active,
.history-chip:active,
.tag-item:active,
.cmp-add-btn:active,
.region-btn:active,
.tab-item:active {
  transform: scale(0.96);
  opacity: 0.86;
}

.share-card,
.share-row,
.share-box {
  border-radius: 24rpx;
  border-color: rgba(47, 102, 244, 0.12);
}

/* ── 汇率换算卡片 ── */
.fx-card {
  margin: 0 24rpx 20rpx;
  background: linear-gradient(135deg, #f0f7ff 0%, #e8f4ff 100%);
  border: 1.5rpx solid #C8DDF6;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
}
.fx-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.fx-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.fx-hint {
  font-size: 22rpx;
  color: var(--text-muted);
}
.fx-body {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.fx-from {
  flex: 1;
  background: #fff;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  text-align: center;
}
.fx-label {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--brand);
  line-height: 1.3;
}
.fx-base-code {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}
.fx-arrow {
  font-size: 32rpx;
  color: var(--brand);
  flex-shrink: 0;
}
.fx-to {
  flex: 1;
  background: #fff;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  text-align: center;
}
.fx-result {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #059669;
  line-height: 1.3;
}
.fx-loading {
  color: var(--text-muted);
  font-size: 26rpx;
  font-weight: 400;
}
.fx-picker {
  margin-top: 8rpx;
}
.fx-picker-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #EEF4FD;
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
}
.fx-target-code {
  font-size: 24rpx;
  color: var(--brand);
  font-weight: 700;
}
.fx-picker-arrow {
  font-size: 18rpx;
  color: var(--brand);
}
