/* pages/project-review/project-review.wxss */
page { background: var(--bg-page); font-family: -apple-system, 'PingFang SC', sans-serif; }

/* Hero */
.hero {
  background: var(--bg-panel);
  padding: 40rpx 28rpx 28rpx;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1.5rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.hero-left { display: flex; flex-direction: column; gap: 6rpx; }
.hero-title { font-size: 40rpx; font-weight: 800; color: var(--text-primary); }
.hero-sub   { font-size: 24rpx; color: var(--text-muted); }
.hero-icon-wrap {
  width: 80rpx; height: 80rpx; background: #FFFBEB;
  border-radius: var(--r-lg);
  display: flex; align-items: center; justify-content: center;
}
.hero-icon { font-size: 40rpx; line-height: 1; }

/* History */
.history-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18rpx 28rpx;
  background: var(--bg-panel);
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}
.hbar-txt   { font-size: 25rpx; color: var(--text-secondary); }
.hbar-arrow { font-size: 20rpx; color: var(--text-muted); }
.history-list { background: var(--bg-panel); padding: 0 24rpx; }
.hist-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0; border-bottom: 1rpx solid #F3F4F6;
}
.hist-item:last-child { border-bottom: none; }
.hist-left  { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; margin-right: 16rpx; }
.hist-date  { font-size: 22rpx; color: var(--text-muted); }
.hist-raw   { font-size: 24rpx; color: var(--text-primary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hist-score-pill {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 800; flex-shrink: 0;
}
.hist-score-pill.good { background: #D1FAE5; color: #059669; }
.hist-score-pill.mid  { background: #FEF3C7; color: #D97706; }
.hist-score-pill.low  { background: #FEE2E2; color: #EF4444; }

/* Input */
.input-wrap  { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.form-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg); padding: 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.form-title  { font-size: 27rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 16rpx; }
.form-item   { margin-bottom: 16rpx; }
.form-item:last-child { margin-bottom: 0; }
.form-label  { font-size: 24rpx; color: var(--text-muted); display: block; margin-bottom: 8rpx; }
.char-count  { font-size: 22rpx; color: var(--text-muted); display: block; text-align: right; margin-top: 6rpx; }
.fi {
  background: #F9FAFB; border: 1.5rpx solid var(--border-light);
  border-radius: 14rpx; padding: 0 20rpx;
  height: 80rpx; font-size: 27rpx; color: var(--text-primary);
  width: 100%; box-sizing: border-box;
}
.fi-ta { height: auto; min-height: 180rpx; padding: 16rpx 20rpx; line-height: 1.7; }
.gen-btn-wrap { padding-bottom: 8rpx; }
.gen-btn { width: 100%; }

/* Loading */
.loading-card {
  margin: 40rpx 24rpx;
  background: var(--bg-panel); border-radius: var(--r-lg);
  padding: 60rpx 32rpx;
  display: flex; flex-direction: column; align-items: center; gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.loading-orb {
  position: relative; width: 120rpx; height: 120rpx;
  display: flex; align-items: center; justify-content: center;
}
.orb-ring {
  position: absolute; border-radius: 50%;
  animation: orb-spin 2s linear infinite;
}
.r1 { width: 120rpx; height: 120rpx; border: 4rpx solid transparent; border-top-color: #F59E0B; }
.r2 { width: 88rpx; height: 88rpx;  border: 4rpx solid transparent; border-top-color: #FCD34D; animation-direction: reverse; animation-duration: 1.5s; }
@keyframes orb-spin { to { transform: rotate(360deg); } }
.orb-icon { font-size: 44rpx; z-index: 1; }
.loading-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); }
.loading-steps { display: flex; align-items: center; gap: 6rpx; flex-wrap: wrap; justify-content: center; }
.lstep {
  font-size: 20rpx; color: var(--text-muted);
  padding: 5rpx 14rpx; border-radius: 50rpx; background: #F3F4F6;
}
.lstep.active { background: #FEF3C7; color: #D97706; font-weight: 700; }
.lstep.done   { background: #D1FAE5; color: #059669; }
.lstep-arr    { font-size: 20rpx; color: var(--text-muted); }

/* Result */
.result-wrap { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 18rpx; }

/* Score */
.score-card {
  background: linear-gradient(135deg, #1E1B4B, #4338CA);
  border-radius: var(--r-lg); padding: 28rpx 24rpx;
  display: flex; justify-content: space-between; align-items: center;
  box-shadow: 0 8rpx 28rpx rgba(67,56,202,0.35);
}
.sc-left   { flex: 1; }
.sc-label  { font-size: 22rpx; color: rgba(255,255,255,0.65); display: block; margin-bottom: 8rpx; }
.sc-comment { font-size: 26rpx; color: #fff; line-height: 1.5; display: block; }
.sc-right  { margin-left: 20rpx; flex-shrink: 0; }
.sc-ring {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center;
}
.sc-ring.green { border-color: #34D399; }
.sc-ring.amber { border-color: #FBBF24; }
.sc-ring.red   { border-color: #F87171; }
.sc-num { font-size: 40rpx; font-weight: 900; color: #fff; line-height: 1; }

/* S/W grid */
.sw-grid { display: flex; gap: 14rpx; }
.sw-card {
  flex: 1; border-radius: var(--r-md); padding: 18rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
}
.sw-card.strengths  { background: #F0FDF4; }
.sw-card.weaknesses { background: #FFF7ED; }
.sw-title  { font-size: 23rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 12rpx; }
.sw-item   { display: flex; gap: 10rpx; align-items: flex-start; margin-bottom: 10rpx; }
.sw-item:last-child { margin-bottom: 0; }
.sw-dot    { width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0; margin-top: 10rpx; }
.green-dot { background: #059669; }
.red-dot   { background: #F97316; }
.sw-txt    { font-size: 22rpx; color: var(--text-body); line-height: 1.6; flex: 1; }

/* Section card */
.section-card {
  background: var(--bg-panel); border-radius: var(--r-lg); padding: 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.sec-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 18rpx; }

/* STAR rows */
.star-row  { display: flex; gap: 14rpx; padding: 12rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.star-row:last-child { border-bottom: none; padding-bottom: 0; }
.star-lbl  { width: 44rpx; height: 44rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 900; flex-shrink: 0; margin-top: 2rpx; }
.s-lbl { background: #EEF2FF; color: #4F46E5; }
.t-lbl { background: #D1FAE5; color: #059669; }
.a-lbl { background: #FEF3C7; color: #D97706; }
.r-lbl { background: #FEE2E2; color: #DC2626; }
.star-body { flex: 1; }
.star-name { font-size: 21rpx; color: var(--text-muted); display: block; margin-bottom: 4rpx; }
.star-txt  { font-size: 25rpx; color: var(--text-body); line-height: 1.6; display: block; }

/* Metrics */
.metric-item { display: flex; gap: 12rpx; align-items: flex-start; margin-bottom: 12rpx; }
.metric-item:last-child { margin-bottom: 0; }
.metric-icon { font-size: 26rpx; flex-shrink: 0; margin-top: 2rpx; }
.metric-txt  { font-size: 25rpx; color: var(--text-body); line-height: 1.6; flex: 1; }

/* Rewrite */
.rewrite-card { background: linear-gradient(to bottom right, #FAFAF7, #F0FDF4); border-color: #BBF7D0; }
.rewrite-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.rewrite-header .sec-title { margin-bottom: 0; }
.copy-btn { font-size: 24rpx; color: var(--brand); font-weight: 600; }
.rewrite-body { font-size: 26rpx; color: var(--text-body); line-height: 1.8; display: block; }

/* Bullets */
.bullet-item { display: flex; gap: 12rpx; align-items: flex-start; margin-bottom: 12rpx; }
.bullet-item:last-child { margin-bottom: 0; }
.bullet-dot  { font-size: 28rpx; color: var(--brand); flex-shrink: 0; line-height: 1.6; }
.bullet-txt  { font-size: 25rpx; color: var(--text-body); line-height: 1.6; flex: 1; }

/* Result actions */
.result-actions { display: flex; gap: 16rpx; }
.result-actions c-button { flex: 1; }
