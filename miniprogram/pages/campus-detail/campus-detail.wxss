/* pages/campus-detail/campus-detail.wxss — Linear Dark Theme */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* 加载 */
.loading-page {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  height: 100vh; gap: 24rpx;
}
.loading-txt { font-size: 28rpx; color: var(--text-muted); }
.spinner {
  width: 56rpx; height: 56rpx;
  border: 5rpx solid rgba(0,0,0,0.04); border-top-color: var(--brand);
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ════ 头部横幅 ════ */
.hero {
  background: var(--bg-panel);
  padding: 44rpx 24rpx 28rpx;
  border-bottom: 1.5rpx solid rgba(0,0,0,0.05);
}
.hero-inner { display: flex; align-items: flex-start; gap: 20rpx; }
.logo-wrap { flex-shrink: 0; }
.logo-img {
  width: 104rpx; height: 104rpx; border-radius: var(--r-lg);
  border: 2rpx solid rgba(255,255,255,0.12);
  background: rgba(0,0,0,0.04);
}
.logo-placeholder {
  width: 104rpx; height: 104rpx; border-radius: var(--r-lg);
  background: rgba(94,106,210,0.20);
  border: 2rpx solid rgba(94,106,210,0.35);
  display: flex; align-items: center; justify-content: center;
}
.logo-char { font-size: 34rpx; font-weight: 800; color: #6366F1; }
.hero-info { flex: 1; min-width: 0; }
.hero-name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.hero-company { font-size: 34rpx; font-weight: 700; color: var(--text-primary); line-height: 1.3; flex: 1; }
.hot-dot {
  font-size: 19rpx; font-weight: 800; color: var(--bg-panel);
  background: var(--danger);
  padding: 3rpx 10rpx; border-radius: 8rpx; flex-shrink: 0;
}
.hero-position { display: block; font-size: 26rpx; color: var(--text-muted); margin-bottom: 14rpx; }
.hero-badges { display: flex; flex-wrap: wrap; gap: 8rpx; }
.badge {
  font-size: 22rpx; font-weight: 500;
  padding: 5rpx 14rpx; border-radius: 10rpx;
  border: 1rpx solid transparent;
}
.grad-badge {
  background: rgba(0,0,0,0.04);
  color: var(--text-muted);
  border-color: rgba(255,255,255,0.10);
}

/* ════ 关键信息卡 ════ */
.info-card {
  background: var(--bg-panel); margin: 14rpx 16rpx 0;
  border-radius: var(--r-lg); padding: 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
}
.kv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx 24rpx; }
.kv-item { display: flex; flex-direction: column; gap: 6rpx; }
.kv-key { font-size: 22rpx; color: var(--text-muted); }
.kv-val { font-size: 27rpx; color: var(--text-secondary); font-weight: 500; line-height: 1.4; }
.kv-val.urgent { color: var(--danger); }

/* ════ 通用卡片 ════ */
.section-card {
  background: var(--bg-panel); margin: 14rpx 16rpx 0;
  border-radius: var(--r-lg); padding: 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
}
.section-title {
  display: flex; align-items: center; gap: 10rpx;
  font-size: 28rpx; font-weight: 700; color: var(--text-primary);
  margin-bottom: 18rpx;
}
.section-icon { font-size: 28rpx; }
.notes-txt { font-size: 27rpx; color: var(--text-muted); line-height: 1.75; display: block; }

/* 投递链接 */
.link-row { margin-bottom: 14rpx; }
.link-label { display: block; font-size: 23rpx; color: var(--text-muted); margin-bottom: 6rpx; }
.link-url {
  display: block; font-size: 24rpx; color: var(--brand);
  word-break: break-all; line-height: 1.5;
}
.copy-btn {
  display: block; text-align: center; margin-top: 18rpx;
  background: #EEF2FF; color: var(--brand);
  font-size: 28rpx; font-weight: 600;
  padding: 18rpx; border-radius: var(--r-sm);
  border: 1.5rpx solid rgba(94,106,210,0.25);
}

/* 数据来源 */
.source-bar {
  margin: 14rpx 16rpx 0; padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.03); border-radius: 14rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
}
.source-txt { font-size: 22rpx; color: var(--text-muted); }

/* ════ 截止提醒卡 ════ */
.remind-card {
  display: flex; align-items: center; justify-content: space-between;
  margin: 14rpx 16rpx 0;
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 22rpx 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  gap: 16rpx;
}
.remind-card:active { opacity: 0.75; }
.remind-left { display: flex; align-items: center; gap: 16rpx; flex: 1; min-width: 0; }
.remind-icon { font-size: 36rpx; flex-shrink: 0; }
.remind-info { flex: 1; min-width: 0; }
.remind-title { display: block; font-size: 27rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 4rpx; }
.remind-sub   { display: block; font-size: 22rpx; color: var(--text-muted); }
.remind-action {
  flex-shrink: 0;
  font-size: 25rpx; font-weight: 600;
  color: var(--brand);
  background: #EEF2FF;
  padding: 10rpx 24rpx;
  border-radius: 9999rpx;
  border: 1.5rpx solid rgba(94,106,210,0.25);
}
.remind-action.subscribed {
  color: #059669;
  background: #ECFDF5;
  border-color: #A7F3D0;
}

/* ════ 底部投递按钮 ════ */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; width: 100%;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--bg-panel);
  border-top: 1.5rpx solid rgba(0,0,0,0.06);
  box-sizing: border-box;
}
.bottom-actions {
  display: flex;
  gap: 16rpx;
}
.collect-btn {
  min-width: 180rpx;
  text-align: center;
  background: #EEF2FF;
  color: var(--brand);
  font-size: 30rpx;
  font-weight: 700;
  padding: 24rpx 0;
  border-radius: 9999rpx;
}
.collect-btn.collected {
  background: #DBEAFE;
  color: #1D4ED8;
}
.apply-btn {
  flex: 1;
  display: block; text-align: center;
  background: var(--brand);
  color: var(--bg-panel); font-size: 32rpx; font-weight: 700;
  padding: 24rpx 0; border-radius: 9999rpx;
}
