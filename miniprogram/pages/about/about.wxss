/* pages/about/about.wxss — Premium Redesign */
page {
  background: #F2F4F8;
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container { padding: 0 24rpx 40rpx; }

/* Logo section */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72rpx 0 48rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #0D1B3E, var(--brand));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(43,92,230,0.35);
}

.app-logo {
  width: 96rpx;
  height: 96rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #0F172A;
  margin-bottom: 8rpx;
}

.app-version {
  font-size: 24rpx;
  color: var(--text-muted);
  background: #F3F4F6;
  padding: 5rpx 18rpx;
  border-radius: var(--r-lg);
}

/* Cards */
.intro-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1.5rpx solid #F1F3F7;
}

.intro-text {
  font-size: 27rpx;
  color: var(--text-secondary);
  line-height: 1.75;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
  padding: 0 0 16rpx;
  padding-left: 18rpx;
  border-left: 6rpx solid var(--brand);
  margin-bottom: 16rpx;
}

.feature-list {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 8rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1.5rpx solid #F1F3F7;
  overflow: hidden;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--bg-raised);
}

.feature-item:last-child { border-bottom: none; }

.feature-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  border-radius: var(--r-md);
}

.feature-info { flex: 1; }

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
  display: block;
  margin-bottom: 5rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
}

.contact-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1.5rpx solid #F1F3F7;
}

.contact-label {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.contact-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.contact-value {
  font-size: 28rpx;
  color: var(--brand);
  font-weight: 600;
}

.copy-hint {
  font-size: 22rpx;
  color: #C4C9D4;
}

.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  font-size: 22rpx;
  color: #C4C9D4;
  line-height: 1.9;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Profile entry page polish */
.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.logo-section {
  margin-bottom: 22rpx;
  padding: 46rpx 28rpx 40rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(20,184,166,0.10), transparent 34%),
    linear-gradient(135deg, rgba(255,255,255,0.98), rgba(241,248,255,0.98));
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 16rpx 42rpx rgba(32,48,70,0.07);
}

.app-logo {
  width: 116rpx;
  height: 116rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  box-shadow: 0 16rpx 34rpx rgba(37,99,235,0.18);
  box-sizing: border-box;
}

.app-name {
  margin-top: 20rpx;
  color: #111827;
  font-size: 38rpx;
}

.app-version {
  color: #1d4ed8;
  background: #eef4ff;
}

.intro-card,
.feature-list,
.contact-card {
  border-radius: 24rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.section-title {
  border-left: 0;
  padding-left: 0;
  color: #111827;
  font-size: 30rpx;
  font-weight: 950;
}

.feature-icon {
  border-radius: 18rpx;
  background: #eef4ff;
}

.feature-title {
  color: #111827;
}

.feature-desc,
.intro-text,
.contact-label,
.copyright {
  color: #667085;
}

.copy-hint {
  color: #2563eb;
}
