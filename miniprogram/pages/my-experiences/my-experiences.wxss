/* pages/my-experiences/my-experiences.wxss */
page {
  background: var(--bg-raised);
  font-family: -apple-system, sans-serif;
}

/* --- 1. 顶部固定区 --- */
.header-fixed {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background: var(--bg-panel);
  z-index: 99;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03);
}

.search-bar {
  padding: 20rpx 30rpx;
  background-color: var(--bg-panel);
}
.search-box {
  background: var(--bg-raised);
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}
.search-box icon { margin-right: 12rpx; }
.search-box input { flex: 1; font-size: 28rpx; color: var(--text-body); }
.ph { color: var(--text-muted); }

.tabs {
  display: flex;
  background: var(--bg-panel);
  border-bottom: 1rpx solid #eee;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: var(--text-secondary);
  padding: 24rpx 0;
  position: relative;
}
.tab.active {
  color: var(--brand);
  font-weight: bold;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--brand);
  border-radius: 4rpx;
}

/* --- 2. 列表区域 --- */
.list-container {
  padding: 24rpx 30rpx;
}

.article-card {
  background: var(--bg-panel);
  padding: 28rpx;
  border-radius: var(--r-lg);
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.article-card:active {
  background: #fafbfc;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.author-info { display: flex; align-items: center; }
.avatar { width: 40rpx; height: 40rpx; border-radius: 50%; margin-right: 12rpx; }
.author-name { font-size: 24rpx; color: var(--text-secondary); font-weight: 500; }
.type-badge {
  font-size: 20rpx;
  color: var(--brand);
  background: #eef4fd;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 12rpx;
}
.post-date { font-size: 22rpx; color: #D1D5DB; }

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
  display: block;
  line-height: 1.4;
}
.summary {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.tags-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.tag {
  font-size: 22rpx;
  color: var(--brand);
  background: #eef4fd;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  border-top: 1rpx solid #F1F3F7;
  padding-top: 20rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}
.stat-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
}
.stat-num { font-weight: 600; color: var(--text-secondary); margin-right: 4rpx; }
.more-action { margin-left: auto; color: #D1D5DB; font-size: 22rpx; }

.footer-tip { text-align: center; color: #D1D5DB; font-size: 24rpx; margin-top: 20rpx; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
}
.empty-img { width: 120rpx; height: 120rpx; margin-bottom: 30rpx; opacity: 0.4; }
.empty-main { font-size: 30rpx; color: var(--text-secondary); font-weight: 600; margin-bottom: 10rpx; }
.empty-sub { font-size: 26rpx; color: var(--text-muted); margin-bottom: 40rpx; }
.empty-btn {
  font-size: 28rpx;
  color: var(--brand);
  background: var(--bg-panel);
  border: 2rpx solid var(--brand);
  border-radius: 40rpx;
  padding: 14rpx 50rpx;
}

/* --- 3. 悬浮按钮组 --- */
.fab-group {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}
.fab-btn-ai {
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #6c5ce7, #a855f7);
  border-radius: 50%;
  box-shadow: 0 8rpx 20rpx rgba(108,92,231,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}
.fab-btn-ai.disabled { opacity: 0.5; }
.fab-btn-ai:active { transform: scale(0.9); }
.fab-text { color: #fff; font-size: 28rpx; font-weight: bold; }
.fab-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
  border-radius: 50%;
  box-shadow: 0 8rpx 20rpx rgba(74,144,226,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}
.fab-btn:active { transform: scale(0.9); }
.plus { color: #fff; font-size: 60rpx; font-weight: 200; margin-top: -8rpx; }

/* --- 4. 发布弹窗 --- */
.publish-modal {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  box-sizing: border-box;
}

.publish-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.publish-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.close-btn {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 10rpx;
  line-height: 1;
}

.publish-form {
  flex: 1;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  background: var(--bg-raised);
  border-radius: var(--r-sm);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-body);
}

.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #D1D5DB;
  font-size: 24rpx;
}

.form-textarea {
  background: var(--bg-raised);
  border-radius: var(--r-sm);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-body);
  width: 100%;
  min-height: 200rpx;
  box-sizing: border-box;
}

.char-hint {
  font-size: 22rpx;
  color: #D1D5DB;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

/* submit-btn 由 c-button 提供样式，仅保留外部边距 */
.submit-btn { margin-top: 16rpx; }
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Profile entry page polish */
.header-fixed {
  background: rgba(255,255,255,0.94);
  border-bottom: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.055);
}

.search-bar {
  padding: 18rpx 28rpx 12rpx;
  background: transparent;
}

.search-box {
  height: 72rpx;
  border-radius: 22rpx;
  background: #f8fbff;
  border: 1rpx solid rgba(220,229,240,0.96);
}

.tabs {
  margin: 0 28rpx 14rpx;
  padding: 8rpx;
  gap: 8rpx;
  border-radius: 22rpx;
  background: #f1f5f9;
  border-bottom: 0;
}

.tab {
  padding: 16rpx 0;
  border-radius: 16rpx;
  color: #64748b;
  font-size: 26rpx;
  font-weight: 850;
}

.tab.active {
  color: #1d4ed8;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(32,48,70,0.06);
}

.tab.active::after {
  display: none;
}

.list-container {
  padding: 22rpx 24rpx 48rpx;
}

.article-card {
  border-radius: 24rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.title {
  color: #111827;
  font-weight: 900;
}

.summary,
.post-date,
.stat-item {
  color: #667085;
}

.tag {
  color: #1d4ed8;
  background: #eef4ff;
  border-color: #d8e7ff;
}

.fab-btn,
.fab-btn-ai {
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  box-shadow: 0 14rpx 28rpx rgba(37,99,235,0.22);
}

/* My experiences workspace polish */
.container {
  min-height: 100vh;
  padding: 22rpx 24rpx 52rpx;
  box-sizing: border-box;
}

.experience-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 58%, #ecfffb 100%);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.08);
}

.hero-kicker,
.hero-title,
.hero-sub,
.count-num,
.count-label,
.stat-num,
.stat-label,
.empty-main,
.empty-sub {
  display: block;
}

.hero-kicker {
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 8rpx;
  color: #101828;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 950;
}

.hero-sub {
  width: 430rpx;
  max-width: 100%;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.hero-count {
  width: 122rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(145deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 18rpx 34rpx rgba(37,99,235,0.22);
  flex-shrink: 0;
}

.count-num {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 950;
}

.count-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 800;
  opacity: 0.88;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin: 16rpx 0;
}

.stat-card {
  min-height: 106rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.055);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-num {
  color: #111827;
  font-size: 32rpx;
  font-weight: 950;
}

.stat-label {
  margin-top: 8rpx;
  color: #718096;
  font-size: 22rpx;
  font-weight: 800;
}

.header-fixed {
  position: static;
  width: auto;
  margin: 0;
  border-radius: 28rpx;
  overflow: hidden;
}

.search-bar {
  padding: 18rpx 18rpx 10rpx;
}

.tabs {
  margin: 0 18rpx 18rpx;
}

.tab {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-count {
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  color: #8aa0bd;
  background: #f3f7ff;
  font-size: 18rpx;
  line-height: 28rpx;
  font-weight: 900;
}

.tab.active .tab-count {
  color: #fff;
  background: #2563eb;
}

.list-container {
  padding: 18rpx 0 90rpx;
}

.article-card {
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.empty-state {
  margin-top: 46rpx;
  padding: 76rpx 36rpx 38rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.07);
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f7ff;
  font-size: 52rpx;
  box-shadow: inset 0 0 0 1rpx rgba(37,99,235,0.08);
}

.empty-main {
  margin-top: 24rpx;
  color: #111827;
  font-size: 31rpx;
  font-weight: 950;
}

.empty-sub {
  width: 540rpx;
  max-width: 100%;
  margin-top: 14rpx;
  color: #718096;
  font-size: 25rpx;
  line-height: 1.62;
  text-align: center;
}

.empty-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 34rpx;
}

.empty-btn {
  min-width: 176rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  color: #2563eb;
  background: #f3f7ff;
  border: 1rpx solid rgba(37,99,235,0.12);
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
}

.empty-btn.primary {
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 12rpx 26rpx rgba(37,99,235,0.22);
}

.empty-tips {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 34rpx;
}

.tip-item {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #667085;
  background: #f8fbff;
  font-size: 22rpx;
  font-weight: 750;
}

.fab-group {
  right: 32rpx;
  bottom: 54rpx;
}

.fab-btn-ai,
.fab-btn {
  width: 92rpx;
  height: 92rpx;
}
