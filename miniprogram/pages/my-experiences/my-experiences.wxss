/* pages/my-experiences/my-experiences.wxss */
page {
  background: var(--bg-raised);
  font-family: -apple-system, sans-serif;
}

/* --- 1. 顶部固定区 --- */
.header-fixed {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background: var(--bg-panel);
  z-index: 99;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03);
}

.search-bar {
  padding: 20rpx 30rpx;
  background-color: var(--bg-panel);
}
.search-box {
  background: var(--bg-raised);
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}
.search-box icon { margin-right: 12rpx; }
.search-box input { flex: 1; font-size: 28rpx; color: var(--text-body); }
.ph { color: var(--text-muted); }

.tabs {
  display: flex;
  background: var(--bg-panel);
  border-bottom: 1rpx solid #eee;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: var(--text-secondary);
  padding: 24rpx 0;
  position: relative;
}
.tab.active {
  color: var(--brand);
  font-weight: bold;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--brand);
  border-radius: 4rpx;
}

/* --- 2. 列表区域 --- */
.list-container {
  padding: 24rpx 30rpx;
}

.article-card {
  background: var(--bg-panel);
  padding: 28rpx;
  border-radius: var(--r-lg);
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.article-card:active {
  background: #fafbfc;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.author-info { display: flex; align-items: center; }
.avatar { width: 40rpx; height: 40rpx; border-radius: 50%; margin-right: 12rpx; }
.author-name { font-size: 24rpx; color: var(--text-secondary); font-weight: 500; }
.type-badge {
  font-size: 20rpx;
  color: var(--brand);
  background: #eef4fd;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 12rpx;
}
.post-date { font-size: 22rpx; color: #D1D5DB; }

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
  display: block;
  line-height: 1.4;
}
.summary {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.tags-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.tag {
  font-size: 22rpx;
  color: var(--brand);
  background: #eef4fd;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  border-top: 1rpx solid #F1F3F7;
  padding-top: 20rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}
.stat-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
}
.stat-num { font-weight: 600; color: var(--text-secondary); margin-right: 4rpx; }
.more-action { margin-left: auto; color: #D1D5DB; font-size: 22rpx; }

.footer-tip { text-align: center; color: #D1D5DB; font-size: 24rpx; margin-top: 20rpx; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
}
.empty-img { width: 120rpx; height: 120rpx; margin-bottom: 30rpx; opacity: 0.4; }
.empty-main { font-size: 30rpx; color: var(--text-secondary); font-weight: 600; margin-bottom: 10rpx; }
.empty-sub { font-size: 26rpx; color: var(--text-muted); margin-bottom: 40rpx; }
.empty-btn {
  font-size: 28rpx;
  color: var(--brand);
  background: var(--bg-panel);
  border: 2rpx solid var(--brand);
  border-radius: 40rpx;
  padding: 14rpx 50rpx;
}

/* --- 3. 悬浮按钮组 --- */
.fab-group {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}
.fab-btn-ai {
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #6c5ce7, #a855f7);
  border-radius: 50%;
  box-shadow: 0 8rpx 20rpx rgba(108,92,231,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}
.fab-btn-ai.disabled { opacity: 0.5; }
.fab-btn-ai:active { transform: scale(0.9); }
.fab-text { color: #fff; font-size: 28rpx; font-weight: bold; }
.fab-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
  border-radius: 50%;
  box-shadow: 0 8rpx 20rpx rgba(74,144,226,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}
.fab-btn:active { transform: scale(0.9); }
.plus { color: #fff; font-size: 60rpx; font-weight: 200; margin-top: -8rpx; }

/* --- 4. 发布弹窗 --- */
.publish-modal {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  box-sizing: border-box;
}

.publish-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.publish-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.close-btn {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 10rpx;
  line-height: 1;
}

.publish-form {
  flex: 1;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  background: var(--bg-raised);
  border-radius: var(--r-sm);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-body);
}

.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #D1D5DB;
  font-size: 24rpx;
}

.form-textarea {
  background: var(--bg-raised);
  border-radius: var(--r-sm);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-body);
  width: 100%;
  min-height: 200rpx;
  box-sizing: border-box;
}

.char-hint {
  font-size: 22rpx;
  color: #D1D5DB;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

/* submit-btn 由 c-button 提供样式，仅保留外部边距 */
.submit-btn { margin-top: 16rpx; }
