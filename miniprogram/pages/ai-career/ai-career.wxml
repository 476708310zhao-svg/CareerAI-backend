<view class="page">
  <c-ai-disclosure text="AI 会读取有限求职画像和当前申请；敏感信息会脱敏，任何写操作都必须再次确认。" />
  <view class="hero">
    <text class="eyebrow">FOUR SPECIALIST AGENTS</text>
    <text class="title">AI Career</text>
    <text class="subtitle">岗位、申请、面试与职业规划统一入口</text>
    <view class="hero-links">
      <view bindtap="openMaterials">申请材料</view>
      <view bindtap="openInterviews">面试空间</view>
      <view bindtap="openAssistant">通用咨询</view>
    </view>
  </view>

  <view wx:if="{{loginRequired}}" class="state-card">
    <text class="state-icon">🔐</text>
    <text class="state-title">登录后使用 AI Career</text>
    <text class="state-desc">登录后 Agent 才能读取你的画像、申请上下文和历史任务。</text>
    <view class="primary-button" bindtap="goProfile">前往登录</view>
  </view>

  <view wx:elif="{{pageLoading}}" class="state-card"><view class="spinner"></view><text>正在准备 Agent…</text></view>
  <view wx:elif="{{error}}" class="state-card"><text class="state-title">暂时无法加载</text><text class="state-desc">{{error}}</text><view class="primary-button" bindtap="retryPage">重新加载</view></view>

  <block wx:else>
    <scroll-view scroll-x class="agent-scroll" enhanced show-scrollbar="{{false}}">
      <view class="agent-row">
        <view wx:for="{{agents}}" wx:key="code" class="agent {{selectedAgent===item.code?'active':''}}" data-code="{{item.code}}" bindtap="selectAgent">
          <text class="agent-name">{{item.name}}</text>
          <text class="agent-desc">{{item.desc}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="composer">
      <picker wx:if="{{applications.length}}" range="{{applications}}" range-key="jobTitle" value="{{applicationIndex}}" bindchange="onApplicationChange">
        <view class="field">
          <text class="field-label">当前申请</text>
          <text>{{applications[applicationIndex].company}} · {{applications[applicationIndex].jobTitle}}</text>
          <text class="chevron">⌄</text>
        </view>
      </picker>
      <view wx:else class="field muted"><text>未关联申请，将仅使用求职画像回答</text></view>
      <textarea class="query" maxlength="2000" placeholder="例如：结合当前申请，告诉我本周最应该先补哪三项？" value="{{query}}" bindinput="onQuery" />
      <view class="write-toggle {{requestWrite?'on':''}}" bindtap="toggleWrite">
        <view class="checkbox">{{requestWrite?'✓':''}}</view>
        <view><text class="toggle-title">允许提出写操作</text><text class="toggle-desc">仍需你在结果页再次确认后才会写入</text></view>
      </view>
      <view class="run {{loading?'disabled':''}}" bindtap="runAgent">{{loading?'Agent 处理中…':'运行 Agent'}}</view>
    </view>

    <view class="section-head"><text class="section-title">任务历史</text><text class="section-count">{{tasks.length}} 条</text></view>
    <view wx:if="{{tasks.length===0}}" class="empty-history">完成第一次咨询后，结果会保存在这里。</view>
    <view wx:for="{{tasks}}" wx:key="id" class="task" data-id="{{item.id}}" bindtap="openTask" hover-class="task-hover">
      <view class="task-copy"><text class="task-name">{{item.agentName}}</text><text class="task-answer">{{item.answer || '任务正在处理中'}}</text><text class="task-time">{{item.createdAt}}</text></view>
      <text class="status status-{{item.status}}">{{item.statusText}}</text>
    </view>
  </block>

  <view wx:if="{{currentTask}}" class="mask" bindtap="closeTask"></view>
  <view wx:if="{{currentTask}}" class="sheet">
    <view class="sheet-handle"></view>
    <text class="sheet-title">{{currentTask.agentName}}</text>
    <text class="meta">{{currentTask.aiModel}} · {{currentTask.promptVersion}}</text>
    <text class="answer">{{currentTask.answer || '任务正在处理中，请稍后刷新。'}}</text>
    <view class="actions">
      <view wx:if="{{currentTask.status==='failed'}}" class="secondary-action" bindtap="retryTask">重试</view>
      <view wx:if="{{currentTask.status==='awaiting_confirmation'}}" class="secondary-action" bindtap="cancelTask">取消</view>
      <view wx:if="{{currentTask.status==='awaiting_confirmation'}}" class="confirm" bindtap="confirmWrite">确认执行写操作</view>
    </view>
  </view>
</view>
