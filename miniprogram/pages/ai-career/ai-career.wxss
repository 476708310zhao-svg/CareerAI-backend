.page{min-height:100vh;box-sizing:border-box;background:#f5f7fb;color:#101828;padding:22rpx 28rpx 190rpx}.hero{margin-top:18rpx;padding:38rpx;border-radius:30rpx;background:linear-gradient(135deg,#101828,#3130a8 62%,#6554d9);color:#fff;box-shadow:0 22rpx 46rpx rgba(49,48,168,.2)}.eyebrow{display:block;font-size:19rpx;letter-spacing:3rpx;opacity:.62}.title{display:block;font-size:52rpx;font-weight:900;margin-top:10rpx}.subtitle{display:block;font-size:24rpx;opacity:.82;margin-top:8rpx}.hero-links{display:flex;gap:12rpx;margin-top:28rpx}.hero-links view{padding:13rpx 18rpx;border:1rpx solid rgba(255,255,255,.24);border-radius:999rpx;background:rgba(255,255,255,.1);font-size:20rpx}.agent-scroll{width:100%;margin:24rpx 0}.agent-row{display:flex;gap:14rpx;width:max-content;padding-right:28rpx}.agent{width:260rpx;box-sizing:border-box;padding:22rpx;border-radius:20rpx;background:#fff;border:1rpx solid #e8ecf3}.agent.active{background:#101828;border-color:#101828;color:#fff}.agent-name,.agent-desc{display:block}.agent-name{font-size:25rpx;font-weight:850}.agent-desc{font-size:20rpx;line-height:1.5;margin-top:8rpx;color:#667085}.agent.active .agent-desc{color:rgba(255,255,255,.68)}.composer,.task{background:#fff;border-radius:24rpx;border:1rpx solid #e8ecf3}.composer{padding:26rpx}.field{position:relative;display:flex;flex-direction:column;padding:18rpx 42rpx 18rpx 20rpx;border-radius:16rpx;background:#f7f9fc;font-size:23rpx;color:#344054}.field.muted{color:#98a2b3}.field-label{color:#98a2b3;font-size:19rpx;margin-bottom:5rpx}.chevron{position:absolute;right:18rpx;top:30rpx}.query{box-sizing:border-box;width:100%;height:230rpx;margin-top:16rpx;padding:20rpx;border-radius:16rpx;background:#f7f9fc;font-size:24rpx;line-height:1.65}.write-toggle{display:flex;align-items:center;gap:14rpx;margin:18rpx 0;color:#667085}.checkbox{width:38rpx;height:38rpx;border-radius:10rpx;border:2rpx solid #cfd6e4;display:flex;align-items:center;justify-content:center}.write-toggle.on .checkbox{background:#4338ca;border-color:#4338ca;color:#fff}.toggle-title,.toggle-desc{display:block}.toggle-title{font-size:22rpx;font-weight:750}.toggle-desc{font-size:19rpx;color:#98a2b3;margin-top:3rpx}.run{padding:22rpx;border-radius:16rpx;background:#4338ca;color:#fff;text-align:center;font-size:25rpx;font-weight:850}.run.disabled{opacity:.55}.section-head{display:flex;align-items:center;justify-content:space-between;margin:30rpx 2rpx 16rpx}.section-title{font-size:30rpx;font-weight:900}.section-count{font-size:20rpx;color:#98a2b3}.task{display:flex;justify-content:space-between;gap:18rpx;padding:24rpx;margin-bottom:14rpx}.task-hover{opacity:.84}.task-copy{flex:1;min-width:0}.task-name,.task-answer,.task-time{display:block}.task-name{font-size:24rpx;font-weight:800}.task-answer{margin-top:8rpx;color:#475467;font-size:22rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.task-time{color:#98a2b3;font-size:19rpx;margin-top:9rpx}.status{align-self:flex-start;padding:8rpx 12rpx;border-radius:999rpx;background:#eef2ff;color:#4338ca;font-size:18rpx}.status-completed{background:#eafbf3;color:#087a55}.status-failed{background:#fff0f0;color:#c02626}.status-awaiting_confirmation{background:#fff6e8;color:#b54708}.empty-history,.state-card{padding:56rpx 30rpx;border-radius:24rpx;background:#fff;text-align:center;color:#667085;border:1rpx solid #e8ecf3}.state-card{margin-top:24rpx}.state-card text{display:block}.state-icon{font-size:54rpx}.state-title{font-size:29rpx;font-weight:850;color:#101828;margin-top:16rpx}.state-desc{font-size:22rpx;line-height:1.6;margin-top:10rpx}.primary-button{display:inline-flex;padding:19rpx 32rpx;margin-top:24rpx;border-radius:15rpx;background:#4338ca;color:#fff;font-weight:800}.spinner{width:46rpx;height:46rpx;margin:0 auto 18rpx;border:5rpx solid #e8ecf3;border-top-color:#4338ca;border-radius:50%;animation:spin .8s linear infinite}.mask{position:fixed;inset:0;background:rgba(16,24,40,.52);z-index:10000}.sheet{position:fixed;z-index:10001;le