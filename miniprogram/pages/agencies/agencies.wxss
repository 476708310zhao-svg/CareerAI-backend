/* pages/agencies/agencies.wxss йИ•?Linear Dark Theme */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* йИєвВђйИєвВђ йН•еУДзХЊжЊґжТЃеДі йИєвВђйИєвВђ */
.fixed-header {
  box-shadow: 0 12rpx 34rpx rgba(15,23,42,0.06);
  position: fixed;
  top: 0; left: 0;
  width: 100%;
  z-index: 100;
  background: rgba(255,255,255,0.96);
  border-bottom: 1rpx solid rgba(148,163,184,0.12);
  padding-top: env(safe-area-inset-top);
}

/* йИєвВђйИєвВђ зїЂиѓ≤зАЈ Tab йИєвВђйИєвВђ */
.type-scroll { width: 100%; }
.type-inner {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx 12rpx;
  white-space: nowrap;
}
.type-pill {
  box-shadow: inset 0 -2rpx 0 rgba(15,23,42,0.02);
  font-weight: 700;
  justify-content: center;
  align-items: center;
  display: inline-flex;
  height: 56rpx;
  min-width: 92rpx;
  font-size: 25rpx;
  color: #7b8797;
  background: #f8fafc;
  padding: 0 24rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  border: 1.5rpx solid rgba(148,163,184,0.16);
}
.type-pill.active {
  box-shadow: 0 10rpx 24rpx rgba(43,92,230,0.12);
  background: linear-gradient(135deg, #eef4ff, #ffffff);
  color: #1d4ed8;
  border-color: rgba(43,92,230,0.28);
  font-weight: 600;
}

/* йИєвВђйИєвВђ йОЉжїЕеВ®йПН?йИєвВђйИєвВђ */
.search-bar { padding: 0 20rpx 14rpx; }
.search-wrap {
  box-shadow: 0 10rpx 26rpx rgba(15,23,42,0.045);
  display: flex;
  align-items: center;
  height: 76rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 0 22rpx;
  gap: 12rpx;
  border: 1.5rpx solid rgba(148,163,184,0.18);
}
.search-input {
  font-weight: 600;
  flex: 1;
  font-size: 27rpx;
  color: var(--text-primary);
  height: 74rpx;
  line-height: 74rpx;
}
.ph { color: var(--text-muted); font-size: 27rpx; }
.search-clear {
  color: #64748b;
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: #eef2f7;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: var(--text-muted); line-height: 40rpx; text-align: center;
}

/* йИєвВђйИєвВђ еЃЄгГ•еПњйПНењЪоФС йИєвВђйИєвВђ */
.toolbar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 22rpx 18rpx;
  gap: 12rpx;
}
.sort-btn {
  box-shadow: 0 8rpx 18rpx rgba(15,23,42,0.04);
  min-height: 52rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #ffffff;
  border: 1.5rpx solid rgba(148,163,184,0.16);
  border-radius: 22rpx;
  padding: 0 20rpx;
  flex-shrink: 0;
}
.sort-label { font-size: 25rpx; color: var(--text-secondary); font-weight: 500; }
.sort-arrow { font-size: 19rpx; color: var(--text-muted); }
.stat-center {
  min-width: 0;
  flex: 1;
  display: flex; align-items: center; justify-content: center; gap: 6rpx;
}
.stat-txt { font-size: 24rpx; color: var(--text-muted); }
.stat-kw  { font-size: 24rpx; color: var(--brand); font-weight: 500; }
.compare-toggle {
  box-shadow: 0 8rpx 18rpx rgba(15,23,42,0.04);
  min-height: 52rpx;
  display: flex; align-items: center;
  background: #ffffff;
  border: 1.5rpx solid rgba(148,163,184,0.16);
  border-radius: 22rpx;
  padding: 0 20rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #667085;
  font-weight: 750;
}
.compare-toggle.active {
  background: #eff6ff;
  border-color: rgba(43,92,230,0.28);
  color: #1d4ed8;
}

/* йИєвВђйИєвВђ йНЧзК±зґЕ йИєвВђйИєвВђ */
.spacer { height: 270rpx; }

/* йИєвВђйИєвВђ йПИзГШзАѓйНТж•ДгАГ йИєвВђйИєвВђ */
.list { padding: 4rpx 16rpx 60rpx; }

/* йИєвВђйИєвВђ йПИзГШзАѓйНЧпЉДеҐЦ йИєвВђйИєвВђ */
.agency-card {
  box-shadow: 0 18rpx 42rpx rgba(15,23,42,0.075);
  position: relative;
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,255,255,0.92)), radial-gradient(circle at 100% 0, rgba(43,92,230,0.10), transparent 34%);
  border-radius: 28rpx;
  border: 1.5rpx solid rgba(148,163,184,0.16);
  padding: 22rpx 20rpx 0;
  margin-bottom: 18rpx;
  overflow: hidden;
}
.agency-card:active { opacity: 0.80; }
.agency-card.compare-mode { padding-left: 76rpx; }
.agency-card.selected {
  border-color: rgba(43,92,230,0.55);
  box-shadow: 0 18rpx 46rpx rgba(43,92,230,0.16);
}

/* жЊґеґЙвВђе§ЛоФЛ */
.check-box {
  position: absolute;
  left: 18rpx;
  top: 50%;
  transform: translateY(-50%);
}
.check-inner {
  box-shadow: 0 8rpx 18rpx rgba(15,23,42,0.08);
  border-color: rgba(43,92,230,0.22);
  width: 46rpx; height: 46rpx;
  border-radius: 50%;
  border: 2.5rpx solid rgba(255,255,255,0.15);
  background: #ffffff;
  display: flex; align-items: center; justify-content: center;
}
.check-inner.checked { background: var(--brand); border-color: var(--brand); }
.check-mark { font-size: 26rpx; color: var(--bg-panel); font-weight: 700; }

/* йИєвВђйИєвВђ йНЧпЉДеҐЦжЊґжТЃеДі йИєвВђйИєвВђ */
.card-head {
  z-index: 1;
  position: relative;
  margin-bottom: 14rpx;
  display: flex; align-items: flex-start;
  gap: 18rpx;
}
.logo-wrap { flex-shrink: 0; }
.logo-img {
  width: 92rpx; height: 92rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.10);
}
.logo-placeholder {
  background-image: linear-gradient(135deg, rgba(255,255,255,0.26), rgba(255,255,255,0));
  box-shadow: 0 12rpx 24rpx rgba(15,23,42,0.12);
  border: 1.5rpx solid rgba(255,255,255,0.70);
  height: 88rpx;
  width: 88rpx;
  border-radius: 22rpx;
  display: flex; align-items: center; justify-content: center;
}
.logo-text { font-size: 28rpx; font-weight: 800; color: #fff; letter-spacing: 1rpx; text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.2); }

.card-info { flex: 1; min-width: 0; padding-top: 2rpx; }
.name-row {
  margin-bottom: 8rpx;
  display: flex; align-items: center;
  gap: 8rpx;
}
.agency-name {
  letter-spacing: 0.1rpx;
  font-weight: 900;
  font-size: 30rpx;
  color: #1f2937;
  flex: 1; overflow: hidden;
  text-overflow: ellipsis; white-space: nowrap;
}
.verified-badge {
  border-color: rgba(16,185,129,0.28);
  background: #ecfdf5;
  border: 1rpx solid rgba(16,185,129,0.30);
  border-radius: 10rpx;
  padding: 4rpx 10rpx;
}
.verified-text { font-size: 20rpx; color: var(--success); font-weight: 600; }
.meta-row { display: flex; align-items: center; gap: 10rpx; }
.type-tag {
  font-weight: 800;
  color: #3157d5;
  border-radius: 10rpx;
  font-size: 22rpx;
  background: #eef4ff;
  padding: 5rpx 14rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(94,106,210,0.30);
}
.city-text { font-size: 23rpx; color: var(--text-muted); }

/* зТЗеЛЂеЮОйНІ?*/
.rating-block {
  padding-top: 0;
  min-width: 88rpx;
  display: flex; flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0; padding-top: 2rpx;
}
.r-score-row { display: flex; align-items: center; gap: 4rpx; }
.r-star { font-size: 26rpx; color: var(--warning); }
.r-num  { font-size: 32rpx; font-weight: 800; color: var(--warning); line-height: 1; }
.r-none { font-size: 24rpx; font-weight: 500; color: var(--text-muted); }
.r-cnt  { font-size: 21rpx; color: var(--text-muted); }

/* йОїењЪе†™ */
.desc {
  z-index: 1;
  position: relative;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.62;
  text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  margin-bottom: 16rpx;
}

/* жґУжТїжЪ±йПНеЫ©оДЈ */
.spec-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 18rpx; }
.spec-tag {
  font-size: 22rpx; color: var(--text-muted);
  background: rgba(0,0,0,0.04);
  padding: 6rpx 16rpx; border-radius: 8rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
}
.spec-more { font-size: 22rpx; color: var(--text-muted); padding: 6rpx 8rpx; }

/* йНЧпЉДеҐЦжРіжЫҐеДі */
.card-footer {
  z-index: 1;
  position: relative;
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 0 18rpx;
  border-top: 1rpx solid rgba(148,163,184,0.14);
  margin-top: 2rpx;
}
.ai-badge {
  border-color: rgba(43,92,230,0.20);
  padding: 7rpx 14rpx;
  display: flex; align-items: center; gap: 6rpx;
  background: linear-gradient(135deg, #eef4ff, #f8fbff);
  border: 1rpx solid rgba(94,106,210,0.25);
  border-radius: 12rpx;
}
.ai-badge.pending {
  background: #f8fafc;
  border-color: rgba(148,163,184,0.16);
}
.ai-badge-txt { font-size: 22rpx; color: var(--brand); font-weight: 500; }
.ai-badge.pending .ai-badge-txt { color: var(--text-muted); }
.arrow { font-size: 26rpx; color: var(--brand); font-weight: 600; }

.compare-hint { justify-content: center; }
.compare-hint-txt { font-size: 24rpx; color: var(--text-muted); }
.agency-card.selected .compare-hint-txt { color: var(--brand); font-weight: 600; }

/* йИєвВђйИєвВђ йНФзКЇжµЗ / зїМиЩєеІЄйОђ?йИєвВђйИєвВђ */
.loading-tip {
  display: flex; align-items: center; justify-content: center;
  gap: 16rpx; padding: 48rpx 0;
  font-size: 27rpx; color: var(--text-muted);
}
.spinner {
  width: 40rpx; height: 40rpx;
  border: 4rpx solid rgba(0,0,0,0.04);
  border-top-color: var(--brand);
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.no-more { text-align: center; padding: 36rpx 0; color: var(--text-muted); font-size: 24rpx; }
.empty {
  display: flex; flex-direction: column;
  align-items: center; padding: 100rpx 48rpx 60rpx; text-align: center;
}
.empty-emoji { font-size: 80rpx; line-height: 1; margin-bottom: 28rpx; }
.empty-txt { font-size: 30rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 16rpx; }
.empty-hint {
  font-size: 26rpx; color: var(--brand);
  padding: 16rpx 36rpx;
  background: rgba(113,112,255,0.10);
  border-radius: 9999rpx;
  border: 1rpx solid #C7D2FE;
  font-weight: 500;
}
.load-more-btn {
  text-align: center; padding: 28rpx 0;
  font-size: 28rpx; color: var(--brand); font-weight: 600;
  background: #eef4ff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(94,106,210,0.25);
}

/* йИєвВђйИєвВђ зАµиІДзШЃйОЃоДБиѓЮйПН?йИєвВђйИєвВђ */
.compare-bar-left { display: flex; align-items: center; gap: 16rpx; }
.compare-dots { display: flex; align-items: center; gap: 10rpx; }
.compare-dot.filled { background: var(--brand); border-color: var(--brand); }
.compare-count { font-size: 27rpx; color: var(--text-secondary); font-weight: 500; }
.compare-go-btn.disabled {
  background: rgba(0,0,0,0.04);
  color: var(--text-muted);
  border: 1.5rpx solid rgba(0,0,0,0.06);
}

/* ===== UI polish: assessment page ===== */
.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 0 0, rgba(43, 92, 230, 0.10), transparent 34%),
    radial-gradient(circle at 96% 8%, rgba(16, 185, 129, 0.09), transparent 30%),
    linear-gradient(180deg, #ffffff 0%, #f6f8fc 34%, #f8fafc 100%);
}

.stat-txt {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 800;
}

.stat-kw {
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.agency-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 26rpx;
  width: 6rpx;
  height: 72rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: linear-gradient(180deg, #2b5ce6, #38bdf8);
  opacity: 0.9;
}

.card-press,
.tap-soft {
  transform: scale(0.982);
  opacity: 0.82;
}

.compare-bar {
  background: rgba(255,255,255,0.96);
  border-top-color: rgba(148,163,184,0.18);
  box-shadow: 0 -16rpx 42rpx rgba(15,23,42,0.10);
}

.compare-dot {
  background: #e5eaf3;
  border-color: transparent;
}

.compare-go-btn {
  background: linear-gradient(135deg, #2b5ce6, #1d4ed8);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(43,92,230,0.24);
}

.assessment-hero {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin: 0 32rpx 22rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.98), rgba(248,251,255,0.94)),
    radial-gradient(circle at 100% 0, rgba(43,92,230,0.13), transparent 36%);
  border: 1.5rpx solid rgba(148,163,184,0.16);
  box-shadow: 0 18rpx 46rpx rgba(15,23,42,0.08);
  overflow: hidden;
}

.assessment-hero::after {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -90rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(43,92,230,0.14), rgba(56,189,248,0.10));
}

.assessment-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.assessment-kicker {
  margin-bottom: 8rpx;
  color: #2b5ce6;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.8rpx;
  text-transform: uppercase;
}

.assessment-title {
  margin-bottom: 8rpx;
  color: #101828;
  font-size: 38rpx;
  font-weight: 950;
  letter-spacing: -0.6rpx;
}

.assessment-sub {
  max-width: 440rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}

.assessment-meter {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 0 0 132rpx;
  height: 132rpx;
  border-radius: 28rpx;
  background: #f8fbff;
  border: 1.5rpx solid rgba(43,92,230,0.12);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.80);
}

.assessment-meter-num {
  color: #1d4ed8;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1;
}

.assessment-meter-label {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 20rpx;
  font-weight: 800;
}

.agency-card-glow {
  position: absolute;
  right: -58rpx;
  top: -68rpx;
  width: 168rpx;
  height: 168rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, rgba(56,189,248,0.16), rgba(56,189,248,0));
  pointer-events: none;
}

