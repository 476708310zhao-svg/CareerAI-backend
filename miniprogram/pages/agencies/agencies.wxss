}

.rating-block {
  padding-top: 0;
}

.r-num {
  color: #172033;
  font-weight: 900;
}

.desc {
  color: #475467;
  line-height: 1.65;
}

.spec-tag {
  color: #344054;
  background: #f8fafc;
