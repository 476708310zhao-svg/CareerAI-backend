/* pages/star-library/star-library.wxss */
page { background: var(--bg-page); font-family: -apple-system, 'PingFang SC', sans-serif; }

/* Hero */
.hero {
  background: var(--bg-panel);
  padding: 40rpx 28rpx 28rpx;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1.5rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.hero-left { display: flex; flex-direction: column; gap: 6rpx; }
.hero-title { font-size: 40rpx; font-weight: 800; color: var(--text-primary); }
.hero-sub   { font-size: 24rpx; color: var(--text-muted); }
.hero-icon-wrap {
  width: 80rpx; height: 80rpx; background: #FFFBEB;
  border-radius: var(--r-lg);
  display: flex; align-items: center; justify-content: center;
}
.hero-icon { font-size: 40rpx; line-height: 1; }

/* Search */
.search-wrap { padding: 18rpx 24rpx; background: var(--bg-panel); border-bottom: 1rpx solid rgba(0,0,0,0.04); }
.search-box {
  display: flex; align-items: center; gap: 12rpx;
  background: #F3F4F6; border-radius: 50rpx; padding: 0 20rpx; height: 68rpx;
}
.search-icon { font-size: 26rpx; }
.search-input { flex: 1; font-size: 26rpx; color: var(--text-primary); }

/* Role filter */
.role-scroll { background: var(--bg-panel); padding: 16rpx 0; border-bottom: 1rpx solid rgba(0,0,0,0.04); }
.role-chips  { display: flex; gap: 12rpx; padding: 0 24rpx; white-space: nowrap; }
.role-chip {
  display: inline-flex; align-items: center;
  font-size: 24rpx; font-weight: 600;
  padding: 10rpx 24rpx; border-radius: 50rpx;
  background: #F3F4F6; color: var(--text-secondary);
  border: 1.5rpx solid transparent;
  flex-shrink: 0;
}
.role-chip.active { font-weight: 700; }

/* Template list */
.tpl-list { padding: 20rpx 24rpx; }

.empty-wrap { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx; gap: 14rpx; }
.empty-icon  { font-size: 72rpx; }
.empty-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); }

.tpl-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  margin-bottom: 16rpx; overflow: hidden;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* Card header */
.tpl-header {
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 22rpx 22rpx 20rpx; gap: 12rpx;
}
.tpl-header:active { opacity: 0.75; }
.tpl-header-left  { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.tpl-header-right { display: flex; align-items: center; gap: 14rpx; flex-shrink: 0; }

.tpl-role-badge {
  display: inline-block;
  font-size: 20rpx; font-weight: 700;
  padding: 3rpx 14rpx; border-radius: 6rpx; align-self: flex-start;
}
.tpl-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); line-height: 1.4; }
.tpl-tags  { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 4rpx; }
.tpl-tag {
  font-size: 20rpx; color: var(--text-muted);
  background: #F3F4F6; padding: 3rpx 10rpx; border-radius: 6rpx;
}
.tpl-save-btn { font-size: 30rpx; color: #F59E0B; line-height: 1; padding: 4rpx 4rpx; }
.tpl-arrow    { font-size: 20rpx; color: var(--text-muted); }

/* STAR body */
.tpl-body { padding: 4rpx 22rpx 20rpx; border-top: 1rpx solid #F3F4F6; }

.star-row {
  display: flex; gap: 16rpx; padding: 14rpx 0;
  border-bottom: 1rpx solid #F9FAFB;
}
.star-row:last-of-type { border-bottom: none; }

.star-label {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 900; flex-shrink: 0;
  margin-top: 4rpx;
}
.s-label { background: #EEF2FF; color: #4F46E5; }
.t-label { background: #D1FAE5; color: #059669; }
.a-label { background: #FEF3C7; color: #D97706; }
.r-label { background: #FEE2E2; color: #DC2626; }

.star-content { flex: 1; min-width: 0; }
.star-title-txt { font-size: 22rpx; color: var(--text-muted); display: block; margin-bottom: 6rpx; }
.star-body-txt  { font-size: 25rpx; color: var(--text-body); line-height: 1.7; display: block; }

/* Action buttons */
.tpl-actions  { display: flex; gap: 10rpx; padding-top: 16rpx; flex-wrap: wrap; }
.tpl-act-btn {
  display: flex; align-items: center; gap: 6rpx;
  background: var(--bg-page); border: 1.5rpx solid rgba(0,0,0,0.06);
  border-radius: var(--r-md); padding: 12rpx 18rpx;
}
.tpl-act-btn:active { opacity: 0.7; }
.tpl-act-btn.ai-btn { background: #FFFBEB; border-color: #FCD34D; }
.tpl-act-icon { font-size: 26rpx; line-height: 1; }
.tpl-act-txt  { font-size: 22rpx; color: var(--text-secondary); white-space: nowrap; }
.tpl-act-btn.ai-btn .tpl-act-txt { color: #D97706; font-weight: 600; }

/* Modal */
.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.45);
  display: flex; align-items: flex-end; z-index: 100;
}
.modal-card {
  background: var(--bg-panel); border-radius: 32rpx 32rpx 0 0;
  padding: 0 28rpx calc(32rpx + env(safe-area-inset-bottom));
  width: 100%; max-height: 90vh; overflow-y: auto; box-sizing: border-box;
}
.modal-handle { width: 64rpx; height: 8rpx; background: var(--border-light); border-radius: 4rpx; margin: 16rpx auto 0; }
.modal-title  { display: block; font-size: 32rpx; font-weight: 700; color: var(--text-primary); margin: 20rpx 0 6rpx; text-align: center; }
.modal-sub    { display: block; font-size: 22rpx; color: var(--text-muted); text-align: center; margin-bottom: 24rpx; }

.form-item { margin-bottom: 20rpx; }
.form-label { display: block; font-size: 24rpx; color: var(--text-body); font-weight: 500; margin-bottom: 10rpx; }
.req { color: #EF4444; }
.fi {
  background: #F9FAFB; border: 1.5rpx solid var(--border-light);
  border-radius: 14rpx; padding: 0 20rpx;
  height: 80rpx; font-size: 27rpx; color: var(--text-primary);
  width: 100%; box-sizing: border-box;
}
.fi-ta { height: auto; min-height: 120rpx; padding: 16rpx 20rpx; line-height: 1.6; }

.btn-gen     { width: 100%; margin-bottom: 16rpx; }
.btn-gen.loading { opacity: 0.7; }
.btn-regen   { margin-top: 16rpx; }
.btn-close-modal { margin-top: 12rpx; width: 100%; }

/* Custom result */
.custom-result {
  background: #F0FDF4; border: 1.5rpx solid #BBF7D0;
  border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx;
}
.cr-header  { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.cr-title   { font-size: 24rpx; font-weight: 700; color: #059669; }
.cr-copy    { font-size: 22rpx; color: var(--brand); font-weight: 600; }
.cr-body    { font-size: 25rpx; color: var(--text-body); line-height: 1.8; display: block; }
