/* pages/resume/resume.wxss */
page {
  overflow-x: hidden;
  background: radial-gradient(circle at 18% 0%, rgba(20, 184, 166, 0.15), transparent 34%), linear-gradient(180deg, #f4fffc 0%, #f7f9fd 54%, #ffffff 100%);
  font-family: -apple-system, sans-serif;
}

.container {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
}

/* --- 澶氫唤绠€鍘嗛€夋嫨鏍?--- */
.resume-switcher {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-panel);
  margin: 20rpx 30rpx 0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.switcher-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}
.switcher-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.switcher-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg-raised);
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
}
.switcher-arrow {
  font-size: 32rpx;
  color: var(--text-secondary);
}
.switcher-vip-badge {
  font-size: 18rpx;
  font-weight: 700;
  color: #92400e;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border: 1rpx solid #f59e0b;
  padding: 3rpx 10rpx;
  border-radius: 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
.rmp-tip-vip {
  color: #b45309;
  font-weight: 600;
}
.switcher-btn {
  font-size: 24rpx;
  color: var(--brand);
  background: rgba(37,99,235,0.08);
  padding: 10rpx 22rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

/* --- 绠€鍘嗙鐞嗛潰鏉块伄缃?--- */
.resume-manager-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
}
.resume-manager-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-panel);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}
.resume-manager-panel.show {
  transform: translateY(0);
}
.rmp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 36rpx 20rpx;
  border-bottom: 1rpx solid var(--border-subtle);
}
.rmp-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.rmp-close {
  font-size: 36rpx;
  color: var(--text-secondary);
  padding: 0 10rpx;
}
.rmp-list {
  flex: 1;
  padding: 16rpx 0;
}
.rmp-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 36rpx;
  border-bottom: 1rpx solid var(--border-subtle);
}
.rmp-item.active {
  background: rgba(37,99,235,0.05);
}
.rmp-item-info {
  flex: 1;
}
.rmp-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}
.rmp-item-time {
  font-size: 22rpx;
  color: var(--text-secondary);
}
.rmp-item-del {
  font-size: 24rpx;
  color: #ef4444;
  padding: 8rpx 20rpx;
}
.rmp-empty {
  text-align: center;
  padding: 60rpx 30rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}
.rmp-footer {
  padding: 20rpx 36rpx 30rpx;
  border-top: 1rpx solid var(--border-subtle);
}
.rmp-tip {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* --- Tab 鍒囨崲 --- */
.tabs {
  border: 0;
  border-radius: 28rpx;
  margin: 18rpx 24rpx 22rpx;
  background: rgba(255, 255, 255, 0.94);
  display: flex;
  padding: 8rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 14rpx 30rpx rgba(20, 55, 90, 0.08);
}

.tab-item {
  transition: transform 0.16s ease, opacity 0.16s ease;
  border-radius: 20rpx;
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}

.tab-item.active {
  box-shadow: 0 10rpx 24rpx rgba(20, 184, 166, 0.22);
  background: linear-gradient(135deg, #14b8a6, #2f66f4);
  color: #ffffff;
  font-weight: bold;
  font-size: 30rpx;
}

.tab-item.active::after {
  display: none;
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--brand);
  border-radius: 4rpx;
}

/* --- 閫氱敤鍐呭鍖?--- */
.tab-content {
  padding: 30rpx;
}

/* --- 瀹屾暣搴﹀崱鐗?--- */
.progress-card {
  margin-right: 24rpx;
  margin-left: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(24, 42, 70, 0.08);
  border: 1rpx solid rgba(38, 95, 121, 0.08);
  overflow: hidden;
  position: relative;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.prog-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.prog-label { font-size: 30rpx; font-weight: bold; }
.prog-val   { color: var(--brand); font-weight: bold; }
.prog-right { display: flex; align-items: center; gap: 16rpx; }
.export-btn {
  box-shadow: 0 10rpx 22rpx rgba(47, 102, 244, 0.12);
  transition: transform 0.16s ease, opacity 0.16s ease;
  border-radius: 999rpx;
  font-size: 22rpx; font-weight: 600; color: #6D28D9;
  background: #F5F3FF; border: 1rpx solid #DDD6FE;
  padding: 6rpx 20rpx; border-radius: 9999rpx;
}
.export-btn.export-loading { opacity: 0.6; }

.progress-track {
  height: 12rpx;
  background: var(--border-faint);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #14b8a6, #2f66f4);
  border-radius: 999rpx;
  transition: width var(--trans-slow);
}

.prog-tip { font-size: 24rpx; color: #fa8c16; }

/* --- 閫氱敤 Section 鍗＄墖 --- */
.section-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.left-border {
  border-left-color: #14b8a6;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  padding-left: 20rpx;
  border-left: 8rpx solid var(--brand);
  line-height: 1;
}

.edit-icon, .add-btn {
  color: var(--brand);
  font-size: 28rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ai-gen-btn {
  font-size: 24rpx;
  color: #6D28D9;
  background: #F5F3FF;
  border: 1rpx solid #DDD6FE;
  border-radius: 9999rpx;
  padding: 6rpx 18rpx;
  font-weight: 600;
}

.empty-hint {
  border: 1rpx dashed rgba(20, 184, 166, 0.28);
  background: #f4fbff;
  border-radius: 22rpx;
  text-align: center;
  color: #D1D5DB;
  font-size: 26rpx;
  padding: 30rpx 0;
}

/* 鍩烘湰淇℃伅 Grid */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
}

.info-item { display: flex; flex-direction: column; }
.info-item .label { font-size: 24rpx; color: var(--text-muted); margin-bottom: 8rpx; }
.info-item .value { font-size: 28rpx; color: var(--text-body); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 涓汉浼樺娍 & AI 鎸夐挳 */
.ai-group { display: flex; gap: 12rpx; }
.ai-btn {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 30rpx;
  color: #fff;
}
.ai-btn.review { background: linear-gradient(135deg, var(--brand), #6366F1); }
.ai-btn.polish { background: linear-gradient(135deg, var(--brand), #6366F1); }

.summary-box {
  background: #F9FAFB;
  padding: 20rpx;
  border-radius: var(--r-sm);
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  position: relative;
}

.tap-edit {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--brand);
  margin-top: 10rpx;
}

/* 宸ヤ綔缁忓巻 */
.exp-item {
  display: flex;
  position: relative;
  padding-bottom: 40rpx;
}
.exp-item:last-child { padding-bottom: 0; }

.exp-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--brand);
  border-radius: 50%;
  margin-top: 10rpx;
  margin-right: 24rpx;
  position: relative;
  flex-shrink: 0;
}

.exp-item:not(:last-child) .exp-dot::after {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 7rpx;
  width: 2rpx;
  height: 150rpx;
  background: var(--border-light);
}

.exp-content { flex: 1; }
.exp-row { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.exp-company { font-size: 30rpx; font-weight: bold; color: var(--text-body); }
.exp-actions { display: flex; gap: 20rpx; color: var(--text-muted); font-size: 28rpx; }

.exp-sub {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.exp-time { color: var(--text-muted); }

.exp-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: #F9FAFB;
  padding: 16rpx;
  border-radius: var(--r-sm);
  line-height: 1.5;
}

/* --- 闄勪欢绠€鍘?--- */
.resume-card {
  background: var(--bg-panel); padding: 30rpx; border-radius: var(--r-lg); margin-bottom: 24rpx;
  display: flex; justify-content: space-between; align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}
.card-left { display: flex; align-items: center; }
.file-icon { width: 80rpx; height: 80rpx; margin-right: 24rpx; }
.info { display: flex; flex-direction: column; }
.name { font-size: 30rpx; font-weight: bold; color: var(--text-body); margin-bottom: 8rpx; }
.date { font-size: 24rpx; color: var(--text-muted); }
.tag { font-size: 22rpx; color: var(--brand); background: #eef4fd; padding: 4rpx 12rpx; border-radius: 8rpx; }
.footer-btn { position: fixed; bottom: 50rpx; left: 0; width: 100%; padding: 0 30rpx; box-sizing: border-box; }
/* upload-btn 鐢?c-button 鎻愪緵鏍峰紡 */

/* ======================== 缂栬緫寮圭獥閫氱敤 ======================== */
.edit-modal {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  box-sizing: border-box;
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-subtle);
}

.edit-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3F4F6;
  border-radius: 50%;
  font-size: 32rpx;
  color: var(--text-secondary);
  line-height: 1;
  flex-shrink: 0;
}

.edit-form {
  flex: 1;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  background: var(--bg-raised);
  border-radius: var(--r-sm);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-body);
}

.form-textarea {
  background: var(--bg-raised);
  border-radius: var(--r-sm);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-body);
  width: 100%;
  min-height: 150rpx;
  box-sizing: border-box;
}

.edit-textarea {
  flex: 1;
  background: var(--bg-raised);
  border-radius: var(--r-sm);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-body);
  min-height: 200rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  width: 100%;
}

.save-btn { margin-top: 16rpx; }
.del-btn  { margin-bottom: 16rpx; }

.edit-modal-footer {
  padding-top: 10rpx;
}

/* ======================== AI 寮圭獥鏍峰紡 ======================== */
.ai-modal {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  box-sizing: border-box;
}

.ai-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid var(--border-subtle);
  padding-bottom: 20rpx;
}

.ai-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.ai-content-scroll {
  flex: 1;
  background: #f9faff;
  border-radius: var(--r-md);
  padding: 30rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

.ai-text {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.8;
  white-space: pre-wrap;
}

.ai-footer {
  display: flex;
  gap: 20rpx;
}

.ai-modal-cancel  { flex: 1; }
.ai-modal-confirm { flex: 2; }

/* 宀椾綅鍖归厤 */
.match-box {
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.match-input {
  flex: 1;
  background: var(--bg-raised);
  border-radius: var(--r-sm);
  padding: 16rpx 20rpx;
  font-size: 26rpx;
}

.ai-btn.match {
  background: linear-gradient(135deg, var(--brand), #6366F1);
  white-space: nowrap;
}

/* 宸ヤ綔缁忓巻娑﹁壊灏忔寜閽?*/
.ai-btn-sm {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--r-lg);
  background: linear-gradient(135deg, var(--brand), #6366F1);
  color: #fff;
  white-space: nowrap;
}

/* ======================== 鏁欒偛缁忓巻 ======================== */
.edu-item {
  padding: 20rpx 0;
  border-bottom: 1.5rpx solid var(--border-faint);
}
.edu-item:last-child { border-bottom: none; }

.edu-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.edu-school {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.edu-time {
  font-size: 22rpx;
  color: var(--text-muted);
}
.edu-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ======================== 鎶€鑳芥爣绛?======================== */
.skills-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.skill-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: #EEF2FF;
  color: var(--brand);
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 30rpx;
  font-weight: 500;
}
.skill-del {
  font-size: 28rpx;
  color: #93C5FD;
  line-height: 1;
  margin-left: 4rpx;
}

/* 鎶€鑳界紪杈戝脊绐?*/
.skills-edit-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  min-height: 80rpx;
  background: #F9FAFB;
  border-radius: var(--r-md);
  padding: 20rpx;
  margin-bottom: 24rpx;
}
.skill-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.skill-input {
  flex: 1;
  background: var(--bg-page);
  border-radius: var(--r-sm);
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  border: 1.5rpx solid var(--border-light);
}
.add-skill-btn {
  background: var(--brand);
  color: #fff;
  font-size: 26rpx;
  padding: 18rpx 28rpx;
  border-radius: var(--r-sm);
  font-weight: 600;
  white-space: nowrap;
}

/* ======================== 椤圭洰缁忓巻 ======================== */
.exp-sub-role {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

/* ======================== 搴曢儴鎿嶄綔鏍?======================== */
.resume-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--bg-panel);
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: var(--shadow-up);
  z-index: 100;
}

.resume-act-btn { flex: 1; gap: 10rpx; }
.resume-act-icon { font-size: 30rpx; line-height: 1; }
.resume-act-txt  { font-size: 28rpx; font-weight: 700; }

/* ======================== NLP 鏅鸿兘浼樺寲 ======================== */
.nlp-row {
  margin-top: 20rpx;
}

.nlp-btn {
  box-shadow: 0 10rpx 22rpx rgba(47, 102, 244, 0.12);
  transition: transform 0.16s ease, opacity 0.16s ease;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: linear-gradient(135deg, #f0f4ff, #e8edff);
  border: 1.5rpx solid #c7d2fe;
  border-radius: 999rpx;
  padding: 22rpx 28rpx;
}

.nlp-btn-loading {
  opacity: 0.7;
}

.nlp-btn-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.nlp-btn-txt {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--brand);
}

.nlp-btn-sub {
  font-size: 20rpx;
  color: var(--text-muted);
  display: block;
  margin-left: auto;
}

/* NLP 缁撴灉闈㈡澘 */
.nlp-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
}

.nlp-panel {
  box-shadow: 0 16rpx 36rpx rgba(24, 42, 70, 0.08);
  border: 1rpx solid rgba(38, 95, 121, 0.08);
  margin-right: 24rpx;
  margin-left: 24rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  border-radius: 30rpx;
  z-index: 201;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.nlp-panel.show {
  transform: translateY(0);
}

.nlp-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 36rpx 20rpx;
  border-bottom: 1rpx solid var(--border-subtle);
}

.nlp-panel-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nlp-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.nlp-ats-badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 5rpx 14rpx;
  border-radius: 20rpx;
}

.nlp-ats-good  { background: #dcfce7; color: #16a34a; }
.nlp-ats-ok    { background: #fef9c3; color: #b45309; }
.nlp-ats-low   { background: #fee2e2; color: #dc2626; }

.nlp-panel-close {
  font-size: 36rpx;
  color: var(--text-secondary);
  padding: 0 10rpx;
}

.nlp-panel-body {
  flex: 1;
  padding: 24rpx 36rpx;
  overflow-y: auto;
}

.nlp-result-text {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.9;
  white-space: pre-wrap;
  display: block;
}

.nlp-panel-footer {
  padding: 16rpx 36rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border-subtle);
}

/* ======================== 瀵煎嚭 Canvas锛堥殣钘忥級======================== */
.export-canvas {
  position: fixed;
  top: -9999px;
  left: -9999px;
  width: 750px;
  height: 1200px;
  pointer-events: none;
}

/* 2026 kingkong polish: resume diagnosis */
.progress-card::before {
  content: '';
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  right: -98rpx;
  top: -110rpx;
  border-radius: 999rpx;
  background: rgba(20, 184, 166, 0.1);
}

/* ===== Premium resume workspace redesign ===== */
page {
  --bg-page: #f5f7fb;
  --bg-panel: #ffffff;
  --bg-raised: #f8fbff;
  --text-primary: #101828;
  --text-body: #344054;
  --text-secondary: #667085;
  --text-muted: #98a2b3;
  --brand: #2563eb;
  --border-subtle: rgba(16, 24, 40, 0.06);
  --border-faint: #edf1f7;
  --border-light: #eaecf0;
  --r-sm: 14rpx;
  --r-md: 20rpx;
  --r-lg: 28rpx;
  --shadow-up: 0 -18rpx 44rpx rgba(16, 24, 40, 0.12);
  --trans-slow: 0.28s ease;
  --resume-bg: #f5f7fb;
  --resume-panel: #ffffff;
  --resume-ink: #101828;
  --resume-body: #344054;
  --resume-muted: #98a2b3;
  --resume-line: rgba(16, 24, 40, 0.07);
  --resume-brand: #2563eb;
  --resume-brand-2: #14b8a6;
  --resume-soft: #eef4ff;
  --resume-shadow: 0 16rpx 44rpx rgba(16, 24, 40, 0.07);
  overflow-x: hidden;
  background:
    radial-gradient(circle at 12% 0, rgba(20,184,166,0.13), transparent 30%),
    radial-gradient(circle at 88% 4%, rgba(37,99,235,0.12), transparent 34%),
    linear-gradient(180deg, #ffffff 0%, #f5f7fb 360rpx, #f5f7fb 100%);
  color: var(--resume-ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
image,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

.container {
  width: 100%;
  max-width: 750rpx;
  min-height: 100vh;
  margin: 0 auto;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
  background: transparent;
  overflow-x: hidden;
}

.tabs {
  position: sticky;
  top: 0;
  z-index: 90;
  margin: 18rpx 28rpx 20rpx;
  padding: 8rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.88);
  border: 1rpx solid rgba(255,255,255,0.75);
  box-shadow: 0 16rpx 42rpx rgba(16,24,40,0.08);
  backdrop-filter: blur(20rpx);
}

.tab-item {
  height: 78rpx;
  padding: 0;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 27rpx;
  font-weight: 800;
}

.tab-item.active {
  color: #ffffff;
  font-size: 28rpx;
  background: linear-gradient(135deg, #0f766e 0%, #2563eb 100%);
  box-shadow: 0 14rpx 28rpx rgba(37,99,235,0.20);
}

.tab-content {
  padding: 0 28rpx;
}

.resume-switcher,
.progress-card,
.section-card,
.resume-card {
  margin-left: 0;
  margin-right: 0;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(16,24,40,0.06);
  box-shadow: var(--resume-shadow);
}

.resume-switcher {
  margin-top: 0;
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
}

.switcher-name {
  color: var(--resume-ink);
  font-size: 29rpx;
  font-weight: 900;
}

.switcher-count,
.switcher-vip-badge {
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  line-height: 34rpx;
}

.switcher-btn,
.edit-icon,
.add-btn {
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2563eb;
  background: #eef4ff;
  font-size: 23rpx;
  font-weight: 850;
}

.progress-card {
  position: relative;
  margin-bottom: 20rpx;
  padding: 26rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 98% 0, rgba(20,184,166,0.14), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,251,255,0.96));
}

.progress-card::before {
  width: 210rpx;
  height: 210rpx;
  right: -92rpx;
  top: -104rpx;
  background: rgba(20,184,166,0.12);
}

.prog-header {
  position: relative;
  z-index: 1;
  align-items: center;
  margin-bottom: 18rpx;
}

.prog-label {
  color: var(--resume-ink);
  font-size: 29rpx;
  font-weight: 950;
}

.prog-val {
  color: #101828;
  font-size: 34rpx;
  font-weight: 950;
}

.export-btn {
  height: 42rpx;
  padding: 0 18rpx;
  color: #6d28d9;
  background: #f5f3ff;
  border: 1rpx solid rgba(109,40,217,0.14);
  font-size: 21rpx;
  line-height: 42rpx;
  box-shadow: 0 10rpx 22rpx rgba(109,40,217,0.12);
}

.progress-track {
  position: relative;
  z-index: 1;
  height: 14rpx;
  margin-bottom: 14rpx;
  background: #e8edf5;
}

.progress-fill {
  background: linear-gradient(90deg, #14b8a6, #2563eb);
}

.prog-tip {
  position: relative;
  z-index: 1;
  color: #f97316;
  font-size: 23rpx;
  font-weight: 700;
}

.section-card {
  margin-bottom: 20rpx;
  padding: 26rpx;
}

.card-header {
  margin-bottom: 22rpx;
}

.left-border {
  padding-left: 0;
  border-left: none;
  color: var(--resume-ink);
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1.2;
}

.left-border::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 26rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #14b8a6, #2563eb);
  vertical-align: -4rpx;
}

.empty-hint {
  min-height: 86rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  border: 1.5rpx dashed rgba(37,99,235,0.16);
  background:
    linear-gradient(180deg, rgba(248,251,255,0.92), rgba(255,255,255,0.96));
  color: #b6c0cf;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 700;
}

.info-grid {
  gap: 18rpx;
}

.info-item {
  min-height: 94rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  border: 1rpx solid #edf1f7;
}

.info-item .label {
  color: var(--resume-muted);
  font-size: 21rpx;
  font-weight: 800;
}

.info-item .value {
  color: var(--resume-body);
  font-size: 27rpx;
  font-weight: 850;
}

.ai-group,
.header-actions {
  gap: 10rpx;
}

.ai-btn,
.ai-gen-btn,
.ai-btn-sm {
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 850;
  color: #2563eb;
  background: #eef4ff;
  border: 1rpx solid rgba(37,99,235,0.12);
}

.ai-btn.review,
.ai-btn.polish,
.ai-btn.match,
.ai-btn-sm {
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e, #2563eb);
  border-color: transparent;
}

.summary-box,
.exp-desc {
  border-radius: 22rpx;
  background: #f8fbff;
  border: 1rpx solid #edf1f7;
  color: #344054;
  font-size: 26rpx;
  line-height: 1.65;
}

.match-box {
  gap: 12rpx;
}

.match-input {
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  color: #344054;
  background: #f8fbff;
  border: 1rpx solid #edf1f7;
  font-size: 25rpx;
}

.nlp-row {
  margin-top: 18rpx;
}

.nlp-btn {
  min-height: 86rpx;
  padding: 18rpx 22rpx;
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 100% 0, rgba(37,99,235,0.12), transparent 34%),
    linear-gradient(135deg, #eef4ff, #f8fbff);
  border: 1rpx solid rgba(37,99,235,0.16);
  box-shadow: 0 14rpx 30rpx rgba(37,99,235,0.10);
}

.nlp-btn-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 18rpx;
  background: rgba(37,99,235,0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.nlp-btn-txt {
  color: #1d2939;
  font-size: 26rpx;
  font-weight: 950;
}

.nlp-btn-sub {
  margin-left: 0;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.35;
}

.exp-item {
  padding: 2rpx 0 28rpx;
}

.exp-dot {
  width: 18rpx;
  height: 18rpx;
  margin-right: 22rpx;
  background: linear-gradient(135deg, #14b8a6, #2563eb);
  box-shadow: 0 0 0 8rpx rgba(37,99,235,0.08);
}

.exp-company,
.edu-school {
  color: #1d2939;
  font-size: 29rpx;
  font-weight: 950;
}

.exp-sub,
.edu-sub,
.edu-time,
.exp-time {
  color: #667085;
}

.edu-item {
  padding: 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid #edf1f7;
  background: #f8fbff;
  margin-bottom: 14rpx;
}

.skills-wrap {
  gap: 12rpx;
}

.skill-tag {
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #2563eb;
  background: #eef4ff;
  border: 1rpx solid rgba(37,99,235,0.12);
  font-size: 23rpx;
  font-weight: 800;
}

.resume-action-bar {
  left: 24rpx;
  right: 24rpx;
  bottom: calc(14rpx + env(safe-area-inset-bottom));
  padding: 12rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(16,24,40,0.08);
  box-shadow: 0 18rpx 44rpx rgba(16,24,40,0.14);
  backdrop-filter: blur(20rpx);
}

.resume-act-btn {
  min-width: 0;
  height: 68rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.resume-act-btn.secondary {
  color: #344054;
  background: #f6f8fb;
}

.resume-action-bar c-button.resume-act-btn,
.resume-act-btn:not(.secondary) {
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e, #2563eb);
  box-shadow: 0 12rpx 24rpx rgba(37,99,235,0.20);
}

.resume-act-icon {
  font-size: 25rpx;
}

.resume-act-txt {
  font-size: 24rpx;
  font-weight: 900;
}

.resume-card {
  padding: 24rpx;
}

.file-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #eef4ff;
}

.name {
  color: #1d2939;
  font-size: 28rpx;
}

.footer-btn {
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  width: auto;
  padding: 0;
}

.resume-manager-panel,
.nlp-panel {
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -20rpx 60rpx rgba(16,24,40,0.16);
}

.edit-modal,
.ai-modal {
  padding: 30rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
}

.form-input,
.form-textarea,
.edit-textarea,
.skill-input {
  border-radius: 20rpx;
  background: #f8fbff;
  border: 1rpx solid #edf1f7;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Profile entry page polish */
.container,
.page {
  background: var(--app-page-bg);
}
