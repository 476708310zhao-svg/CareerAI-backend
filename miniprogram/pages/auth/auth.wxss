/* pages/auth/auth.wxss */

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #E8F0FF 0%, #F3EEFF 60%, #FFF0F8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx 80rpx;
  box-sizing: border-box;
}

/* ── 品牌区 ── */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  margin-bottom: 56rpx;
}

.logo-wrap {
  width: 136rpx;
  height: 136rpx;
  background: linear-gradient(135deg, #3B6EF8, #2B5CE6);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(43, 92, 230, 0.32);
}

.logo {
  width: 76rpx;
  height: 76rpx;
  filter: brightness(10);
}

.app-name {
  font-size: 52rpx;
  font-weight: 800;
  color: #1A1D27;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.tagline {
  font-size: 26rpx;
  color: #6B7280;
  letter-spacing: 1rpx;
}

/* ── 功能亮点 ── */
.features {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.65);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 40rpx;
  backdrop-filter: blur(8px);
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.feature-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.feature-label {
  font-size: 22rpx;
  color: #374151;
  font-weight: 500;
}

.feature-sep {
  width: 1rpx;
  height: 48rpx;
  background: #E5E7EB;
  margin: 0 4rpx;
}

/* ── 登录卡片 ── */
.login-card {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 48rpx rgba(43, 92, 230, 0.10);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  text-align: center;
  margin-bottom: 36rpx;
  display: block;
}

/* ── 隐私协议 ── */
.privacy-row {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
  padding: 4rpx 0;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid #D1D5DB;
  background: #F9FAFB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #2B5CE6;
  border-color: #2B5CE6;
}

.check-mark {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.privacy-desc {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  flex: 1;
}

.privacy-text {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}

.privacy-link {
  font-size: 24rpx;
  color: #2B5CE6;
  line-height: 1.5;
}

/* ── Shake 动画 ── */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20%       { transform: translateX(-6rpx); }
  40%       { transform: translateX(6rpx); }
  60%       { transform: translateX(-4rpx); }
  80%       { transform: translateX(4rpx); }
}

.checkbox.shake {
  animation: shake 0.4s ease;
  border-color: #EF4444;
}

/* ── 按钮 ── */
.btn-wrap {
  width: 100%;
  margin-bottom: 20rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 1rpx;
}

.btn::after {
  border: none;
}

.btn[disabled] {
  opacity: 0.45;
}

.btn-emoji {
  font-size: 34rpx;
  margin-right: 12rpx;
  line-height: 1;
}

.btn-label {
  line-height: 1;
}

.btn-wechat {
  background: linear-gradient(135deg, #1AAD19, #0F9B0F);
  color: #ffffff;
  box-shadow: 0 6rpx 24rpx rgba(26, 173, 25, 0.30);
}

.btn-phone {
  background: linear-gradient(135deg, #3B6EF8, #2B5CE6);
  color: #ffffff;
  box-shadow: 0 6rpx 24rpx rgba(43, 92, 230, 0.30);
  margin-bottom: 0;
}

/* ── 底部提示 ── */
.bottom-tip {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
  margin-top: 36rpx;
  line-height: 1.6;
}
