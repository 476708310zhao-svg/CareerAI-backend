<!-- pages/auth/auth.wxml -->
<view class="page">

  <!-- 顶部安全区占位 -->
  <view class="safe-top" style="height: {{statusBarHeight}}px"></view>

  <!-- 品牌区 -->
  <view class="brand">
    <view class="logo-wrap">
      <image class="logo" src="/images/home-active.png" mode="aspectFit" />
    </view>
    <text class="app-name">职引</text>
    <text class="tagline">专为留学生打造的一站式求职平台</text>
  </view>

  <!-- 功能亮点 -->
  <view class="features">
    <view class="feature-item">
      <text class="feature-emoji">🌍</text>
      <text class="feature-label">全球职位</text>
    </view>
    <view class="feature-sep"></view>
    <view class="feature-item">
      <text class="feature-emoji">🤖</text>
      <text class="feature-label">AI 面试</text>
    </view>
    <view class="feature-sep"></view>
    <view class="feature-item">
      <text class="feature-emoji">📅</text>
      <text class="feature-label">校招日历</text>
    </view>
    <view class="feature-sep"></view>
    <view class="feature-item">
      <text class="feature-emoji">📄</text>
      <text class="feature-label">简历诊断</text>
    </view>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">

    <text class="card-title">登录后开始求职之旅</text>

    <!-- 隐私协议 -->
    <view class="privacy-row" bindtap="toggleAgree">
      <view class="checkbox {{agreed ? 'checked' : ''}} {{shakeCheckbox ? 'shake' : ''}}">
        <text wx:if="{{agreed}}" class="check-mark">✓</text>
      </view>
      <view class="privacy-desc">
        <text class="privacy-text">我已阅读并同意</text>
        <text class="privacy-link" catchtap="onPrivacyTap">《用户协议与隐私政策》</text>
      </view>
    </view>

    <!-- 微信一键登录 -->
    <view class="btn-wrap" catchtap="onUnagreedTap">
      <button
        class="btn btn-wechat"
        bindtap="onWechatLogin"
        loading="{{loadingWechat}}"
        disabled="{{!agreed || loadingWechat || loadingPhone}}"
      >
        <text class="btn-emoji">💬</text>
        <text class="btn-label">微信一键登录</text>
      </button>
    </view>

    <!-- 手机号快捷登录 -->
    <view class="btn-wrap" catchtap="onUnagreedTap">
      <button
        class="btn btn-phone"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
        loading="{{loadingPhone}}"
        disabled="{{!agreed || loadingWechat || loadingPhone}}"
      >
        <text class="btn-emoji">📱</text>
        <text class="btn-label">手机号快捷登录</text>
      </button>
    </view>

  </view>

  <text class="bottom-tip">首次登录将自动创建账号，资料可随时补充完善</text>

</view>
