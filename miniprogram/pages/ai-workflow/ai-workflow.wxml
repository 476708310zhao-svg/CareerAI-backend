<!-- pages/ai-workflow/ai-workflow.wxml -->
<view class="page">

  <view class="drawer-mask {{drawerOpen ? 'show' : ''}}" catchtap="closeDrawer"></view>
  <view class="side-drawer {{drawerOpen ? 'show' : ''}}">
    <view class="drawer-brand">
      <view class="brand-mark">AI</view>
      <view class="brand-copy">
        <text class="brand-title">求职助手</text>
        <text class="brand-sub">你的职业规划工作台</text>
      </view>
    </view>

    <view class="drawer-primary" hover-class="drawer-press" bindtap="startNewChat">
      <text class="drawer-primary-icon">✎</text>
      <text class="drawer-primary-text">新聊天</text>
    </view>

    <view class="drawer-search">
      <text class="drawer-search-icon">⌕</text>
      <input
        class="drawer-search-input"
        placeholder="搜索聊天"
        value="{{sessionSearch}}"
        bindinput="onSessionSearch"
      />
      <text wx:if="{{sessionSearch}}" class="drawer-search-clear" catchtap="clearSessionSearch">×</text>
    </view>

    <view class="drawer-section">
      <view class="drawer-section-title">常用功能</view>
      <view class="tool-grid">
        <view
          wx:for="{{quickTools}}"
          wx:key="module"
          class="tool-card"
          data-module="{{item.module}}"
          bindtap="onToolTap"
          hover-class="drawer-press"
        >
          <text class="tool-icon">{{item.icon}}</text>
          <view class="tool-copy">
            <text class="tool-title">{{item.title}}</text>
            <text class="tool-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="drawer-section history-section-drawer">
      <view class="drawer-section-head">
        <text class="drawer-section-title">最近对话</text>
        <text class="drawer-count">{{filteredSessions.length}}</text>
      </view>
      <scroll-view scroll-y class="session-scroll">
        <view
          wx:for="{{filteredSessions}}"
          wx:key="id"
          class="session-item {{activeSessionId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectSession"
          hover-class="drawer-press"
        >
          <view class="session-dot"></view>
          <view class="session-main">
            <text class="session-title">{{item.title}}</text>
            <text class="session-preview">{{item.preview}}</text>
          </view>
          <view class="session-side">
            <text class="session-time">{{item.timeLabel}}</text>
            <text class="session-delete" catchtap="deleteSession" data-id="{{item.id}}">×</text>
          </view>
        </view>
        <view wx:if="{{filteredSessions.length === 0}}" class="drawer-empty">
          <text>还没有历史对话</text>
          <text>发起一次咨询后会自动保存</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="top-bar">
    <view class="menu-btn" bindtap="toggleDrawer" hover-class="top-press">
      <text class="menu-line"></text>
      <text class="menu-line"></text>
    </view>
    <view class="top-title">
      <text class="top-icon">✦</text>
      <view class="top-copy">
        <text class="top-name">AI 求职助手</text>
        <text class="top-model">CareerGPT</text>
      </view>
    </view>
    <view class="top-actions">
      <view class="new-chat-btn" bindtap="startNewChat" hover-class="top-press">＋</view>
      <view class="clear-btn" bindtap="onClear" hover-class="clear-hover">
        <text class="clear-txt">清空</text>
      </view>
    </view>
  </view>

  <scroll-view
    class="msg-scroll"
    scroll-y
    scroll-into-view="{{scrollId}}"
    scroll-with-animation
    style="margin-bottom: {{keyboardHeight > 0 ? keyboardHeight + 'px' : '0'}};"
  >
    <view class="msg-list">
      <block wx:for="{{messages}}" wx:key="id">
        <view wx:if="{{item.showTime}}" class="time-stamp">{{item.timeLabel}}</view>

        <view id="msg-{{index}}" class="msg-row {{item.role === 'user' ? 'user-row' : 'ai-row'}}">
          <view wx:if="{{item.role === 'ai'}}" class="ai-avatar">
            <text class="ai-avatar-icon">✦</text>
          </view>

          <view class="bubble-wrap">
            <view class="bubble {{item.role === 'user' ? 'user-bubble' : item.type === 'error' ? 'error-bubble' : 'ai-bubble'}}">
              <text class="bubble-text" user-select>{{item.text}}</text>
            </view>

            <view wx:if="{{item.actions && item.actions.length}}" class="action-cards">
              <view
                wx:for="{{item.actions}}"
                wx:for-item="action"
                wx:key="module"
                class="action-card"
                bindtap="onActionTap"
                data-module="{{action.module}}"
                data-params="{{action.params}}"
                hover-class="card-hover"
              >
                <text class="action-icon">{{action.icon}}</text>
                <text class="action-label">{{action.label}}</text>
                <text class="action-arrow">→</text>
              </view>
            </view>

            <view wx:if="{{item.suggestions && item.suggestions.length && index === latestAiIdx}}" class="suggestions">
              <view
                wx:for="{{item.suggestions}}"
                wx:for-item="sug"
                wx:key="*this"
                class="sug-chip {{loading ? 'sug-disabled' : ''}}"
                bindtap="onSuggestionTap"
                data-text="{{sug}}"
                hover-class="chip-hover"
              >{{sug}}</view>
            </view>
          </view>
        </view>
      </block>

      <view wx:if="{{loading}}" class="msg-row ai-row">
        <view class="ai-avatar"><text class="ai-avatar-icon">✦</text></view>
        <view class="bubble ai-bubble loading-bubble">
          <view class="dot-wrap">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>

      <view class="msg-bottom-spacer"></view>
    </view>
  </scroll-view>

  <view class="input-bar">
    <view class="input-wrap">
      <input
        class="input"
        placeholder="输入你的求职需求..."
        placeholder-class="input-ph"
        value="{{inputText}}"
        bindinput="onInputChange"
        bindconfirm="onSend"
        bindkeyboardheightchange="onKeyboardHeight"
        confirm-type="send"
        maxlength="200"
        adjust-position="{{false}}"
      />
    </view>
    <view class="input-right">
      <text wx:if="{{inputLen > 0}}" class="char-count {{inputLen >= 180 ? 'char-warn' : ''}}">{{inputLen}}/200</text>
      <view
        class="send-btn {{inputText && !loading ? 'active' : 'disabled'}}"
        bindtap="onSend"
        hover-class="{{inputText && !loading ? 'send-hover' : ''}}"
      >
        <text class="send-icon">↑</text>
      </view>
    </view>
  </view>

</view>
