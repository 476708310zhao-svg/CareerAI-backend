/* pages/ai-workflow/ai-workflow.wxss */
page { background: #F2F2F7; }

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F2F2F7;
}

/* ── 顶部栏 ── */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 16rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}
.top-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.top-icon {
  font-size: 28rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  color: transparent;
}
.top-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
}
.clear-btn {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #F2F2F7;
}
.clear-hover { opacity: 0.6; }
.clear-txt {
  font-size: 24rpx;
  color: #8E8E93;
}

/* ── 消息滚动区 ── */
.msg-scroll {
  flex: 1;
  overflow: hidden;
  transition: margin-bottom 0.25s;
}
.msg-list { padding: 16rpx 24rpx 0; }

/* ── 时间戳 ── */
.time-stamp {
  text-align: center;
  font-size: 22rpx;
  color: #C7C7CC;
  margin: 8rpx 0 4rpx;
}

/* ── 消息行 ── */
.msg-row {
  display: flex;
  margin-bottom: 28rpx;
  align-items: flex-end;
}
.ai-row  { flex-direction: row; }
.user-row { flex-direction: row-reverse; }

/* ── AI 头像 ── */
.ai-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-bottom: 4rpx;
}
.ai-avatar-icon { font-size: 28rpx; color: #fff; }

/* ── 气泡容器 ── */
.bubble-wrap {
  max-width: 82%;
  display: flex;
  flex-direction: column;
}
.ai-row .bubble-wrap   { align-items: flex-start; }
.user-row .bubble-wrap { align-items: flex-end; }

/* ── 气泡 ── */
.bubble {
  padding: 22rpx 26rpx;
  border-radius: 24rpx;
  word-break: break-word;
}
.ai-bubble {
  background: #FFFFFF;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
}
.user-bubble {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-bottom-right-radius: 8rpx;
}
.error-bubble {
  background: #FFF2F2;
  border: 1rpx solid #FFD0D0;
  border-bottom-left-radius: 8rpx;
}
.bubble-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #1C1C1E;
}
.user-bubble .bubble-text  { color: #FFFFFF; }
.error-bubble .bubble-text { color: #FF3B30; }

/* ── 操作卡片 ── */
.action-cards {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  width: 100%;
}
.action-card {
  display: flex;
  align-items: center;
  background: #fff;
  border: 1.5rpx solid #E5E7FF;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(102,126,234,0.08);
}
.card-hover { opacity: 0.7; }
.action-icon {
  font-size: 30rpx;
  margin-right: 14rpx;
}
.action-label {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #5B5FC7;
}
.action-arrow {
  font-size: 28rpx;
  color: #A0A4E0;
}

/* ── 快捷建议 ── */
.suggestions {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.sug-chip {
  background: #EEF0FF;
  color: #5B5FC7;
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #D0D4FF;
}
.sug-disabled { opacity: 0.45; }
.chip-hover { opacity: 0.65; }

/* ── 加载动画 ── */
.loading-bubble { padding: 20rpx 28rpx; }
.dot-wrap {
  display: flex;
  gap: 10rpx;
  align-items: center;
  height: 32rpx;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #C0C0C0;
  animation: bounce 1.2s infinite ease-in-out;
}
.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
  40%           { transform: scale(1.2); opacity: 1; }
}

/* ── 输入栏 ── */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #E5E5EA;
  gap: 16rpx;
}
.input-wrap {
  flex: 1;
  background: #F2F2F7;
  border-radius: 44rpx;
  padding: 0 28rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
}
.input {
  width: 100%;
  font-size: 28rpx;
  color: #1C1C1E;
  line-height: 72rpx;
}
.input-ph { color: #AEAEB2; }

.input-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}
.char-count {
  font-size: 20rpx;
  color: #AEAEB2;
  line-height: 1;
}
.char-warn { color: #FF9500; }

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #C7C7CC;
  display: flex;
  align-items: center;
  justify-content: center;
}
.send-btn.active  { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.send-btn.disabled { opacity: 0.5; }
.send-hover { opacity: 0.8; }
.send-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

/* 2026 kingkong polish: AI workflow */
page {
  background:
    radial-gradient(circle at 18% 0%, rgba(47, 102, 244, 0.14), transparent 34%),
    linear-gradient(180deg, #f7faff 0%, #f7f8fc 56%, #ffffff 100%);
  overflow-x: hidden;
}

.page {
  overflow-x: hidden;
}

.top-bar {
  margin: 16rpx 24rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(47, 102, 244, 0.1);
  background: linear-gradient(135deg, rgba(17, 36, 91, 0.98), rgba(47, 102, 244, 0.96));
  box-shadow: 0 18rpx 38rpx rgba(47, 102, 244, 0.22);
}

.top-name,
.top-icon {
  color: #ffffff;
}

.clear-btn {
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.clear-txt {
  color: rgba(255, 255, 255, 0.86);
}

.msg-scroll {
  margin-top: 18rpx;
}

.msg-list {
  padding: 0 24rpx calc(156rpx + env(safe-area-inset-bottom));
}

.ai-avatar {
  background: linear-gradient(135deg, #2f66f4, #13bfa6);
  box-shadow: 0 10rpx 20rpx rgba(47, 102, 244, 0.22);
}

.ai-bubble {
  border: 1rpx solid rgba(47, 102, 244, 0.08);
  border-radius: 8rpx 26rpx 26rpx 26rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(20, 34, 66, 0.08);
}

.user-bubble {
  border-radius: 26rpx 8rpx 26rpx 26rpx;
  background: linear-gradient(135deg, #2f66f4, #13bfa6);
  box-shadow: 0 12rpx 28rpx rgba(47, 102, 244, 0.18);
}

.action-card,
.sug-chip,
.clear-btn,
.send-btn {
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.action-card {
  border-radius: 24rpx;
  border: 1rpx solid rgba(47, 102, 244, 0.1);
  background: linear-gradient(180deg, #ffffff 0%, #f7faff 100%);
  box-shadow: 0 10rpx 22rpx rgba(20, 34, 66, 0.06);
}

.sug-chip {
  border-radius: 999rpx;
  background: #eef4ff;
  color: #2f66f4;
  border: 1rpx solid rgba(47, 102, 244, 0.12);
}

.input-bar {
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  width: auto;
  border-radius: 30rpx;
  border: 1rpx solid rgba(47, 102, 244, 0.1);
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 18rpx 38rpx rgba(20, 34, 66, 0.12);
}

.input-wrap {
  border-radius: 24rpx;
  background: #f7faff;
}

.send-btn.active {
  background: linear-gradient(135deg, #2f66f4, #13bfa6);
  box-shadow: 0 10rpx 22rpx rgba(47, 102, 244, 0.24);
}

.action-card:active,
.sug-chip:active,
.clear-btn:active,
.send-btn:active {
  transform: scale(0.94);
  opacity: 0.86;
}

/* 2026 ChatGPT-style workflow shell */
page {
  background: #f7f7f4;
}

.page {
  position: relative;
  height: 100vh;
  background:
    radial-gradient(circle at 16% 0%, rgba(47, 102, 244, 0.08), transparent 32%),
    #f7f7f4;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  background: rgba(15, 23, 42, 0);
  pointer-events: none;
  transition: background 0.2s ease;
}

.drawer-mask.show {
  background: rgba(15, 23, 42, 0.28);
  pointer-events: auto;
}

.side-drawer {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  z-index: 90;
  width: 560rpx;
  padding: calc(22rpx + env(safe-area-inset-top)) 20rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f2f2ef;
  border-right: 1rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 24rpx 0 48rpx rgba(15, 23, 42, 0.14);
  transform: translateX(-104%);
  transition: transform 0.24s ease;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.side-drawer.show {
  transform: translateX(0);
}

.drawer-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 6rpx 8rpx 10rpx;
}

.brand-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  background: #111827;
}

.brand-copy {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.brand-title {
  font-size: 30rpx;
  font-weight: 850;
  color: #111827;
}

.brand-sub {
  font-size: 22rpx;
  color: #6b7280;
}

.drawer-primary,
.drawer-search,
.tool-card,
.session-item {
  border-radius: 22rpx;
}

.drawer-primary {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 78rpx;
  padding: 0 20rpx;
  color: #111827;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
}

.drawer-primary-icon {
  font-size: 28rpx;
}

.drawer-primary-text {
  font-size: 27rpx;
  font-weight: 750;
}

.drawer-search {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  padding: 0 18rpx;
  background: #e9e9e5;
}

.drawer-search-icon {
  font-size: 28rpx;
  color: #6b7280;
}

.drawer-search-input {
  flex: 1;
  height: 72rpx;
  font-size: 25rpx;
  color: #111827;
}

.drawer-search-clear {
  width: 40rpx;
  height: 40rpx;
  text-align: center;
  line-height: 40rpx;
  color: #6b7280;
}

.drawer-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.drawer-section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.drawer-section-title {
  padding: 0 8rpx;
  font-size: 23rpx;
  font-weight: 750;
  color: #6b7280;
}

.drawer-count {
  min-width: 34rpx;
