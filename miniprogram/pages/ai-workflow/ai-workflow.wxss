/* pages/ai-workflow/ai-workflow.wxss */

page {
  background: #ffffff;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #ffffff;
  overflow-x: hidden;
  position: relative;
}

/* ── 抽屉遮罩 ── */
.drawer-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  background: rgba(15, 23, 42, 0);
  pointer-events: none;
  transition: background 0.2s ease;
}
.drawer-mask.show {
  background: rgba(15, 23, 42, 0.28);
  pointer-events: auto;
}

/* ── 侧边抽屉 ── */
.side-drawer {
  position: fixed;
  left: 0; top: 0; bottom: 0;
  z-index: 90;
  width: 590rpx;
  padding: calc(22rpx + env(safe-area-inset-top)) 22rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
  border-right: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 24rpx 0 54rpx rgba(15, 23, 42, 0.12);
  transform: translateX(-104%);
  transition: transform 0.24s ease;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.side-drawer.show { transform: translateX(0); }

.drawer-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 4rpx 14rpx;
}
.brand-mark {
  width: 58rpx; height: 58rpx;
  border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  color: #ffffff;
  font-size: 24rpx; font-weight: 900;
  background: #111827;
}
.brand-copy { display: flex; flex-direction: column; gap: 4rpx; }
.brand-title { font-size: 29rpx; font-weight: 850; color: #111827; }
.brand-sub   { font-size: 22rpx; color: #8a93a3; }

.drawer-primary {
  display: flex; align-items: center; gap: 14rpx;
  height: 76rpx; padding: 0 20rpx;
  color: #111827; background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  border-radius: 18rpx;
}
.drawer-primary:active { background: #f8fafc; }
.drawer-primary-icon { font-size: 28rpx; }
.drawer-primary-text { font-size: 27rpx; font-weight: 750; }

.drawer-search {
  display: flex; align-items: center; gap: 12rpx;
  height: 76rpx; padding: 0 18rpx;
  background: #f7f7f8;
  border-radius: 18rpx;
  border: 0;
}
.drawer-search-icon  { font-size: 28rpx; color: #6b7280; }
.drawer-search-input { flex: 1; height: 72rpx; font-size: 25rpx; color: #111827; }
.drawer-search-clear { width: 40rpx; height: 40rpx; text-align: center; line-height: 40rpx; color: #6b7280; }

.drawer-section      { display: flex; flex-direction: column; gap: 12rpx; }
.drawer-section-head { display: flex; justify-content: space-between; align-items: center; }
.drawer-section-title { padding: 0 4rpx; font-size: 23rpx; font-weight: 750; color: #6b7280; }
.drawer-count {
  min-width: 34rpx; height: 34rpx;
  padding: 0 10rpx; border-radius: 999rpx;
  text-align: center; line-height: 34rpx;
  color: #2563eb; background: #e5edff;
  font-size: 20rpx; font-weight: 800;
}

.tool-grid { display: flex; flex-direction: column; gap: 4rpx; }
.tool-card {
  display: flex; align-items: center; gap: 14rpx;
  padding: 14rpx 10rpx;
  border: 0; border-radius: 18rpx; background: #ffffff;
}
.tool-card:active { background: #f7f7f8; }
.tool-icon {
  width: 50rpx; height: 50rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
  background: #f7f7f8;
}
.tool-copy  { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 3rpx; }
.tool-title { color: #111827; font-size: 25rpx; font-weight: 750; }
.tool-desc  { color: #7b8190; font-size: 20rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.history-section-drawer { flex: 1; min-height: 0; }
.session-scroll { flex: 1; min-height: 0; max-height: 46vh; background: #ffffff; }

.session-item {
  position: relative;
  display: flex; align-items: center; gap: 12rpx;
  padding: 14rpx 10rpx; margin-bottom: 4rpx;
  border: 0; border-radius: 18rpx; background: #ffffff;
}
.session-item:active { background: #f8fafc; }
.session-item.active { background: #f7f7f8; border: 0; box-shadow: none; }
.session-dot {
  width: 8rpx; height: 8rpx;
  border-radius: 50%; background: #d1d5db; flex-shrink: 0;
}
.session-item.active .session-dot { background: #2563eb; }
.session-main   { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.session-title  { font-size: 25rpx; font-weight: 700; color: #111827; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.session-preview { font-size: 20rpx; color: #7b8190; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.session-side   { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; }
.session-time   { font-size: 19rpx; color: #9ca3af; }
.session-delete { width: 34rpx; height: 34rpx; border-radius: 50%; text-align: center; line-height: 34rpx; color: #a2a9b5; }

.drawer-empty {
  display: flex; flex-direction: column; align-items: center;
  gap: 8rpx; padding: 36rpx 16rpx;
  color: #9ca3af; font-size: 23rpx; background: #ffffff;
}
.drawer-press, .top-press { transform: scale(0.96); opacity: 0.82; }

/* ── 顶部栏 ── */
.top-bar {
  display: flex; align-items: center; justify-content: space-between;
  position: relative; z-index: 10;
  margin: 0; padding: 18rpx 28rpx 16rpx;
  border-radius: 0; border: 0;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
  background: #ffffff; box-shadow: none;
}
.menu-btn {
  width: 56rpx; height: 56rpx; border-radius: 16rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx;
  background: transparent;
}
.menu-line { width: 28rpx; height: 3rpx; border-radius: 999rpx; background: #0f172a; }
.top-title { display: flex; align-items: center; gap: 12rpx; flex: 1; min-width: 0; justify-content: center; }
.top-icon {
  width: 48rpx; height: 48rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
  color: #ffffff; background: #111827;
}
.top-copy  { display: flex; flex-direction: column; gap: 2rpx; }
.top-name  { font-size: 29rpx; font-weight: 850; color: #111827; letter-spacing: -0.2rpx; }
.top-model { font-size: 19rpx; color: #8a93a3; }
.top-actions { display: flex; align-items: center; gap: 10rpx; flex-shrink: 0; width: 56rpx; justify-content: flex-end; }
.new-chat-btn {
  width: 56rpx; height: 56rpx; border-radius: 16rpx;
  text-align: center; line-height: 56rpx;
  color: #0f172a; background: transparent;
  font-size: 30rpx; font-weight: 700;
}
.clear-btn  { height: 58rpx; padding: 0 20rpx; display: flex; align-items: center; background: #f4f4f1; border: 0; border-radius: 20rpx; }
.clear-txt  { font-size: 24rpx; color: #374151; }
.clear-hover { opacity: 0.6; }

/* ── 消息区 ── */
.msg-scroll {
  flex: 1; overflow: hidden; margin-top: 0; background: #ffffff;
  transition: margin-bottom 0.25s;
}
.msg-list { padding: 24rpx 32rpx calc(142rpx + env(safe-area-inset-bottom)); background: #ffffff; }
.msg-bottom-spacer { height: 12rpx; }

.time-stamp { text-align: center; font-size: 22rpx; color: #a2a9b5; margin: 2rpx 0 18rpx; }

.msg-row  { display: flex; align-items: flex-start; margin-bottom: 26rpx; }
.ai-row   { flex-direction: row; }
.user-row { flex-direction: row-reverse; }

.ai-avatar {
  width: 50rpx; height: 50rpx; border-radius: 14rpx;
  background: #111827;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-right: 14rpx; margin-bottom: 4rpx;
}
.ai-avatar-icon { font-size: 24rpx; color: #fff; }

.bubble-wrap { max-width: 86%; display: flex; flex-direction: column; }
.ai-row .bubble-wrap   { align-items: flex-start; }
.user-row .bubble-wrap { align-items: flex-end; }

.bubble       { padding: 20rpx 24rpx; border-radius: 24rpx; word-break: break-word; }
.ai-bubble    { border: 0; border-radius: 18rpx; background: #ffffff; box-shadow: none; }
.user-bubble  { border-radius: 22rpx; background: #f4f4f5; box-shadow: none; }
.error-bubble { background: #FFF2F2; border: 1rpx solid #FFD0D0; border-bottom-left-radius: 8rpx; }
.bubble-text  { font-size: 28rpx; line-height: 1.78; color: #20242d; }
.user-bubble .bubble-text  { color: #111827; }
.error-bubble .bubble-text { color: #FF3B30; }

/* ── 操作卡片 ── */
.action-cards { margin-top: 14rpx; display: flex; flex-direction: column; gap: 12rpx; width: 100%; }
.action-card {
  display: flex; align-items: center;
  background: #ffffff;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  box-shadow: none;
}
.card-hover   { opacity: 0.7; }
.action-icon  { font-size: 30rpx; margin-right: 14rpx; }
.action-label { flex: 1; font-size: 26rpx; font-weight: 600; color: #2563eb; }
.action-arrow { font-size: 28rpx; color: #2563eb; }

/* ── 快捷建议 ── */
.suggestions { margin-top: 16rpx; display: flex; flex-wrap: wrap; gap: 12rpx; }
.sug-chip {
  background: #ffffff; color: #2563eb;
  font-size: 24rpx; font-weight: 500;
  padding: 10rpx 18rpx; border-radius: 999rpx;
  border: 1rpx solid rgba(37, 99, 235, 0.22);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.05);
}
.sug-disabled { opacity: 0.45; }
.chip-hover   { opacity: 0.65; }

/* ── 加载动画 ── */
.loading-bubble { padding: 20rpx 28rpx; }
.dot-wrap { display: flex; gap: 10rpx; align-items: center; height: 32rpx; }
.dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  background: #C0C0C0;
  animation: bounce 1.2s infinite ease-in-out;
}
.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
  40%           { transform: scale(1.2); opacity: 1; }
}

/* ── 输入栏 ── */
.input-bar {
  position: fixed;
  left: 20rpx; right: 20rpx;
  bottom: calc(14rpx + env(safe-area-inset-bottom));
  width: auto; z-index: 20;
  min-height: 88rpx; padding: 10rpx 12rpx;
  box-sizing: border-box;
  display: flex; align-items: center; gap: 16rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.10);
}
.input-wrap {
  flex: 1; background: #f6f7f9;
  border-radius: 22rpx; padding: 0 24rpx;
  height: 66rpx; display: flex; align-items: center;
}
.input    { width: 100%; font-size: 27rpx; color: #1C1C1E; height: 66rpx; line-height: 66rpx; }
.input-ph { color: #a2a9b5; }
.input-right { display: flex; flex-direction: column; align-items: center; gap: 4rpx; flex-shrink: 0; }
.char-count  { font-size: 20rpx; color: #AEAEB2; line-height: 1; }
.char-warn   { color: #FF9500; }
.send-btn    { width: 66rpx; height: 66rpx; border-radius: 50%; background: #e5e7eb; display: flex; align-items: center; justify-content: center; }
.send-btn.active   { background: #111827; box-shadow: none; }
.send-btn.disabled { opacity: 0.5; }
.send-hover { opacity: 0.8; }
.send-icon  { font-size: 32rpx; color: #fff; font-weight: 700; }

/* ── 触摸反馈 ── */
.action-card:active,
.sug-chip:active,
.clear-btn:active,
.send-btn:active {
  transform: scale(0.94);
  opacity: 0.86;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}
