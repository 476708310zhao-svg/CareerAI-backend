/* pages/settings/settings.wxss */
page {
  background: #F2F4F8;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.container {
  padding: 24rpx 24rpx 40rpx;
}

/* 给每个 cell-group 之间留间距 */
t-cell-group {
  margin-bottom: 24rpx;
}

.version-info {
  text-align: center;
  font-size: 24rpx;
  color: #C4C9D4;
  padding: 40rpx 0;
  line-height: 1.8;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Profile entry page polish */
.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-intro {
  margin-bottom: 24rpx;
}

.page-title {
  display: block;
  color: #111827;
  font-size: 42rpx;
  font-weight: 950;
}

.page-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
}

t-cell-group {
  display: block;
  margin-bottom: 22rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.version-info {
  color: #98a2b3;
}
