/* pages/vip/vip.wxss */
page {
  --vip-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  --vip-brand: #2563eb;
  --vip-teal: #14b8a6;
  --vip-ink: #111827;
  --vip-body: #475569;
  --vip-muted: #94a3b8;
  --vip-line: #e4eaf2;
  --vip-soft: #f8fbff;
  background: var(--vip-bg);
  background-color: #ffffff;
  color: var(--vip-ink);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.vip-page {
  min-height: 100vh;
  padding: 18rpx 24rpx 0;
  background: var(--vip-bg);
  box-sizing: border-box;
}

.hero-card,
.section,
.compare-card,
.vip-active-card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(220, 229, 240, 0.96);
  box-shadow: 0 16rpx 42rpx rgba(32, 48, 70, 0.07);
}

.hero-card {
  padding: 26rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 96% 0%, rgba(20, 184, 166, 0.12), transparent 34%),
    linear-gradient(135deg, rgba(255,255,255,0.98) 0%, rgba(241,248,255,0.98) 62%, rgba(236,253,245,0.96) 100%);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-kicker {
  display: block;
  color: var(--vip-brand);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 1.4rpx;
}

.hero-title {
  display: block;
  margin-top: 8rpx;
  color: var(--vip-ink);
  font-size: 46rpx;
  line-height: 1.08;
  font-weight: 950;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  color: var(--vip-body);
  font-size: 25rpx;
  line-height: 1.45;
}

.hero-status {
  flex-shrink: 0;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  color: #64748b;
  background: #f1f5f9;
  font-size: 22rpx;
  font-weight: 850;
}

.hero-status.active {
  color: #047857;
  background: #ecfdf5;
}

.member-card {
  position: relative;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 100% 0%, rgba(255,255,255,0.22), transparent 34%),
    linear-gradient(135deg, #172554 0%, #2563eb 62%, #14b8a6 100%);
  box-shadow: 0 18rpx 38rpx rgba(37, 99, 235, 0.18);
}

.member-main {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.member-label {
  display: block;
  color: rgba(255,255,255,0.72);
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.member-name {
  display: block;
  margin-top: 20rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 950;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-desc {
  display: block;
  margin-top: 8rpx;
  color: rgba(255,255,255,0.78);
  font-size: 23rpx;
  line-height: 1.35;
}

.member-mark {
  width: 108rpx;
  height: 108rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.15);
  border: 1rpx solid rgba(255,255,255,0.2);
}

.member-mark-num {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1;
}

.member-mark-txt {
  margin-top: 4rpx;
  color: rgba(255,255,255,0.76);
  font-size: 20rpx;
  font-weight: 850;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 20rpx;
}

.stat-item {
  min-width: 0;
  padding: 16rpx 8rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.82);
  border: 1rpx solid rgba(220, 229, 240, 0.82);
  text-align: center;
}

.stat-num {
  display: block;
  color: var(--vip-brand);
  font-size: 30rpx;
  line-height: 1;
  font-weight: 950;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 20rpx;
  font-weight: 750;
}

.section {
  margin-top: 20rpx;
  padding: 24rpx;
}

.plans-section {
  background:
    radial-gradient(circle at 100% 0%, rgba(37,99,235,0.07), transparent 34%),
    rgba(255,255,255,0.96);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  color: var(--vip-ink);
  font-size: 31rpx;
  font-weight: 950;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.35;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.plan-card {
  position: relative;
  min-height: 122rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 26rpx 26rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1.5rpx solid var(--vip-line);
  box-shadow: 0 10rpx 24rpx rgba(32, 48, 70, 0.045);
  box-sizing: border-box;
  overflow: hidden;
}

.plan-card.selected {
  border-color: rgba(37,99,235,0.56);
  background:
    radial-gradient(circle at 100% 0%, rgba(20,184,166,0.10), transparent 34%),
    linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  box-shadow: 0 16rpx 34rpx rgba(37,99,235,0.14);
}

.plan-ribbon {
  position: absolute;
  top: 0;
  left: 0;
  padding: 6rpx 18rpx;
  border-radius: 24rpx 0 18rpx 0;
  color: #ffffff;
  background: linear-gradient(135deg, var(--vip-brand), var(--vip-teal));
  font-size: 20rpx;
  font-weight: 850;
}

.plan-info {
  flex: 1;
  min-width: 0;
  padding-top: 8rpx;
}

.plan-name {
  display: block;
  color: var(--vip-ink);
  font-size: 30rpx;
  font-weight: 900;
}

.plan-sub {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
}

.plan-save {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  color: #047857;
  background: #ecfdf5;
  font-size: 21rpx;
  font-weight: 800;
}

.plan-price {
  flex-shrink: 0;
  text-align: right;
}

.price-row {
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  gap: 2rpx;
}

.price-unit {
  color: var(--vip-brand);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.35;
}

.price-num {
  color: var(--vip-brand);
  font-size: 50rpx;
  line-height: 0.95;
  font-weight: 950;
}

.price-origin {
  display: block;
  margin-top: 8rpx;
  color: #b8c0cc;
  font-size: 22rpx;
  text-decoration: line-through;
}

.plan-check {
  position: absolute;
  right: 18rpx;
  bottom: 16rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  color: #ffffff;
  background: linear-gradient(135deg, var(--vip-brand), var(--vip-teal));
  font-size: 21rpx;
  font-weight: 900;
  line-height: 34rpx;
  text-align: center;
}

.benefit-grid,
.ai-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.benefit-card,
.ai-card,
.case-card {
  background: #ffffff;
  border: 1rpx solid var(--vip-line);
  box-shadow: 0 10rpx 24rpx rgba(32, 48, 70, 0.045);
}

.benefit-card {
  min-height: 176rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
}

.benefit-icon {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: var(--vip-brand);
  background: #eef4ff;
  font-size: 24rpx;
  font-weight: 950;
}

.benefit-title {
  display: block;
  margin-top: 16rpx;
  color: var(--vip-ink);
  font-size: 26rpx;
  font-weight: 900;
}

.benefit-desc {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.4;
}

.ai-card {
  position: relative;
  min-height: 204rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.ai-card.locked::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(248, 251, 255, 0.38);
  pointer-events: none;
}

.ai-card.unlocked {
  background:
    radial-gradient(circle at 100% 0%, rgba(37,99,235,0.07), transparent 34%),
    #ffffff;
}

.ai-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10rpx;
}

.ai-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef4ff;
  font-size: 31rpx;
}

.ai-badge {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #1d4ed8;
  background: #eef4ff;
  border: 1rpx solid #d8e7ff;
  font-size: 18rpx;
  font-weight: 900;
}

.ai-badge.new {
  color: #047857;
  background: #ecfdf5;
  border-color: #c9f4e5;
}

.ai-name {
  display: block;
  margin-top: 16rpx;
  color: var(--vip-ink);
  font-size: 26rpx;
  line-height: 1.28;
  font-weight: 900;
}

.ai-desc {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.42;
}

.ai-lock,
.ai-arrow {
  position: absolute;
  right: 18rpx;
  bottom: 16rpx;
  font-size: 20rpx;
  font-weight: 850;
}

.ai-lock {
  color: #98a2b3;
}

.ai-arrow {
  color: var(--vip-brand);
}

.cases-scroll {
  width: 100%;
  white-space: nowrap;
}

.cases-inner {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 2rpx;
}

.case-card {
  width: 318rpx;
  min-height: 308rpx;
  flex-shrink: 0;
  padding: 22rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  white-space: normal;
}

.case-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.case-avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #eaf2ff, #ecfdf5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.case-tag {
  padding: 5rpx 13rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, var(--vip-brand), var(--vip-teal));
  font-size: 19rpx;
  font-weight: 850;
}

.case-name {
  display: block;
  margin-top: 16rpx;
  color: var(--vip-ink);
  font-size: 27rpx;
  font-weight: 900;
}

.case-role {
  display: block;
  margin-top: 6rpx;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.32;
}

.case-story {
  display: block;
  margin-top: 18rpx;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.5;
}

.case-result {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fbff;
  border: 1rpx solid #dbeafe;
}

.case-label {
  color: #64748b;
  font-size: 21rpx;
}

.case-value {
  color: var(--vip-brand);
  font-size: 23rpx;
  font-weight: 900;
}

.compare-card {
  margin-top: 20rpx;
  overflow: hidden;
}

.compare-toggle {
  height: 92rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--vip-brand);
  font-size: 26rpx;
  font-weight: 850;
}

.compare-icon {
  color: #94a3b8;
  font-size: 20rpx;
}

.compare-table {
  border-top: 1rpx solid var(--vip-line);
}

.compare-head,
.compare-row {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1.2fr;
  gap: 10rpx;
  padding: 18rpx 22rpx;
  align-items: center;
}

.compare-head {
  background: #f8fbff;
  color: var(--vip-ink);
  font-size: 23rpx;
  font-weight: 900;
}

.compare-row {
  border-top: 1rpx solid #f1f5f9;
  color: #667085;
  font-size: 22rpx;
}

.col-free,
.col-vip {
  text-align: center;
}

.vip-value {
  color: #0f766e;
  font-weight: 850;
}

.vip-active-card {
  margin-top: 20rpx;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, var(--vip-brand), var(--vip-teal));
  border-color: rgba(255,255,255,0.44);
}

.active-title {
  display: block;
  font-size: 32rpx;
  font-weight: 950;
}

.active-sub,
.active-hint {
  display: block;
  margin-top: 8rpx;
  color: rgba(255,255,255,0.86);
  font-size: 24rpx;
  line-height: 1.5;
}

.restore-link {
  padding: 28rpx 0 10rpx;
  color: #64748b;
  text-align: center;
  font-size: 24rpx;
}

.disclaimer {
  padding: 16rpx 18rpx 0;
  color: #98a2b3;
  text-align: center;
  font-size: 21rpx;
  line-height: 1.5;
}

.bottom-space {
  height: calc(160rpx + env(safe-area-inset-bottom));
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.95);
  border-top: 1rpx solid rgba(220, 229, 240, 0.96);
  box-shadow: 0 -12rpx 36rpx rgba(32, 48, 70, 0.08);
  backdrop-filter: blur(20rpx);
}

.footer-price {
  width: 150rpx;
  flex-shrink: 0;
}

.fp-label {
  display: block;
  color: #94a3b8;
  font-size: 22rpx;
}

.fp-row {
  display: flex;
  align-items: flex-end;
  gap: 2rpx;
}

.fp-unit {
  color: var(--vip-brand);
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.35;
}

.fp-num {
  color: var(--vip-brand);
  font-size: 48rpx;
  line-height: 0.95;
  font-weight: 950;
}

.pay-btn {
  flex: 1;
  min-width: 0;
  height: 86rpx;
  border-radius: 999rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, var(--vip-brand), var(--vip-teal));
  box-shadow: 0 14rpx 28rpx rgba(37,99,235,0.22);
}

.pay-btn.paying {
  opacity: 0.72;
}

.pay-main {
  font-size: 29rpx;
  line-height: 1.1;
  font-weight: 950;
}

.pay-sub {
  margin-top: 5rpx;
  color: rgba(255,255,255,0.82);
  font-size: 19rpx;
  font-weight: 750;
}
