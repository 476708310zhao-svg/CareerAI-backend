page {
  min-height: 100%;
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding: 22rpx 26rpx 0;
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 30rpx 30rpx 32rpx;
  border-radius: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #17284d 0%, #2457d6 62%, #4d7cf1 100%);
  box-shadow: 0 18rpx 38rpx rgba(37, 87, 214, 0.2);
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-orb-one {
  width: 190rpx;
  height: 190rpx;
  right: -52rpx;
  top: -66rpx;
}

.hero-orb-two {
  width: 92rpx;
  height: 92rpx;
  right: 102rpx;
  bottom: -48rpx;
}

.hero-kicker,
.hero-title,
.hero-desc,
.section-title,
.section-subtitle,
.primary-title,
.primary-desc,
.resource-title,
.resource-desc {
  display: block;
}

.hero-kicker {
  position: relative;
  color: #a9c5ff;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.hero-title {
  position: relative;
  margin-top: 9rpx;
  font-size: 40rpx;
  font-weight: 850;
}

.hero-desc {
  position: relative;
  width: 82%;
  margin-top: 11rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 21rpx;
  line-height: 1.55;
}

.section {
  margin-top: 30rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 4rpx;
  margin-bottom: 14rpx;
}

.section-title {
  color: #111d32;
  font-size: 30rpx;
  font-weight: 850;
}

.section-subtitle {
  margin-top: 4rpx;
  color: #8794a7;
  font-size: 19rpx;
}

.primary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.primary-card {
  position: relative;
  min-height: 138rpx;
  display: flex;
  align-items: center;
  gap: 13rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: 1rpx solid #e3eaf3;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 9rpx 24rpx rgba(33, 54, 88, 0.055);
}

.primary-copy,
.resource-copy {
  min-width: 0;
  flex: 1;
}

.resource-icon {
  width: 54rpx;
  height: 54rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 17rpx;
  font-size: 18rpx;
  font-weight: 850;
}

.tone-blue { color: #2462df; background: #eaf2ff; }
.tone-violet { color: #6850db; background: #f0edff; }
.tone-green { color: #168b68; background: #e7f8f1; }
.tone-amber { color: #be761b; background: #fff3df; }

.primary-title,
.resource-title {
  overflow: hidden;
  color: #1a263b;
  font-size: 23rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.primary-desc,
.resource-desc {
  margin-top: 5rpx;
  overflow: hidden;
  color: #8490a2;
  font-size: 18rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.primary-arrow,
.resource-arrow {
  flex-shrink: 0;
  color: #a4afbd;
  font-size: 31rpx;
}

.resource-list {
  overflow: hidden;
  border: 1rpx solid #e2e9f2;
  border-radius: 26rpx;
  background: #fff;
  box-shadow: 0 10rpx 27rpx rgba(33, 54, 88, 0.045);
}

.resource-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid #edf1f6;
}

.resource-row:last-child {
  border-bottom: 0;
}

.card-hover,
.row-hover {
  opacity: 0.82;
  background: #f7faff;
}

.bottom-spacer {
  height: calc(150rpx + env(safe-area-inset-bottom));
}
