<view class="page">
  <view class="hero">
    <view class="hero-orb hero-orb-one"></view>
    <view class="hero-orb hero-orb-two"></view>
    <text class="hero-kicker">RESOURCE LIBRARY</text>
    <text class="hero-title">求职资源库</text>
    <text class="hero-desc">从面试准备、笔试练习到职业探索，一站找到需要的工具与内容。</text>
  </view>

  <view class="section primary-section">
    <view class="section-head">
      <view>
        <text class="section-title">常用资源</text>
        <text class="section-subtitle">高频求职场景快速入口</text>
      </view>
    </view>
    <view class="primary-grid">
      <view
        class="primary-card"
        wx:for="{{primaryResources}}"
        wx:key="id"
        data-url="{{item.url}}"
        bindtap="openResource"
        hover-class="card-hover"
      >
        <view class="resource-icon tone-{{item.tone}}">{{item.icon}}</view>
        <view class="primary-copy">
          <text class="primary-title">{{item.title}}</text>
          <text class="primary-desc">{{item.desc}}</text>
        </view>
        <text class="primary-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section resource-section" wx:for="{{resourceSections}}" wx:key="id">
    <view class="section-head">
      <view>
        <text class="section-title">{{item.title}}</text>
        <text class="section-subtitle">{{item.subtitle}}</text>
      </view>
    </view>
    <view class="resource-list">
      <view
        class="resource-row"
        wx:for="{{item.items}}"
        wx:for-item="resource"
        wx:key="id"
        data-url="{{resource.url}}"
        bindtap="openResource"
        hover-class="row-hover"
      >
        <view class="resource-icon tone-{{resource.tone}}">{{resource.icon}}</view>
        <view class="resource-copy">
          <text class="resource-title">{{resource.title}}</text>
          <text class="resource-desc">{{resource.desc}}</text>
        </view>
        <text class="resource-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>
