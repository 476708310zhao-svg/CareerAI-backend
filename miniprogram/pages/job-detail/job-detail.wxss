/* pages/job-detail/job-detail.wxss */
page {
  background: var(--bg-raised);
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

/* ====== 头部卡片 ====== */
.head-card {
  margin: 24rpx;
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 36rpx;
  box-shadow: var(--shadow-md);
}

.head-top {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.head-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--r-lg);
  border: 1.5rpx solid var(--border);
  margin-right: 24rpx;
  background: var(--bg-raised);
  flex-shrink: 0;
}

.head-info { flex: 1; min-width: 0; }

.head-company {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 6rpx;
}

.head-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.35;
  display: block;
}

/* 薪资行 */
.salary-row {
  background: var(--success-bg-solid);
  border-radius: var(--r-sm);
  padding: 22rpx 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: baseline;
  border: 1rpx solid var(--success-bg);
}

.salary-val {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--success-text);
}

.salary-unit {
  font-size: 22rpx;
  color: var(--success-text);
  margin-left: 6rpx;
}

/* 技能图标 */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}
.skill-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #F8FAFF;
  border: 1.5rpx solid #E4EEFF;
  border-radius: 16rpx;
  padding: 8rpx 18rpx 8rpx 10rpx;
}
.skill-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}
.skill-name {
  font-size: 22rpx;
  color: #374151;
  font-weight: 500;
}

/* 信息标签 */
.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

/* ====== 描述卡片 ====== */
.desc-card {
  margin: 0 24rpx 24rpx;
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 36rpx;
  box-shadow: var(--shadow-md);
}

.desc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-left: 18rpx;
  border-left: 8rpx solid var(--brand);
  line-height: 1;
}

.desc-body {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.85;
  white-space: pre-wrap;
  display: block;
}

/* ====== 底部操作栏 ====== */
.footer-icons {
  width: 146rpx;
  max-width: 146rpx;
}

.f-icon-txt {
  color: inherit;
  font-size: 30rpx;
  line-height: 1;
}

.f-btn-ai {
  font-size: 25rpx;
}

.ai-badge {
  width: 36rpx; height: 36rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, var(--brand), #6366F1);
  color: #fff;
  font-size: 16rpx;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 6rpx;
  flex-shrink: 0;
}

/* ====== Loading ====== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 240rpx;
}

.spinner {
  width: 48rpx; height: 48rpx;
  border: 5rpx solid #F1F3F7;
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

.loading-txt { font-size: 26rpx; color: var(--text-muted); }

@keyframes spin { to { transform: rotate(360deg); } }

/* ====== 一键投递弹窗 ====== */
.apply-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 500;
}

.apply-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--bg-panel);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 501;
  padding: 32rpx 36rpx calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
}

.apply-panel.show {
  transform: translateY(0);
}

.ap-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.ap-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.ap-close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 0 8rpx;
}

.ap-job-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--bg-raised);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.ap-job-logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.ap-job-info { flex: 1; min-width: 0; }

.ap-job-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ap-job-company {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.ap-resume-card {
  background: #f8faff;
  border: 1.5rpx solid #c7d2fe;
  border-radius: 18rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
}

.ap-resume-label {
  display: block;
  font-size: 20rpx;
  color: var(--brand);
  font-weight: 600;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.ap-rname {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.ap-rsub {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.ap-rcontact {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.ap-rskills {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.ap-resume-empty {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.ap-resume-link {
  color: var(--brand);
  font-weight: 600;
}

.ap-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.ap-btn-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  background: var(--bg-raised);
  color: var(--text-secondary);
  border: 1.5rpx solid rgba(0,0,0,0.08);
}

.ap-btn-submit {
  flex: 2;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--brand), #6366F1);
  box-shadow: 0 6rpx 20rpx rgba(37,99,235,0.35);
}

.ap-tip {
  display: block;
  font-size: 20rpx;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.6;
}

/* ── 求职路线规划入口 ── */
.roadmap-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 24rpx 0;
  padding: 24rpx 26rpx;
  background: linear-gradient(135deg, #EEF2FF 0%, #F5F3FF 100%);
  border-radius: var(--r-lg);
  border: 1.5rpx solid #C7D2FE;
  gap: 16rpx;
}
.roadmap-cta:active { opacity: 0.75; }

.roadmap-cta-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}
.roadmap-cta-icon  { font-size: 44rpx; flex-shrink: 0; }
.roadmap-cta-info  { flex: 1; min-width: 0; }
.roadmap-cta-title {
  display: block;
  font-size: 28rpx; font-weight: 700; color: #1e3a8a;
  margin-bottom: 6rpx;
}
.roadmap-cta-sub {
  display: block;
  font-size: 22rpx; color: #4338CA;
  line-height: 1.5;
}
.roadmap-cta-arrow {
  font-size: 40rpx; color: var(--brand);
  flex-shrink: 0;
}

/* Job detail product polish */
page {
  background:
    radial-gradient(circle at 14% 0%, rgba(43, 92, 230, 0.08), transparent 30%),
    linear-gradient(180deg, #f8fbff 0%, #f6f8fc 52%, #ffffff 100%);
}

.page {
  min-height: 100vh;
  overflow-x: hidden;
}

.head-card,
.desc-card,
.roadmap-cta {
  border: 1rpx solid rgba(31, 45, 74, 0.06);
  box-shadow: 0 18rpx 44rpx rgba(31, 45, 74, 0.08);
}

.head-card {
  margin: 20rpx 24rpx;
  padding: 34rpx 32rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(43, 92, 230, 0.09), transparent 34%),
    #ffffff;
}

.head-top {
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.head-logo-wrap {
  width: 108rpx;
  height: 108rpx;
  margin-right: 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(31, 45, 74, 0.08);
  background: linear-gradient(145deg, #ffffff, #f2f6ff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 12rpx 26rpx rgba(31, 45, 74, 0.08);
}

.head-logo {
  width: 88rpx;
  height: 88rpx;
  margin: 0;
  border: none;
  border-radius: 0;
  background: transparent;
}

.head-logo-initial,
.ap-job-logo-initial {
  color: #2b5ce6;
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.head-company {
  margin-bottom: 8rpx;
  color: #667085;
  font-size: 25rpx;
  font-weight: 650;
}

.head-title {
  color: #172033;
  font-size: 38rpx;
  letter-spacing: -0.6rpx;
}

.salary-row {
  margin-bottom: 22rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #e8fbf3 0%, #f0fdf8 100%);
  border-color: rgba(16, 185, 129, 0.16);
}

.salary-val {
  color: #059669;
  font-size: 34rpx;
}

.info-tags {
  gap: 14rpx 12rpx;
}

.desc-card {
  margin: 0 24rpx 22rpx;
  padding: 34rpx 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
}

.desc-title {
  margin-bottom: 22rpx;
  padding-left: 18rpx;
  border-left-width: 7rpx;
  font-size: 31rpx;
}

.desc-body {
  color: #596579;
  line-height: 1.88;
}

.roadmap-cta {
  margin: 0 24rpx 22rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #eef5ff 0%, #f7f3ff 100%);
}

.roadmap-cta-title {
  color: #1d4ed8;
}

.roadmap-cta-sub {
  color: #5865d6;
}

.detail-safe-tail {
  height: calc(112rpx + env(safe-area-inset-bottom));
}

.footer-icons {
  width: 146rpx;
  max-width: 146rpx;
}

.ap-job-logo-wrap {
  width: 78rpx;
  height: 78rpx;
  border-radius: 18rpx;
  background: #eef4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.ap-job-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 0;
  background: transparent;
}

/* Conversion-first detail */
.head-kicker {
  display: block;
  margin-bottom: 6rpx;
  color: #2b5ce6;
  font-size: 21rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
}

.head-conversion-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.conversion-pill {
  min-width: 0;
  padding: 16rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(248, 250, 252, 0.92);
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  text-align: center;
}

.conversion-num {
  display: block;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1.1;
}

.conversion-label {
  display: block;
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 19rpx;
  font-weight: 700;
}

.action-lab {
  margin: 0 24rpx 22rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(43,92,230,0.10), transparent 36%),
    #ffffff;
  border: 1rpx solid rgba(226,232,240,0.9);
  box-shadow: 0 18rpx 44rpx rgba(31,45,74,0.075);
}

.action-lab-head {
  margin-bottom: 20rpx;
}

.action-lab-kicker {
  display: block;
  margin-bottom: 6rpx;
  color: #2b5ce6;
  font-size: 21rpx;
  font-weight: 850;
  letter-spacing: 0.8rpx;
}

.action-lab-title {
  display: block;
  color: #172033;
  font-size: 31rpx;
  font-weight: 900;
  letter-spacing: -0.4rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action-card {
  min-width: 0;
  padding: 20rpx 18rpx;
  border-radius: 26rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(226,232,240,0.9);
  display: flex;
  align-items: center;
  gap: 14rpx;
  transition: transform var(--trans-fast), opacity var(--trans-fast);
}

.action-card:active {
  transform: scale(0.982);
  opacity: 0.82;
}

.action-card.primary {
  background: linear-gradient(135deg, #eef5ff 0%, #f7f3ff 100%);
  border-color: rgba(43,92,230,0.16);
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #2b5ce6;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon.doc {
  background: #0f172a;
  font-size: 26rpx;
}

.action-copy {
  flex: 1;
  min-width: 0;
}

.action-title {
  display: block;
  color: #172033;
  font-size: 25rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-sub {
  display: block;
  margin-top: 5rpx;
  color: #758195;
  font-size: 20rpx;
  line-height: 1.35;
}

.roadmap-cta {
  box-shadow: 0 16rpx 38rpx rgba(43, 92, 230, 0.08);
}

.f-btn-ai {
  color: #1d4ed8;
}

.f-btn-apply {
  font-weight: 800;
}

.apply-panel {
  background:
    radial-gradient(circle at 50% -8%, rgba(43,92,230,0.10), transparent 34%),
    #ffffff;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}
