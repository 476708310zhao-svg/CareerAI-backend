/* pages/jobs/jobs.wxss */
page {
  background: #f6f8fc;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 14% 2%, rgba(43, 92, 230, 0.12), transparent 30%),
    radial-gradient(circle at 92% 8%, rgba(16, 185, 129, 0.12), transparent 32%),
    linear-gradient(180deg, #fbfdff 0%, #f6f8fc 48%, #ffffff 100%);
}

.mock-tip {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 120;
  padding: 12rpx 24rpx;
  background: rgba(255, 251, 235, 0.96);
  color: #b45309;
  font-size: 22rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(245, 158, 11, 0.22);
}

.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  padding-top: calc(env(safe-area-inset-top) + 6rpx);
  background: rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(24rpx);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.82);
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.04);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 28rpx 10rpx;
}

.search-wrap {
  flex: 1;
  height: 78rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(248, 250, 252, 0.92);
  border: 1.5rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.95), 0 10rpx 28rpx rgba(15,23,42,0.045);
}

.search-icon {
  color: var(--color-neutral-muted);
  font-size: 30rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  height: 74rpx;
  line-height: 74rpx;
  color: var(--color-ink);
  font-size: 27rpx;
}

.ph {
  color: #a1aab8;
}

.search-clear {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: var(--color-neutral);
  background: #e2e8f0;
  text-align: center;
  line-height: 40rpx;
  font-size: 30rpx;
}

.filter-btn {
  position: relative;
  height: 78rpx;
  min-width: 120rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1.5rpx solid rgba(148, 163, 184, 0.22);
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.07);
}

.filter-btn.active {
  color: var(--color-brand);
  background: var(--color-brand-tint);
  border-color: rgba(37, 99, 235, 0.28);
}

.filter-icon {
  font-size: 24rpx;
}

.filter-txt {
  font-size: 25rpx;
  font-weight: 700;
  color: #475569;
}

.filter-btn.active .filter-txt {
  color: var(--color-brand);
}

.filter-dot {
  position: absolute;
  top: 12rpx;
  right: 14rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ef4444;
}

.history-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 2rpx 24rpx 10rpx;
  overflow: hidden;
}

.row-label {
  flex-shrink: 0;
  font-size: 23rpx;
  font-weight: 800;
  color: var(--color-neutral-muted);
}

.history-tag {
  flex-shrink: 0;
  max-width: 170rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #475569;
  background: var(--color-surface-muted);
  border: 1rpx solid rgba(226,232,240,0.95);
  font-size: 23rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.history-clear {
  margin-left: auto;
  color: var(--color-neutral-muted);
  font-size: 22rpx;
}

.quick-scroll {
  width: 100%;
  white-space: nowrap;
}

.quick-inner {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 24rpx 18rpx;
}

.co-label {
  color: var(--color-warning-strong);
}

.quick-tag {
  flex-shrink: 0;
  padding: 11rpx 22rpx;
  border-radius: 999rpx;
  color: var(--color-neutral);
  background: #ffffff;
  border: 1.5rpx solid rgba(226,232,240,0.95);
  font-size: 23rpx;
  font-weight: 650;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.quick-tag.active {
  color: var(--color-brand);
  background: linear-gradient(135deg, #dbeafe, var(--color-brand-tint-legacy));
  border-color: rgba(37, 99, 235, 0.28);
}

.quick-tag.co.active {
  color: #d97706;
  background: var(--color-warning-soft);
  border-color: rgba(245, 158, 11, 0.34);
}

.quick-sep {
  width: 1rpx;
  height: 32rpx;
  margin: 0 6rpx;
  background: rgba(148, 163, 184, 0.24);
}

.spacer {
  height: calc(188rpx + env(safe-area-inset-top));
}

.spacer-history {
  height: calc(238rpx + env(safe-area-inset-top));
}

.match-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 0 24rpx 8rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(226,232,240,0.78);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.04);
  overflow: hidden;
}

.match-toggle {
  height: 62rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  border-radius: 999rpx;
  color: #334155;
  background: rgba(255, 255, 255, 0.9);
  border: 1.5rpx solid rgba(226,232,240,0.9);
  box-shadow: none;
}

.match-toggle.match-on {
  color: #047857;
  background: linear-gradient(135deg, var(--color-success-tint), #f0fdfa);
  border-color: rgba(16, 185, 129, 0.26);
}

.match-toggle-icon {
  font-size: 25rpx;
}

.match-toggle-txt {
  font-size: 25rpx;
  font-weight: 800;
}

.match-toggle-badge {
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #10b981;
  font-size: 18rpx;
  font-weight: 900;
}

.match-kw-scroll {
  flex: 1;
}

.match-kw-inner {
  display: inline-flex;
  gap: 8rpx;
  white-space: nowrap;
}

.match-kw-pill {
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  color: #047857;
  background: var(--color-success-tint);
  font-size: 22rpx;
  border: 1rpx solid rgba(16, 185, 129, 0.18);
}

.match-incomplete-txt,
.match-setup-btn {
  color: var(--color-brand);
  font-size: 23rpx;
  font-weight: 800;
  white-space: nowrap;
}

.match-no-profile {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.match-no-txt {
  color: var(--color-neutral);
  font-size: 22rpx;
}

.result-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 4rpx 24rpx 14rpx;
  padding: 18rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,0.74);
  border: 1rpx solid rgba(226,232,240,0.78);
}

.result-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 3rpx;
}

.result-count {
  flex-shrink: 0;
  color: var(--color-ink);
  font-size: 30rpx;
  font-weight: 900;
}

.result-kw {
  color: var(--color-neutral-muted);
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.view-toggle {
  flex-shrink: 0;
  display: flex;
  padding: 5rpx;
  gap: 4rpx;
  border-radius: 999rpx;
  background: var(--color-surface-muted);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.vt-btn {
  height: 48rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  gap: 5rpx;
  border-radius: 999rpx;
  color: var(--color-neutral);
  font-size: 22rpx;
  font-weight: 800;
}

.vt-active {
  color: var(--color-brand);
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.08);
}

.list {
  padding: 0 24rpx 54rpx;
}

.card {
  position: relative;
  margin-bottom: 18rpx;
  padding: 26rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.98);
  border: 1rpx solid rgba(226,232,240,0.9);
  box-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.065);
  overflow: hidden;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.card::before {
  content: '';
  display: none;
  position: absolute;
  left: 0;
  top: 28rpx;
  width: 6rpx;
  height: 54rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: linear-gradient(180deg, #38bdf8, #10b981);
}

.card:active {
  transform: scale(0.985);
  opacity: 0.86;
}

.card-top {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.logo-wrap,
.mcp-logo-wrap {
  flex-shrink: 0;
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #ffffff, var(--color-surface-muted));
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, 0.07);
  overflow: hidden;
}

.logo-img,
.mcp-logo {
  width: 72rpx;
  height: 72rpx;
}

.logo-initial,
.mcp-logo-initial {
  width: 100%;
  height: 100%;
  line-height: 84rpx;
  text-align: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #38bdf8, #6366f1);
}

.card-info {
  flex: 1;
  min-width: 0;
  padding-top: 2rpx;
}

.card-title {
  display: block;
  color: #111827;
  font-size: 31rpx;
  line-height: 1.32;
  font-weight: 900;
  letter-spacing: -0.35rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-company {
  display: block;
  margin-top: 8rpx;
  color: var(--color-neutral);
  font-size: 25rpx;
  font-weight: 650;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-save {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  color: var(--color-neutral-muted);
  background: var(--color-surface-subtle);
  border: 1rpx solid var(--color-neutral-line-strong);
}

.save-icon {
  font-size: 38rpx;
  line-height: 1;
}

.card-save.saved {
  color: #f43f5e;
  background: #fff1f2;
}

.card-salary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.card-salary {
  color: var(--color-success-text);
  font-size: 31rpx;
  font-weight: 950;
  letter-spacing: -0.4rpx;
}

.card-salary.muted {
  color: var(--color-neutral);
  font-size: 25rpx;
  font-weight: 700;
}

.card-time {
  color: var(--color-neutral-muted);
  font-size: 22rpx;
  font-weight: 650;
}

.card-tags,
.mcp-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 9rpx;
  margin-top: 16rpx;
}

.ctag,
.mcp-tag {
  max-width: 100%;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--color-neutral-line-strong);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ctag.loc {
  color: #4f46e5;
  background: var(--color-brand-tint-legacy);
  border: 1rpx solid rgba(99, 102, 241, 0.16);
}

.ctag.type {
  color: var(--color-neutral);
  background: var(--color-surface-muted);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.ctag.opt,
.mcp-opt {
  color: #047857;
  background: var(--color-success-tint);
  border: 1rpx solid rgba(16, 185, 129, 0.18);
}

.ctag.match-high {
  color: #0369a1;
  background: #e0f2fe;
  border: 1rpx solid rgba(14, 165, 233, 0.22);
}

.ctag.match-mid {
  color: var(--color-brand);
  background: var(--color-brand-tint);
  border: 1rpx solid rgba(37, 99, 235, 0.18);
}

.card-match-row {
  margin-top: 12rpx;
}

.match-reason-txt {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  color: #047857;
  background: rgba(236, 253, 245, 0.9);
  font-size: 22rpx;
  font-weight: 700;
}

.filter-panel {
  padding: 34rpx 32rpx calc(env(safe-area-inset-bottom) + 28rpx);
  border-radius: 34rpx 34rpx 0 0;
  background:
    radial-gradient(circle at 50% -10%, rgba(43,92,230,0.10), transparent 34%),
    #ffffff;
}

.filter-panel-title {
  margin-bottom: 10rpx;
  color: var(--color-ink);
  font-size: 34rpx;
  font-weight: 950;
  text-align: left;
}

.filter-section-label {
  margin-bottom: 14rpx;
  color: #334155;
  font-size: 26rpx;
  font-weight: 850;
}

.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 30rpx;
}

.fchip {
  padding: 15rpx 28rpx;
  border-radius: 999rpx;
  color: #475569;
  background: #ffffff;
  border: 1.5rpx solid rgba(226,232,240,0.95);
  font-size: 25rpx;
  font-weight: 800;
}

.fchip.active {
  color: #ffffff;
  background: linear-gradient(135deg, var(--color-brand), #1d4ed8);
  border-color: transparent;
  box-shadow: 0 10rpx 24rpx rgba(37,99,235,0.22);
}

.filter-country-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 30rpx;
}
.filter-chips-row {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 14rpx;
  padding-bottom: 4rpx;
}
.fchip-country {
  white-space: nowrap;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-actions {
  display: flex;
  gap: 18rpx;
}

.filter-reset,
.filter-confirm {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.filter-reset {
  flex: 1;
  color: #475569;
  background: var(--color-surface-subtle);
  border: 1.5rpx solid var(--color-neutral-line);
}

.filter-confirm {
  flex: 2;
  color: #ffffff;
  background: linear-gradient(135deg, var(--color-brand), #10b981);
  box-shadow: 0 16rpx 30rpx rgba(37, 99, 235, 0.22);
}

.map-wrap {
  position: relative;
  margin: 0 24rpx;
  width: auto;
  height: calc(100vh - 330rpx - env(safe-area-inset-top));
  overflow: hidden;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.1);
}

.job-map {
  width: 100%;
  height: 100%;
}

.map-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 520rpx;
  transform: translate(-50%, -50%);
  padding: 40rpx 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 50rpx rgba(15, 23, 42, 0.12);
}

.map-empty-icon {
  color: var(--color-brand);
  font-size: 52rpx;
}

.map-empty-txt {
  color: var(--color-ink);
  font-size: 29rpx;
  font-weight: 900;
}

.map-empty-sub {
  color: var(--color-neutral);
  font-size: 23rpx;
  text-align: center;
  line-height: 1.5;
}

.map-legend {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #475569;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.1);
}

.map-legend-dot,
.map-legend-txt {
  font-size: 21rpx;
  font-weight: 750;
}

.map-city-mask {
  position: absolute;
  inset: 0;
  z-index: 10;
  background: rgba(15, 23, 42, 0.3);
}

.map-city-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 11;
  max-height: 62vh;
  display: flex;
  flex-direction: column;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 -18rpx 48rpx rgba(15, 23, 42, 0.16);
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
}

.map-city-panel.show {
  transform: translateY(0);
}

.mcp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 18rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.14);
}

.mcp-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.mcp-city {
  color: var(--color-ink);
  font-size: 31rpx;
  font-weight: 950;
}

.mcp-count {
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  color: var(--color-brand);
  background: var(--color-brand-tint);
  font-size: 22rpx;
  font-weight: 850;
}

.mcp-close {
  color: var(--color-neutral-muted);
  font-size: 40rpx;
  line-height: 1;
  padding: 4rpx 10rpx;
}

.mcp-list {
  flex: 1;
  padding: 10rpx 0 24rpx;
}

.mcp-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 30rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.mcp-card-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.mcp-logo-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
}

.mcp-logo {
  width: 62rpx;
  height: 62rpx;
}

.mcp-logo-initial {
  line-height: 72rpx;
  font-size: 26rpx;
}

.mcp-info {
  flex: 1;
  min-width: 0;
}

.mcp-title,
.mcp-company {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mcp-title {
  color: var(--color-ink);
  font-size: 27rpx;
  font-weight: 900;
}

.mcp-company {
  margin-top: 6rpx;
  color: var(--color-neutral);
  font-size: 22rpx;
  font-weight: 700;
}

.mcp-tags {
  margin-top: 10rpx;
}

.mcp-tag {
  color: var(--color-neutral);
  background: var(--color-surface-muted);
}

.mcp-salary {
  color: #10b981;
  background: var(--color-success-tint);
}

.mcp-arrow {
  color: #cbd5e1;
  font-size: 42rpx;
}

.skeleton-list {
  padding-top: 4rpx;
}

.skeleton-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid var(--color-neutral-line-strong);
}

.sk-top {
  display: flex;
  gap: 18rpx;
}

.sk-logo {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.sk-info {
  flex: 1;
  padding-top: 8rpx;
}

.sk-line {
  height: 22rpx;
  margin-bottom: 14rpx;
  border-radius: 999rpx;
}

.sk-title {
  width: 62%;
  height: 28rpx;
}

.sk-sub {
  width: 42%;
}

.sk-salary-row {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.sk-salary {
  width: 34%;
}

.sk-time {
  width: 20%;
}

.sk-tags {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
}

.sk-tag {
  width: 128rpx;
  height: 36rpx;
  border-radius: 999rpx;
}

.shimmer {
  background: linear-gradient(90deg, #edf2f7 25%, #ffffff 50%, #edf2f7 75%);
  background-size: 240% 100%;
  animation: shimmer 1.35s ease-in-out infinite;
}

@keyframes shimmer {
  0% { background-position: 120% 0; }
  100% { background-position: -120% 0; }
}

.tip {
  padding: 34rpx 0;
  color: var(--color-neutral-muted);
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
}

.safe-tail {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

.jobs-brief {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin: 18rpx 24rpx 8rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.95), rgba(246,249,255,0.95));
  border: 1.5rpx solid rgba(226,232,240,0.88);
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.075);
  overflow: hidden;
}

.jobs-brief::after {
  content: '';
  position: absolute;
  right: -72rpx;
  top: -82rpx;
  width: 230rpx;
  height: 230rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(43,92,230,0.16), rgba(43,92,230,0));
}

.jobs-brief-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.brief-kicker {
  display: block;
  margin-bottom: 8rpx;
  color: var(--color-brand);
  font-size: 21rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
}

.brief-title {
  display: block;
  color: var(--color-ink);
  font-size: 42rpx;
  font-weight: 950;
  letter-spacing: -1rpx;
  line-height: 1.12;
}

.brief-subtitle {
  display: block;
  margin-top: 12rpx;
  color: var(--color-neutral);
  font-size: 24rpx;
  line-height: 1.52;
}

.brief-metric {
  position: relative;
  z-index: 1;
  width: 124rpx;
  height: 124rpx;
  flex-shrink: 0;
  border-radius: 34rpx;
  background: linear-gradient(145deg, var(--color-ink), var(--color-brand));
  box-shadow: 0 18rpx 38rpx rgba(37, 99, 235, 0.26);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.brief-metric-num {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 950;
  letter-spacing: -0.5rpx;
}

.brief-metric-label {
  margin-top: 2rpx;
  color: rgba(255,255,255,0.72);
  font-size: 18rpx;
  font-weight: 700;
}

.result-label {
  color: var(--color-brand);
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 0.8rpx;
}

.card-glow {
  position: absolute;
  right: -54rpx;
  top: -64rpx;
  width: 170rpx;
  height: 170rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(43,92,230,0.12), rgba(43,92,230,0));
  pointer-events: none;
}
