/* pages/agency-compare/agency-compare.wxss — Linear Dark Theme */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ── 加载态 ── */
.loading-wrap {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 160rpx 0; gap: 32rpx;
}
.spinner {
  width: 60rpx; height: 60rpx;
  border: 5rpx solid rgba(0,0,0,0.04);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.loading-txt { font-size: 28rpx; color: var(--text-muted); }
@keyframes spin { to { transform: rotate(360deg); } }

/* ── 机构头部区 ── */
.header-section {
  background: var(--bg-panel);
  border-bottom: 1.5rpx solid rgba(0,0,0,0.05);
  margin-bottom: 0;
}
.header-grid { display: flex; }
.header-label-col { width: 140rpx; flex-shrink: 0; }
.agency-head-cell {
  flex: 1;
  display: flex; flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx 24rpx;
  border-left: 1.5rpx solid rgba(0,0,0,0.04);
  gap: 12rpx;
}
.agency-logo-wrap { flex-shrink: 0; }
.agency-logo {
  width: 96rpx; height: 96rpx;
  border-radius: var(--r-lg);
  border: 1.5rpx solid rgba(255,255,255,0.10);
}
.agency-logo-placeholder {
  width: 96rpx; height: 96rpx;
  border-radius: var(--r-lg);
  background: rgba(94,106,210,0.20);
  border: 1.5rpx solid rgba(94,106,210,0.30);
  display: flex; align-items: center; justify-content: center;
}
.agency-logo-text { font-size: 30rpx; font-weight: 700; color: #6366F1; }
.agency-head-name {
  font-size: 28rpx; font-weight: 700;
  color: var(--text-primary); text-align: center; line-height: 1.3;
}
.agency-head-type {
  font-size: 22rpx; color: #6366F1;
  background: #EEF2FF;
  padding: 4rpx 14rpx; border-radius: 8rpx;
  border: 1rpx solid rgba(94,106,210,0.25);
}
.agency-head-detail-btn {
  font-size: 22rpx; color: var(--brand);
  background: #EEF2FF;
  padding: 8rpx 20rpx; border-radius: 9999rpx;
  font-weight: 500;
  border: 1rpx solid rgba(94,106,210,0.25);
}

/* ── 表格 ── */
.table-section { margin: 0 0 24rpx; }
.table-row {
  display: flex; align-items: stretch; min-height: 88rpx;
}
.table-row.even { background: var(--bg-panel); }
.table-row.odd  { background: rgba(255,255,255,0.02); }

/* 行标签列 */
.row-label-col {
  width: 140rpx; flex-shrink: 0;
  display: flex; align-items: center;
  padding: 16rpx 12rpx 16rpx 20rpx;
  border-right: 1.5rpx solid rgba(0,0,0,0.04);
}
.row-label { font-size: 24rpx; color: var(--text-muted); font-weight: 500; line-height: 1.4; }

/* 数据列 */
.data-col {
  flex: 1;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 16rpx 12rpx;
  border-left: 1.5rpx solid rgba(255,255,255,0.04);
  gap: 6rpx;
}
.data-col.best { background: rgba(94,106,210,0.08); }

/* 评分 */
.score-num { font-size: 36rpx; font-weight: 800; color: var(--warning); line-height: 1; }
.score-num.best-score { color: var(--brand); }
.stars-row { display: flex; gap: 2rpx; }
.star { font-size: 18rpx; }
.star.full  { color: var(--warning); }
.star.half  { color: var(--warning); opacity: 0.5; }
.star.empty { color: var(--bg-raised); }
.no-data { font-size: 26rpx; color: var(--text-muted); }

/* 数量 */
.num-val { font-size: 30rpx; font-weight: 700; color: var(--text-secondary); }
.num-val.best-score { color: var(--brand); }

/* 标签 */
.tag-list {
  display: flex; flex-wrap: wrap;
  gap: 6rpx; justify-content: center;
}
.mini-tag {
  font-size: 20rpx; color: var(--text-muted);
  background: rgba(0,0,0,0.04);
  padding: 4rpx 12rpx; border-radius: 6rpx;
  border: 1rpx solid rgba(0,0,0,0.05);
}

/* 价格 */
.price-txt {
  font-size: 22rpx; color: var(--text-secondary);
  line-height: 1.6; text-align: center; white-space: pre-wrap;
}

/* 布尔 */
.bool-badge {
  font-size: 23rpx; font-weight: 600;
  padding: 6rpx 16rpx; border-radius: 10rpx;
}
.bool-badge.verified   { color: var(--success); background: rgba(16,185,129,0.15); border: 1rpx solid rgba(16,185,129,0.25); }
.bool-badge.unverified { color: var(--text-muted); background: rgba(255,255,255,0.04); border: 1rpx solid rgba(0,0,0,0.06); }

/* 普通文本 */
.plain-txt { font-size: 26rpx; color: var(--text-secondary); text-align: center; line-height: 1.5; }

/* ── 底部区 ── */
.footer-section {
  padding: 24rpx 24rpx 60rpx;
  display: flex; flex-direction: column;
  align-items: center; gap: 20rpx;
}
.footer-tip { font-size: 24rpx; color: var(--text-muted); }
.footer-btns { display: flex; gap: 16rpx; flex-wrap: wrap; justify-content: center; }
.footer-detail-btn {
  background: var(--brand);
  color: var(--bg-panel); font-size: 26rpx; font-weight: 600;
  padding: 18rpx 36rpx; border-radius: 9999rpx;
}
