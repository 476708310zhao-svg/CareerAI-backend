<!-- pages/profile/profile.wxml -->
<view class="container">
  <view class="profile-top">
    <block wx:if="{{!isLogin}}">
      <view class="profile-main" bindtap="onLogin" hover-class="tap-soft">
        <view class="avatar-wrap">
          <image class="avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
          <view class="avatar-badge">登录</view>
        </view>
        <view class="info-text">
          <view class="name-row">
            <text class="nickname">点击登录 / 注册</text>
            <text class="profile-chevron">›</text>
          </view>
          <text class="school">建立求职档案，获取精准推荐</text>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="profile-main" bindtap="goToEditProfile" hover-class="tap-soft">
        <view class="avatar-wrap">
          <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        </view>
        <view class="info-text">
          <view class="name-row">
            <text class="nickname">{{userInfo.nickName}}</text>
            <view class="vip-badge" wx:if="{{isVip}}">会员已开通</view>
            <text class="profile-chevron">›</text>
          </view>
          <text class="school">{{userInfo.school || '点击完善学校信息'}}{{userInfo.major ? ' · ' + userInfo.major : ''}}</text>
        </view>
      </view>
    </block>

    <view class="header-actions">
      <view class="header-action" bindtap="goToFeedback" hover-class="tap-soft">
        <view class="header-action-icon">?</view>
        <text>帮助</text>
      </view>
      <view class="header-action" bindtap="goToSettings" hover-class="tap-soft">
        <view class="header-action-icon">设</view>
        <text>设置</text>
      </view>
    </view>
  </view>

  <view wx:if="{{membershipEnabled}}" class="vip-banner {{isVip ? 'vip-banner-active' : ''}}" bindtap="goToVip" hover-class="panel-press">
    <view class="vip-left">
      <view class="vip-title-row">
        <text class="vip-crown">{{isVip ? 'VIP' : 'PRO'}}</text>
        <text class="vip-title">{{isVip ? '会员已生效' : '解锁求职进阶能力'}}</text>
      </view>
      <text wx:if="{{isVip}}" class="vip-desc">有效期至 {{vipInfo.expireDate || '长期有效'}} · 高级工具已解锁</text>
      <text wx:else class="vip-desc">简历优化、AI 面试与薪资洞察</text>
      <view wx:if="{{isVip}}" class="vip-unlocked-row">
        <text>ATS不限次</text>
        <text>AI面试</text>
        <text>薪资高级数据</text>
      </view>
    </view>
    <view class="vip-btn">{{isVip ? '查看权益 ›' : '去开通 ›'}}</view>
  </view>

  <c-ai-disclosure text="我的页面中的简历优化、AI 面试与智能建议由人工智能生成，仅供求职参考，请核验后使用。" />

  <view class="stats-card">
    <view class="stat-item" bindtap="goToFavorites" hover-class="tap-soft">
      <text class="stat-num">{{stats.favorites}}</text>
      <text class="stat-label">我的收藏</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.viewed}}</text>
      <text class="stat-label">历史浏览</text>
    </view>
    <view class="stat-item" bindtap="goToJobProgress" hover-class="tap-soft">
      <text class="stat-num">{{stats.applications}}</text>
      <text class="stat-label">求职进度</text>
    </view>
    <view class="stat-item" bindtap="goToInterviews" hover-class="tap-soft">
      <text class="stat-num">{{stats.interviews}}</text>
      <text class="stat-label">面试记录</text>
    </view>
  </view>

  <view class="asset-card">
    <view class="asset-head">
      <view class="section-copy">
        <text class="section-kicker">CAREER ASSETS</text>
        <text class="section-title">{{assetHealth.title}}</text>
        <text class="section-desc">{{assetHealth.desc}}</text>
      </view>
      <view class="asset-progress">
        <text class="asset-percent">{{assetHealth.percent}}%</text>
        <text class="asset-label">完成</text>
      </view>
    </view>

    <view class="asset-bar">
      <view class="asset-bar-fill" style="width: {{assetHealth.percent}}%;"></view>
    </view>

    <view class="asset-grid">
      <view wx:for="{{assetCards}}" wx:key="key" class="asset-item asset-{{item.tone}}" bindtap="goToAssetCard" data-url="{{item.url}}" hover-class="tile-press">
        <view class="asset-item-top">
          <text class="asset-item-title">{{item.title}}</text>
          <text class="asset-status">{{item.status}}</text>
        </view>
        <view class="asset-value-row">
          <text class="asset-value">{{item.value}}</text>
          <text class="asset-suffix">{{item.suffix}}</text>
        </view>
        <text class="asset-desc">{{item.desc}}</text>
      </view>
    </view>

    <view class="asset-primary" bindtap="goToAssetAction" hover-class="tap-soft">{{assetHealth.primaryText}} ›</view>
  </view>

  <view class="tool-card">
    <view class="section-head compact">
      <view class="section-copy">
        <text class="section-title">求职工具</text>
        <text class="section-desc">常用能力，一步直达</text>
      </view>
    </view>

    <view class="tool-grid">
      <view class="tool-item" bindtap="goToMessages" hover-class="tile-press">
        <view class="tool-icon tone-blue"><image class="tool-icon-image" src="/images/profile-message.png" mode="aspectFit" /></view>
        <text class="tool-name">消息通知</text>
      </view>
      <view class="tool-item" bindtap="goToFavorites" hover-class="tile-press">
        <view class="tool-icon tone-amber"><image class="tool-icon-image" src="/images/profile-favorite.png" mode="aspectFit" /></view>
        <text class="tool-name">我的收藏</text>
      </view>
      <view class="tool-item" bindtap="goToResumes" hover-class="tile-press">
        <view class="tool-icon tone-mint"><image class="tool-icon-image" src="/images/profile-resume.png" mode="aspectFit" /></view>
        <text class="tool-name">我的简历</text>
      </view>
      <view class="tool-item" bindtap="goToAIInterview" hover-class="tile-press">
        <view class="tool-icon tone-violet"><image class="tool-icon-image" src="/images/profile-interview.png" mode="aspectFit" /></view>
        <view class="tool-badge">NEW</view>
        <text class="tool-name">模拟面试</text>
      </view>
      <view class="tool-item" bindtap="goToDailyBrief" hover-class="tile-press">
        <view class="tool-icon tone-amber"><image class="tool-icon-image" src="/images/icon-calendar.png" mode="aspectFit" /></view>
        <text class="tool-name">每日简报</text>
      </view>
      <view class="tool-item" bindtap="goToApplicationMaterials" hover-class="tile-press">
        <view class="tool-icon tone-blue"><image class="tool-icon-image" src="/images/application.png" mode="aspectFit" /></view>
        <text class="tool-name">材料库</text>
      </view>
      <view class="tool-item" bindtap="goToInterviewNotebook" hover-class="tile-press">
        <view class="tool-icon tone-mint"><image class="tool-icon-image" src="/images/profile-interview.png" mode="aspectFit" /></view>
        <text class="tool-name">错题本</text>
      </view>
      <view class="tool-item" bindtap="goToMyExperiences" hover-class="tile-press">
        <view class="tool-icon tone-coral"><image class="tool-icon-image" src="/images/profile-experience.png" mode="aspectFit" /></view>
        <text class="tool-name">笔经面经</text>
      </view>
    </view>
  </view>

  <view class="service-card">
    <view class="section-head compact">
      <view class="section-copy">
        <text class="section-title">其他服务</text>
      </view>
    </view>

    <view class="service-grid">
      <view class="service-item" bindtap="goToFeedback" hover-class="tile-press">
        <view class="service-icon service-blue"><image class="service-icon-image" src="/images/profile-feedback.png" mode="aspectFit" /></view>
        <text>意见反馈</text>
      </view>
      <view class="service-item" bindtap="goToUsageGuide" hover-class="tile-press">
        <view class="service-icon service-green"><image class="service-icon-image" src="/images/profile-about.png" mode="aspectFit" /></view>
        <text>使用指南</text>
      </view>
      <view class="service-item" bindtap="goToAbout" hover-class="tile-press">
        <view class="service-icon service-green"><image class="service-icon-image" src="/images/profile-about.png" mode="aspectFit" /></view>
        <text>关于我们</text>
      </view>
      <view wx:if="{{membershipEnabled}}" class="service-item" bindtap="goToVip" hover-class="tile-press">
        <view class="service-icon service-orange"><image class="service-icon-image" src="/images/profile-vip.png" mode="aspectFit" /></view>
        <text>会员权益</text>
      </view>
      <view class="service-item" bindtap="goToSettings" hover-class="tile-press">
        <view class="service-icon service-gray"><image class="service-icon-image" src="/images/profile-settings.png" mode="aspectFit" /></view>
        <text>设置</text>
      </view>
    </view>
  </view>
</view>

<c-login-popup
  show="{{showLoginPopup}}"
  bind:close="onLoginPopupClose"
  bind:success="onLoginSuccess"
/>
