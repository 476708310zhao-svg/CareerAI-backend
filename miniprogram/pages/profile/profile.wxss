/* pages/profile/profile.wxss */
page {
  width: 100%;
  min-height: 100%;
  overflow-x: hidden;
  background: #f6f8fc;
  color: #101828;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  -webkit-font-smoothing: antialiased;
}

view,
text,
image {
  box-sizing: border-box;
}

.container {
  width: 100%;
  max-width: 750rpx;
  min-height: 100vh;
  margin: 0 auto;
  padding: 18rpx 24rpx calc(52rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  background:
    radial-gradient(circle at 12% 0, rgba(37,99,235,0.08), transparent 34%),
    linear-gradient(180deg, #ffffff 0%, #f6f8fc 340rpx, #f6f8fc 100%);
}

.user-header,
.vip-banner,
.workspace-card,
.menu-group {
  width: 100%;
  overflow: hidden;
}

.user-header {
  position: relative;
  padding: 30rpx 26rpx 24rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(255,255,255,0.18), transparent 32%),
    linear-gradient(135deg, #1d4ed8 0%, #2447bf 48%, #172554 100%);
  box-shadow: 0 18rpx 44rpx rgba(29,78,216,0.20);
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  background: rgba(255,255,255,0.08);
}

.deco1 {
  width: 250rpx;
  height: 250rpx;
  top: -92rpx;
  right: -70rpx;
}

.deco2 {
  width: 150rpx;
  height: 150rpx;
  left: -54rpx;
  bottom: 96rpx;
}

.user-info {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
  padding-bottom: 26rpx;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.avatar {
  display: block;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255,255,255,0.68);
  background: rgba(255,255,255,0.20);
  box-shadow: 0 14rpx 28rpx rgba(15,23,42,0.22);
}

.avatar-badge {
  position: absolute;
  right: -8rpx;
  bottom: 0;
  min-width: 48rpx;
  height: 28rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ffffff;
  background: #f59e0b;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 28rpx;
  text-align: center;
}

.info-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.nickname {
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.22;
}

.school {
  margin-top: 8rpx;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: rgba(255,255,255,0.78);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.35;
}

.vip-badge {
  flex-shrink: 0;
  height: 30rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(253,230,138,0.46);
  background: rgba(245,158,11,0.22);
  color: #fde68a;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 30rpx;
}

.edit-btn,
.arrow-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: rgba(255,255,255,0.15);
  border: 1rpx solid rgba(255,255,255,0.26);
}

.edit-btn {
  height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.arrow-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  font-size: 42rpx;
  line-height: 1;
}

.stats-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  min-height: 112rpx;
  padding: 18rpx 8rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.96);
  box-shadow: 0 14rpx 32rpx rgba(15,23,42,0.12);
}

.stat-item {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  flex-direction: column;
  gap: 8rpx;
}

.stat-num {
  color: #172554;
  font-size: 33rpx;
  font-weight: 950;
  line-height: 1;
}

.stat-label {
  color: #667085;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
}

.stat-divider {
  width: 1rpx;
  height: 42rpx;
  background: #e6ebf2;
  flex-shrink: 0;
}

.vip-banner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(245,158,11,0.18);
  background:
    radial-gradient(circle at 98% 0, rgba(37,99,235,0.08), transparent 34%),
    linear-gradient(135deg, #fffaf0 0%, #fff4d7 48%, #ffffff 100%);
  box-shadow: 0 10rpx 28rpx rgba(245,158,11,0.10);
}

.vip-left {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.vip-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.vip-crown {
  width: 38rpx;
  height: 38rpx;
  border-radius: 12rpx;
  background: rgba(245,158,11,0.14);
  color: #b45309;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 38rpx;
  text-align: center;
}

.vip-title {
  color: #92400e;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.25;
}

.vip-desc {
  color: #b45309;
  font-size: 22rpx;
  font-weight: 650;
  line-height: 1.35;
}

.vip-btn {
  flex-shrink: 0;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f59e0b, #f97316);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 56rpx;
  box-shadow: 0 10rpx 20rpx rgba(249,115,22,0.24);
}

.workspace-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(16,24,40,0.06);
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(16,24,40,0.055);
}

.workspace-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.workspace-head > view {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.workspace-kicker {
  color: #2563eb;
  font-size: 19rpx;
  font-weight: 950;
  line-height: 1;
}

.workspace-title {
  margin-top: 8rpx;
  color: #101828;
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1.22;
}

.workspace-status {
  flex-shrink: 0;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 850;
  line-height: 42rpx;
}

.workspace-actions {
  display: flex;
  gap: 12rpx;
}

.workspace-action {
  flex: 1;
  min-width: 0;
  min-height: 138rpx;
  padding: 18rpx 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid #eaecf0;
  background: #fbfdff;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.workspace-action.primary {
  flex: 1.1;
  border-color: transparent;
  background: linear-gradient(135deg, #172554, #2563eb);
  box-shadow: 0 12rpx 24rpx rgba(37,99,235,0.18);
}

.workspace-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 12rpx;
  border-radius: 14rpx;
  background: #eef4ff;
  color: #2563eb;
  font-size: 19rpx;
  font-weight: 950;
}

.workspace-name {
  color: #1d2939;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.28;
}

.workspace-desc {
  margin-top: 6rpx;
  color: #98a2b3;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.2;
}

.workspace-action.primary .workspace-icon {
  color: #ffffff;
  background: rgba(255,255,255,0.18);
}

.workspace-action.primary .workspace-name,
.workspace-action.primary .workspace-desc {
  color: #ffffff;
}

.menu-group {
  margin-top: 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(16,24,40,0.06);
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(16,24,40,0.045);
}

.group-title {
  height: 58rpx;
  padding: 20rpx 24rpx 0;
  color: #98a2b3;
  font-size: 21rpx;
  font-weight: 850;
  line-height: 1;
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 90rpx;
  padding: 0 24rpx;
  gap: 18rpx;
  border-bottom: 1rpx solid rgba(16,24,40,0.055);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-box {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
}

.menu-emoji {
  color: #344054;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
}

.menu-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #263241;
  font-size: 27rpx;
  font-weight: 760;
  line-height: 1.2;
}

.tag-new {
  flex-shrink: 0;
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(37,99,235,0.14);
  background: #eef4ff;
  color: #2563eb;
  font-size: 17rpx;
  font-weight: 900;
  line-height: 32rpx;
}

.menu-arrow {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  border-top: 2.5rpx solid #d9e0ea;
  border-right: 2.5rpx solid #d9e0ea;
  transform: rotate(45deg);
}

.panel-press,
.menu-press,
.tap-soft {
  transform: scale(0.985);
  opacity: 0.86;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}
