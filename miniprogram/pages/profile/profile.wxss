/* pages/profile/profile.wxss */
page {
  width: 100%;
  min-height: 100%;
  overflow-x: hidden;
  background: #f5f6f8;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  -webkit-font-smoothing: antialiased;
}

view,
text,
image {
  box-sizing: border-box;
}

.container {
  width: 100%;
  max-width: 750rpx;
  min-height: 100vh;
  margin: 0 auto;
  padding: 12rpx 22rpx calc(172rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  background:
    radial-gradient(circle at 8% 0, rgba(37,99,235,0.055), transparent 27%),
    linear-gradient(180deg, #ffffff 0, #f5f6f8 300rpx, #f5f6f8 100%);
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 118rpx;
  padding: 10rpx 6rpx 14rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.avatar {
  display: block;
  width: 94rpx;
  height: 94rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  background: #e9f0fb;
  box-shadow: 0 8rpx 22rpx rgba(37,68,112,0.13);
}

.avatar-badge {
  position: absolute;
  right: -8rpx;
  bottom: -1rpx;
  min-width: 48rpx;
  height: 27rpx;
  padding: 0 9rpx;
  border: 2rpx solid #ffffff;
  border-radius: 999rpx;
  color: #ffffff;
  background: #2563eb;
  font-size: 16rpx;
  font-weight: 900;
  line-height: 27rpx;
  text-align: center;
}

.info-text {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.nickname {
  max-width: 250rpx;
  overflow: hidden;
  color: #111827;
  font-size: 33rpx;
  font-weight: 950;
  line-height: 1.18;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-chevron {
  flex-shrink: 0;
  color: #667085;
  font-size: 35rpx;
  font-weight: 500;
  line-height: 1;
}

.school {
  max-width: 280rpx;
  margin-top: 7rpx;
  overflow: hidden;
  color: #7b8797;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vip-badge {
  flex-shrink: 0;
  height: 32rpx;
  padding: 0 12rpx;
  border: 1rpx solid rgba(16,185,129,0.22);
  border-radius: 999rpx;
  color: #047857;
  background: #dcfce7;
  font-size: 16rpx;
  font-weight: 950;
  line-height: 32rpx;
}

.header-actions {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  flex-shrink: 0;
}

.header-action {
  display: flex;
  align-items: center;
  width: 52rpx;
  flex-direction: column;
  gap: 6rpx;
  color: #3f4a5a;
  font-size: 17rpx;
  font-weight: 700;
  line-height: 1;
}

.header-action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #273142;
  border-radius: 15rpx;
  color: #273142;
  background: rgba(255,255,255,0.8);
  font-size: 21rpx;
  font-weight: 950;
  line-height: 1;
}

.vip-banner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 112rpx;
  padding: 20rpx 22rpx;
  overflow: hidden;
  border: 1rpx solid rgba(234,179,8,0.16);
  border-radius: 23rpx 23rpx 0 0;
  background:
    radial-gradient(circle at 90% 14%, rgba(255,255,255,0.58), transparent 25%),
    linear-gradient(115deg, #fff87a 0%, #ffe62e 50%, #ffd51f 100%);
  box-shadow: 0 10rpx 24rpx rgba(202,138,4,0.11);
}

.vip-banner::after {
  content: '';
  position: absolute;
  right: 78rpx;
  top: -56rpx;
  width: 126rpx;
  height: 126rpx;
  border: 18rpx solid rgba(255,255,255,0.18);
  border-radius: 50%;
}

.vip-banner-active {
  min-height: 152rpx;
  border-color: rgba(16,185,129,0.22);
  background:
    radial-gradient(circle at 86% 12%, rgba(255,255,255,0.22), transparent 25%),
    linear-gradient(135deg, #052e2b 0%, #047857 58%, #10b981 100%);
  box-shadow: 0 14rpx 30rpx rgba(4,120,87,0.18);
}

.vip-banner-active .vip-crown {
  color: #064e3b;
  background: #ecfdf5;
}

.vip-banner-active .vip-title {
  color: #ffffff;
}

.vip-banner-active .vip-desc {
  color: #d1fae5;
}

.vip-banner-active .vip-btn {
  color: #047857;
  background: #ffffff;
  border-color: rgba(255,255,255,0.92);
}

.vip-left,
.vip-title-row {
  position: relative;
  z-index: 1;
  display: flex;
  min-width: 0;
}

.vip-left {
  flex: 1;
  flex-direction: column;
  gap: 7rpx;
}

.vip-title-row {
  align-items: center;
  gap: 9rpx;
}

.vip-crown {
  width: 47rpx;
  height: 31rpx;
  border-radius: 9rpx;
  color: #6d5200;
  background: rgba(255,255,255,0.6);
  font-size: 14rpx;
  font-weight: 950;
  line-height: 31rpx;
  text-align: center;
}

.vip-title {
  overflow: hidden;
  color: #2b2510;
  font-size: 27rpx;
  font-weight: 950;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vip-desc {
  overflow: hidden;
  color: #65551f;
  font-size: 20rpx;
  font-weight: 650;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vip-btn {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  height: 50rpx;
  padding: 0 17rpx;
  border: 1rpx solid rgba(255,255,255,0.74);
  border-radius: 999rpx;
  color: #5b4600;
  background: rgba(255,255,255,0.78);
  box-shadow: 0 7rpx 16rpx rgba(161,98,7,0.1);
  font-size: 19rpx;
  font-weight: 900;
  line-height: 50rpx;
}

.vip-unlocked-row {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 8rpx;
  min-width: 0;
  overflow: hidden;
}

.vip-unlocked-row text {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 11rpx;
  border: 1rpx solid rgba(255,255,255,0.24);
  border-radius: 999rpx;
  color: #ecfdf5;
  background: rgba(255,255,255,0.13);
  font-size: 17rpx;
  font-weight: 800;
  line-height: 34rpx;
  white-space: nowrap;
}

.stats-card {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  padding: 18rpx 4rpx;
  border: 1rpx solid rgba(15,23,42,0.045);
  border-top: none;
  border-radius: 0 0 23rpx 23rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(15,23,42,0.045);
}

.stat-item {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 8rpx;
}

.stat-num {
  color: #111827;
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1;
}

.stat-label {
  overflow: hidden;
  color: #3f4a5a;
  font-size: 19rpx;
  font-weight: 750;
  line-height: 1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.workspace-card,
.tool-card,
.service-card {
  width: 100%;
  margin-top: 14rpx;
  overflow: hidden;
  border: 1rpx solid rgba(15,23,42,0.045);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(15,23,42,0.045);
}

.workspace-card {
  padding: 22rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-head.compact {
  margin-bottom: 20rpx;
  padding: 22rpx 22rpx 0;
}

.section-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 6rpx;
}

.section-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 950;
  line-height: 1.2;
}

.section-desc {
  color: #98a2b3;
  font-size: 19rpx;
  font-weight: 600;
  line-height: 1.2;
}

.section-status {
  flex-shrink: 0;
  height: 37rpx;
  padding: 0 13rpx;
  border-radius: 999rpx;
  color: #2563eb;
  background: #eef4ff;
  font-size: 17rpx;
  font-weight: 900;
  line-height: 37rpx;
}

.workspace-actions {
  display: flex;
  gap: 10rpx;
}

.workspace-action {
  display: flex;
  justify-content: center;
  flex: 1;
  min-width: 0;
  min-height: 126rpx;
  padding: 16rpx 12rpx;
  flex-direction: column;
  overflow: hidden;
  border: 1rpx solid #e8edf4;
  border-radius: 18rpx;
  background: #fafcff;
}

.workspace-action.primary {
  border-color: #c7d9ff;
  background: linear-gradient(145deg, #edf4ff 0%, #f8fbff 100%);
  box-shadow: inset 0 4rpx 0 #2563eb;
}

.workspace-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin-bottom: 9rpx;
  border-radius: 12rpx;
  color: #2563eb;
  background: #eaf2ff;
  font-size: 16rpx;
  font-weight: 950;
}

.workspace-action.primary .workspace-icon {
  color: #ffffff;
  background: #2563eb;
}

.workspace-name {
  overflow: hidden;
  color: #263247;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.workspace-desc {
  margin-top: 5rpx;
  overflow: hidden;
  color: #98a2b3;
  font-size: 17rpx;
  font-weight: 650;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-grid {
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
  row-gap: 24rpx;
  padding: 0 8rpx 24rpx;
}

.tool-item {
  position: relative;
  display: flex;
  align-items: center;
  width: 20%;
  min-width: 0;
  flex-direction: column;
}

.tool-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(15,23,42,0.07);
  border-radius: 20rpx;
  font-size: 21rpx;
  font-weight: 950;
}

.tool-icon-image {
  display: block;
  width: 34rpx;
  height: 34rpx;
}

.tone-blue {
  color: #2459b8;
  background: #edf4ff;
}

.tone-amber {
  color: #a65c00;
  background: #fff5dc;
}

.tone-mint {
  color: #047857;
  background: #eafaf4;
}

.tone-violet {
  color: #6d46c4;
  background: #f3efff;
}

.tone-coral {
  color: #c04a44;
  background: #fff0ef;
}

.tool-name {
  width: 100%;
  overflow: hidden;
  color: #263247;
  font-size: 19rpx;
  font-weight: 750;
  line-height: 1.2;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-badge {
  position: absolute;
  top: -8rpx;
  left: calc(50% + 9rpx);
  height: 24rpx;
  padding: 0 7rpx;
  border: 2rpx solid #ffffff;
  border-radius: 999rpx;
  color: #ffffff;
  background: #2563eb;
  font-size: 12rpx;
  font-weight: 950;
  line-height: 24rpx;
}

.service-grid {
  display: flex;
  align-items: flex-start;
  padding: 0 12rpx 24rpx;
}

.service-item {
  display: flex;
  align-items: center;
  width: 25%;
  min-width: 0;
  flex-direction: column;
  gap: 11rpx;
  color: #263247;
  font-size: 20rpx;
  font-weight: 750;
  line-height: 1.2;
}

.service-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 950;
  box-shadow: 0 7rpx 16rpx rgba(15,23,42,0.09);
}

.service-icon-image {
  display: block;
  width: 31rpx;
  height: 31rpx;
}

.service-blue { background: linear-gradient(135deg, #60a5fa, #2563eb); }
.service-green { background: linear-gradient(135deg, #34d399, #059669); }
.service-orange { background: linear-gradient(135deg, #fbbf24, #f97316); font-size: 13rpx; }
.service-gray { background: linear-gradient(135deg, #94a3b8, #475569); }

.panel-press,
.tile-press,
.tap-soft {
  transform: scale(0.97);
  opacity: 0.84;
}
