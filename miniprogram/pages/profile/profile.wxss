/* pages/profile/profile.wxss */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container { display: flex; flex-direction: column; }

/* ── 用户头部 ── */
.user-header {
  background: linear-gradient(135deg, var(--brand) 0%, #1C3578 100%);
  padding: 48rpx 32rpx 0;
  position: relative;
  overflow: hidden;
}

/* 装饰圆 — 极淡，纯装饰 */
.deco-circle {
  position: absolute; border-radius: 50%;
  background: rgba(255,255,255,0.06); pointer-events: none;
}
.deco1 { width: 300rpx; height: 300rpx; top: -80rpx; right: -60rpx; }
.deco2 { width: 200rpx; height: 200rpx; bottom: 40rpx; left: -60rpx; }

/* 用户信息行 */
.user-info {
  display: flex; align-items: center;
  gap: 20rpx; padding-bottom: 36rpx;
}
.avatar-wrap { position: relative; flex-shrink: 0; }
.avatar {
  width: 108rpx; height: 108rpx; border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.15); display: block;
}
.avatar-badge {
  position: absolute; bottom: -2rpx; right: -2rpx;
  background: var(--brand); color: #fff;
  font-size: 18rpx; font-weight: 700;
  padding: 3rpx 10rpx; border-radius: 10rpx;
  border: 2rpx solid #fff;
}

.info-text {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 8rpx;
}
.name-row { display: flex; align-items: center; gap: 14rpx; }
.nickname {
  font-size: 36rpx; font-weight: 700; color: var(--bg-panel); letter-spacing: -0.5rpx;
}
.vip-badge {
  display: flex; align-items: center; justify-content: center;
  background: rgba(245,158,11,0.25);
  border: 1rpx solid rgba(245,158,11,0.6);
  color: #FCD34D; font-size: 19rpx;
  padding: 4rpx 14rpx; border-radius: 8rpx;
  font-weight: 700; letter-spacing: 1rpx;
}
.school {
  font-size: 24rpx; color: rgba(255,255,255,0.7);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.edit-btn {
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: rgba(255,255,255,0.9);
  border: 1.5rpx solid rgba(255,255,255,0.35);
  padding: 10rpx 26rpx; border-radius: 32rpx;
  background: rgba(255,255,255,0.12); flex-shrink: 0;
}
.arrow-btn {
  font-size: 44rpx; color: rgba(255,255,255,0.5);
  flex-shrink: 0; line-height: 1;
}

/* ── 统计数据卡 ── */
.stats-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg) 20rpx 0 0;
  padding: 32rpx 20rpx;
  display: flex; align-items: center; justify-content: space-around;
}
.stat-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; gap: 6rpx;
}
.stat-divider {
  width: 1.5rpx; height: 44rpx;
  background: #F1F5F9; flex-shrink: 0;
}
.stat-num {
  font-size: 36rpx; font-weight: 700; color: var(--text-primary);
  line-height: 1; letter-spacing: -0.5rpx;
}
.stat-label { font-size: 22rpx; color: var(--text-muted); font-weight: 500; }

/* ── VIP Banner ── */
.vip-banner {
  margin: 16rpx 20rpx 0;
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border: 1.5rpx solid rgba(245,158,11,0.3);
  border-radius: var(--r-lg);
  padding: 26rpx 28rpx;
  display: flex; justify-content: space-between; align-items: center;
  overflow: hidden; position: relative;
}
.vip-banner::after {
  content: '';
  position: absolute; top: -40rpx; right: -20rpx;
  width: 180rpx; height: 180rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(245,158,11,0.15), transparent 70%);
  pointer-events: none;
}
.vip-left { display: flex; flex-direction: column; gap: 6rpx; }
.vip-title-row { display: flex; align-items: center; gap: 8rpx; }
.vip-crown { font-size: 28rpx; line-height: 1; }
.vip-title { font-size: 28rpx; font-weight: 800; color: #92400e; letter-spacing: 0.3rpx; }
.vip-desc  { font-size: 22rpx; color: #b45309; }
.vip-btn {
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx;
  background: var(--warning);
  color: #fff;
  padding: 14rpx 28rpx; border-radius: 28rpx;
  font-weight: 700; flex-shrink: 0; z-index: 1; white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(245,158,11,0.35);
}

/* ── 菜单分组 ── */
.menu-group {
  background: var(--bg-panel);
  margin: 16rpx 20rpx 0;
  border-radius: var(--r-lg);
  overflow: hidden;
  border: 1.5rpx solid rgba(0,0,0,0.05);
}
.group-title {
  padding: 22rpx 28rpx 10rpx;
  font-size: 21rpx; font-weight: 700; color: var(--text-muted);
  letter-spacing: 2rpx;
}
.menu-item {
  display: flex; align-items: center;
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid #F1F5F9;
  gap: 20rpx;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #F9FAFB; }
.menu-icon-box {
  width: 72rpx; height: 72rpx;
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.menu-emoji { font-size: 34rpx; line-height: 1; }
.menu-name { flex: 1; font-size: 30rpx; color: var(--text-primary); font-weight: 500; }
.tag-new {
  display: flex; align-items: center; justify-content: center;
  font-size: 18rpx; color: var(--brand);
  background: #EEF2FF;
  padding: 4rpx 12rpx; border-radius: 8rpx;
  font-weight: 700; letter-spacing: 0.5rpx; flex-shrink: 0;
  border: 1rpx solid rgba(94,106,210,0.25);
}
.menu-arrow {
  width: 14rpx; height: 14rpx;
  border-right: 3rpx solid #D1D5DB;
  border-top: 3rpx solid #D1D5DB;
  transform: rotate(45deg); flex-shrink: 0;
}

/* ===== UI polish: profile page ===== */
page {
  background:
    radial-gradient(circle at 10% -4%, rgba(43,92,230,0.13), transparent 34%),
    radial-gradient(circle at 92% 8%, rgba(245,158,11,0.12), transparent 28%),
    linear-gradient(180deg, #ffffff 0%, #f6f8fc 38%, #f8fafc 100%);
}

.container {
  width: 100%;
  min-height: 100vh;
  overflow-x: hidden;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
}

.user-header {
  margin: 0 0 28rpx;
  padding: 54rpx 28rpx 26rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 86% 18%, rgba(255,255,255,0.16), transparent 26%),
    linear-gradient(135deg, #1d4ed8 0%, #2447bf 46%, #172554 100%);
  border-radius: 0 0 42rpx 42rpx;
  box-shadow: 0 22rpx 50rpx rgba(29,78,216,0.22);
}

.deco-circle {
  background: rgba(255,255,255,0.08);
}

.deco1 {
  width: 340rpx;
  height: 340rpx;
  top: -70rpx;
  right: -74rpx;
  border: 1rpx solid rgba(255,255,255,0.10);
}

.deco2 {
  width: 190rpx;
  height: 190rpx;
  left: -52rpx;
  bottom: 76rpx;
}

.user-info {
  position: relative;
  z-index: 1;
  min-height: 142rpx;
  padding: 8rpx 8rpx 28rpx;
  align-items: flex-start;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border: 5rpx solid rgba(255,255,255,0.72);
  background: rgba(255,255,255,0.22);
  box-shadow: 0 18rpx 34rpx rgba(15,23,42,0.22);
}

.avatar-badge {
  right: -8rpx;
  bottom: 0;
  background: linear-gradient(135deg, #f59e0b, #fb7185);
  border-radius: 999rpx;
  box-shadow: 0 8rpx 16rpx rgba(15,23,42,0.18);
}

.nickname {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 0.2rpx;
}

.school {
  max-width: 420rpx;
  color: rgba(255,255,255,0.78);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 34rpx;
}

.edit-btn,
.arrow-btn {
  color: #ffffff;
  background: rgba(255,255,255,0.16);
  border: 1.5rpx solid rgba(255,255,255,0.32);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.20);
}

.edit-btn {
  padding: 12rpx 28rpx;
  font-weight: 800;
}

.vip-badge {
  background: linear-gradient(135deg, rgba(245,158,11,0.32), rgba(251,191,36,0.20));
  color: #fde68a;
}

.stats-card {
  position: relative;
  z-index: 2;
  padding: 24rpx 12rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.96);
  border: 1.5rpx solid rgba(148,163,184,0.14);
  box-shadow: 0 18rpx 44rpx rgba(15,23,42,0.13);
}

.stat-item {
  padding: 6rpx 0;
  border-radius: 18rpx;
}

.stat-num {
  color: #172554;
  font-size: 34rpx;
  font-weight: 950;
}

.stat-label {
  color: #8a94a6;
  font-size: 21rpx;
  font-weight: 750;
}

.stat-divider {
  background: rgba(148,163,184,0.18);
}

.vip-banner {
  margin: 18rpx 22rpx 0;
  padding: 26rpx 26rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 86% 16%, rgba(255,255,255,0.38), transparent 30%),
    linear-gradient(135deg, #fff7d6 0%, #ffedb6 48%, #fff8e8 100%);
  border: 1.5rpx solid rgba(245,158,11,0.26);
  box-shadow: 0 16rpx 36rpx rgba(245,158,11,0.13);
}

.vip-title {
  color: #92400e;
  font-size: 28rpx;
  font-weight: 950;
}

.vip-desc {
  color: #b45309;
  font-size: 22rpx;
  font-weight: 650;
}

.vip-btn {
  padding: 15rpx 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f59e0b, #f97316);
  box-shadow: 0 12rpx 22rpx rgba(249,115,22,0.28);
}

.menu-group {
  margin: 18rpx 22rpx 0;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.94);
  border: 1.5rpx solid rgba(148,163,184,0.14);
  box-shadow: 0 16rpx 40rpx rgba(15,23,42,0.06);
}

.group-title {
  padding: 24rpx 28rpx 12rpx;
  color: #8a94a6;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1.2rpx;
}

.menu-item {
  min-height: 100rpx;
  padding: 20rpx 28rpx;
  border-bottom-color: rgba(148,163,184,0.12);
}

.menu-icon-box {
  width: 70rpx;
  height: 70rpx;
  border-radius: 20rpx;
  box-shadow: inset 0 -2rpx 0 rgba(15,23,42,0.03);
}

.menu-name {
  color: #1f2937;
  font-size: 29rpx;
  font-weight: 780;
}

.menu-arrow {
  border-color: #cbd5e1;
}

.tag-new {
  color: #2557d6;
  background: #eef4ff;
  border-radius: 999rpx;
  font-size: 18rpx;
}

.panel-press,
.menu-press,
.tap-soft {
  transform: scale(0.982);
  opacity: 0.84;
}
