/* pages/profile/profile.wxss */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container { display: flex; flex-direction: column; }

/* ── 用户头部 ── */
.user-header {
  background: linear-gradient(135deg, var(--brand) 0%, #1C3578 100%);
  padding: 48rpx 32rpx 0;
  position: relative;
  overflow: hidden;
}

/* 装饰圆 — 极淡，纯装饰 */
.deco-circle {
  position: absolute; border-radius: 50%;
  background: rgba(255,255,255,0.06); pointer-events: none;
}
.deco1 { width: 300rpx; height: 300rpx; top: -80rpx; right: -60rpx; }
.deco2 { width: 200rpx; height: 200rpx; bottom: 40rpx; left: -60rpx; }

/* 用户信息行 */
.user-info {
  display: flex; align-items: center;
  gap: 20rpx; padding-bottom: 36rpx;
}
.avatar-wrap { position: relative; flex-shrink: 0; }
.avatar {
  width: 108rpx; height: 108rpx; border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.15); display: block;
}
.avatar-badge {
  position: absolute; bottom: -2rpx; right: -2rpx;
  background: var(--brand); color: #fff;
  font-size: 18rpx; font-weight: 700;
  padding: 3rpx 10rpx; border-radius: 10rpx;
  border: 2rpx solid #fff;
}

.info-text {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 8rpx;
}
.name-row { display: flex; align-items: center; gap: 14rpx; }
.nickname {
  font-size: 36rpx; font-weight: 700; color: var(--bg-panel); letter-spacing: -0.5rpx;
}
.vip-badge {
  display: flex; align-items: center; justify-content: center;
  background: rgba(245,158,11,0.25);
  border: 1rpx solid rgba(245,158,11,0.6);
  color: #FCD34D; font-size: 19rpx;
  padding: 4rpx 14rpx; border-radius: 8rpx;
  font-weight: 700; letter-spacing: 1rpx;
}
.school {
  font-size: 24rpx; color: rgba(255,255,255,0.7);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.edit-btn {
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: rgba(255,255,255,0.9);
  border: 1.5rpx solid rgba(255,255,255,0.35);
  padding: 10rpx 26rpx; border-radius: 32rpx;
  background: rgba(255,255,255,0.12); flex-shrink: 0;
}
.arrow-btn {
  font-size: 44rpx; color: rgba(255,255,255,0.5);
  flex-shrink: 0; line-height: 1;
}

/* ── 统计数据卡 ── */
.stats-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg) 20rpx 0 0;
  padding: 32rpx 20rpx;
  display: flex; align-items: center; justify-content: space-around;
}
.stat-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; gap: 6rpx;
}
.stat-divider {
  width: 1.5rpx; height: 44rpx;
  background: #F1F5F9; flex-shrink: 0;
}
.stat-num {
  font-size: 36rpx; font-weight: 700; color: var(--text-primary);
  line-height: 1; letter-spacing: -0.5rpx;
}
.stat-label { font-size: 22rpx; color: var(--text-muted); font-weight: 500; }

/* ── VIP Banner ── */
.vip-banner {
  margin: 16rpx 20rpx 0;
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border: 1.5rpx solid rgba(245,158,11,0.3);
  border-radius: var(--r-lg);
  padding: 26rpx 28rpx;
  display: flex; justify-content: space-between; align-items: center;
  overflow: hidden; position: relative;
}
.vip-banner::after {
  content: '';
  position: absolute; top: -40rpx; right: -20rpx;
  width: 180rpx; height: 180rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(245,158,11,0.15), transparent 70%);
  pointer-events: none;
}
.vip-left { display: flex; flex-direction: column; gap: 6rpx; }
.vip-title-row { display: flex; align-items: center; gap: 8rpx; }
.vip-crown { font-size: 28rpx; line-height: 1; }
.vip-title { font-size: 28rpx; font-weight: 800; color: #92400e; letter-spacing: 0.3rpx; }
.vip-desc  { font-size: 22rpx; color: #b45309; }
.vip-btn {
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx;
  background: var(--warning);
  color: #fff;
  padding: 14rpx 28rpx; border-radius: 28rpx;
  font-weight: 700; flex-shrink: 0; z-index: 1; white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(245,158,11,0.35);
}

/* ── 菜单分组 ── */
.menu-group {
  background: var(--bg-panel);
  margin: 16rpx 20rpx 0;
  border-radius: var(--r-lg);
  overflow: hidden;
  border: 1.5rpx solid rgba(0,0,0,0.05);
}
.group-title {
  padding: 22rpx 28rpx 10rpx;
  font-size: 21rpx; font-weight: 700; color: var(--text-muted);
  letter-spacing: 2rpx;
}
.menu-item {
  display: flex; align-items: center;
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid #F1F5F9;
  gap: 20rpx;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #F9FAFB; }
.menu-icon-box {
  width: 72rpx; height: 72rpx;
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.menu-emoji { font-size: 34rpx; line-height: 1; }
.menu-name { flex: 1; font-size: 30rpx; color: var(--text-primary); font-weight: 500; }
.tag-new {
  display: flex; align-items: center; justify-content: center;
  font-size: 18rpx; color: var(--brand);
  background: #EEF2FF;
  padding: 4rpx 12rpx; border-radius: 8rpx;
  font-weight: 700; letter-spacing: 0.5rpx; flex-shrink: 0;
  border: 1rpx solid rgba(94,106,210,0.25);
}
.menu-arrow {
  width: 14rpx; height: 14rpx;
  border-right: 3rpx solid #D1D5DB;
  border-top: 3rpx solid #D1D5DB;
  transform: rotate(45deg); flex-shrink: 0;
}
