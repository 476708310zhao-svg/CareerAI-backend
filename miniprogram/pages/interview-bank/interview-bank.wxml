<!-- pages/interview-bank/interview-bank.wxml -->
<view class="page">
  <view class="top-tabs">
    <block wx:for="{{modes}}" wx:key="key">
      <view class="top-tab mode-{{item.key}} {{activeMode === item.key ? 'active' : ''}}" bindtap="switchMode" data-key="{{item.key}}">
        <text class="top-tab-title">{{item.label}}</text>
        <text class="top-tab-badge {{item.key === 'elite' ? 'flame' : ''}}">{{item.badge}}</text>
      </view>
    </block>
  </view>

  <view class="filter-card">
    <view class="search-box">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索题目关键词"
        placeholder-class="placeholder"
        value="{{searchKey}}"
        bindinput="onSearch"
        confirm-type="search"
      />
      <view wx:if="{{searchKey}}" class="search-clear" catchtap="clearSearch">×</view>
    </view>

    <scroll-view scroll-x class="chip-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="chip-row">
        <block wx:for="{{categories}}" wx:key="key">
          <view class="chip {{activeCategory === item.key ? 'active' : ''}}" bindtap="selectCategory" data-key="{{item.key}}">{{item.label}}</view>
        </block>
      </view>
    </scroll-view>

    <scroll-view scroll-x class="chip-scroll compact" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="chip-row">
        <block wx:for="{{difficulties}}" wx:key="key">
          <view class="chip soft {{activeDifficulty === item.key ? 'active' : ''}}" bindtap="selectDifficulty" data-key="{{item.key}}">{{item.label}}</view>
        </block>
      </view>
    </scroll-view>

    <view class="chip-row last-row">
      <block wx:for="{{qualities}}" wx:key="key">
        <view class="chip soft {{activeQuality === item.key ? 'active' : ''}}" bindtap="selectQuality" data-key="{{item.key}}">{{item.label}}</view>
      </block>
      <view class="reset-link" bindtap="resetFilters">重置</view>
    </view>

    <view class="ai-card">
      <view class="ai-icon">AI</view>
      <view class="ai-copy">
        <text class="ai-title">智能出题</text>
        <text class="ai-sub">DeepSeek AI 生成高频面试题</text>
      </view>
      <view class="ai-btn" bindtap="generateAiQuestions">生成题目</view>
    </view>
  </view>

  <view class="summary-row">
    <view>
      <text class="summary-title">精选题库</text>
      <text class="summary-sub">共 {{filtered.length}} 题</text>
    </view>
    <view class="progress-pill">
      <text>{{doneCount}}</text>
      <text class="progress-muted">已练</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{filtered.length === 0}}">
    <text class="empty-icon">⌕</text>
    <text class="empty-title">没有找到相关题目</text>
    <text class="empty-sub">换个关键词或清空筛选条件试试</text>
    <view class="empty-btn" bindtap="resetFilters">清空筛选</view>
  </view>

  <view class="question-list" wx:else>
    <view wx:for="{{filtered}}" wx:key="qid" class="question-card" bindtap="openQuestion" data-id="{{item.id}}">
      <view class="card-main">
        <view class="number-badge">{{index + 1}}</view>
        <view class="question-body">
          <view class="title-row">
            <text class="question-title">{{item.title}}</text>
            <text class="difficulty {{item.difficultyTone}}">{{item.difficulty}}</text>
          </view>
          <view class="meta-row">
            <text class="meta-chip featured" wx:if="{{item.isFeatured}}">精华</text>
            <text class="meta-chip">{{item.categoryName}}</text>
            <text class="meta-dot">•</text>
            <text class="views">{{item.views}} 浏览</text>
          </view>
          <text class="answer-preview">{{item.answer}}</text>
          <view class="bottom-row">
            <view class="status-group">
              <text class="status done" wx:if="{{item.isDone}}">已练习</text>
              <text class="status saved" wx:if="{{item.isCollected}}">已收藏</text>
            </view>
            <view class="practice-link" catchtap="practiceQuestion" data-id="{{item.id}}">练习 →</view>
          </view>
        </view>
      </view>
      <view class="card-actions">
        <view class="action {{item.isCollected ? 'active' : ''}}" catchtap="toggleCollect" data-id="{{item.id}}">
          <text>{{item.isCollected ? '★' : '☆'}}</text>
          <text>{{item.isCollected ? '已收藏' : '收藏'}}</text>
        </view>
        <view class="action" catchtap="markDone" data-id="{{item.id}}">
          <text>✓</text>
          <text>标记练习</text>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-tail"></view>
</view>
