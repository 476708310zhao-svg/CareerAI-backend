/* pages/interview-bank/interview-bank.wxss */
page {
  background: #f6f8fc;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.page {
  min-height: 100vh;
  padding: 0 22rpx;
  background:
    radial-gradient(circle at 8% 2%, rgba(37, 99, 235, 0.12), transparent 34%),
    radial-gradient(circle at 94% 6%, rgba(245, 158, 11, 0.11), transparent 30%),
    linear-gradient(180deg, #ffffff 0%, #f6f8fc 36%, #f8fafc 100%);
}

.top-tabs {
  padding: 16rpx 2rpx 10rpx;
  white-space: nowrap;
  width: 100%;
  box-sizing: border-box;
}

.top-tab-track {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  min-width: 100%;
  box-sizing: border-box;
}

.top-tab {
  position: relative;
  flex: 0 0 auto;
  height: 62rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  color: #94a3b8;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
}

.top-tab.mode-featured {
  width: auto;
}

.top-tab.mode-leetcode {
  width: auto;
}

.top-tab.mode-topics {
  width: auto;
}

.top-tab.mode-elite {
  width: auto;
}

.top-tab.active {
  color: #2563eb;
  background: rgba(37, 99, 235, 0.08);
}

.top-tab.active::after {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  height: 5rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2563eb, #38bdf8);
}

.top-tab-title {
  display: inline-block;
  flex: none;
  word-break: keep-all;
  white-space: nowrap;
  line-height: 28rpx;
}

.top-tab-badge {
  flex-shrink: 0;
  min-width: 28rpx;
  height: 24rpx;
  padding: 0 7rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  color: #2563eb;
  background: #dbeafe;
  font-size: 17rpx;
  font-weight: 950;
  line-height: 24rpx;
  text-align: center;
}

.top-tab-badge.flame {
  color: #ea580c;
  background: #ffedd5;
}

.filter-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(148, 163, 184, 0.13);
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.07);
}

.search-box {
  height: 72rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  border: 1.5rpx solid rgba(148, 163, 184, 0.18);
}

.search-icon {
  color: #94a3b8;
  font-size: 30rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  height: 72rpx;
  color: #0f172a;
  font-size: 26rpx;
  line-height: 72rpx;
}

.placeholder {
  color: #a1aab8;
}

.search-clear {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  color: #64748b;
  background: #e2e8f0;
  font-size: 30rpx;
  line-height: 36rpx;
  text-align: center;
}

.chip-scroll {
  margin-top: 16rpx;
  white-space: nowrap;
}

.chip-scroll.compact {
  margin-top: 12rpx;
}

.chip-row {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-width: 100%;
}

.last-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.chip {
  flex-shrink: 0;
  padding: 11rpx 22rpx;
  border-radius: 999rpx;
  color: #64748b;
  background: #f8fafc;
  border: 1.5rpx solid rgba(148, 163, 184, 0.18);
  font-size: 23rpx;
  font-weight: 800;
}

.chip.soft {
  padding: 10rpx 20rpx;
  background: #f1f5f9;
}

.chip.active {
  color: #2563eb;
  background: linear-gradient(135deg, #dbeafe, #eef2ff);
  border-color: rgba(37, 99, 235, 0.28);
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.08);
}

.reset-link {
  margin-left: auto;
  padding: 10rpx 4rpx 10rpx 18rpx;
  color: #94a3b8;
  font-size: 23rpx;
  font-weight: 800;
}

.ai-card {
  margin-top: 20rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #edf4ff, #f8fbff 48%, #eef2ff);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  box-shadow: 0 12rpx 30rpx rgba(37, 99, 235, 0.09);
}

.ai-icon {
  width: 58rpx;
  height: 58rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  font-size: 23rpx;
  font-weight: 950;
  line-height: 58rpx;
  text-align: center;
}

.ai-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ai-title {
  color: #172554;
  font-size: 27rpx;
  font-weight: 950;
}

.ai-sub {
  color: #64748b;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ai-btn {
  flex-shrink: 0;
  padding: 15rpx 24rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  font-size: 24rpx;
  font-weight: 950;
  box-shadow: 0 10rpx 24rpx rgba(37, 99, 235, 0.28);
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 6rpx 14rpx;
}

.summary-title {
  color: #94a3b8;
  font-size: 25rpx;
  font-weight: 850;
}

.summary-sub {
  margin-left: 8rpx;
  color: #64748b;
  font-size: 25rpx;
  font-weight: 900;
}

.progress-pill {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #047857;
  background: #ecfdf5;
  font-size: 24rpx;
  font-weight: 950;
}

.progress-muted {
  color: #10b981;
  font-size: 21rpx;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.question-card {
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(148, 163, 184, 0.13);
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.065);
  overflow: hidden;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.question-card:active {
  transform: scale(0.986);
  opacity: 0.86;
}

.card-main {
  display: flex;
  gap: 14rpx;
  padding: 22rpx 22rpx 18rpx;
}

.number-badge {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  border-radius: 14rpx;
  color: #64748b;
  background: #f1f5f9;
  font-size: 23rpx;
  font-weight: 950;
  line-height: 44rpx;
  text-align: center;
}

.question-body {
  flex: 1;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.question-title {
  flex: 1;
  color: #0f172a;
  font-size: 29rpx;
  line-height: 1.42;
  font-weight: 950;
}

.difficulty {
  flex-shrink: 0;
  padding: 6rpx 13rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 950;
}

.difficulty.easy {
  color: #059669;
  background: #ecfdf5;
}

.difficulty.medium {
  color: #d97706;
  background: #fffbeb;
}

.difficulty.hard {
  color: #dc2626;
  background: #fef2f2;
}

.meta-row {
  margin-top: 11rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #94a3b8;
  font-size: 21rpx;
  font-weight: 750;
}

.meta-chip {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  color: #64748b;
  background: #f1f5f9;
}

.meta-chip.featured {
  color: #d97706;
  background: #fffbeb;
  border: 1rpx solid rgba(245, 158, 11, 0.18);
}

.meta-dot {
  color: #fbbf24;
  font-size: 24rpx;
}

.views {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.answer-preview {
  display: -webkit-box;
  margin-top: 13rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.55;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.bottom-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.status-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 32rpx;
}

.status {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 850;
}

.status.done {
  color: #047857;
  background: #ecfdf5;
}

.status.saved {
  color: #2563eb;
  background: #eff6ff;
}

.practice-link {
  flex-shrink: 0;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 950;
}

.card-actions {
  display: flex;
  border-top: 1rpx solid rgba(148, 163, 184, 0.1);
  background: #fbfdff;
}

.action {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  font-weight: 850;
}

.action + .action {
  border-left: 1rpx solid rgba(148, 163, 184, 0.1);
}

.action.active {
  color: #2563eb;
}

.empty-state {
  margin: 34rpx 0;
  padding: 80rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(148, 163, 184, 0.13);
}

.empty-icon {
  color: #cbd5e1;
  font-size: 68rpx;
}

.empty-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 950;
}

.empty-sub {
  color: #64748b;
  font-size: 24rpx;
}

.empty-btn {
  margin-top: 12rpx;
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #2563eb;
  font-size: 25rpx;
  font-weight: 900;
}

.safe-tail {
  height: calc(42rpx + env(safe-area-inset-bottom));
}
