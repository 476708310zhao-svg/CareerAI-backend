<!-- pages/messages/messages.wxml -->
<view class="container">

  <view class="message-hero">
    <view>
      <text class="hero-kicker">MESSAGE CENTER</text>
      <text class="hero-title">消息中心</text>
      <text class="hero-sub">申请进度、互动回复和系统提醒都会同步到这里</text>
    </view>
    <view class="hero-count">
      <text class="count-num">{{unreadTotal}}</text>
      <text class="count-label">未读</text>
    </view>
  </view>

  <view class="quick-panel">
    <block wx:for="{{quickActions}}" wx:key="type">
      <view class="quick-card" bindtap="handleQuickAction" data-type="{{item.type}}">
        <text class="quick-title">{{item.title}}</text>
        <text class="quick-desc">{{item.desc}}</text>
      </view>
    </block>
  </view>

  <!-- Tab 栏 -->
  <view class="tab-bar">
    <block wx:for="{{tabs}}" wx:key="*this">
      <view class="tab-item {{currentTab === index ? 'active' : ''}}" bindtap="switchTab" data-index="{{index}}">
        <text>{{item}}</text>
        <text class="tab-count">{{tabCounts[index] || 0}}</text>
      </view>
    </block>
    <view class="read-all-btn" bindtap="markAllRead">全部已读</view>
  </view>

  <!-- 消息列表 -->
  <view class="message-list">
    <block wx:for="{{filteredMessages}}" wx:key="id">
      <view class="message-card {{item.isRead ? 'read' : 'unread'}}" bindtap="tapMessage" data-index="{{index}}">
        <!-- 未读红点 -->
        <view class="unread-dot" wx:if="{{!item.isRead}}"></view>

        <!-- 图标 -->
        <view class="msg-icon-wrap">
          <image class="msg-icon-img" src="{{item.icon}}" mode="aspectFit" lazy-load></image>
        </view>

        <!-- 内容 -->
        <view class="msg-body">
          <view class="msg-top">
            <text class="msg-title">{{item.title}}</text>
            <text class="msg-time">{{item.createdAt}}</text>
          </view>
          <text class="msg-content">{{item.content}}</text>
        </view>
      </view>
    </block>

    <!-- 清空按钮 -->
    <view wx:if="{{filteredMessages.length > 0}}" class="clear-wrap" bindtap="clearMessages">
      <text class="clear-text">清空所有消息</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{filteredMessages.length === 0}}" class="empty">
      <image class="empty-icon" src="/images/home-active.png" mode="aspectFit" lazy-load></image>
      <text class="empty-text">暂无消息</text>
      <text class="empty-sub">投递进度、互动提醒和系统通知会出现在这里</text>
      <view class="empty-actions">
        <view class="empty-action primary" bindtap="goApplications">查看网申</view>
        <view class="empty-action" bindtap="goInterview">开始面试</view>
      </view>
    </view>
  </view>

</view>
