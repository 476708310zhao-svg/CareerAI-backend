/* pages/ai-assistant/ai-assistant.wxss */
page { background: #F2F2F7; }

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F2F2F7;
}

/* ── 顶部栏 ── */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 16rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.top-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 88rpx;
}
.top-icon {
  font-size: 28rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  color: transparent;
}
.top-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C1C1E;
  letter-spacing: 0.5px;
}
.clear-btn {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: #F2F2F7;
}
.clear-txt { font-size: 26rpx; color: #8E8E93; }

/* ── 消息滚动区 ── */
.msg-scroll {
  flex: 1;
  overflow: hidden;
  transition: margin-bottom 0.25s;
}
.msg-list { padding: 24rpx 24rpx 0; }

/* ── 时间戳 ── */
.time-stamp {
  text-align: center;
  font-size: 22rpx;
  color: #C7C7CC;
  margin: 8rpx 0 20rpx;
}

/* ── 消息行 ── */
.msg-row {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-end;
}
.ai-row   { flex-direction: row; }
.user-row { flex-direction: row-reverse; }

/* ── AI 头像 ── */
.ai-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 18rpx;
  margin-bottom: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.35);
}
.ai-avatar-icon { font-size: 28rpx; color: #fff; }

/* ── 气泡容器 ── */
.bubble-wrap {
  max-width: 80%;
  display: flex;
  flex-direction: column;
}
.ai-row   .bubble-wrap { align-items: flex-start; }
.user-row .bubble-wrap { align-items: flex-end; }

/* ── 气泡 ── */
.bubble {
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  word-break: break-word;
}
.ai-bubble {
  background: #FFFFFF;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.07);
}
.user-bubble {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}
.error-bubble {
  background: #FFF2F2;
  border: 1.5rpx solid #FFD0D0;
  border-bottom-left-radius: 8rpx;
}

/* ── 气泡文本（<text> 和 <rich-text> 共用） ── */
.bubble-text {
  font-size: 28rpx;
  line-height: 1.75;
  color: #1C1C1E;
  display: block;
}
.user-bubble  .bubble-text { color: #FFFFFF; }
.error-bubble .bubble-text { color: #FF3B30; }

/* rich-text 块宽度撑满气泡 */
.bubble-rich { width: 100%; }

/* ── 错误重试按钮 ── */
.retry-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
}
.retry-btn {
  display: flex;
  align-items: center;
  background: #FFF2F2;
  border: 1.5rpx solid #FFD0D0;
  border-radius: 20rpx;
  padding: 10rpx 22rpx;
}
.retry-txt {
  font-size: 24rpx;
  color: #FF453A;
  font-weight: 600;
}

/* ── 2×2 快捷指令网格 ── */
.quick-grid {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
}
.quick-card {
  width: calc(50% - 8rpx);
  box-sizing: border-box;
  background: #F0EFFF;
  border: 1.5rpx solid #D8D5FF;
  border-radius: 20rpx;
  padding: 22rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.quick-card.quick-disabled { opacity: 0.45; }
.quick-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #6C5CE7;
  text-align: center;
  line-height: 1.4;
}

/* ── 后续建议 chips ── */
.suggestions {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.sug-chip {
  background: #EEF0FF;
  color: #5B5FC7;
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #D0D4FF;
}
.chip-hover { opacity: 0.65; }

/* ── 加载动画 ── */
.loading-bubble { padding: 22rpx 28rpx; }
.dot-wrap {
  display: flex;
  gap: 10rpx;
  align-items: center;
  height: 32rpx;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #BDBDBD;
  animation: bounce 1.2s infinite ease-in-out;
}
.dot:nth-child(1) { animation-delay: 0s;   }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.4; }
  40%           { transform: scale(1.2); opacity: 1;   }
}

/* ── 输入栏 ── */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 24rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E5E5EA;
  gap: 16rpx;
}
.input-wrap {
  flex: 1;
  background: #F2F2F7;
  border-radius: 44rpx;
  padding: 0 28rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
}
.input {
  width: 100%;
  font-size: 28rpx;
  color: #1C1C1E;
  line-height: 76rpx;
}
.input-ph { color: #AEAEB2; }

.input-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}
.char-count { font-size: 20rpx; color: #AEAEB2; line-height: 1; }
.char-warn  { color: #FF9500; }

/* ── 发送 / 停止按钮 ── */
.send-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.send-btn.active   {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 14rpx rgba(102, 126, 234, 0.4);
}
.send-btn.inactive { background: #C7C7CC; }
.send-btn.stop-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A24 100%);
  box-shadow: 0 4rpx 14rpx rgba(238, 90, 36, 0.4);
}
.send-icon {
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
}
.btn-hover { opacity: 0.7; }

/* ===== Phase 4 polish: ChatGPT style workspace ===== */
page {
  background: #ffffff;
}

.page {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 12% 0, rgba(43,92,230,0.06), transparent 30%),
    linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
}

.top-bar {
  position: relative;
  z-index: 12;
  min-height: 88rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 12rpx;
  background: rgba(255,255,255,0.98);
  border-bottom: 1rpx solid rgba(226,232,240,0.88);
  box-shadow: 0 10rpx 26rpx rgba(15,23,42,0.04);
}

.menu-btn,
.new-chat-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1.5rpx solid rgba(226,232,240,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-btn {
  flex-direction: column;
  gap: 8rpx;
}

.menu-line {
  width: 26rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #0f172a;
}

.menu-line.short {
  width: 18rpx;
}

.top-title {
  height: 72rpx;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
  margin-left: 12rpx;
}

.top-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 15rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f172a, #2447d8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 950;
  box-shadow: 0 10rpx 18rpx rgba(36,71,216,0.22);
}

.top-copy {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.top-name {
  color: #101828;
  font-size: 30rpx;
  font-weight: 900;
  letter-spacing: -0.2rpx;
  line-height: 1.15;
}

.top-sub {
  margin-top: 4rpx;
  color: #98a2b3;
  font-size: 20rpx;
  font-weight: 700;
}

.new-chat-icon {
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 500;
  line-height: 1;
}

.drawer-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 18;
  background: rgba(15,23,42,0.18);
}

.drawer {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  z-index: 19;
  width: 610rpx;
  box-sizing: border-box;
  padding: 28rpx 22rpx calc(28rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-right: 1rpx solid rgba(226,232,240,0.88);
  box-shadow: 28rpx 0 60rpx rgba(15,23,42,0.14);
  transform: translateX(-104%);
  transition: transform 240ms ease;
}

.drawer.open {
  transform: translateX(0);
}

.drawer-brand,
.drawer-new,
.drawer-search,
.drawer-tool,
.recent-chat {
  position: relative;
  z-index: 1;
}

.drawer-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 8rpx 22rpx;
}

.drawer-logo {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #0f172a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 950;
}

.drawer-title-wrap {
  display: flex;
  flex-direction: column;
}

.drawer-title {
  color: #101828;
  font-size: 31rpx;
  font-weight: 950;
}

.drawer-sub {
  margin-top: 4rpx;
  color: #98a2b3;
  font-size: 21rpx;
  font-weight: 700;
}

.drawer-new {
  height: 74rpx;
  border-radius: 22rpx;
  background: #101828;
  color: #ffffff;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 26rpx rgba(15,23,42,0.16);
}

.drawer-new-icon {
  font-size: 34rpx;
  font-weight: 500;
}

.drawer-search {
  height: 72rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #f6f8fb;
  color: #98a2b3;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.drawer-section-title {
  margin: 28rpx 8rpx 14rpx;
  color: #8a94a6;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.6rpx;
}

.drawer-tool,
.recent-chat {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid transparent;
}

.drawer-tool:active,
.recent-chat:active {
  background: #f8fafc;
}

.drawer-tool-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #eef4ff;
  color: #2557d6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19rpx;
  font-weight: 950;
  flex-shrink: 0;
}

.drawer-tool-copy,
.recent-copy {
  flex: 1;
  min-width: 0;
  margin-left: 14rpx;
  display: flex;
  flex-direction: column;
}

.drawer-tool-title,
.recent-name {
  color: #1f2937;
  font-size: 25rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.drawer-tool-desc,
.recent-preview {
  margin-top: 4rpx;
  color: #98a2b3;
  font-size: 20rpx;
  font-weight: 650;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recent-title {
  margin-top: 22rpx;
}

.recent-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #2b5ce6;
  flex-shrink: 0;
}

.recent-time {
  margin-left: 12rpx;
  color: #98a2b3;
  font-size: 19rpx;
  font-weight: 700;
}

.msg-list {
  padding: 30rpx 28rpx 0;
}

.msg-row {
  margin-bottom: 34rpx;
  align-items: flex-start;
}

.ai-avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 18rpx;
  margin-right: 16rpx;
  background: #101828;
  box-shadow: 0 12rpx 24rpx rgba(15,23,42,0.14);
}

.ai-avatar-icon {
  color: #ffffff;
  font-size: 24rpx;
}

.bubble-wrap {
  max-width: 82%;
}

.bubble {
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
}

.ai-bubble {
  background: #ffffff;
  border: 1.5rpx solid rgba(226,232,240,0.9);
  border-bottom-left-radius: 12rpx;
  box-shadow: 0 14rpx 36rpx rgba(15,23,42,0.055);
}

.user-bubble {
  background: #101828;
  border-bottom-right-radius: 12rpx;
  box-shadow: 0 14rpx 28rpx rgba(15,23,42,0.16);
}

.bubble-text {
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.72;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-card,
.sug-chip {
  background: #ffffff;
  border: 1.5rpx solid rgba(43,92,230,0.16);
  box-shadow: 0 8rpx 20rpx rgba(43,92,230,0.045);
}

.quick-card {
  width: calc(50% - 6rpx);
  box-sizing: border-box;
  min-height: 70rpx;
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
}

.quick-text,
.sug-chip {
  color: #2557d6;
  font-weight: 850;
}

.loading-bubble {
  min-width: 360rpx;
  padding: 24rpx;
}

.thinking-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.thinking-title {
  color: #344054;
  font-size: 25rpx;
  font-weight: 900;
}

.thinking-steps {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.thinking-steps text {
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #f6f8fb;
  color: #8a94a6;
  font-size: 20rpx;
  font-weight: 750;
}

.dot {
  width: 9rpx;
  height: 9rpx;
  background: #2557d6;
}

.input-bar {
  position: relative;
  z-index: 10;
  padding: 14rpx 22rpx 24rpx;
  background: rgba(255,255,255,0.98);
  border-top: 1rpx solid rgba(226,232,240,0.9);
  box-shadow: 0 -14rpx 34rpx rgba(15,23,42,0.045);
}

.input-wrap {
  height: 78rpx;
  border-radius: 26rpx;
  background: #f8fafc;
  border: 1.5rpx solid rgba(226,232,240,0.9);
  padding: 0 24rpx;
}

.input {
  color: #101828;
  font-size: 28rpx;
  line-height: 78rpx;
}

.input-ph {
  color: #98a2b3;
}

.send-btn {
  width: 74rpx;
  height: 74rpx;
}

.send-btn.active {
  background: #101828;
  box-shadow: 0 12rpx 24rpx rgba(15,23,42,0.18);
}

.send-btn.inactive {
  background: #e5eaf3;
}

.send-btn.stop-btn {
  background: #ef4444;
  box-shadow: 0 12rpx 24rpx rgba(239,68,68,0.18);
}

/* ===== Phase 4 polish: actionable AI result card ===== */
.answer-action-card {
  width: 100%;
  box-sizing: border-box;
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 26rpx;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,251,255,0.94)),
    radial-gradient(circle at 100% 0, rgba(43,92,230,0.10), transparent 34%);
  border: 1.5rpx solid rgba(226,232,240,0.92);
  box-shadow: 0 12rpx 30rpx rgba(15,23,42,0.055);
}

.answer-action-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.answer-action-mark {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: #101828;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 950;
  flex-shrink: 0;
}

.answer-action-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.answer-action-title {
  color: #101828;
  font-size: 25rpx;
  font-weight: 950;
  line-height: 1.2;
}

.answer-action-sub {
  margin-top: 5rpx;
  color: #98a2b3;
  font-size: 20rpx;
  font-weight: 650;
  line-height: 1.35;
}

.answer-action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.answer-action-btn {
  width: calc(50% - 5rpx);
  min-height: 64rpx;
  box-sizing: border-box;
  padding: 0 14rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1.5rpx solid rgba(226,232,240,0.92);
  color: #344054;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 23rpx;
  font-weight: 850;
}

.answer-action-btn.primary {
  color: #2557d6;
  background: #eef4ff;
  border-color: rgba(43,92,230,0.18);
}

.answer-action-icon {
  font-size: 22rpx;
  font-weight: 900;
}
