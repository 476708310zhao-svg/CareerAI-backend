.page{min-height:100vh;box-sizing:border-box;background:#f5f7fb;color:#101828;padding:24rpx 28rpx 190rpx}.hero{padding:36rpx;border-radius:30rpx;background:linear-gradient(135deg,#173d8f,#2b5ce6 58%,#5a7cf0);color:#fff;box-shadow:0 20rpx 44rpx rgba(43,92,230,.2)}.eyebrow{display:block;font-size:19rpx;letter-spacing:3rpx;opacity:.68}.title{display:block;margin-top:10rpx;font-size:48rpx;font-weight:900}.subtitle{display:block;margin-top:8rpx;font-size:24rpx;opacity:.82}.hero-stats{display:flex;margin-top:30rpx;padding-top:24rpx;border-top:1rpx solid rgba(255,255,255,.18)}.hero-stat{flex:1}.stat-value,.stat-label{display:block}.stat-value{font-size:36rpx;font-weight:900}.stat-label{font-size:21rpx;opacity:.72;margin-top:4rpx}.filter-scroll{width:100%;margin:24rpx 0 18rpx}.filter-row{display:flex;gap:12rpx;width:max-content;padding-right:28rpx}.filter{display:flex;align-items:center;gap:8rpx;padding:16rpx 22rpx;border-radius:999rpx;background:#fff;color:#667085;font-size:23rpx;border:1rpx solid #e8ecf3}.filter.active{background:#101828;color:#fff;border-color:#101828}.filter-count{min-width:28rpx;text-align:center;font-size:19rpx;opacity:.72}.application-list{display:flex;flex-direction:column;gap:18rpx}.application-card{padding:26rpx;border-radius:24rpx;background:#fff;border:1rpx solid #e8ecf3;box-shadow:0 10rpx 30rpx rgba(16,24,40,.05)}.card-hover{opacity:.84;transform:scale(.99)}.card-top{display:flex;align-items:flex-start}.company-mark{width:76rpx;height:76rpx;border-radius:20rpx;background:#edf3ff;color:#2b5ce6;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:900}.card-copy{flex:1;min-width:0;margin:0 18rpx}.job-title,.company{display:block}.job-title{font-size:29rpx;font-weight:850;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.company{font-size:22rpx;color:#667085;margin-top:8rpx}.status{padding:8rpx 13rpx;border-radius:999rpx;font-size:19rpx;font-weight:750;background:#eef4ff;color:#2b5ce6}.status-interview{background:#fff5e8;color:#b54708}.status-offer{background:#eafbf3;color:#087a55}.status-closed{background:#f2f4f7;color:#667085}.next-action{display:flex;align-items:flex-start;margin-top:22rpx;padding:18rpx;border-radius:16rpx;background:#f8faff}.next-label{flex:none;margin-right:14rpx;color:#2b5ce6;font-size:21rpx;font-weight:800}.next-text{font-size:22rpx;color:#344054;line-height:1.5}.card-meta{display:flex;justify-content:space-between;margin-top:18rpx;color:#98a2b3;font-size:20rpx}.state-card{margin-top:22rpx;padding:70rpx 36rpx;border-radius:26rpx;background:#fff;text-align:center;border:1rpx solid #e8ecf3}.state-card text{display:block}.state-icon{font-size:58rpx}.state-title{margin-top:18rpx;font-size:30rpx;font-weight:850}.state-desc{margin-top:12rpx;color:#667085;font-size:23rpx;line-height:1.6}.primary-button{display:inline-flex;margin-top:26rpx;padding:20rpx 34rpx;border-radius:16rpx;background:#2b5ce6;color:#fff;font-size:24rpx;font-weight:800}.spinner{width:46rpx;height:46rpx;margin:0 auto 20rpx;border:5rpx solid #e8ecf3;border-top-color:#2b5ce6;border-radius:50%;animation:spin .8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}
