<view class="page">
  <view class="hero">
    <text class="eyebrow">APPLICATION CRM</text>
    <text class="title">申请看板</text>
    <text class="subtitle">从准备材料到 Offer，统一记录每一次推进</text>
    <view class="hero-stats">
      <view class="hero-stat"><text class="stat-value">{{total}}</text><text class="stat-label">全部申请</text></view>
      <view class="hero-stat"><text class="stat-value">{{statistics.interview || 0}}</text><text class="stat-label">面试中</text></view>
      <view class="hero-stat"><text class="stat-value">{{statistics.offer || 0}}</text><text class="stat-label">Offer</text></view>
    </view>
  </view>

  <scroll-view wx:if="{{!loginRequired}}" class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-row">
      <view wx:for="{{filters}}" wx:key="key" class="filter {{activeGroup===item.key?'active':''}}" data-group="{{item.key}}" bindtap="changeGroup">
        <text>{{item.label}}</text><text class="filter-count">{{item.count}}</text>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="state-card">
    <view class="spinner"></view>
    <text>正在同步申请记录…</text>
  </view>

  <view wx:elif="{{loginRequired}}" class="state-card">
    <text class="state-icon">🔐</text>
    <text class="state-title">登录后同步申请看板</text>
    <text class="state-desc">申请状态、材料、联系人和任务会安全同步到你的账号。</text>
    <view class="primary-button" bindtap="goProfile">前往登录</view>
  </view>

  <view wx:elif="{{error}}" class="state-card">
    <text class="state-icon">↻</text>
    <text class="state-title">暂时无法加载</text>
    <text class="state-desc">{{error}}</text>
    <view class="primary-button" bindtap="retry">重新加载</view>
  </view>

  <view wx:elif="{{visibleApplications.length===0}}" class="state-card">
    <text class="state-icon">＋</text>
    <text class="state-title">{{activeGroup==='all'?'还没有申请记录':'该阶段暂无申请'}}</text>
    <text class="state-desc">找到合适岗位后加入申请，即可在这里持续跟进。</text>
    <view class="primary-button" bindtap="goJobs">浏览岗位</view>
  </view>

  <view wx:else class="application-list">
    <view wx:for="{{visibleApplications}}" wx:key="id" class="application-card" data-id="{{item.id}}" bindtap="openApplication" hover-class="card-hover">
      <view class="card-top">
        <view class="company-mark">{{item.companyInitial}}</view>
        <view class="card-copy">
          <text class="job-title">{{item.jobTitle || '目标岗位'}}</text>
          <text class="company">{{item.company || '目标公司'}}<text wx:if="{{item.city}}"> · {{item.city}}</text></text>
        </view>
        <text class="status status-{{item.group}}">{{item.statusText || item.status}}</text>
      </view>
      <view class="next-action">
        <text class="next-label">下一步</text>
        <text class="next-text">{{item.nextAction || '补充跟进计划'}}</text>
      </view>
      <view class="card-meta">
        <text wx:if="{{item.deadline}}">截止 {{item.deadline}}</text>
        <text wx:else>未设置截止时间</text>
        <text>查看详情 ›</text>
      </view>
    </view>
  </view>
</view>
