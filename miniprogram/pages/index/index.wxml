<view class="page">
  <view class="search-wrap" bindtap="goToJobSearch" hover-class="search-hover">
    <image src="/images/search.png" class="search-icon" mode="aspectFit"></image>
    <text class="search-text">搜索职位、公司或岗位</text>
  </view>

  <view class="home-content">
    <home-career-plan
      plan="{{workbench}}"
      bind:action="navigateToPage"
    ></home-career-plan>

    <home-core-tools
      tools="{{workbenchActions}}"
      bind:select="navigateToPage"
    ></home-core-tools>

    <view class="banner-wrap" wx:if="{{bannerList.length > 0}}">
      <swiper
        class="banner-swiper"
        autoplay
        circular
        interval="4000"
        indicator-dots="{{bannerList.length > 1}}"
        indicator-color="rgba(255,255,255,0.55)"
        indicator-active-color="#ffffff"
        bindchange="onBannerChange"
      >
        <block wx:for="{{bannerList}}" wx:key="id">
          <swiper-item>
            <view class="banner-item" bindtap="navigateToPage" data-url="{{item.url}}" hover-class="banner-hover">
              <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" class="banner-bg-image" mode="aspectFill" data-index="{{index}}" binderror="onBannerImageError"></image>
              <view wx:else class="banner-gradient" style="background:{{item.gradient}};">
                <view class="banner-copy">
                  <text class="banner-title">{{item.title}}</text>
                  <text class="banner-sub">{{item.subtitle}}</text>
                  <text class="banner-action">立即查看</text>
                </view>
                <text class="banner-icon">{{item.icon}}</text>
              </view>
            </view>
          </swiper-item>
        </block>
      </swiper>
    </view>

    <home-recommended-jobs
      wx:if="{{recruitmentEnabled}}"
      jobs="{{recommendJobs}}"
      loading="{{loadingJobs}}"
      error="{{jobsError}}"
      personalization="{{recommendTitle}}"
      bind:select="goToJobDetail"
      bind:more="viewMoreJobs"
      bind:complete="goCompleteProfile"
      bind:retry="retryRecommendJobs"
    ></home-recommended-jobs>

    <home-campus-updates
      featured="{{campusFeatured}}"
      updates="{{campusUpdates}}"
      loading="{{campusUpdateLoading}}"
      ready="{{campusUpdateReady}}"
      date-label="{{campusUpdateDateLabel}}"
      bind:more="goToCampusList"
      bind:select="goToCampusUpdateDetail"
      bind:logoerror="onCampusLogoError"
    ></home-campus-updates>

    <home-career-insights
      insights="{{newsFeed}}"
      loading="{{newsLoading}}"
      error="{{newsError}}"
      bind:select="viewNewsDetail"
      bind:more="goToNews"
      bind:retry="retryNews"
    ></home-career-insights>
  </view>

  <view class="page-bottom-spacer"></view>
</view>
