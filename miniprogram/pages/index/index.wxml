<page-meta page-style="background-color: #FFFFFF;"></page-meta>

<view class="page">

  <view class="home-hero">
    <view class="hero-copy">
      <text class="hero-kicker">CareerAI Workspace</text>
      <text class="hero-title">留学生求职助手</text>
      <text class="hero-subtitle">岗位推荐、名企情报、面试准备和求职规划，一站式 AI 工作台。</text>
      <view class="hero-actions">
        <view class="hero-primary" bindtap="goCompleteProfile" hover-class="opacity-hover">建立求职档案</view>
        <view class="hero-secondary" bindtap="navigateToPage" data-url="/package-ai/pages/ai-assistant/ai-assistant" hover-class="opacity-hover">问 AI 助手</view>
      </view>
    </view>
    <view class="hero-orb">
      <text class="hero-orb-main">AI</text>
      <text class="hero-orb-sub">Ready</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-wrap" bindtap="goToJobSearch">
    <image src="/images/search.png" class="search-icon"></image>
    <text class="search-text">搜索职位、公司或面经</text>
  </view>

  <!-- Banner 轮播 -->
  <view class="banner-wrap" wx:if="{{bannerList.length > 0}}">
    <swiper class="banner-swiper" autoplay circular interval="4000" indicator-dots indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#ffffff" bindchange="onBannerChange">
      <block wx:for="{{bannerList}}" wx:key="id">
        <swiper-item>
          <view wx:if="{{item.imageUrl}}" class="banner-item" bindtap="navigateToPage" data-url="{{item.url}}" hover-class="opacity-hover">
            <image src="{{item.imageUrl}}" class="banner-bg-image" mode="aspectFill" data-index="{{index}}" binderror="onBannerImageError"></image>
          </view>
          <view wx:else class="banner-item banner-gradient" bindtap="navigateToPage" data-url="{{item.url}}" hover-class="opacity-hover"
            style="background:{{item.gradient}};">
            <view class="banner-text-layer">
              <text class="banner-icon">{{item.icon}}</text>
              <text class="banner-title">{{item.title}}</text>
              <text class="banner-sub">{{item.subtitle}}</text>
            </view>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <!-- 金刚区 -->
  <view class="feature-grid">
    <block wx:for="{{features}}" wx:key="id">
      <view class="feature-item {{item.badge == 'AI' ? 'is-ai' : ''}}" bindtap="navigateToPage" data-url="{{item.url}}" hover-class="opacity-hover">
        <view class="feature-icon-wrap" style="background: {{item.bg}};">
          <image src="{{item.icon}}" class="feature-icon" mode="aspectFit"></image>
          <view wx:if="{{item.badge}}" class="feature-badge">{{item.badge}}</view>
        </view>
        <text class="feature-name">{{item.name}}</text>
      </view>
    </block>
  </view>

  <view class="pro-teaser" bindtap="navigateToPage" data-url="/package-user/pages/vip/vip" hover-class="opacity-hover">
    <view class="pro-copy">
      <text class="pro-kicker">CareerAI Pro</text>
      <text class="pro-title">把简历、投递、面试连成闭环</text>
      <text class="pro-sub">解锁 AI 简历深度优化、无限模拟面试和高优先级求职规划。</text>
    </view>
    <view class="pro-cta">了解会员</view>
  </view>

  <view class="career-loop">
    <view class="career-loop-head">
      <view class="career-loop-copy">
        <text class="career-loop-kicker">Career Loop</text>
        <text class="career-loop-title">从准备到录用，按这条路径推进</text>
        <text class="career-loop-sub">先补简历，再匹配岗位，接着练面试，最后生成求职规划。</text>
      </view>
      <view class="career-loop-badge">4 steps</view>
    </view>
    <view class="career-loop-steps">
      <view class="career-loop-step" bindtap="navigateToPage" data-url="/package-career/pages/resume/resume" hover-class="opacity-hover">
        <text class="loop-step-index">01</text>
        <text class="loop-step-title">简历定位</text>
        <text class="loop-step-desc">完善亮点</text>
        <text class="loop-step-arrow">›</text>
      </view>
      <view class="career-loop-step" bindtap="navigateToPage" data-url="/pages/jobs/jobs" hover-class="opacity-hover">
        <text class="loop-step-index">02</text>
        <text class="loop-step-title">岗位匹配</text>
        <text class="loop-step-desc">推荐机会</text>
        <text class="loop-step-arrow">›</text>
      </view>
      <view class="career-loop-step" bindtap="navigateToPage" data-url="/package-ai/pages/interview-setup/interview-setup" hover-class="opacity-hover">
        <text class="loop-step-index">03</text>
        <text class="loop-step-title">面试训练</text>
        <text class="loop-step-desc">模拟问答</text>
        <text class="loop-step-arrow">›</text>
      </view>
      <view class="career-loop-step" bindtap="navigateToPage" data-url="/package-career/pages/career-planner/career-planner" hover-class="opacity-hover">
        <text class="loop-step-index">04</text>
        <text class="loop-step-title">求职规划</text>
        <text class="loop-step-desc">路线拆解</text>
        <text class="loop-step-arrow">›</text>
      </view>
    </view>
    <view class="career-loop-actions">
      <view class="career-loop-btn primary" bindtap="navigateToPage" data-url="/package-career/pages/resume/resume" hover-class="opacity-hover">从简历开始</view>
      <view class="career-loop-btn" bindtap="navigateToPage" data-url="/pages/jobs/jobs" hover-class="opacity-hover">查看岗位</view>
    </view>
  </view>

  <!-- 热门企业 -->
  <view class="section">
    <view class="section-header">
      <view class="section-heading">
        <text class="section-title">热门企业</text>
        <text class="section-subtitle">名企情报 · Logo 实时同步</text>
      </view>
      <view bindtap="viewMoreCompanies" hover-class="opacity-hover">
        <text class="section-more">查看全部 ›</text>
      </view>
    </view>
    <scroll-view scroll-x enhanced show-scrollbar="{{false}}" style="white-space:nowrap;">
      <view class="company-scroll-list">
        <block wx:for="{{hotCompanies}}" wx:key="id">
          <view class="company-card" bindtap="goToCompanyDetail" data-id="{{item.id}}" data-name="{{item.name}}" hover-class="opacity-hover">
            <c-company-logo
              logo="{{item.logoFailed ? '' : item.logo}}"
              name="{{item.name}}"
              fallback="{{item.initial}}"
              size="md"
              lazy-load="{{true}}"
              custom-class="company-avatar"
              bind:error="onCompanyLogoError"
              data-idx="{{index}}"
            ></c-company-logo>
            <text class="company-name">{{item.name}}</text>
            <text class="company-desc">{{item.description}}</text>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <!-- 今日热门 -->
  <view class="section">
    <view class="section-header">
      <view class="section-heading">
        <text class="section-title">今日热门</text>
        <text class="section-subtitle">按你的方向优先推荐</text>
      </view>
      <view bindtap="viewMoreJobs" hover-class="opacity-hover">
        <text class="section-more">查看更多 ›</text>
      </view>
    </view>

    <!-- 骨架屏 -->
    <block wx:if="{{loadingJobs && recommendJobs.length === 0}}">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="job-card skeleton">
        <view class="job-card-body">
          <view class="skeleton-line" style="width:110rpx;height:22rpx;margin-bottom:14rpx;border-radius:6rpx;"></view>
          <view class="skeleton-line long"></view>
          <view class="skeleton-line short" style="margin-top:10rpx;"></view>
        </view>
        <view class="skeleton-thumb" style="width:88rpx;height:88rpx;border-radius:16rpx;flex-shrink:0;"></view>
      </view>
    </block>

    <view wx:if="{{!loadingJobs && recommendJobs.length === 0}}" class="jobs-empty-card">
      <view class="jobs-empty-icon">AI</view>
      <text class="jobs-empty-title">还没有匹配到岗位</text>
      <text class="jobs-empty-desc">先完善求职档案，或直接搜索目标岗位，系统会重新生成推荐。</text>
      <view class="jobs-empty-actions">
        <view class="jobs-empty-btn primary" bindtap="goCompleteProfile" hover-class="opacity-hover">完善档案</view>
        <view class="jobs-empty-btn" bindtap="goToJobSearch" hover-class="opacity-hover">搜索岗位</view>
      </view>
    </view>

    <!-- 职位列表 -->
    <block wx:for="{{recommendJobs}}" wx:key="id">
      <view class="job-card" bindtap="goToJobDetail" data-id="{{item.id}}" data-title="{{item.title}}" hover-class="opacity-hover">
        <view class="job-card-body">
          <view class="job-card-topline">
            <text class="job-card-loc">{{item.city}}{{item.state ? ', ' + item.state : ''}}</text>
            <text class="job-card-pill">推荐</text>
          </view>
          <text class="job-card-title">{{item.title}}</text>
          <view class="job-card-meta">
            <text class="job-card-co">{{item.company}}</text>
            <text class="job-card-dot">·</text>
            <text class="job-card-sal">{{item.salary}}</text>
          </view>
        </view>
        <c-company-logo
          logo="{{item.logoFailed ? '' : item.logo}}"
          name="{{item.company}}"
          fallback="{{item.companyInitial || 'C'}}"
          size="md"
          lazy-load="{{true}}"
          custom-class="job-card-logo-wrap"
          bind:error="onLogoError"
          data-index="{{index}}"
        ></c-company-logo>
      </view>
    </block>
  </view>

  <!-- 求职快讯 -->
  <view class="section">
    <view class="section-header">
      <view class="section-heading">
        <text class="section-title">求职快讯</text>
        <text class="section-subtitle">政策、面经、数据趋势</text>
      </view>
      <view bindtap="goToNews" hover-class="opacity-hover">
        <text class="section-more">更多 ›</text>
      </view>
    </view>

    <block wx:for="{{newsFeed}}" wx:key="id">
      <view class="news-item" bindtap="viewNewsDetail" data-item="{{item}}" hover-class="opacity-hover">
        <view class="news-content">
          <text class="news-category {{item.type}}">{{item.type === 'tip' ? '技巧' : item.type === 'news' ? '资讯' : item.type === 'policy' ? '政策' : '数据'}}</text>
          <text class="news-title">{{item.title}}</text>
          <view class="news-meta">
            <text class="news-source">{{item.source || '求职助手'}}</text>
            <text class="news-dot">·</text>
            <text class="news-time">{{item.time}}</text>
          </view>
        </view>
        <image wx:if="{{item.image}}" src="{{item.image}}" class="news-thumb" mode="aspectFill"></image>
        <view wx:else class="news-thumb-placeholder {{item.type}}">
          <view class="news-thumb-aura"></view>
          <view class="news-icon-card">
            <view class="news-icon-dot"></view>
            <view class="news-icon-line main"></view>
            <view class="news-icon-line"></view>
            <view class="news-icon-line short"></view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部留白 -->
  <view style="height: 32rpx;"></view>

</view>
