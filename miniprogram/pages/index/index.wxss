.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-top: 18rpx;
  color: #111c31;
  background: linear-gradient(180deg, #fbfdff 0%, #f7f9fc 55%, #f9fbfd 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
}

.home-content {
  padding: 0 32rpx;
}

.search-wrap {
  height: 72rpx;
  display: flex;
  align-items: center;
  margin: 0 32rpx 20rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border: 1.5rpx solid #d9e3f0;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 8rpx 24rpx rgba(35, 56, 88, 0.035);
}

.search-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  margin-right: 15rpx;
  opacity: 0.5;
}

.search-text {
  overflow: hidden;
  color: #98a5b8;
  font-size: 27rpx;
  font-weight: 500;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-hover,
.banner-hover {
  opacity: 0.84;
}

.banner-wrap {
  margin-top: 28rpx;
}

.membership-benefit-banner {
  position: relative;
  min-height: 108rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  overflow: hidden;
  border: 1.5rpx solid rgba(190, 205, 232, 0.82);
  border-radius: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 100% 0, rgba(96, 165, 250, 0.18), transparent 38%),
    linear-gradient(135deg, #ffffff 0%, #f1f5ff 100%);
  box-shadow: 0 12rpx 30rpx rgba(31, 66, 135, 0.07);
}

.membership-benefit-banner::before {
  position: absolute;
  top: 18rpx;
  bottom: 18rpx;
  left: 0;
  width: 6rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: linear-gradient(180deg, #2563eb, #7c3aed);
  content: '';
}

.membership-benefit-banner.is-preview {
  border-color: rgba(203, 213, 225, 0.88);
  background:
    radial-gradient(circle at 100% 0, rgba(148, 163, 184, 0.12), transparent 38%),
    linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
}

.membership-benefit-hover {
  opacity: 0.86;
  transform: scale(0.988);
}

.membership-benefit-mark {
  flex-shrink: 0;
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #2563eb 0%, #6d5dfc 100%);
  box-shadow: 0 10rpx 22rpx rgba(64, 91, 214, 0.2);
  font-size: 18rpx;
  font-weight: 950;
  letter-spacing: 0.5rpx;
}

.membership-benefit-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.membership-benefit-title {
  color: #111c31;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.membership-benefit-sub {
  margin-top: 7rpx;
  overflow: hidden;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.membership-benefit-action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  color: #315fd1;
  font-size: 21rpx;
  font-weight: 850;
}

.membership-benefit-arrow {
  margin-left: 5rpx;
  font-size: 32rpx;
  line-height: 1;
}

.banner-swiper {
  width: 100%;
  height: 214rpx;
  overflow: hidden;
  border: 1.5rpx solid #d9e5f4;
  border-radius: 26rpx;
  background: #edf5ff;
  box-shadow: 0 14rpx 34rpx rgba(41, 95, 174, 0.08);
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 26rpx;
}

.banner-bg-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.banner-gradient {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.banner-copy {
  position: relative;
  z-index: 2;
  min-width: 0;
  width: 76%;
}

.banner-title,
.banner-sub,
.banner-action {
  display: block;
}

.banner-title {
  overflow: hidden;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 850;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.banner-sub {
  margin-top: 10rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.82);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.banner-action {
  width: fit-content;
  margin-top: 18rpx;
  padding: 9rpx 19rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 999rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.16);
  font-size: 20rpx;
  font-weight: 750;
}

.banner-icon {
  position: absolute;
  right: 30rpx;
  bottom: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 82rpx;
  line-height: 1;
  transform: rotate(-7deg);
}

.page-bottom-spacer {
  height: calc(190rpx + env(safe-area-inset-bottom));
}
