  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}
.job-card-meta {
  display: flex;
  align-items: center;
}
.job-card-co {
  font-size: 24rpx;
  color: var(--text-muted);
}
.job-card-dot {
  font-size: 24rpx;
  color: var(--text-muted);
  margin: 0 8rpx;
  opacity: 0.4;
}
.job-card-sal {
  font-size: 24rpx;
  color: var(--text-muted);
}
.job-card-logo-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 1.5rpx solid var(--border-light);
}
.job-card-logo {
  width: 78rpx;
  height: 78rpx;
}
.job-card-logo-initial {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--brand);
}

