page, .page {
  --bg-page: #FFFFFF;
  --bg-panel: #FFFFFF;
  --bg-raised: #F7F8FB;
  --text-primary: #101828;
  --text-body: #344054;
  --text-muted: #98A2B3;
  --brand: #2563EB;
  --success: #10B981;
  --danger: #EF4444;
  --border: rgba(16,24,40,0.08);
  --border-light: #EAECF0;
  --r-sm: 14rpx;
  --r-md: 20rpx;
  --r-lg: 28rpx;
  --r-xl: 36rpx;
  --shadow-sm: 0 12rpx 34rpx rgba(16,24,40,0.06);
  --skeleton-base: #F2F4F7;
  --skeleton-shine: #FFFFFF;
  --trans-fast: 0.16s ease;
  background-color: var(--bg-page);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
}

/* ── 搜索框 ── */
.search-wrap {
  margin: calc(env(safe-area-inset-top) + 16rpx) 32rpx 20rpx;
  height: 80rpx;
  background: var(--bg-raised);
  border-radius: var(--r-xl);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border: 1.5rpx solid var(--border);
}
.search-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
  margin-right: 16rpx;
}
.search-text {
  font-size: 30rpx;
  color: var(--text-muted);
}

/* ── Banner 轮播 ── */
.banner-wrap {
  margin: 0 32rpx 32rpx;
}
.banner-swiper {
  width: 100%;
  height: 300rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
.banner-item {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}
.banner-bg-image {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
}
.banner-gradient {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.banner-text-layer {
  position: relative;
  z-index: 1;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
}
.banner-icon  { font-size: 56rpx; margin-bottom: 10rpx; }
.banner-title { color: #fff; font-size: 36rpx; font-weight: 800; letter-spacing: -0.5rpx; }
.banner-sub   { color: rgba(255,255,255,0.8); font-size: 24rpx; margin-top: 8rpx; }

/* ── 通用区块 ── */
.section {
  margin-bottom: 24rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 24rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}
.section-more {
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 500;
}

/* ── 新闻列表项 ── */
.news-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  margin: 0 32rpx 16rpx;
  border: 1.5rpx solid var(--border-light);
  border-radius: var(--r-lg);
  background: var(--bg-panel);
  box-shadow: var(--shadow-sm);
  transition: transform var(--trans-fast), opacity var(--trans-fast);
}
.news-item:active {
  transform: scale(0.988);
  opacity: 0.86;
}
.news-content {
  flex: 1;
  margin-right: 20rpx;
  overflow: hidden;
}
.news-category {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--brand);
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}
.news-category.tip  { color: var(--success); }
.news-category.news { color: var(--brand); }
.news-category.data { color: var(--danger); }
.news-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.55;
  margin-bottom: 12rpx;
}
.news-meta {
  display: flex;
  align-items: center;
}
.news-source {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 400;
}
.news-dot {
  font-size: 22rpx;
  color: var(--text-muted);
  margin: 0 8rpx;
  opacity: 0.4;
}
.news-salary {
  font-size: 22rpx;
  color: var(--brand);
  font-weight: 500;
}
.news-time {
  font-size: 22rpx;
  color: var(--text-muted);
}
.news-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--r-sm);
  background: var(--bg-raised);
  flex-shrink: 0;
}
.news-thumb-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #eaf2ff 0%, #f6f0ff 100%);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.9), 0 12rpx 28rpx rgba(37,99,235,0.12);
}
.news-thumb-placeholder.tip  { background: linear-gradient(145deg, #e9fff4 0%, #eef7ff 100%); }
.news-thumb-placeholder.data { background: linear-gradient(145deg, #fff2ed 0%, #fff7df 100%); }
.news-thumb-placeholder.policy { background: linear-gradient(145deg, #fff6e8 0%, #eef4ff 100%); }
.news-thumb-aura {
  position: absolute;
  right: -18rpx;
  top: -18rpx;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(37,99,235,0.14);
}
.news-thumb-placeholder.tip .news-thumb-aura { background: rgba(16,185,129,0.16); }
.news-thumb-placeholder.data .news-thumb-aura { background: rgba(245,101,101,0.16); }
.news-thumb-placeholder.policy .news-thumb-aura { background: rgba(250,140,22,0.18); }
.news-icon-card {
  position: relative;
  width: 58rpx;
  height: 68rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.9);
  box-shadow: 0 10rpx 22rpx rgba(30,41,59,0.12);
  padding: 16rpx 12rpx 0;
  box-sizing: border-box;
}
.news-icon-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #2563eb;
  margin-bottom: 10rpx;
}
.news-thumb-placeholder.tip .news-icon-dot { background: #10b981; }
.news-thumb-placeholder.data .news-icon-dot { background: #f56565; }
.news-thumb-placeholder.policy .news-icon-dot { background: #fa8c16; }
.news-icon-line {
  height: 6rpx;
  border-radius: 999rpx;
  background: #cbd5e1;
  margin-bottom: 7rpx;
}
.news-icon-line.main {
  width: 34rpx;
  background: #64748b;
}
.news-icon-line.short {
  width: 24rpx;
}

/* ── 功能入口网格 ── */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 16rpx 4rpx;
  margin: 0 32rpx 24rpx;
  border: 1.5rpx solid var(--border-light);
  border-radius: var(--r-lg);
  background: var(--bg-panel);
  box-shadow: var(--shadow-sm);
}
.feature-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
  transition: opacity var(--trans-fast);
}
.feature-item:active { opacity: 0.65; }
.feature-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: var(--r-md);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 10rpx;
  position: relative;
  border: 1rpx solid var(--border);
}
.feature-icon {
  width: 44rpx;
  height: 44rpx;
}
.feature-badge {
  position: absolute;
  top: -4rpx;
  right: -8rpx;
  background: var(--danger);
  color: #FFF;
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
  border: 3rpx solid var(--bg-panel);
}
.feature-name {
  font-size: 23rpx;
  color: var(--text-body);
  font-weight: 500;
}

/* ── 热门企业 ── */
.company-scroll-list {
  display: inline-flex;
  padding: 0 32rpx 6rpx;
  gap: 14rpx;
}
.company-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 154rpx;
  padding: 18rpx 12rpx 14rpx;
  border: 1.5rpx solid var(--border-light);
  border-radius: 22rpx;
  background: var(--bg-panel);
  box-shadow: var(--shadow-sm);
  transition: transform var(--trans-fast), opacity var(--trans-fast);
}
.company-card:active {
  transform: scale(0.96);
  opacity: 0.82;
}
.company-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  overflow: hidden;
}
.company-logo {
  width: 100%;
  height: 100%;
}
.company-initial {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
}
.company-name {
  width: 100%;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.company-desc {
  width: 100%;
  font-size: 20rpx;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── 骨架屏 ── */
.skeleton .news-content { gap: 12rpx; }
.skeleton-line {
  height: 28rpx;
  background: var(--skeleton-base);
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  animation: shimmer 1.5s ease-in-out infinite;
  background: linear-gradient(90deg, var(--skeleton-base) 25%, var(--skeleton-shine) 50%, var(--skeleton-base) 75%);
  background-size: 400% 100%;
}
.skeleton-line.long  { width: 80%; }
.skeleton-line.short { width: 50%; }
.skeleton-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--r-sm);
  background: var(--skeleton-base);
  flex-shrink: 0;
}

.opacity-hover { opacity: 0.6; }

/* ── 职位卡片（今日热门） ── */
.job-card {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  margin: 0 32rpx 16rpx;
  background: var(--bg-panel);
  border: 1.5rpx solid var(--border-light);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-sm);
  transition: opacity var(--trans-fast);
}
.job-card:active { opacity: 0.72; }
.job-card-body {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}
.job-card-loc {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--brand);
  margin-bottom: 6rpx;
  letter-spacing: 0.2rpx;
}
.job-card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}
.job-card-meta {
  display: flex;
  align-items: center;
}
.job-card-co {
  font-size: 24rpx;
  color: var(--text-muted);
}
.job-card-dot {
  font-size: 24rpx;
  color: var(--text-muted);
  margin: 0 8rpx;
  opacity: 0.4;
}
.job-card-sal {
  font-size: 24rpx;
  color: var(--text-muted);
}
.job-card-logo-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 1.5rpx solid var(--border-light);
}
.job-card-logo {
  width: 78rpx;
  height: 78rpx;
}
.job-card-logo-initial {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--brand);
}

/* ── 快讯类型 policy ── */
.news-category.policy { color: #FA8C16; }

/* Product homepage polish */
.page {
  position: relative;
  overflow-x: hidden;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%),
    linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
}

.home-hero {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 196rpx;
  margin: calc(env(safe-area-inset-top) + 18rpx) 32rpx 18rpx;
  padding: 30rpx 30rpx 28rpx;
  border-radius: 32rpx;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.94) 0%, rgba(244,248,255,0.96) 100%);
  border: 1.5rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 18rpx 52rpx rgba(15, 23, 42, 0.08);
  overflow: hidden;
}

.home-hero::before {
  content: '';
  position: absolute;
  right: -86rpx;
  top: -92rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(43,92,230,0.18), rgba(43,92,230,0));
}

.hero-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  padding-right: 26rpx;
}

.hero-kicker {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--brand);
  letter-spacing: 1rpx;
}

.hero-title {
  display: block;
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 800;
  color: #0f172a;
  letter-spacing: -1rpx;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #64748b;
}

.hero-orb {
  position: relative;
  z-index: 1;
  width: 124rpx;
  height: 124rpx;
  border-radius: 36rpx;
  background:
    linear-gradient(145deg, #0f172a 0%, #2447d8 100%);
  box-shadow: 0 18rpx 38rpx rgba(43,92,230,0.28);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-orb-main {
  font-size: 36rpx;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: -0.5rpx;
}

.hero-orb-sub {
  margin-top: 2rpx;
  font-size: 18rpx;
  color: rgba(255,255,255,0.74);
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 22rpx;
}

.hero-primary,
.hero-secondary {
  height: 60rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 850;
  white-space: nowrap;
}

.hero-primary {
  color: #ffffff;
  background: #101828;
  box-shadow: 0 12rpx 24rpx rgba(15,23,42,0.18);
}

.hero-secondary {
  color: #2557d6;
  background: #eef4ff;
  border: 1rpx solid rgba(43,92,230,0.16);
}

.onboarding-card {
  margin: 0 32rpx 24rpx;
  padding: 26rpx;
  border-radius: 30rpx;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,251,255,0.94)),
    radial-gradient(circle at 100% 0, rgba(43,92,230,0.11), transparent 34%);
  border: 1.5rpx solid rgba(226,232,240,0.92);
  box-shadow: 0 16rpx 42rpx rgba(15,23,42,0.065);
}

.onboarding-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.onboarding-head > view {
  display: flex;
  flex-direction: column;
}

.onboarding-kicker,
.pro-kicker {
  color: #2b5ce6;
  font-size: 20rpx;
  font-weight: 950;
  letter-spacing: 0.8rpx;
  text-transform: uppercase;
}

.onboarding-title {
  margin-top: 6rpx;
  color: #101828;
  font-size: 32rpx;
  font-weight: 950;
  letter-spacing: -0.4rpx;
}

.onboarding-score {
  color: #2557d6;
  font-size: 34rpx;
  font-weight: 950;
}

.onboarding-progress {
  height: 12rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: #e5eaf3;
  overflow: hidden;
}

.onboarding-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #2b5ce6, #38bdf8);
}

.onboarding-copy {
  margin-top: 16rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}

.onboarding-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.onboarding-btn {
  flex: 1;
  height: 66rpx;
  border-radius: 20rpx;
  color: #2557d6;
  background: #eef4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.onboarding-btn.primary {
  color: #ffffff;
  background: #101828;
}

.search-wrap {
  margin-top: 0;
  margin-bottom: 22rpx;
  height: 78rpx;
  background: rgba(255,255,255,0.92);
  border-color: rgba(226,232,240,0.95);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
}

.banner-wrap {
  margin-bottom: 30rpx;
}

.banner-swiper,
.banner-item {
  border-radius: 30rpx;
}

.banner-swiper {
  height: 292rpx;
  box-shadow: 0 18rpx 48rpx rgba(30, 64, 175, 0.12);
}

.feature-grid {
  padding: 18rpx 16rpx 2rpx;
  margin-bottom: 32rpx;
  border-radius: 28rpx;
  border-color: rgba(226,232,240,0.9);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,251,255,0.94)),
    radial-gradient(circle at 90% 0, rgba(43,92,230,0.08), transparent 34%);
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.055);
}

.feature-icon-wrap {
  width: 82rpx;
  height: 82rpx;
  border-radius: 24rpx;
  border-color: rgba(226,232,240,0.92);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.94),
    0 12rpx 24rpx rgba(15,23,42,0.055);
}

.feature-item.is-ai .feature-icon-wrap {
  background: linear-gradient(145deg, #eef4ff 0%, #f7f3ff 100%) !important;
  border-color: rgba(43,92,230,0.16);
}

.feature-icon {
  width: 48rpx;
  height: 48rpx;
}

.feature-name {
  font-size: 22rpx;
  color: #334155;
}

.pro-teaser {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: -8rpx 32rpx 34rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 100% 0, rgba(250,204,21,0.18), transparent 34%),
    linear-gradient(135deg, #101828 0%, #172554 100%);
  box-shadow: 0 18rpx 42rpx rgba(15,23,42,0.16);
}

.pro-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.pro-kicker {
  color: #fde68a;
}

.pro-title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 950;
  letter-spacing: -0.4rpx;
}

.pro-sub {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.72);
  font-size: 22rpx;
  line-height: 1.45;
}

.pro-cta {
  flex-shrink: 0;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  color: #101828;
  background: #ffffff;
  font-size: 23rpx;
  font-weight: 950;
  box-shadow: 0 10rpx 20rpx rgba(255,255,255,0.12);
}

.section {
  margin-bottom: 34rpx;
}

.section-header {
  padding-bottom: 18rpx;
}

.section-heading {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}

.section-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.section-more {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(43,92,230,0.08);
  font-size: 24rpx;
  font-weight: 700;
}

.company-scroll-list {
  gap: 16rpx;
}

.company-card {
  width: 148rpx;
  padding: 18rpx 12rpx 16rpx;
  border-radius: 26rpx;
  border-color: rgba(226,232,240,0.92);
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.055);
}

.company-avatar {
  width: 78rpx;
  height: 78rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, #f8fafc, #eef2ff) !important;
  border: 1rpx solid rgba(226,232,240,0.9);
}

.company-name {
  font-size: 23rpx;
}

.company-desc {
  font-size: 19rpx;
  color: #94a3b8;
}

.job-card {
  align-items: flex-start;
  padding: 26rpx 26rpx;
  border-radius: 28rpx;
  border-color: rgba(226,232,240,0.92);
  box-shadow: 0 14rpx 38rpx rgba(15, 23, 42, 0.058);
  transition: transform var(--trans-fast), opacity var(--trans-fast);
}

.job-card:active {
  transform: scale(0.986);
  opacity: 0.86;
}

.job-card-topline {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.job-card-loc {
  margin-bottom: 0;
  color: #64748b;
}

.job-card-pill {
  margin-left: 12rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(16,185,129,0.10);
  color: #059669;
  font-size: 18rpx;
  font-weight: 800;
}

.job-card-title {
  font-size: 31rpx;
  letter-spacing: -0.3rpx;
}

.job-card-meta {
  min-width: 0;
}

.job-card-co,
.job-card-sal {
  font-size: 23rpx;
}

.job-card-logo-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f8fafc, #eef2ff);
  border-color: rgba(226,232,240,0.92);
}

.news-item {
  padding: 24rpx 24rpx;
  border-radius: 28rpx;
  border-color: rgba(226,232,240,0.92);
  box-shadow: 0 14rpx 38rpx rgba(15, 23, 42, 0.052);
}

.news-title {
  font-size: 29rpx;
  line-height: 1.48;
}

.news-category {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(43,92,230,0.08);
  font-size: 20rpx;
}

.news-category.tip { background: rgba(16,185,129,0.10); }
.news-category.data { background: rgba(239,68,68,0.08); }
.news-category.policy { background: rgba(250,140,22,0.10); }

.news-thumb,
.news-thumb-placeholder {
  width: 112rpx;
  height: 112rpx;
  border-radius: 26rpx;
}

.career-loop {
  margin: 0 32rpx 34rpx;
  padding: 26rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 100% 0, rgba(43,92,230,0.08), transparent 34%),
    linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1.5rpx solid rgba(226,232,240,0.92);
  box-shadow: 0 16rpx 44rpx rgba(15,23,42,0.06);
}

.career-loop-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.career-loop-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.career-loop-kicker {
  color: #2b5ce6;
  font-size: 20rpx;
  font-weight: 950;
  letter-spacing: 0.8rpx;
  text-transform: uppercase;
}

.career-loop-title {
  margin-top: 8rpx;
  color: #101828;
  font-size: 32rpx;
  font-weight: 950;
  letter-spacing: -0.4rpx;
  line-height: 1.28;
}

.career-loop-sub {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.career-loop-badge {
  flex-shrink: 0;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  color: #2557d6;
  background: #eef4ff;
  font-size: 20rpx;
  font-weight: 900;
  border: 1rpx solid rgba(43,92,230,0.12);
}

.career-loop-steps {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.career-loop-step {
  display: flex;
  align-items: center;
  min-height: 78rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  background: rgba(248,250,252,0.92);
  border: 1rpx solid rgba(226,232,240,0.86);
  transition: transform var(--trans-fast), opacity var(--trans-fast);
}

.career-loop-step:active {
  transform: scale(0.986);
  opacity: 0.84;
}

.loop-step-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  color: #2557d6;
  background: #eef4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19rpx;
  font-weight: 950;
  margin-right: 18rpx;
}

.loop-step-title {
  color: #101828;
  font-size: 27rpx;
  font-weight: 900;
  margin-right: 14rpx;
}

.loop-step-desc {
  flex: 1;
  min-width: 0;
  color: #94a3b8;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loop-step-arrow {
  color: #94a3b8;
  font-size: 34rpx;
  line-height: 1;
}

.career-loop-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.career-loop-btn {
  flex: 1;
  height: 68rpx;
  border-radius: 22rpx;
  color: #2557d6;
  background: #eef4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 950;
}

.career-loop-btn.primary {
  color: #ffffff;
  background: #101828;
  box-shadow: 0 14rpx 28rpx rgba(15,23,42,0.16);
}

.jobs-empty-card {
  margin: 0 32rpx 16rpx;
  padding: 34rpx 28rpx 30rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 100% 0, rgba(56,189,248,0.10), transparent 34%),
    linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1.5rpx solid rgba(226,232,240,0.92);
  box-shadow: 0 14rpx 38rpx rgba(15,23,42,0.055);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.jobs-empty-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 26rpx;
  background: linear-gradient(145deg, #101828, #2557d6);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 950;
  box-shadow: 0 16rpx 30rpx rgba(43,92,230,0.22);
}

.jobs-empty-title {
  margin-top: 18rpx;
  color: #101828;
  font-size: 31rpx;
  font-weight: 950;
  letter-spacing: -0.3rpx;
}

.jobs-empty-desc {
  margin-top: 10rpx;
  max-width: 520rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}

.jobs-empty-actions {
  display: flex;
  gap: 14rpx;
  width: 100%;
  margin-top: 24rpx;
}

.jobs-empty-btn {
  flex: 1;
  height: 66rpx;
  border-radius: 22rpx;
  color: #2557d6;
  background: #eef4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 950;
}

.jobs-empty-btn.primary {
  color: #ffffff;
  background: #101828;
}

/* Compact first-screen modules */
.home-hero {
  min-height: 156rpx;
  margin: calc(env(safe-area-inset-top) + 14rpx) 32rpx 12rpx;
  padding: 22rpx 24rpx 20rpx;
  border-radius: 26rpx;
}

.hero-copy {
  padding-right: 18rpx;
}

.hero-kicker {
  margin-bottom: 6rpx;
  font-size: 20rpx;
}

.hero-title {
  font-size: 36rpx;
  line-height: 1.12;
}

.hero-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.42;
}

.hero-orb {
  width: 104rpx;
  height: 104rpx;
  border-radius: 30rpx;
}

.hero-orb-main {
  font-size: 31rpx;
}

.hero-orb-sub {
  font-size: 16rpx;
}

.hero-actions {
  gap: 10rpx;
  margin-top: 14rpx;
}

.hero-primary,
.hero-secondary {
  height: 52rpx;
  padding: 0 18rpx;
  font-size: 21rpx;
}

.onboarding-card {
  margin: 0 32rpx 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 26rpx;
}

.onboarding-kicker,
.pro-kicker {
  font-size: 18rpx;
}

.onboarding-title {
  margin-top: 5rpx;
  font-size: 28rpx;
  line-height: 1.22;
}

.onboarding-score {
  font-size: 30rpx;
}

.onboarding-progress {
  height: 10rpx;
  margin-top: 12rpx;
}

.onboarding-copy {
  display: none;
  margin-top: 0;
  font-size: 22rpx;
  line-height: 1.42;
}

.onboarding-actions {
  gap: 12rpx;
  margin-top: 12rpx;
}

.onboarding-btn {
  height: 52rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
}

.search-wrap {
  margin-bottom: 18rpx;
}
