.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-top: 18rpx;
  color: #111c31;
  background: linear-gradient(180deg, #fbfdff 0%, #f7f9fc 55%, #f9fbfd 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
}

.home-content {
  padding: 0 32rpx;
}

.search-wrap {
  height: 72rpx;
  display: flex;
  align-items: center;
  margin: 0 32rpx 20rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border: 1.5rpx solid #d9e3f0;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 8rpx 24rpx rgba(35, 56, 88, 0.035);
}

.search-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  margin-right: 15rpx;
  opacity: 0.5;
}

.search-text {
  overflow: hidden;
  color: #98a5b8;
  font-size: 27rpx;
  font-weight: 500;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-hover,
.banner-hover {
  opacity: 0.84;
}

.banner-wrap {
  margin-top: 28rpx;
}

.banner-swiper {
  width: 100%;
  height: 214rpx;
  overflow: hidden;
  border: 1.5rpx solid #d9e5f4;
  border-radius: 26rpx;
  background: #edf5ff;
  box-shadow: 0 14rpx 34rpx rgba(41, 95, 174, 0.08);
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 26rpx;
}

.banner-bg-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.banner-gradient {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.banner-copy {
  position: relative;
  z-index: 2;
  min-width: 0;
  width: 76%;
}

.banner-title,
.banner-sub,
.banner-action {
  display: block;
}

.banner-title {
  overflow: hidden;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 850;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.banner-sub {
  margin-top: 10rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.82);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.banner-action {
  width: fit-content;
  margin-top: 18rpx;
  padding: 9rpx 19rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 999rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.16);
  font-size: 20rpx;
  font-weight: 750;
}

.banner-icon {
  position: absolute;
  right: 30rpx;
  bottom: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 82rpx;
  line-height: 1;
  transform: rotate(-7deg);
}

.page-bottom-spacer {
  height: calc(190rpx + env(safe-area-inset-bottom));
}
