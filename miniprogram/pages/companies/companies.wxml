<!-- pages/companies/companies.wxml -->
<view class="page">

  <!-- Tab 筛选 -->
  <view class="tab-bar">
    <block wx:for="{{tabs}}" wx:key="value">
      <view
        class="tab-item {{currentTab === item.value ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="{{item.value}}"
      >{{item.label}}</view>
    </block>
  </view>

  <!-- 公司列表 -->
  <view class="list">
    <block wx:for="{{list}}" wx:key="id">
      <view class="company-row" bindtap="onCompanyTap" data-id="{{item.id}}" data-name="{{item.name}}" hover-class="row-hover">

        <view class="avatar" style="background:{{item.logoFailed ? item.color : '#f5f5f7'}};">
          <image
            wx:if="{{!item.logoFailed}}"
            class="logo-img"
            src="{{item.logo}}"
            mode="aspectFit"
            binderror="onLogoError"
            data-idx="{{index}}"
          />
          <text wx:else class="initial">{{item.initial}}</text>
        </view>

        <view class="info">
          <text class="name">{{item.name}}</text>
          <text class="desc">{{item.desc}}</text>
        </view>

        <view class="industry-tag">{{item.industry}}</view>
        <text class="arrow">›</text>

      </view>
    </block>
  </view>

  <view wx:if="{{loading}}" class="empty-text">加载中...</view>
  <view wx:if="{{!loading && list.length === 0}}" class="empty-text">暂无公司数据</view>

  <view style="height:40rpx;"></view>
</view>
