.page { background: #F2F2F7; min-height: 100vh; }

/* Tab */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #E5E5EA;
}
.tab-item {
  padding: 24rpx 24rpx;
  font-size: 28rpx;
  color: #8E8E93;
  font-weight: 500;
  position: relative;
}
.tab-item.active {
  color: #007AFF;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #007AFF;
  border-radius: 2rpx;
}

/* 列表 */
.list { padding: 16rpx 32rpx 0; }

.company-row {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.05);
}
.row-hover { opacity: 0.7; }

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}
.logo-img { width: 100%; height: 100%; }
.initial {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.info {
  flex: 1;
  margin: 0 20rpx;
  overflow: hidden;
}
.name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 6rpx;
}
.desc {
  display: block;
  font-size: 24rpx;
  color: #8E8E93;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.industry-tag {
  font-size: 22rpx;
  color: #007AFF;
  background: #EAF2FF;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}
.arrow {
  font-size: 36rpx;
  color: #C7C7CC;
  flex-shrink: 0;
}

.empty-text {
  text-align: center;
  color: #8E8E93;
  font-size: 26rpx;
  padding: 40rpx 0;
}
