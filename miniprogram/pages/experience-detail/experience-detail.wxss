/* pages/experience-detail/experience-detail.wxss */
page {
  background: var(--bg-raised);
  font-family: -apple-system, sans-serif;
}

/* ====== 1. 作者卡片 ====== */
.author-card {
  display: flex;
  align-items: center;
  background: var(--bg-panel);
  margin: 24rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  background: #f0f1f5;
  flex-shrink: 0;
}

.author-body { flex: 1; min-width: 0; }

.author-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
}

.author-time {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 4rpx;
}

.author-follow {
  font-size: 24rpx;
  color: var(--brand);
  background: #eef4fd;
  border: 2rpx solid #c8ddf6;
  padding: 10rpx 24rpx;
  border-radius: var(--r-lg);
  font-weight: 600;
  flex-shrink: 0;
}

.author-follow:active { opacity: 0.7; }

/* ====== 2. 标题卡片 ====== */
.title-card {
  background: var(--bg-panel);
  margin: 16rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.exp-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a2e;
  line-height: 1.4;
  display: block;
  margin-bottom: 20rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-pill {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-raised);
  padding: 8rpx 18rpx;
  border-radius: 10rpx;
}

.meta-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  flex-shrink: 0;
}

/* ====== 3. 正文 ====== */
.content-card {
  background: var(--bg-panel);
  margin: 16rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.plain-text {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.85;
  white-space: pre-wrap;
  display: block;
}

/* 富文本 */
.rich-text {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.85;
  white-space: pre-wrap;
  display: block;
  margin-bottom: 18rpx;
}

.rich-heading {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin: 28rpx 0 14rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--brand);
  line-height: 1.3;
}

.rich-img-wrap {
  margin: 20rpx 0;
  border-radius: var(--r-sm);
  overflow: hidden;
}

.rich-img {
  width: 100%;
  border-radius: var(--r-sm);
}

.rich-caption {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  font-style: italic;
}

.rich-quote {
  background: var(--bg-raised);
  border-left: 6rpx solid #D1D5DB;
  padding: 18rpx 22rpx;
  margin: 18rpx 0;
  border-radius: 0 10rpx 10rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  font-style: italic;
}

.rich-code {
  background: #1e1e2e;
  border-radius: 14rpx;
  padding: 24rpx;
  margin: 18rpx 0;
  overflow-x: auto;
}

.code-text {
  font-size: 24rpx;
  color: #a6e3a1;
  line-height: 1.6;
  font-family: 'Courier New', monospace;
  white-space: pre-wrap;
  word-break: break-all;
}

/* ====== 4. 标签 ====== */
.tags-card {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  background: var(--bg-panel);
  margin: 16rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.exp-tag {
  font-size: 24rpx;
  color: var(--brand);
  background: #eef4fd;
  padding: 8rpx 18rpx;
  border-radius: 10rpx;
}

/* ====== 5. 互动栏 ====== */
.action-bar {
  display: flex;
  background: var(--bg-panel);
  margin: 16rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 28rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.act-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.act-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-raised);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

.act-icon-box.liked { background: #fff1f0; }
.act-icon-box.saved { background: #fff7e6; }
.act-icon-box.ai {
  background: linear-gradient(135deg, var(--brand), #6c5ce7);
}

.act-icon-box.saving {
  background: #F0FDF4;
}

.act-icon-box.saving .act-icon { color: #16A34A; }

.save-icon-txt {
  font-size: 32rpx;
  font-weight: 700;
}

.act-icon {
  font-size: 28rpx;
  color: var(--text-muted);
  line-height: 1;
}

.act-icon-box.liked .act-icon { color: #e5534b; }
.act-icon-box.saved .act-icon { color: #faad14; }
.act-icon-box.ai .act-icon { color: #fff; font-size: 22rpx; font-weight: 800; }

.act-num {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.act-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.act-item:active .act-icon-box { transform: scale(0.88); }

/* ====== 6. 评论区 ====== */
.comment-card {
  background: var(--bg-panel);
  margin: 16rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.comment-head {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f1f5;
  margin-bottom: 8rpx;
}

.comment-head-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.comment-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 30rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--brand);
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* 评论条目 */
.cmt-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f8fa;
}

.cmt-item:last-child { border-bottom: none; }

.cmt-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: #f0f1f5;
}

.cmt-body { flex: 1; min-width: 0; }

.cmt-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.cmt-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.cmt-date {
  font-size: 22rpx;
  color: #D1D5DB;
}

.cmt-text {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.cmt-actions {
  display: flex;
  gap: 28rpx;
}

.cmt-act {
  font-size: 24rpx;
  color: var(--text-muted);
}

.cmt-act.liked { color: #e5534b; }
.cmt-act.cmt-del { color: var(--danger); }
.cmt-act:active { opacity: 0.6; }

/* 回复 */
.reply-list {
  background: var(--bg-raised);
  border-radius: var(--r-sm);
  padding: 16rpx 18rpx;
  margin-top: 14rpx;
}

.reply-item {
  padding: 8rpx 0;
  font-size: 26rpx;
  line-height: 1.5;
}

.reply-item:not(:last-child) {
  border-bottom: 1rpx solid #ecedf1;
  padding-bottom: 12rpx;
  margin-bottom: 8rpx;
}

.reply-name {
  color: var(--brand);
  font-weight: 600;
  margin-right: 8rpx;
}

.reply-text { color: var(--text-secondary); }
.reply-date { font-size: 22rpx; color: #D1D5DB; margin-left: 10rpx; }

.empty-cmt {
  text-align: center;
  color: #D1D5DB;
  padding: 40rpx;
  font-size: 26rpx;
}

/* ====== 7. 底部输入栏 ====== */
.input-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--bg-panel);
  padding: 14rpx 24rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
  z-index: 999;
}

.reply-hint {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 6rpx 8rpx;
}

.cancel-reply {
  color: var(--brand);
  font-weight: 600;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.input-field {
  flex: 1;
  height: 72rpx;
  background: var(--bg-raised);
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text-body);
}

.send-btn {
  background: #e0e3e8;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  white-space: nowrap;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
}

.send-btn:active { transform: scale(0.95); }

/* 隐藏画布 */
.exp-save-canvas {
  position: fixed;
  top: -9999px;
  left: -9999px;
  width: 750px;
  height: 1050px;
}
