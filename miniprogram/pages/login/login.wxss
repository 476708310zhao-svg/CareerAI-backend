/* pages/login/login.wxss */

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #EBF4FF 0%, #F5F0FF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx 60rpx;
  box-sizing: border-box;
}

/* ── 顶部品牌 ── */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.logo-circle {
  width: 128rpx;
  height: 128rpx;
  background: #2B5CE6;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(43, 92, 230, 0.3);
}

.logo-img {
  width: 72rpx;
  height: 72rpx;
  filter: brightness(10);  /* 让图标变白 */
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1D27;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.app-desc {
  font-size: 26rpx;
  color: #6B7280;
}

/* ── 登录卡片 ── */
.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  width: 100%;
  box-shadow: 0 4rpx 32rpx rgba(43, 92, 230, 0.08);
  margin-bottom: 40rpx;
}

/* ── 头像区 ── */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  line-height: 1;
  position: relative;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #EEF2FF;
  display: block;
}

.avatar-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  background: #2B5CE6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #ffffff;
}

.badge-icon {
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
}

.avatar-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ── 昵称输入 ── */
.form-row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #F3F4F6;
  padding: 16rpx 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  width: 80rpx;
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1D27;
  height: 64rpx;
  padding-left: 16rpx;
}

.input-placeholder {
  color: #C4C9D4;
  font-size: 26rpx;
}

/* ── 确认按钮 ── */
.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3B6EF8, #2B5CE6);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(43, 92, 230, 0.3);
  letter-spacing: 2rpx;
}

.confirm-btn[disabled] {
  opacity: 0.65;
}

/* ── 隐私协议 ── */
.privacy {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
}

.privacy-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

.privacy-link {
  font-size: 22rpx;
  color: #2B5CE6;
}
