<!-- pages/cron-status/cron-status.wxml -->
<view class="page">

  <!-- 头部统计卡片 -->
  <view class="header-card">
    <view class="header-title">N8N 定时抓取状态</view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{stats.total || 0}}</text>
        <text class="stat-label">职位总数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{totalRuns}}</text>
        <text class="stat-label">运行次数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num next-run">{{nextRunIn}}</text>
        <text class="stat-label">下次运行</text>
      </view>
    </view>
  </view>

  <!-- 最近一次运行 -->
  <view wx:if="{{lastRun}}" class="last-run-card">
    <view class="card-title">最近一次运行</view>
    <view class="last-run-row">
      <view class="last-tag" style="background:{{lastRun.status==='ok'?'#dcfce7':lastRun.status==='partial'?'#fef9c3':'#fee2e2'}};color:{{lastRun.status==='ok'?'#16a34a':lastRun.status==='partial'?'#92400e':'#dc2626'}}">
        {{lastRun.status === 'ok' ? '✅ 成功' : lastRun.status === 'partial' ? '⚠️ 部分失败' : '❌ 失败'}}
      </view>
      <text class="last-time">{{lastRun.ran_at}}</text>
    </view>
    <view class="last-detail-row">
      <text class="detail-text">新增/更新 <text class="detail-num">{{lastRun.total_saved}}</text> 条</text>
      <text class="detail-text">成功 <text class="detail-num green">{{lastRun.success_count}}</text> 家</text>
      <text class="detail-text" wx:if="{{lastRun.error_count > 0}}">失败 <text class="detail-num red">{{lastRun.error_count}}</text> 家</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spin"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 运行记录列表 -->
  <view wx:if="{{!loading && logs.length > 0}}" class="section">
    <view class="section-title">运行记录（最近30次）</view>
    <view class="log-list">
      <view wx:for="{{logs}}" wx:key="id" class="log-item">
        <view class="log-left">
          <view class="log-status-dot" style="background:{{item.statusColor}}"></view>
          <view class="log-info">
            <text class="log-time">{{item.ranAtFmt}}</text>
            <text class="log-by">{{item.triggered_by}}</text>
          </view>
        </view>
        <view class="log-right">
          <view class="log-tag" style="color:{{item.statusColor}}">{{item.statusLabel}}</view>
          <text class="log-saved">+{{item.total_saved}} 条</text>
          <text class="log-dur">{{item.durationFmt}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && logs.length === 0}}" class="empty-wrap">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无运行记录，N8N 工作流尚未触发</text>
  </view>

</view>
