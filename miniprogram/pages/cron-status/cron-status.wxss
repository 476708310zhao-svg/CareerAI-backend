/* pages/cron-status/cron-status.wxss */
.page {
  min-height: 100vh;
  background: #f3f4f6;
  padding-bottom: 40rpx;
}

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #1e40af, #3b82f6);
  padding: 40rpx 32rpx 36rpx;
  color: #fff;
}
.header-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 28rpx;
}
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.stat-num {
  font-size: 44rpx;
  font-weight: 800;
}
.stat-num.next-run {
  font-size: 30rpx;
}
.stat-label {
  font-size: 22rpx;
  opacity: 0.85;
}
.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}

/* 最近一次运行 */
.last-run-card {
  background: #fff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-title {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 18rpx;
  font-weight: 600;
}
.last-run-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.last-tag {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}
.last-time {
  font-size: 24rpx;
  color: #6b7280;
}
.last-detail-row {
  display: flex;
  gap: 24rpx;
}
.detail-text {
  font-size: 24rpx;
  color: #6b7280;
}
.detail-num {
  font-weight: 700;
  color: #1f2937;
}
.detail-num.green { color: #16a34a; }
.detail-num.red   { color: #dc2626; }

/* 加载 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 20rpx;
}
.loading-spin {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e5e7eb;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 26rpx; color: #9ca3af; }

/* 运行记录 */
.section {
  margin: 24rpx 24rpx 0;
}
.section-title {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 600;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}
.log-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.log-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f3f4f6;
}
.log-item:last-child { border-bottom: none; }
.log-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.log-status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.log-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.log-time {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}
.log-by {
  font-size: 22rpx;
  color: #9ca3af;
}
.log-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.log-tag {
  font-size: 22rpx;
  font-weight: 600;
}
.log-saved {
  font-size: 22rpx;
  color: #374151;
}
.log-dur {
  font-size: 22rpx;
  color: #9ca3af;
  min-width: 60rpx;
  text-align: right;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  gap: 20rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #9ca3af; text-align: center; }
