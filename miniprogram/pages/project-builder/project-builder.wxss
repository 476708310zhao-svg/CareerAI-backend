}

.hero-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 18rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.14);
  box-shadow: inset 0 0 0 1rpx rgba(255,255,255,0.18);
}

.hero-title {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 950;
  letter-spacing: -0.8rpx;
}

.hero-sub {
  margin-top: 12rpx;
  color: rgba(255,255,255,0.78);
  font-size: 25rpx;
  line-height: 1.6;
}

.form-section,
.history-section,
.result-header,
.result-card {
  margin-left: 24rpx;
  margin-right: 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdff);
  border: 1rpx solid rgba(109, 40, 217, 0.08);
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.06);
}

.form-section + .form-section {
