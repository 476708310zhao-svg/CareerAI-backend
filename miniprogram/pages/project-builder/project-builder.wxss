/* pages/project-builder/project-builder.wxss */
page {
  overflow-x: hidden;
  background: radial-gradient(circle at 90% 10%, rgba(109, 40, 217, 0.08), transparent 24%), linear-gradient(180deg, #fbfdff 0%, #f7f9ff 54%, #ffffff 100%);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* 閳烘劏鏅?Hero 閳烘劏鏅?*/
.hero {
  box-shadow: 0 22rpx 44rpx rgba(109, 40, 217, 0.24);
  overflow: hidden;
  border-radius: 34rpx;
  margin: 16rpx 24rpx 28rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #27115f 0%, #6d28d9 56%, #2f66f4 100%);
  padding: 44rpx 34rpx 42rpx;
  text-align: center;
}
.hero-icon  { font-size: 60rpx; margin-bottom: 14rpx; }
.hero-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 10rpx; letter-spacing: 1rpx; }
.hero-sub   { font-size: 25rpx; color: rgba(255,255,255,0.82); line-height: 1.7; }

/* 閳烘劏鏅?妫板嫬锝為幓鎰仛 閳烘劏鏅?*/
.prefill-tip {
  margin: 16rpx 24rpx 0;
  padding: 16rpx 22rpx;
  background: rgba(94,106,210,0.08);
  border: 1rpx solid rgba(94,106,210,0.18);
  border-radius: var(--r-md);
  font-size: 25rpx;
  color: var(--brand);
  line-height: 1.5;
}

/* 閳烘劏鏅?鐞涖劌宕熼崠鍝勬健 閳烘劏鏅?*/
.form-section {
  box-shadow: 0 16rpx 36rpx rgba(38, 27, 75, 0.08);
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  border-radius: 32rpx;
  border: 1rpx solid rgba(71, 42, 132, 0.08);
  padding: 28rpx 24rpx 30rpx;
  margin: 24rpx 24rpx 0;
}

.section-label {
  line-height: 42rpx;
  display: flex;
  align-items: center;
  font-size: 29rpx;
  font-weight: 850;
  color: #172033;
  margin-bottom: 22rpx;
}
.section-label.no-margin { margin-bottom: 0; }
.section-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.label-num {
  box-shadow: 0 10rpx 20rpx rgba(47, 102, 244, 0.2);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx; height: 44rpx;
  background: linear-gradient(135deg, #2f66f4 0%, #7c3aed 100%);
  color: #fff;
  border-radius: 15rpx;
  font-size: 23rpx;
  font-weight: 900;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.required { color: var(--danger); font-weight: 500; }
.optional  { color: var(--text-muted); font-size: 23rpx; font-weight: 400; margin-left: 4rpx; }
.char-count { font-size: 22rpx; color: var(--text-muted); }
.field-hint { font-size: 23rpx; color: var(--text-muted); line-height: 1.5; margin-bottom: 12rpx; display: block; }

/* 閳烘劏鏅?閺傜懓鎮滈崡锛勫缂冩垶鐗?閳烘劏鏅?*/
.track-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}
.track-card {
  transition: transform 0.16s ease, opacity 0.16s ease;
  min-height: 134rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx 22rpx;
  background: #fbf8ff;
  border-radius: 26rpx;
  border: 1rpx solid rgba(109, 40, 217, 0.1);
  text-align: center;
  overflow: hidden;
}
.track-card:active { opacity: 0.75; }
.track-card.track-selected { border-width: 2.5rpx; }

.track-icon  { font-size: 40rpx; margin-bottom: 8rpx; line-height: 1; }
.track-label { font-size: 26rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 4rpx; }
.track-desc  { font-size: 19rpx; color: var(--text-muted); line-height: 1.4; }
.track-check {
  position: absolute;
  top: 10rpx; right: 10rpx;
  width: 28rpx; height: 28rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 16rpx; font-weight: 800; color: #fff;
}

/* 閳烘劏鏅?缁狙冨焼 Chips 閳烘劏鏅?*/
.chip-row { display: flex; gap: 14rpx; }
.chip {
  transition: transform 0.16s ease, opacity 0.16s ease;
  border-radius: 999rpx;
  font-weight: 750;
  color: #566174;
  justify-content: center;
  align-items: center;
  display: flex;
  min-height: 72rpx;
  flex: 1; text-align: center;
  font-size: 27rpx;
  padding: 0 22rpx;
  background: #ffffff;
  border: 1rpx solid rgba(23, 32, 51, 0.08);
}
.chip.chip-active {
  box-shadow: 0 10rpx 22rpx rgba(109, 40, 217, 0.2);
  background: linear-gradient(135deg, #6d28d9, #2f66f4);
  color: #ffffff;
  border-color: transparent;
}

/* 閳烘劏鏅?閺傚洦婀版潏鎾冲弳 閳烘劏鏅?*/
.text-input {
  height: 90rpx;
  width: 100%; height: 84rpx;
  background: #faf7ff;
  border-radius: 22rpx;
  padding: 0 26rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(109, 40, 217, 0.12);
  box-sizing: border-box;
}
.text-area {
  min-height: 176rpx;
  width: 100%; min-height: 140rpx;
  background: #faf7ff;
  border-radius: 22rpx;
  padding: 24rpx 26rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(109, 40, 217, 0.12);
  box-sizing: border-box;
  line-height: 1.55;
}

/* 閳烘劏鏅?閻㈢喐鍨氶幐澶愭尦 閳烘劏鏅?*/
.gen-btn {
  box-shadow: 0 14rpx 28rpx rgba(109, 40, 217, 0.22);
  border-radius: 999rpx;
  --btn-font-size: 28rpx;
  --btn-height: 82rpx;
  display: block;
  max-width: calc(100vw - 136rpx);
  margin: 26rpx auto 18rpx;
  width: 560rpx;
}

/* 閳烘劏鏅?閸樺棗褰剁拋鏉跨秿 閳烘劏鏅?*/
.history-section {
  box-shadow: 0 16rpx 36rpx rgba(38, 27, 75, 0.08);
  padding: 28rpx 24rpx;
  margin: 28rpx 24rpx 0;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  border-radius: 30rpx;
  border: 1rpx solid rgba(71, 42, 132, 0.08);
  overflow: hidden;
}
.history-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 22rpx 28rpx;
}
.history-title  { font-size: 27rpx; font-weight: 600; color: var(--text-primary); }
.history-toggle { font-size: 22rpx; color: var(--text-muted); }
.history-list   { border-top: 1rpx solid #F3F4F6; }
.history-card {
  transition: transform 0.16s ease, opacity 0.16s ease;
  border-radius: 26rpx;
  display: flex; align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
}
.history-card:active { background: rgba(0,0,0,0.03); }
.hc-icon-wrap {
  width: 64rpx; height: 64rpx; border-radius: 14rpx;
  background: #F3F4F6;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.hc-icon  { font-size: 32rpx; }
.hc-info  { flex: 1; min-width: 0; }
.hc-title {
  display: block; font-size: 27rpx; font-weight: 600; color: var(--text-primary);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 4rpx;
}
.hc-meta  { font-size: 22rpx; color: var(--text-muted); }
.hc-arrow { font-size: 34rpx; color: var(--text-muted); flex-shrink: 0; }
.history-clear-btn {
  display: flex; justify-content: center; padding: 18rpx;
}
.history-clear-txt { font-size: 24rpx; color: var(--danger); }

/* 閳烘劏鏅?閸旂姾娴囨い?閳烘劏鏅?*/
.loading-page {
  background: radial-gradient(circle at center 28%, rgba(109, 40, 217, 0.12), transparent 38%), linear-gradient(180deg, #faf7ff, #ffffff);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  min-height: 80vh; padding: 0 48rpx; gap: 32rpx;
}
.loading-anim {
  position: relative; width: 120rpx; height: 120rpx;
  display: flex; align-items: center; justify-content: center;
}
.pulse-ring {
  position: absolute; width: 120rpx; height: 120rpx;
  border-radius: 50%; border: 4rpx solid #6D28D9;
  animation: pulse 1.4s ease-in-out infinite;
}
.pulse-core {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--brand), #6D28D9);
  color: #fff; font-size: 28rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
}
@keyframes pulse {
  0%   { transform: scale(0.9); opacity: 1; }
  70%  { transform: scale(1.25); opacity: 0.2; }
  100% { transform: scale(0.9); opacity: 1; }
}
.loading-tip {
  font-size: 30rpx; font-weight: 600; color: var(--text-primary); text-align: center;
}
.loading-steps {
  display: flex; align-items: center; gap: 10rpx;
}
.lstep {
  font-size: 22rpx; color: var(--text-muted);
  padding: 7rpx 18rpx; border-radius: var(--r-lg); background: #F3F4F6;
}
.lstep.done { color: #6D28D9; background: #F5F3FF; font-weight: 600; }
.lstep-sep  { font-size: 26rpx; color: #D1D5DB; }
.loading-note { font-size: 24rpx; color: var(--text-muted); }

/* 閳烘劏鏅?缂佹挻鐏夋い?閳烘劏鏅?*/
.result-page { padding: 16rpx 24rpx; }

.result-header {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.result-title-row {
  display: flex; align-items: flex-start;
  justify-content: space-between; gap: 16rpx;
  margin-bottom: 16rpx;
}
.result-project-title {
  font-size: 34rpx; font-weight: 800; color: var(--text-primary);
  flex: 1; line-height: 1.35;
}
.result-duration {
  flex-shrink: 0;
  background: #F5F3FF;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  margin-top: 4rpx;
}
.duration-txt { font-size: 22rpx; color: #6D28D9; font-weight: 600; }

.result-track-row {
  display: flex; align-items: center; justify-content: space-between;
}
.result-track-badge {
  display: flex; align-items: center; gap: 8rpx;
}
.result-track-icon  { font-size: 28rpx; }
.result-track-label { font-size: 24rpx; font-weight: 600; }
.top-btn {
  display: flex; align-items: center; gap: 6rpx;
  padding: 10rpx 22rpx; border-radius: 9999rpx;
  background: rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.08);
}
.top-btn-icon { font-size: 26rpx; color: var(--text-muted); }
.top-btn-txt  { font-size: 24rpx; color: var(--text-muted); font-weight: 500; }

/* 閳烘劏鏅?缂佹挻鐏夐崡锛勫 閳烘劏鏅?*/
.result-card {
  transition: transform 0.16s ease, opacity 0.16s ease;
  overflow: hidden;
  margin-top: 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  border-radius: 32rpx;
  padding: 30rpx 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(71, 42, 132, 0.08);
  box-shadow: 0 16rpx 36rpx rgba(38, 27, 75, 0.08);
}

.card-label-row {
  display: flex; align-items: center; gap: 10rpx;
  margin-bottom: 16rpx;
}
.card-label-icon { font-size: 28rpx; }
.card-label-txt  { font-size: 27rpx; font-weight: 700; color: var(--text-primary); flex: 1; }
.card-label-sub  { font-size: 22rpx; color: var(--text-muted); }

.card-body-text {
  font-size: 27rpx; color: var(--text-body);
  line-height: 1.8; display: block;
}

/* 閺佺増宓侀弶銉︾爱 + 閹垛偓閺堫垱鐖ら獮鑸靛笓 */
.two-col-card { display: flex; gap: 0; }
.half-col     { flex: 1; min-width: 0; }
.col-divider  { width: 1.5rpx; background: #F3F4F6; margin: 0 20rpx; flex-shrink: 0; }

.tag-list { display: flex; flex-wrap: wrap; gap: 10rpx; }
.data-tag {
  font-size: 22rpx; color: #3B82F6;
  background: #EFF6FF; border: 1rpx solid #BFDBFE;
  border-radius: 8rpx; padding: 5rpx 14rpx;
}
.tech-tag {
  font-size: 22rpx; color: #059669;
  background: #ECFDF5; border: 1rpx solid #A7F3D0;
  border-radius: 8rpx; padding: 5rpx 14rpx;
}

/* 閸忔娊鏁幋鎰亯 */
.results-list { display: flex; flex-direction: column; gap: 14rpx; }
.result-item  { display: flex; align-items: flex-start; gap: 14rpx; }
.result-num-badge {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--brand), #6D28D9);
  color: #fff; font-size: 20rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-top: 2rpx;
}
.result-item-txt {
  font-size: 27rpx; color: var(--text-body); line-height: 1.7; flex: 1;
}

/* 缁犫偓閸樺棔绔寸悰宀€澧?*/
.resume-bullet-card { cursor: pointer; }
.resume-bullet-card:active { opacity: 0.75; }
.bullet-copy-hint {
  font-size: 22rpx; color: var(--brand);
  background: #EEF2FF; padding: 4rpx 14rpx;
  border-radius: 8rpx; flex-shrink: 0;
}
.resume-bullet-text {
  font-size: 27rpx; color: var(--brand);
  line-height: 1.7; display: block;
  background: #EEF2FF;
  border-radius: var(--r-sm);
  padding: 16rpx 18rpx;
  border-left: 5rpx solid var(--brand);
}

/* 閳烘劏鏅?閹垮秳缍旈幐澶愭尦缂?閳烘劏鏅?*/
.action-btn {
  flex: 1; display: flex;
  align-items: center; justify-content: center;
  gap: 10rpx; height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx; font-weight: 600;
}
.action-btn:active { transform: scale(0.97); opacity: 0.85; }

.action-copy {
  background: var(--bg-panel);
  border: 1.5rpx solid rgba(0,0,0,0.08);
  color: var(--text-secondary);
}
.action-btn-icon { font-size: 30rpx; }
.action-btn-txt  { font-size: 28rpx; }

/* 2026 kingkong polish: project builder */
.hero::after {
  content: '';
  position: absolute;
  width: 260rpx;
  height: 260rpx;
  right: -96rpx;
  top: -96rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.hero-title {
  color: #ffffff;
  font-size: 42rpx;
  letter-spacing: -0.8rpx;
}

.action-group {
  margin-left: 24rpx;
  margin-right: 24rpx;
}

.action-resume {
  background: linear-gradient(135deg, #6d28d9, #2f66f4);
  box-shadow: 0 14rpx 28rpx rgba(109, 40, 217, 0.22);
}

/* 2026 project builder spacing polish */
.hero-icon {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 18rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.14);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.18);
}

.hero-sub {
  margin-top: 12rpx;
  line-height: 1.6;
}

.form-section + .form-section {
  margin-top: 26rpx;
}

/* 2026 project builder bottom tighten */

