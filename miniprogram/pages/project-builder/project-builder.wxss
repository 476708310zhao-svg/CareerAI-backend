  margin-left: 24rpx;
  margin-right: 24rpx;
}

.action-resume {
  background: linear-gradient(135deg, #6d28d9, #2f66f4);
  box-shadow: 0 14rpx 28rpx rgba(109, 40, 217, 0.22);
}

.loading-page {
  background:
    radial-gradient(circle at 50% 8%, rgba(109, 40, 217, 0.12), transparent 36%),
    #f6f8fc;
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}
