  position: relative;
  margin: 16rpx 24rpx 18rpx;
  padding: 36rpx 30rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 86% 12%, rgba(255,255,255,0.24), transparent 32%),
    linear-gradient(135deg, #3b0764 0%, #6d28d9 50%, #2563eb 130%);
