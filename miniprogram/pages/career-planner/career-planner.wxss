/* pages/career-planner/career-planner.wxss */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ══ 顶部 Banner ══ */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #1C3578 0%, var(--brand) 100%);
  padding: 48rpx 40rpx 44rpx;
  text-align: center;
}
.hero-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.hero-title {
  font-size: 36rpx; font-weight: 700; color: #fff;
  margin-bottom: 12rpx; letter-spacing: 1rpx;
}
.hero-sub { font-size: 25rpx; color: rgba(255,255,255,0.82); line-height: 1.7; }

/* ══ 表单卡片 ══ */
.form-card {
  background: var(--bg-panel);
  margin: 20rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 8rpx 0 28rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.field { padding: 24rpx 28rpx 8rpx; }

.field-label {
  display: flex; align-items: center;
  font-size: 27rpx; font-weight: 600; color: var(--text-primary);
  margin-bottom: 14rpx;
}
.field-label-row {
  display: flex; align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}
.field-label-row .field-label { margin-bottom: 0; }
.label-icon { margin-right: 8rpx; font-size: 28rpx; }
.required { color: var(--danger); font-weight: 500; }
.optional { color: var(--text-muted); font-size: 23rpx; font-weight: 400; margin-left: 4rpx; }

.field-input {
  width: 100%;
  height: 84rpx;
  background: #F9FAFB;
  border-radius: var(--r-sm);
  padding: 0 20rpx;
  font-size: 27rpx; color: var(--text-primary);
  border: 1.5rpx solid var(--border-light);
  box-sizing: border-box;
}

.field-hint {
  font-size: 23rpx; color: var(--text-muted);
  margin-bottom: 12rpx; line-height: 1.5;
}
.char-count { font-size: 22rpx; color: var(--text-muted); }

.field-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F9FAFB;
  border-radius: var(--r-sm);
  padding: 18rpx 20rpx;
  font-size: 27rpx; color: var(--text-primary);
  border: 1.5rpx solid var(--border-light);
  box-sizing: border-box;
  line-height: 1.7;
  margin-top: 8rpx;
}

.field-divider {
  height: 1rpx;
  background: #F3F4F6;
  margin: 8rpx 28rpx 0;
}

.gen-btn {
  width: calc(100% - 56rpx);
  margin: 28rpx 28rpx 0;
}

/* ══ 提示卡片 ══ */
.tips-card {
  margin: 16rpx 24rpx 0;
  background: var(--bg-panel);
  border-radius: var(--r-md);
  padding: 24rpx 28rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
}
.tips-title {
  display: block;
  font-size: 26rpx; font-weight: 600; color: var(--text-body);
  margin-bottom: 16rpx;
}
.tips-list { display: flex; flex-direction: column; gap: 10rpx; }
.tips-item { display: flex; align-items: flex-start; gap: 10rpx; }
.ti-dot { color: var(--brand); font-size: 28rpx; flex-shrink: 0; line-height: 1.6; }
.ti-txt { font-size: 25rpx; color: var(--text-secondary); line-height: 1.6; flex: 1; }

/* ══ 加载页 ══ */
.loading-page {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  min-height: 80vh; padding: 0 48rpx;
  gap: 32rpx;
}
.loading-anim {
  position: relative; width: 120rpx; height: 120rpx;
  display: flex; align-items: center; justify-content: center;
}
.pulse-ring {
  position: absolute; width: 120rpx; height: 120rpx;
  border-radius: 50%; border: 4rpx solid var(--brand);
  animation: pulse 1.4s ease-in-out infinite;
}
.pulse-core {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: var(--brand); color: #fff;
  font-size: 28rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
}
@keyframes pulse {
  0%   { transform: scale(0.9); opacity: 1; }
  70%  { transform: scale(1.25); opacity: 0.2; }
  100% { transform: scale(0.9); opacity: 1; }
}
.loading-tip {
  font-size: 30rpx; font-weight: 600; color: var(--text-primary);
  text-align: center;
}
.loading-steps {
  display: flex; align-items: center; gap: 10rpx;
}
.lstep {
  font-size: 22rpx; color: var(--text-muted);
  padding: 7rpx 18rpx; border-radius: var(--r-lg);
  background: #F3F4F6;
}
.lstep.done { color: var(--brand); background: #EEF2FF; font-weight: 600; }
.lstep-arrow { font-size: 26rpx; color: #D1D5DB; }
.loading-note { font-size: 24rpx; color: var(--text-muted); }

/* ══ 结果页 ══ */
.result-page { padding: 16rpx 24rpx; }

.sec-card {
  background: var(--bg-panel); border-radius: var(--r-lg);
  padding: 28rpx 24rpx; margin-bottom: 16rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.sec-header {
  display: flex; align-items: center; gap: 10rpx;
  margin-bottom: 24rpx;
}
.sec-icon { font-size: 30rpx; }
.sec-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); }

/* 两列分析 */
.two-col { display: flex; gap: 0; margin-bottom: 24rpx; }
.col-box { flex: 1; }
.col-sep { width: 1.5rpx; background: #F3F4F6; margin: 0 16rpx; }
.col-title {
  display: block;
  font-size: 23rpx; font-weight: 600;
  margin-bottom: 12rpx;
}
.col-title.blue { color: var(--brand); }
.col-title.green { color: var(--success); }
.tag-wrap { display: flex; flex-wrap: wrap; gap: 8rpx; }
.tag {
  font-size: 21rpx; font-weight: 500;
  padding: 5rpx 14rpx; border-radius: 8rpx;
}
.blue-tag { color: var(--brand); background: #EEF2FF; border: 1rpx solid rgba(94,106,210,0.2); }
.green-tag { color: var(--success); background: rgba(16,185,129,0.10); border: 1rpx solid rgba(16,185,129,0.2); }

/* 差距 */
.gap-block {
  background: #FFF7F7; border-radius: var(--r-sm);
  padding: 16rpx 18rpx;
  border-left: 4rpx solid var(--danger);
}
.gap-label {
  display: block;
  font-size: 24rpx; font-weight: 600; color: var(--text-body);
  margin-bottom: 10rpx;
}
.gap-row { display: flex; align-items: flex-start; gap: 8rpx; margin-top: 8rpx; }
.gap-dot { color: var(--danger); font-size: 28rpx; flex-shrink: 0; }
.gap-txt { font-size: 25rpx; color: var(--text-secondary); flex: 1; line-height: 1.6; }

/* 阶段 Tabs */
.phase-tabs { display: flex; gap: 10rpx; margin-bottom: 24rpx; }
.phase-tab {
  flex: 1; text-align: center;
  font-size: 26rpx; color: var(--text-muted); font-weight: 500;
  padding: 16rpx 0; border-radius: var(--r-sm);
  background: #F9FAFB;
  border: 1.5rpx solid var(--border-light);
}
.phase-tab.active {
  color: var(--brand); background: #EEF2FF;
  border-color: #A5B4FC; font-weight: 700;
}

/* 阶段内容 */
.phase-body { display: flex; flex-direction: column; gap: 20rpx; }
.phase-goal {
  font-size: 27rpx; font-weight: 600; color: #1e3a5f;
  background: #EEF2FF; padding: 18rpx 20rpx;
  border-radius: var(--r-sm); line-height: 1.6;
  border-left: 5rpx solid var(--brand);
}
.detail-block { display: flex; flex-direction: column; gap: 10rpx; }
.db-title { font-size: 25rpx; font-weight: 600; color: var(--text-body); }
.pill-wrap { display: flex; flex-wrap: wrap; gap: 10rpx; }
.pill {
  font-size: 23rpx; color: var(--brand);
  background: #EEF2FF; padding: 7rpx 18rpx;
  border-radius: 9999rpx; border: 1rpx solid rgba(94,106,210,0.2);
}
.arrow-item { display: flex; align-items: flex-start; gap: 10rpx; }
.arrow { color: var(--brand); font-size: 26rpx; flex-shrink: 0; }
.arrow-txt { font-size: 25rpx; color: var(--text-secondary); flex: 1; line-height: 1.6; }
.db-text { font-size: 25rpx; color: var(--text-secondary); line-height: 1.75; }

/* 推荐资源 */
.res-group { margin-bottom: 20rpx; }
.res-group:last-child { margin-bottom: 0; }
.res-cat {
  display: block;
  font-size: 25rpx; font-weight: 600; color: var(--text-body);
  margin-bottom: 10rpx;
}
.res-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 18rpx; margin-bottom: 8rpx;
  background: #F9FAFB; border-radius: 10rpx;
  border: 1rpx solid var(--border-light);
}
.res-txt { font-size: 25rpx; color: var(--text-body); flex: 1; line-height: 1.5; }
.res-copy {
  font-size: 22rpx; color: var(--brand);
  background: #EEF2FF; padding: 4rpx 14rpx;
  border-radius: 8rpx; flex-shrink: 0; margin-left: 12rpx;
}

.regen-btn { margin-top: 8rpx; }

/* ══ 预填提示 ══ */
.prefill-tip, .from-job-tip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 16rpx 24rpx 0;
  padding: 18rpx 22rpx;
  border-radius: var(--r-md);
  font-size: 25rpx;
}
.prefill-tip {
  background: rgba(94,106,210,0.08);
  border: 1rpx solid rgba(94,106,210,0.18);
}
.prefill-icon, .fj-icon { font-size: 26rpx; flex-shrink: 0; }
.prefill-txt { color: var(--brand); line-height: 1.5; flex: 1; }

.from-job-tip {
  background: rgba(245,158,11,0.08);
  border: 1rpx solid rgba(245,158,11,0.20);
}
.fj-txt { color: #B45309; line-height: 1.5; flex: 1; }

/* ══ 历史规划 ══ */
.history-section {
  margin: 16rpx 24rpx 0;
  background: var(--bg-panel);
  border-radius: var(--r-md);
  border: 1.5rpx solid rgba(0,0,0,0.05);
  overflow: hidden;
}
.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 28rpx;
}
.history-head-title {
  font-size: 27rpx; font-weight: 600; color: var(--text-primary);
}
.history-toggle-icon { font-size: 22rpx; color: var(--text-muted); }

.history-list { border-top: 1rpx solid #F3F4F6; }

.history-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #F3F4F6;
  gap: 16rpx;
}
.history-card:active { background: rgba(0,0,0,0.03); }
.hc-left { flex: 1; min-width: 0; }
.hc-position {
  display: block;
  font-size: 27rpx; font-weight: 600; color: var(--text-primary);
  margin-bottom: 6rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.hc-meta { font-size: 23rpx; color: var(--text-muted); }
.hc-arrow { font-size: 34rpx; color: var(--text-muted); flex-shrink: 0; }

.history-clear {
  display: flex;
  justify-content: center;
  padding: 18rpx;
}
.hc-clear-txt { font-size: 24rpx; color: var(--danger); }

/* ══ 结果标题栏 ══ */
.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 4rpx 8rpx;
  margin-bottom: 4rpx;
}
.result-header-left { flex: 1; min-width: 0; }
.result-title {
  display: block;
  font-size: 30rpx; font-weight: 800; color: var(--text-primary);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  margin-bottom: 4rpx;
}
.result-meta { font-size: 23rpx; color: var(--text-muted); }
.result-regen {
  display: flex; align-items: center; gap: 6rpx;
  flex-shrink: 0; margin-left: 16rpx;
  padding: 10rpx 22rpx; border-radius: 9999rpx;
  background: rgba(0,0,0,0.04); border: 1rpx solid rgba(0,0,0,0.08);
}
.regen-icon { font-size: 28rpx; color: var(--text-muted); }
.regen-txt  { font-size: 24rpx; color: var(--text-muted); font-weight: 500; }

/* ══ 里程碑 Tab 特殊样式 ══ */
.phase-tab.milestone-tab {
  color: #7C3AED;
  background: #EDE9FE;
  border-color: #DDD6FE;
}

/* ══ 月度里程碑时间线 ══ */
.milestone-body {
  display: flex;
  flex-direction: column;
  padding-top: 4rpx;
}

.ms-item {
  display: flex;
  gap: 0;
  min-height: 100rpx;
}

.ms-axis {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}
.ms-dot {
  width: 20rpx; height: 20rpx;
  border-radius: 50%;
  background: var(--brand);
  border: 4rpx solid #EEF2FF;
  flex-shrink: 0;
  z-index: 1;
}
.ms-line {
  flex: 1;
  width: 3rpx;
  background: linear-gradient(to bottom, var(--brand) 0%, rgba(94,106,210,0.15) 100%);
  margin-top: 4rpx;
  min-height: 40rpx;
}

.ms-content {
  flex: 1;
  padding: 0 0 28rpx 16rpx;
  min-width: 0;
}
.ms-header-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}
.ms-month {
  font-size: 24rpx; font-weight: 700;
  color: var(--brand);
  background: #EEF2FF;
  padding: 4rpx 14rpx; border-radius: 8rpx;
  flex-shrink: 0;
}
.ms-focus {
  font-size: 26rpx; font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}
.ms-actions { display: flex; flex-direction: column; gap: 10rpx; }
.ms-action-row { display: flex; align-items: flex-start; gap: 10rpx; }
.ms-action-dot {
  font-size: 22rpx; color: #059669;
  flex-shrink: 0; margin-top: 2rpx; font-weight: 700;
}
.ms-action-txt { font-size: 25rpx; color: var(--text-secondary); line-height: 1.6; flex: 1; }
