/* pages/skill-pathways/skill-pathways.wxss */
page { background: var(--bg-page); font-family: -apple-system, 'PingFang SC', sans-serif; }

/* Hero */
.hero {
  background: var(--bg-panel);
  padding: 40rpx 28rpx 28rpx;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1.5rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.hero-left { display: flex; flex-direction: column; gap: 6rpx; }
.hero-title { font-size: 40rpx; font-weight: 800; color: var(--text-primary); }
.hero-sub   { font-size: 24rpx; color: var(--text-muted); }
.hero-icon-wrap {
  width: 80rpx; height: 80rpx; background: #EEF2FF;
  border-radius: var(--r-lg);
  display: flex; align-items: center; justify-content: center;
}
.hero-icon { font-size: 40rpx; line-height: 1; }

/* History */
.history-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18rpx 28rpx; background: var(--bg-panel);
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}
.hbar-txt   { font-size: 25rpx; color: var(--text-secondary); }
.hbar-arrow { font-size: 20rpx; color: var(--text-muted); }
.history-list { background: var(--bg-panel); padding: 0 24rpx; }
.hist-item {
  padding: 14rpx 0; border-bottom: 1rpx solid #F3F4F6;
  display: flex; flex-direction: column; gap: 4rpx;
}
.hist-item:last-child { border-bottom: none; }
.hist-role { font-size: 26rpx; font-weight: 700; color: var(--text-primary); }
.hist-meta { font-size: 22rpx; color: var(--text-muted); }

/* Input */
.input-wrap  { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.section-card {
  background: var(--bg-panel); border-radius: var(--r-lg); padding: 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.section-title { font-size: 27rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 18rpx; }
.req { color: #EF4444; }

/* Role grid */
.role-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; }
.role-card {
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  padding: 20rpx 12rpx; border-radius: var(--r-md);
  border: 2rpx solid rgba(0,0,0,0.07);
  background: var(--bg-page);
  text-align: center;
}
.role-card.selected { border-width: 2.5rpx; }
.role-card:active { opacity: 0.75; }
.role-icon  { font-size: 36rpx; line-height: 1; }
.role-label { font-size: 24rpx; font-weight: 700; color: var(--text-primary); }
.role-desc  { font-size: 19rpx; color: var(--text-muted); }

/* Level list */
.level-list { display: flex; flex-direction: column; gap: 12rpx; }
.level-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 18rpx; border-radius: var(--r-md);
  border: 1.5rpx solid rgba(0,0,0,0.07);
  background: var(--bg-page);
}
.level-item.selected { border-color: var(--brand); background: #EEF2FF; }
.level-item:active   { opacity: 0.75; }
.level-radio {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  border: 2rpx solid #D1D5DB; flex-shrink: 0;
}
.level-radio.active { border-color: var(--brand); background: var(--brand); position: relative; }
.level-radio.active::after {
  content: ''; position: absolute;
  width: 14rpx; height: 14rpx; border-radius: 50%; background: #fff;
  top: 50%; left: 50%; transform: translate(-50%, -50%);
}
.level-text  { flex: 1; }
.level-name  { font-size: 26rpx; font-weight: 600; color: var(--text-primary); display: block; }
.level-desc  { font-size: 22rpx; color: var(--text-muted); }

/* Timeline */
.timeline-row { display: flex; gap: 12rpx; }
.timeline-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4rpx;
  padding: 18rpx 8rpx; border-radius: var(--r-md);
  border: 2rpx solid rgba(0,0,0,0.07);
  background: var(--bg-page);
}
.timeline-btn.active { border-color: var(--brand); background: #EEF2FF; }
.timeline-btn:active  { opacity: 0.75; }
.tl-label { font-size: 28rpx; font-weight: 800; color: var(--text-primary); }
.timeline-btn.active .tl-label { color: var(--brand); }
.tl-desc  { font-size: 20rpx; color: var(--text-muted); }

.fi    { background: #F9FAFB; border: 1.5rpx solid var(--border-light); border-radius: 14rpx; padding: 0 20rpx; height: 80rpx; font-size: 27rpx; color: var(--text-primary); width: 100%; box-sizing: border-box; }
.fi-ta { height: auto; min-height: 100rpx; padding: 16rpx 20rpx; line-height: 1.7; }
.gen-btn-wrap { padding-bottom: 8rpx; }
.gen-btn { width: 100%; }

/* Loading */
.loading-card {
  margin: 40rpx 24rpx; background: var(--bg-panel); border-radius: var(--r-lg);
  padding: 60rpx 32rpx;
  display: flex; flex-direction: column; align-items: center; gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.loading-map { display: flex; align-items: center; gap: 0; }
.map-dot {
  width: 24rpx; height: 24rpx; border-radius: 50%;
  background: #D1D5DB; border: 3rpx solid #fff;
}
.map-dot.active { background: var(--brand); width: 32rpx; height: 32rpx; animation: dot-pulse 1.2s ease-in-out infinite; }
.map-line { width: 60rpx; height: 4rpx; background: #E5E7EB; }
@keyframes dot-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(43,92,230,0.4); }
  50%       { box-shadow: 0 0 0 12rpx rgba(43,92,230,0); }
}
.loading-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); }
.loading-steps { display: flex; align-items: center; gap: 6rpx; flex-wrap: wrap; justify-content: center; }
.lstep { font-size: 20rpx; color: var(--text-muted); padding: 5rpx 14rpx; border-radius: 50rpx; background: #F3F4F6; }
.lstep.active { background: #EEF2FF; color: var(--brand); font-weight: 700; }
.lstep.done   { background: #D1FAE5; color: #059669; }
.lstep-arr    { font-size: 20rpx; color: var(--text-muted); }

/* Result */
.result-wrap { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 18rpx; }

.result-header {
  border-radius: var(--r-lg); padding: 24rpx 22rpx;
  display: flex; justify-content: space-between; align-items: center;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.2);
}
.rh-left  { display: flex; align-items: center; gap: 16rpx; }
.rh-icon  { font-size: 44rpx; line-height: 1; }
.rh-text  { display: flex; flex-direction: column; gap: 4rpx; }
.rh-title { font-size: 30rpx; font-weight: 800; color: #fff; }
.rh-meta  { font-size: 22rpx; color: rgba(255,255,255,0.75); }
.rh-copy  { font-size: 24rpx; color: rgba(255,255,255,0.9); font-weight: 600; background: rgba(255,255,255,0.2); padding: 10rpx 20rpx; border-radius: 50rpx; flex-shrink: 0; }

.summary-card {
  background: #F8FAFC; border-radius: var(--r-md); padding: 20rpx 22rpx;
  border: 1.5rpx solid rgba(0,0,0,0.05);
}
.summary-txt { font-size: 26rpx; color: var(--text-body); line-height: 1.8; display: block; }

/* Core skills */
.sec-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 18rpx; }
.skill-item { display: flex; gap: 14rpx; align-items: flex-start; padding: 14rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.skill-item:last-child { border-bottom: none; padding-bottom: 0; }
.priority-badge {
  font-size: 19rpx; font-weight: 700; padding: 4rpx 12rpx; border-radius: 6rpx;
  flex-shrink: 0; margin-top: 4rpx; white-space: nowrap;
}
.p-must { background: #FEE2E2; color: #DC2626; }
.p-good { background: #FEF3C7; color: #D97706; }
.p-nice { background: #D1FAE5; color: #059669; }
.skill-info { flex: 1; }
.skill-name { font-size: 26rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 4rpx; }
.skill-desc { font-size: 23rpx; color: var(--text-muted); line-height: 1.6; display: block; }
.skill-resources { margin-top: 8rpx; display: flex; flex-direction: column; gap: 4rpx; }
.skill-res  { font-size: 21rpx; color: var(--brand); }

/* Month plan timeline */
.phase-item { display: flex; gap: 0; position: relative; padding-bottom: 28rpx; }
.phase-item:last-child { padding-bottom: 0; }
.phase-dot {
  width: 20rpx; height: 20rpx; border-radius: 50%;
  background: var(--brand); border: 4rpx solid #EEF2FF;
  flex-shrink: 0; margin-top: 8rpx; margin-right: 20rpx; z-index: 1;
}
.phase-line {
  position: absolute; left: 8rpx; top: 24rpx; bottom: 0;
  width: 4rpx; background: #E5E7EB;
}
.phase-content { flex: 1; padding-bottom: 4rpx; }
.phase-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; flex-wrap: wrap; }
.phase-month  { font-size: 22rpx; color: var(--brand); font-weight: 700; background: #EEF2FF; padding: 3rpx 12rpx; border-radius: 6rpx; }
.phase-title  { font-size: 26rpx; font-weight: 700; color: var(--text-primary); }
.phase-tasks  { display: flex; flex-direction: column; gap: 10rpx; margin-bottom: 12rpx; }
.phase-task   { display: flex; gap: 10rpx; align-items: flex-start; }
.task-check   { font-size: 22rpx; color: #D1D5DB; flex-shrink: 0; margin-top: 2rpx; }
.task-txt     { font-size: 24rpx; color: var(--text-body); line-height: 1.6; flex: 1; }
.phase-milestone {
  display: flex; align-items: center; gap: 8rpx;
  background: #F0FDF4; border-radius: 8rpx; padding: 10rpx 14rpx;
}
.milestone-icon { font-size: 22rpx; flex-shrink: 0; }
.milestone-txt  { font-size: 23rpx; color: #059669; font-weight: 600; line-height: 1.5; flex: 1; }

/* Projects */
.project-item { display: flex; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.project-item:last-child { border-bottom: none; padding-bottom: 0; }
.project-num {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--brand); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 900; flex-shrink: 0;
}
.project-body  { flex: 1; }
.project-name  { font-size: 26rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 6rpx; }
.project-desc  { font-size: 23rpx; color: var(--text-muted); line-height: 1.6; display: block; margin-bottom: 10rpx; }
.project-outcome { background: #EEF2FF; border-radius: 8rpx; padding: 10rpx 14rpx; display: flex; flex-direction: column; gap: 4rpx; }
.outcome-label { font-size: 20rpx; color: var(--brand); font-weight: 700; }
.outcome-txt   { font-size: 22rpx; color: var(--text-body); line-height: 1.5; }

/* Certs */
.cert-item { padding: 14rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.cert-item:last-child { border-bottom: none; }
.cert-name { font-size: 26rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 4rpx; }
.cert-why  { font-size: 23rpx; color: var(--text-muted); line-height: 1.6; display: block; }

/* Tips */
.tip-item { display: flex; gap: 12rpx; align-items: flex-start; margin-bottom: 14rpx; }
.tip-item:last-child { margin-bottom: 0; }
.tip-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--brand); flex-shrink: 0; margin-top: 10rpx; }
.tip-txt { font-size: 25rpx; color: var(--text-body); line-height: 1.7; flex: 1; }

/* Result actions */
.result-actions { padding-bottom: 8rpx; }
