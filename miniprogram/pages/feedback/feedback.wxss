/* pages/feedback/feedback.wxss — Premium Redesign */
page {
  background: #F2F4F8;
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container { padding: 24rpx; }

/* Hero */
.page-hero {
  background: linear-gradient(160deg, #0D1B3E 0%, #1C3578 55%, var(--brand) 100%);
  border-radius: var(--r-lg);
  padding: 40rpx 36rpx;
  margin-bottom: 28rpx;
  position: relative;
  overflow: hidden;
}

.page-hero::before {
  content: '';
  position: absolute;
  bottom: -40rpx; right: -30rpx;
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

/* Form sections */
.form-section {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1.5rpx solid #F1F3F7;
  position: relative;
}

.label {
  font-size: 26rpx;
  font-weight: 700;
  color: #0F172A;
  display: block;
  margin-bottom: 18rpx;
  padding-left: 16rpx;
  border-left: 5rpx solid var(--brand);
}

.picker-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-body);
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F1F3F7;
}

.arrow { color: #C4C9D4; font-size: 24rpx; }

.textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.65;
  box-sizing: border-box;
}

.char-count {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  font-size: 22rpx;
  color: #C4C9D4;
}

.input {
  font-size: 28rpx;
  color: var(--text-body);
  padding: 14rpx 0;
}

.submit-btn { margin-top: 12rpx; }
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Profile entry page polish */
.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-intro {
  margin-bottom: 24rpx;
}

.page-title {
  display: block;
  color: #111827;
  font-size: 42rpx;
  font-weight: 950;
}

.page-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.45;
}

.form-section {
  border-radius: 24rpx;
  padding: 28rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.label {
  border-left: 0;
  padding-left: 0;
  color: #111827;
  font-weight: 900;
}

.picker-box,
.input,
.textarea {
  border-radius: 18rpx;
  background: #f8fbff;
  border: 1rpx solid #e4eaf2;
  box-sizing: border-box;
}

.picker-box {
  padding: 20rpx 22rpx;
}

.input {
  height: 78rpx;
  padding: 0 22rpx;
}

.textarea {
  min-height: 220rpx;
  padding: 20rpx 22rpx;
}

.char-count {
  color: #98a2b3;
}

/* Feedback page polish */
.feedback-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 58%, #ecfffb 100%);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.08);
}

.hero-kicker,
.hero-title,
.hero-sub,
.badge-num,
.badge-label,
.label,
.section-tip,
.type-title,
.type-desc {
  display: block;
}

.hero-kicker {
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 8rpx;
  color: #101828;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 950;
}

.hero-sub {
  width: 430rpx;
  max-width: 100%;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.hero-badge {
  width: 122rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(145deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 18rpx 34rpx rgba(37,99,235,0.22);
  flex-shrink: 0;
}

.badge-num {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 950;
}

.badge-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 800;
  opacity: 0.88;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-tip {
  margin-top: 8rpx;
  color: #718096;
  font-size: 23rpx;
  line-height: 1.45;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.type-card {
  min-height: 132rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f8fbff;
  border: 1rpx solid #e4eaf2;
  display: flex;
  gap: 14rpx;
  box-sizing: border-box;
}

.type-card.active {
  background: #eef4ff;
  border-color: rgba(37,99,235,0.38);
  box-shadow: 0 12rpx 26rpx rgba(37,99,235,0.10);
}

.type-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  font-size: 32rpx;
  line-height: 44rpx;
}

.type-body {
  flex: 1;
  min-width: 0;
}

.type-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.type-desc {
  margin-top: 8rpx;
  color: #718096;
  font-size: 21rpx;
  line-height: 1.42;
}

.textarea {
  min-height: 260rpx;
}

.textarea-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.helper-text {
  color: #98a2b3;
  font-size: 22rpx;
}

.char-count {
  position: static;
  font-size: 22rpx;
}

.char-count.warn {
  color: #f59e0b;
}

.promise-card {
  margin: 8rpx 0 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.88);
  border: 1rpx solid rgba(220,229,240,0.96);
}

.promise-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.6;
}

.promise-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #18b6b0;
  flex-shrink: 0;
}

.submit-wrap {
  margin-top: 8rpx;
}
