/* pages/feedback/feedback.wxss — Premium Redesign */
page {
  background: #F2F4F8;
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container { padding: 24rpx; }

/* Hero */
.page-hero {
  background: linear-gradient(160deg, #0D1B3E 0%, #1C3578 55%, var(--brand) 100%);
  border-radius: var(--r-lg);
  padding: 40rpx 36rpx;
  margin-bottom: 28rpx;
  position: relative;
  overflow: hidden;
}

.page-hero::before {
  content: '';
  position: absolute;
  bottom: -40rpx; right: -30rpx;
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

/* Form sections */
.form-section {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1.5rpx solid #F1F3F7;
  position: relative;
}

.label {
  font-size: 26rpx;
  font-weight: 700;
  color: #0F172A;
  display: block;
  margin-bottom: 18rpx;
  padding-left: 16rpx;
  border-left: 5rpx solid var(--brand);
}

.picker-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-body);
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F1F3F7;
}

.arrow { color: #C4C9D4; font-size: 24rpx; }

.textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.65;
  box-sizing: border-box;
}

.char-count {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  font-size: 22rpx;
  color: #C4C9D4;
}

.input {
  font-size: 28rpx;
  color: var(--text-body);
  padding: 14rpx 0;
}

.submit-btn { margin-top: 12rpx; }
