/* pages/interview-dialog/interview-dialog.wxss */

page {
  height: 100vh;
  background: var(--bg-page);
  display: flex;
  flex-direction: column;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: var(--bg-page);
}

/* ─── Progress Header ───────────────────────────── */
.progress-header {
  background: var(--bg-panel);
  padding: 18rpx 28rpx 14rpx;
  border-bottom: 1rpx solid #EAECF0;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.progress-meta {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-type {
  font-size: 22rpx;
  color: var(--brand);
  font-weight: 600;
  background: #EEF2FF;
  padding: 4rpx 12rpx;
  border-radius: var(--r-lg);
  flex-shrink: 0;
}

.progress-sep {
  font-size: 22rpx;
  color: #CBD5E0;
  margin: 0 6rpx;
  flex-shrink: 0;
}

.progress-pos {
  font-size: 22rpx;
  color: var(--text-body);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 1;
}

.progress-company {
  font-size: 20rpx;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 2;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.progress-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.progress-count {
  font-size: 22rpx;
  color: var(--brand);
  font-weight: 700;
}

.progress-track {
  height: 6rpx;
  background: var(--border-light);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--brand), #60A5FA);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}

/* ─── Finished Header ───────────────────────────── */
.finished-header {
  background: var(--bg-panel);
  padding: 24rpx 28rpx 20rpx;
  border-bottom: 1rpx solid #EAECF0;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.finished-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10B981, #059669);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  flex-shrink: 0;
}

.finished-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.finished-sub {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-left: auto;
}

/* ─── Chat List ─────────────────────────────────── */
.chat-list {
  flex: 1;
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.padding-top { height: 24rpx; }
.padding-bottom { height: 50rpx; }

/* ─── Message Groups ────────────────────────────── */
.message-group {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* AI avatar: blue gradient rounded square */
.ai-avatar {
  background: linear-gradient(135deg, var(--brand), #6366F1);
  margin-right: 18rpx;
  border-radius: var(--r-md);
  box-shadow: 0 4rpx 12rpx rgba(43,92,230,0.3);
}

.ai-avatar-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
}

/* User avatar: dark circle */
.user-avatar {
  background: var(--text-body);
  margin-left: 18rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.user-avatar-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.content-wrapper {
  max-width: 72%;
  display: flex;
  flex-direction: column;
}

/* ─── Bubbles ───────────────────────────────────── */
.bubble {
  padding: 22rpx 24rpx;
  border-radius: var(--r-md);
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
  position: relative;
}

/* AI group layout */
.ai-group { flex-direction: row; }

/* AI question bubble: white card */
.ai-bubble {
  background: var(--bg-panel);
  color: #1F2937;
  border: 1rpx solid var(--border-light);
  border-radius: 4rpx 16rpx 16rpx 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
}

/* AI feedback bubble: amber tinted */
.feedback-bubble {
  background: #FFFBEB;
  color: #78350F;
  border: 1rpx solid #FDE68A;
  border-left: 4rpx solid #F59E0B;
  border-radius: 4rpx 16rpx 16rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(245,158,11,0.1);
}

.feedback-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 700;
  color: #D97706;
  background: #FEF3C7;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
  margin-right: 6rpx;
}

/* User group layout */
.user-group { flex-direction: row-reverse; }

/* User bubble: brand blue */
.user-bubble {
  background: var(--brand);
  color: #fff;
  border-radius: var(--r-md) 4rpx 16rpx 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(43,92,230,0.25);
}

/* ─── System / Summary Message ──────────────────── */
.system-message {
  margin: 32rpx 0;
  display: flex;
  justify-content: center;
}

.system-card {
  background: var(--bg-panel);
  border: 1rpx solid var(--border-light);
  border-radius: var(--r-lg);
  padding: 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.system-icon {
  font-size: 56rpx;
  margin-bottom: 14rpx;
}

.system-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  text-align: center;
}

/* check-report-btn 由 c-button 提供样式 */

/* ─── Loading Dots ──────────────────────────────── */
.loading-wrap {
  display: flex;
  justify-content: flex-start;
  padding-left: 90rpx;
  margin-bottom: 24rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
  background: var(--bg-panel);
  padding: 18rpx 22rpx;
  border-radius: var(--r-md);
  border: 1rpx solid var(--border-light);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #93C5FD;
  border-radius: 50%;
  animation: blink 1.4s infinite both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.2; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

/* ─── Footer Bar ────────────────────────────────── */
.footer-bar {
  background: var(--bg-panel);
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: flex-end;
  border-top: 1rpx solid var(--border-light);
  min-height: 100rpx;
  box-sizing: content-box;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.04);
}

.input-box {
  flex: 1;
  background: #F9FAFB;
  border-radius: var(--r-md);
  border: 1rpx solid var(--border-light);
  padding: 18rpx 20rpx;
  font-size: 30rpx;
  margin-right: 16rpx;
  min-height: 44rpx;
  max-height: 200rpx;
  width: auto;
  line-height: 1.5;
  color: #1F2937;
}

.send-btn {
  background: linear-gradient(135deg, var(--brand), #6366F1);
  color: #fff;
  padding: 0 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--r-md);
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(43,92,230,0.3);
}

.send-btn.disabled {
  background: #BFDBFE;
  color: #EFF6FF;
  box-shadow: none;
}

/* ─── Mic / Voice Button ─────────────────────────── */
.mic-btn {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: #F3F4F6; border: 1.5rpx solid rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: center;
  margin-right: 12rpx; flex-shrink: 0;
  align-self: flex-end; margin-bottom: 4rpx;
}
.mic-btn:active { opacity: 0.7; transform: scale(0.93); }
.mic-btn.recording {
  background: #FEE2E2; border-color: #EF4444;
  animation: mic-pulse 1s ease-in-out infinite;
}
.mic-btn.voice-loading { background: #EEF2FF; border-color: var(--brand); opacity: 0.8; }
.mic-icon { font-size: 30rpx; line-height: 1; }

@keyframes mic-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.4); }
  50%       { box-shadow: 0 0 0 10rpx rgba(239,68,68,0); }
}

/* ─── Finished Bar ──────────────────────────────── */
.finished-bar {
  display: flex;
  width: 100%;
  gap: 20rpx;
}

.action-btn { flex: 1; }

/* ─── Modal ─────────────────────────────────────── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  touch-action: none;
}

.modal-content {
  width: 100%;
  height: 88vh;
  background: var(--bg-panel);
  border-radius: 28rpx 28rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx 30rpx 28rpx;
  text-align: center;
  border-bottom: 1rpx solid #F3F4F6;
  position: relative;
  flex-shrink: 0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.close-icon {
  position: absolute;
  right: 24rpx;
  top: 28rpx;
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 8rpx 16rpx;
}

/* ─── Report Scroll Area ────────────────────────── */
.report-scroll {
  flex: 1;
  height: 0;
  background: var(--bg-page);
  width: 100%;
}

.report-inner {
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 60rpx;
}

/* ─── Score Card ────────────────────────────────── */
.score-card {
  background: linear-gradient(135deg, #0D1B3E, var(--brand));
  border-radius: var(--r-lg);
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(43,92,230,0.35);
}

.score-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.score-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.score-num {
  font-size: 80rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.score-unit {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.score-bar-track {
  width: 100%;
  height: 8rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 4rpx;
  margin: 16rpx 0;
  overflow: hidden;
}

.score-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #34D399, #10B981);
  border-radius: 4rpx;
  transition: width 0.6s ease;
}

.score-stars {
  display: flex;
  gap: 10rpx;
}

.star {
  font-size: 32rpx;
  color: rgba(255,255,255,0.2);
}

.star.lit {
  color: #FBBF24;
}

/* ─── Report Sections ───────────────────────────── */
.report-section {
  background: var(--bg-panel);
  padding: 28rpx;
  border-radius: var(--r-lg);
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.section-head {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: var(--text-primary);
  border-left: 6rpx solid var(--brand);
  padding-left: 16rpx;
}

.section-body {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.7;
}

/* ─── Record Cards ──────────────────────────────── */
.record-card {
  margin-bottom: 28rpx;
  border-bottom: 1rpx dashed var(--border-light);
  padding-bottom: 28rpx;
}

.record-card:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.record-row {
  display: flex;
  margin-bottom: 14rpx;
  align-items: flex-start;
}

.label {
  font-size: 22rpx;
  color: #fff;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  margin-right: 14rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  font-weight: 700;
}

.q-label { background: #EF4444; }
.a-label { background: #3B82F6; }
.f-label { background: #F59E0B; }

.text-content {
  font-size: 28rpx;
  color: var(--text-body);
  line-height: 1.6;
  flex: 1;
}

.strong {
  font-weight: 600;
  color: var(--text-primary);
}

.feedback-box {
  background: #FFFBEB;
  padding: 14rpx;
  border-radius: 10rpx;
  border-left: 4rpx solid #F59E0B;
}

.feedback-text {
  color: #92400E;
  font-size: 26rpx;
}

/* ─── Modal Footer ──────────────────────────────── */
.modal-footer {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #F3F4F6;
  background: var(--bg-panel);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

/* close-btn 由 c-button 提供样式 */
