/* pages/company-detail/company-detail.wxss */
page { background: var(--bg-raised); }

/* 公司头部 */
.company-header {
  background: var(--bg-panel);
  padding: 40rpx 30rpx;
  display: flex;
  align-items: flex-start;
}

.company-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--r-lg);
  border: 1rpx solid #f0f0f0;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: var(--bg-panel);
}

.header-info { flex: 1; }

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.company-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.rating-badge {
  background: #ff9500;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.company-meta {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
  display: block;
}

.tag-row { display: flex; flex-wrap: wrap; gap: 12rpx; }

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background: #f0f7ff;
  color: var(--brand);
  border-radius: 8rpx;
}

/* 公司简介卡片 */
.section-card {
  margin: 24rpx 30rpx;
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  border-left: 8rpx solid var(--brand);
  padding-left: 16rpx;
}

.desc-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 20rpx;
  display: block;
}

.info-row {
  display: flex;
  justify-content: space-between;
  background: #F9FAFB;
  border-radius: var(--r-sm);
  padding: 20rpx;
}

.info-item { text-align: center; }
.info-label { font-size: 22rpx; color: var(--text-muted); display: block; margin-bottom: 6rpx; }
.info-value { font-size: 26rpx; color: var(--text-body); font-weight: bold; display: block; }

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: var(--bg-panel);
  margin: 0 30rpx;
  border-radius: var(--r-lg) 20rpx 0 0;
  padding: 0 10rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--brand);
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--brand);
  border-radius: 4rpx;
}

/* Tab 内容 */
.tab-content {
  margin: 0 30rpx;
  background: var(--bg-panel);
  border-radius: 0 0 20rpx 20rpx;
  padding: 20rpx;
}

/* 职位卡片 */
.job-card {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.job-card:last-child { border-bottom: none; }

.job-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.job-title { font-size: 28rpx; font-weight: bold; color: var(--text-body); }
.job-salary { font-size: 28rpx; font-weight: bold; color: #059669; }

.job-bottom { display: flex; gap: 12rpx; }
.job-tag { font-size: 22rpx; background: var(--bg-raised); color: var(--text-secondary); padding: 4rpx 12rpx; border-radius: 6rpx; }

/* 面经卡片 */
.exp-card {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.exp-card:last-child { border-bottom: none; }

.exp-title { font-size: 28rpx; font-weight: bold; color: var(--text-body); display: block; margin-bottom: 12rpx; }
.exp-meta { display: flex; gap: 20rpx; font-size: 22rpx; color: var(--text-muted); }
.exp-type { background: #fff7e6; color: #fa8c16; padding: 2rpx 10rpx; border-radius: 6rpx; }

/* 薪资卡片 */
.salary-card {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.salary-card:last-child { border-bottom: none; }

.salary-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.salary-position { font-size: 28rpx; font-weight: bold; color: var(--text-body); }
.salary-avg { font-size: 30rpx; font-weight: bold; color: var(--brand); }

.salary-bar-track {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  margin-bottom: 12rpx;
}

.salary-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #69c0ff, var(--brand));
  border-radius: 6rpx;
}

.salary-bottom {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--text-muted);
}

/* API实时标记 */
.api-badge {
  font-size: 18rpx;
  color: #52c41a;
  background: #f6ffed;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  border: 1rpx solid #b7eb8f;
}

/* AI面经生成按钮 */
.ai-exp-bar {
  padding: 16rpx 24rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.ai-exp-btn {
  background: linear-gradient(135deg, var(--brand), #6c5ce7);
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  padding: 16rpx 0;
  border-radius: 30rpx;
  text-align: center;
}
.ai-exp-btn.disabled { opacity: 0.6; }

/* AI标记 */
.exp-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.exp-title-row .exp-title { flex: 1; margin-bottom: 0; }
.ai-tag {
  font-size: 20rpx;
  color: #6c5ce7;
  background: #f0e6ff;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: bold;
  border: 1rpx solid #d3adf7;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 加载提示 */
.loading-hint {
  text-align: center;
  color: var(--text-muted);
  font-size: 24rpx;
  padding: 30rpx 0;
}

.empty {
  text-align: center;
  color: #D1D5DB;
  padding: 60rpx 0;
  font-size: 28rpx;
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: var(--bg-panel);
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  display: flex;
  gap: 20rpx;
  box-sizing: border-box;
}

.fav-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: var(--bg-raised);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.share-btn { flex: 1; }

.intro-loading {
  padding: 16rpx 0;
}
.intro-loading-text {
  font-size: 26rpx;
  color: #6366f1;
}

/* ══ AI 洞察 ══ */
.insight-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 20rpx;
}
.insight-spin {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.insight-loading-txt { font-size: 26rpx; color: var(--brand); }

.insight-card {
  padding: 22rpx 0 22rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.insight-card:last-child { border-bottom: none; }
.insight-card-header {
  display: flex; align-items: center; gap: 10rpx;
  margin-bottom: 14rpx;
}
.insight-icon { font-size: 28rpx; }
.insight-card-title { font-size: 28rpx; font-weight: bold; color: var(--text-primary); }
.insight-card-body {
  font-size: 26rpx; color: var(--text-secondary);
  line-height: 1.7; display: block;
}
.insight-qlist { display: flex; flex-direction: column; gap: 12rpx; }
.insight-q-item {
  display: flex; align-items: flex-start; gap: 12rpx;
  background: #F9FAFB; border-radius: 12rpx;
  padding: 14rpx 16rpx;
}
.insight-q-num {
  font-size: 20rpx; color: var(--brand); font-weight: bold;
  background: #EEF2FF; padding: 2rpx 10rpx; border-radius: 8rpx;
  flex-shrink: 0; margin-top: 2rpx;
}
.insight-q-txt { font-size: 26rpx; color: var(--text-body); line-height: 1.6; flex: 1; }
.insight-tips { display: flex; flex-direction: column; gap: 12rpx; }
.insight-tip-item { display: flex; align-items: flex-start; gap: 12rpx; }
.insight-tip-check { font-size: 22rpx; color: #059669; font-weight: bold; flex-shrink: 0; margin-top: 4rpx; }
.insight-tip-txt { font-size: 26rpx; color: var(--text-body); line-height: 1.6; flex: 1; }
.insight-refresh-row { text-align: center; padding: 16rpx 0; }
.insight-refresh-txt { font-size: 24rpx; color: var(--text-muted); }

.insight-empty {
  display: flex; flex-direction: column;
  align-items: center; padding: 50rpx 20rpx; gap: 18rpx;
}
.insight-gen-btn {
  background: linear-gradient(135deg, var(--brand), #6c5ce7);
  color: #fff; font-size: 28rpx; font-weight: bold;
  padding: 20rpx 52rpx; border-radius: 40rpx; text-align: center;
}
.insight-empty-sub { font-size: 24rpx; color: var(--text-muted); }

/* 2026 company detail polish */
page {
  background:
    radial-gradient(circle at 10% 0%, rgba(43, 92, 230, 0.08), transparent 30%),
    linear-gradient(180deg, #f8fbff 0%, #f6f8fc 50%, #ffffff 100%);
}

.container {
  min-height: 100vh;
  overflow-x: hidden;
}

.company-header {
  margin: 18rpx 24rpx 22rpx;
  padding: 34rpx 30rpx;
  border-radius: 34rpx;
  border: 1rpx solid rgba(31, 45, 74, 0.06);
  background:
    radial-gradient(circle at 100% 0%, rgba(43, 92, 230, 0.09), transparent 35%),
    #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(31, 45, 74, 0.08);
}

.company-logo-wrap {
  width: 124rpx;
  height: 124rpx;
  margin-right: 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(31, 45, 74, 0.08);
  background: linear-gradient(145deg, #ffffff, #f2f6ff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 12rpx 26rpx rgba(31, 45, 74, 0.08);
}

.company-logo {
  width: 98rpx;
  height: 98rpx;
  margin: 0;
  border: none;
  border-radius: 0;
  background: transparent;
}

.company-logo-initial {
  color: #2b5ce6;
  font-size: 42rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.company-name {
  color: #172033;
  font-size: 38rpx;
  line-height: 1.25;
  letter-spacing: -0.6rpx;
}

.company-meta {
  color: #667085;
  line-height: 1.55;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  color: #2b5ce6;
  background: #edf4ff;
}

.section-card,
.tab-bar,
.tab-content {
  margin-left: 24rpx;
  margin-right: 24rpx;
  border: 1rpx solid rgba(31, 45, 74, 0.06);
  background: #ffffff;
  box-shadow: 0 16rpx 38rpx rgba(31, 45, 74, 0.07);
}

.section-card {
  margin-top: 0;
  margin-bottom: 22rpx;
  padding: 32rpx 30rpx;
  border-radius: 32rpx;
}

.section-title {
  font-size: 31rpx;
  border-left-width: 7rpx;
}

.desc-text {
  color: #596579;
  line-height: 1.85;
}

.info-row {
  gap: 10rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #f5f8fd;
}

.info-item {
  flex: 1;
  min-width: 0;
}

.info-value {
  color: #263247;
  font-size: 25rpx;
  line-height: 1.35;
}

.tab-bar {
  border-radius: 28rpx 28rpx 0 0;
  padding: 4rpx 10rpx 0;
  box-shadow: none;
}

.tab-item {
  padding: 24rpx 0 22rpx;
  font-size: 27rpx;
}

.tab-content {
  padding: 18rpx;
  border-top: none;
  border-radius: 0 0 28rpx 28rpx;
  box-shadow: 0 16rpx 38rpx rgba(31, 45, 74, 0.07);
}

.job-card,
.exp-card,
.salary-card,
.insight-card {
  margin-bottom: 14rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(31, 45, 74, 0.06);
  border-radius: 24rpx;
  background: #fbfdff;
}

.job-card:last-child,
.exp-card:last-child,
.salary-card:last-child,
.insight-card:last-child {
  margin-bottom: 0;
  border-bottom: 1rpx solid rgba(31, 45, 74, 0.06);
}

.job-top,
.salary-top {
  align-items: flex-start;
  gap: 18rpx;
}

.job-title,
.salary-position {
  flex: 1;
  min-width: 0;
  color: #263247;
  line-height: 1.45;
}

.job-salary,
.salary-avg {
  color: #059669;
  flex-shrink: 0;
}

.job-bottom {
  flex-wrap: wrap;
}

.job-tag {
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  background: #f1f5fb;
}

.api-badge {
  border-radius: 10rpx;
}

.ai-exp-btn,
.insight-gen-btn {
  background: linear-gradient(135deg, #2b5ce6 0%, #465ff2 100%);
}

.detail-safe-tail {
  height: calc(112rpx + env(safe-area-inset-bottom));
}

.footer-bar {
  padding: 14rpx 28rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -16rpx 36rpx rgba(31, 45, 74, 0.08);
}

.fav-btn {
  padding: 18rpx;
  border-radius: 999rpx;
  color: #5d6678;
  background: #f3f6fb;
  font-weight: 700;
}

.share-btn {
  flex: 1;
  --btn-height: 76rpx;
  --btn-font-size: 28rpx;
  border-radius: 999rpx;
  box-shadow: 0 12rpx 26rpx rgba(43, 92, 230, 0.28);
}
