.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 18rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 9999;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.ai-float {
  position: fixed;
  right: 28rpx;
  top: 58vh;
  width: 142rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

.ai-float-hover {
  opacity: 0.92;
}

.ai-float-core {
  position: relative;
  width: 142rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: ai-float-drift 3.8s ease-in-out infinite;
  transform-origin: center;
  transition: transform 0.14s ease, opacity 0.14s ease;
}

.ai-float-hover .ai-float-core {
  animation-play-state: paused;
  transform: translateY(4rpx) scale(0.94);
}

.ai-float-glow {
  position: absolute;
  left: 28rpx;
  top: 16rpx;
  width: 88rpx;
  height: 66rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, rgba(71, 116, 255, 0.26) 0%, rgba(71, 116, 255, 0.08) 54%, rgba(71, 116, 255, 0) 72%);
  animation: ai-glow-breathe 2.6s ease-in-out infinite;
  pointer-events: none;
}

.ai-float-orbit {
  position: absolute;
  left: 2rpx;
  top: 17rpx;
  width: 138rpx;
  height: 56rpx;
  border: 2rpx solid rgba(128, 170, 255, 0.28);
  border-radius: 50%;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.26);
  pointer-events: none;
  transform-origin: center;
}

.ai-float-orbit.orbit-a {
  animation: ai-orbit-a 6.2s linear infinite;
}

.ai-float-orbit.orbit-b {
  border-color: rgba(124, 92, 255, 0.2);
  animation: ai-orbit-b 7.4s linear infinite;
}

.ai-float-spark {
  position: absolute;
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #65C7FF;
  box-shadow: 0 0 14rpx rgba(101, 199, 255, 0.58);
  pointer-events: none;
}

.ai-float-spark.spark-one {
  left: 22rpx;
  top: 31rpx;
  animation: ai-spark-one 2.8s ease-in-out infinite;
}

.ai-float-spark.spark-two {
  right: 25rpx;
  bottom: 24rpx;
  background: #7C5CFF;
  box-shadow: 0 0 14rpx rgba(124, 92, 255, 0.5);
  animation: ai-spark-two 3.2s ease-in-out infinite;
}

.ai-float-mark {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #7DDCFF 0%, #3B73FF 52%, #7659FF 100%);
  box-shadow:
    0 16rpx 30rpx rgba(59, 115, 255, 0.26),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.28);
  animation: ai-mark-breathe 2.8s ease-in-out infinite;
  transform: rotate(-4deg);
}

.ai-float-text {
  color: #FFFFFF;
  font-size: 31rpx;
  font-weight: 950;
  letter-spacing: 0;
  line-height: 34rpx;
}

@keyframes ai-float-drift {
  0%, 100% { transform: translate3d(0, 0, 0); }
  50% { transform: translate3d(0, -8rpx, 0); }
}

@keyframes ai-glow-breathe {
  0%, 100% { opacity: 0.72; transform: scale(0.88); }
  50% { opacity: 1; transform: scale(1.1); }
}

@keyframes ai-orbit-a {
  0% { transform: rotate(-18deg) scaleX(1); }
  50% { transform: rotate(162deg) scaleX(1.04); }
  100% { transform: rotate(342deg) scaleX(1); }
}

@keyframes ai-orbit-b {
  0% { transform: rotate(18deg) scaleX(1); }
  50% { transform: rotate(-162deg) scaleX(1.04); }
  100% { transform: rotate(-342deg) scaleX(1); }
}

@keyframes ai-mark-breathe {
  0%, 100% {
    transform: rotate(-4deg) scale(1);
    box-shadow: 0 16rpx 30rpx rgba(59, 115, 255, 0.24), inset 0 2rpx 0 rgba(255, 255, 255, 0.28);
  }
  50% {
    transform: rotate(-2deg) scale(1.035);
    box-shadow: 0 20rpx 38rpx rgba(59, 115, 255, 0.32), inset 0 2rpx 0 rgba(255, 255, 255, 0.34);
  }
}

@keyframes ai-spark-one {
  0%, 100% { opacity: 0.38; transform: translate3d(0, 0, 0) scale(0.8); }
  45% { opacity: 1; transform: translate3d(-5rpx, -4rpx, 0) scale(1.12); }
}

@keyframes ai-spark-two {
  0%, 100% { opacity: 0.34; transform: translate3d(0, 0, 0) scale(0.78); }
  55% { opacity: 0.95; transform: translate3d(5rpx, 4rpx, 0) scale(1.08); }
}

.tabbar-panel {
  width: calc(100vw - 64rpx);
  max-width: 686rpx;
  min-height: 112rpx;
  padding: 10rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1.5rpx solid rgba(226, 232, 240, 0.8);
  box-shadow:
    0 16rpx 38rpx rgba(15, 23, 42, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
  pointer-events: auto;
}

.tabbar-item {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 94rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  transition: background 0.08s ease;
}

.tabbar-item.is-active {
  background: linear-gradient(180deg, rgba(43, 92, 230, 0.1) 0%, rgba(43, 92, 230, 0.055) 100%);
}

.tabbar-icon-wrap {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 5rpx;
}

.tabbar-item.is-active .tabbar-icon-wrap {
  background: transparent;
}

.tabbar-icon {
  width: 42rpx;
  height: 42rpx;
  display: block;
}

.tabbar-text {
  max-width: 100%;
  color: #6B7280;
  font-size: 21rpx;
  line-height: 25rpx;
  font-weight: 600;
  text-align: center;
  white-space: nowrap;
}

.tabbar-item.is-active .tabbar-text {
  color: #2B5CE6;
  font-weight: 800;
}

.tabbar-badge {
  position: absolute;
  top: -10rpx;
  right: -18rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #EF4444;
  border: 3rpx solid rgba(255, 255, 255, 0.92);
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(239, 68, 68, 0.3);
}
