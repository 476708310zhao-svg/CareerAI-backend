<view class="custom-tabbar">
  <view
    class="ai-float"
    catchtap="goAiAssistant"
    hover-class="ai-float-hover"
    aria-role="button"
    aria-label="AI求职助手"
  >
    <view class="ai-float-core">
      <view class="ai-float-glow"></view>
      <view class="ai-float-orbit orbit-a"></view>
      <view class="ai-float-orbit orbit-b"></view>
      <view class="ai-float-spark spark-one"></view>
      <view class="ai-float-spark spark-two"></view>
      <view class="ai-float-mark">
        <text class="ai-float-text">AI</text>
      </view>
    </view>
  </view>
  <view class="tabbar-panel">
    <block wx:for="{{list}}" wx:key="pagePath">
      <view
        class="tabbar-item {{selected === index ? 'is-active' : ''}}"
        catchtap="switchTab"
        data-index="{{index}}"
        hover-class="tabbar-item-hover"
      >
        <view class="tabbar-icon-wrap">
          <image
            class="tabbar-icon"
            src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
            mode="aspectFit"
          />
          <view wx:if="{{item.showBadge && unreadCount > 0}}" class="tabbar-badge">{{badgeText}}</view>
        </view>
        <text class="tabbar-text">{{item.text}}</text>
      </view>
    </block>
  </view>
</view>
