/* pages/career-planner/career-planner.wxss */
page {
  --bg-page: #f6f8fc;
  --panel: #ffffff;
  --panel-soft: #f8fbff;
  --text-main: #101828;
  --text-body: #344054;
  --text-muted: #667085;
  --text-light: #98a2b3;
  --brand: #2563eb;
  --teal: #14b8a6;
  --green: #039855;
  --orange: #f97316;
  --purple: #7c3aed;
  --danger: #ef4444;
  --border: rgba(16, 24, 40, 0.08);
  --shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.07);
  overflow-x: hidden;
  background:
    radial-gradient(circle at 16% -6%, rgba(37, 99, 235, 0.12), transparent 34%),
    radial-gradient(circle at 92% 8%, rgba(20, 184, 166, 0.10), transparent 30%),
    var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.page {
  min-height: 100vh;
  overflow-x: hidden;
  background: transparent;
}

.input-page {
  padding: 16rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.hub-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 190rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  color: #ffffff;
  background:
    radial-gradient(circle at 88% 12%, rgba(255,255,255,0.28), transparent 34%),
    linear-gradient(135deg, #183b8f 0%, #2563eb 58%, #14b8a6 130%);
  box-shadow: 0 22rpx 48rpx rgba(37, 99, 235, 0.20);
}

.hub-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hub-kicker {
  color: rgba(255,255,255,0.72);
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 900;
  letter-spacing: 0;
}

.hub-title {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.16;
  font-weight: 950;
  letter-spacing: 0;
}

.hub-sub {
  margin-top: 12rpx;
  color: rgba(255,255,255,0.82);
  font-size: 25rpx;
  line-height: 1.5;
}

.hub-count {
  width: 118rpx;
  height: 118rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(255,255,255,0.16);
  border: 1rpx solid rgba(255,255,255,0.28);
}

.hub-count-num {
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 950;
}

.hub-count-label {
  margin-top: 8rpx;
  color: rgba(255,255,255,0.76);
  font-size: 18rpx;
  line-height: 1;
  font-weight: 900;
}

.section-head,
.planner-head,
.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-head {
  margin: 28rpx 2rpx 16rpx;
}

.section-title {
  display: block;
  color: var(--text-main);
  font-size: 32rpx;
  line-height: 1.22;
  font-weight: 950;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.45;
}

.section-chip {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #175cd3;
  background: #eef4ff;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 900;
}

.ai-chip {
  color: #027a48;
  background: #ecfdf3;
  border-color: rgba(2, 122, 72, 0.12);
}

.tool-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.tool-card {
  width: calc(50% - 8rpx);
  min-height: 176rpx;
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid var(--border);
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.055);
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.tool-card:nth-child(odd) {
  margin-right: 16rpx;
}

.tool-card:active,
.card-hover {
  transform: scale(0.985);
  opacity: 0.86;
}

.tool-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.tool-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: var(--brand);
  font-size: 18rpx;
  line-height: 1;
  font-weight: 950;
}

.tool-arrow {
  color: #98a2b3;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 500;
}

.tool-title {
  display: block;
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.28;
  font-weight: 950;
}

.tool-desc {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.42;
  overflow: hidden;
}

.tool-card.indigo .tool-icon { background: #4f46e5; }
.tool-card.cyan .tool-icon { background: #0891b2; }
.tool-card.green .tool-icon { background: #039855; }
.tool-card.orange .tool-icon { background: #f97316; }
.tool-card.purple .tool-icon { background: #7c3aed; }
.tool-card.slate .tool-icon { background: #344054; }
.tool-card.teal .tool-icon { background: #0f766e; }

.planner-panel,
.history-section,
.sec-card,
.result-header,
.loading-card {
  background: rgba(255,255,255,0.96);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
}

.planner-panel {
  padding: 28rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
}

.planner-head-copy {
  flex: 1;
  min-width: 0;
}

.status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 22rpx;
}

.status-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #175cd3;
  background: #eef4ff;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 850;
}

.status-pill.warm {
  color: #b45309;
  background: #fff7ed;
}

.field {
  margin-top: 24rpx;
}

.field-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 12rpx;
}

.field-label {
  color: var(--text-main);
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 900;
}

.required {
  color: var(--danger);
}

.optional,
.char-count {
  color: var(--text-light);
  font-size: 22rpx;
  font-weight: 600;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  color: var(--text-main);
  background: var(--panel-soft);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  border-radius: 22rpx;
  font-size: 27rpx;
  line-height: 1.55;
}

.field-input {
  height: 84rpx;
  padding: 0 22rpx;
}

.field-textarea {
  min-height: 156rpx;
  padding: 20rpx 22rpx;
}

.gen-btn {
  width: 100%;
  margin-top: 28rpx;
  --btn-height: 86rpx;
  --btn-font-size: 28rpx;
  --brand: #2563eb;
  --brand-dark: #175cd3;
  --brand-shadow: rgba(37, 99, 235, 0.22);
}

.history-section {
  margin-top: 24rpx;
  border-radius: 30rpx;
  overflow: hidden;
}

.history-head {
  padding: 24rpx 28rpx;
}

.history-head-title {
  display: block;
  color: var(--text-main);
  font-size: 29rpx;
  line-height: 1.25;
  font-weight: 950;
}

.history-head-sub {
  display: block;
  margin-top: 6rpx;
  color: var(--text-light);
  font-size: 22rpx;
  line-height: 1.3;
}

.history-toggle-icon {
  color: #175cd3;
  font-size: 24rpx;
  font-weight: 900;
}

.history-list {
  padding: 0 18rpx 18rpx;
}

.history-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  margin-top: 12rpx;
  border-radius: 24rpx;
  background: var(--panel-soft);
  border: 1rpx solid rgba(37, 99, 235, 0.08);
}

.hc-left {
  flex: 1;
  min-width: 0;
}

.hc-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hc-position {
  flex: 1;
  min-width: 0;
  color: var(--text-main);
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hc-pill {
  flex-shrink: 0;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  color: #175cd3;
  background: #eef4ff;
  font-size: 20rpx;
  font-weight: 900;
}

.hc-meta,
.hc-preview {
  display: block;
  color: var(--text-muted);
  font-size: 23rpx;
  line-height: 1.45;
}

.hc-meta {
  margin-top: 8rpx;
}

.hc-preview {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hc-open {
  height: 56rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
  color: #175cd3;
  background: #eef4ff;
}

.hc-open-txt {
  font-size: 22rpx;
  font-weight: 900;
}

.hc-arrow {
  font-size: 30rpx;
  line-height: 1;
}

.history-clear {
  display: flex;
  justify-content: center;
  padding: 18rpx 0 2rpx;
}

.hc-clear-txt {
  color: var(--danger);
  font-size: 24rpx;
  font-weight: 800;
}

.bottom-spacer {
  height: calc(46rpx + env(safe-area-inset-bottom));
}

.loading-page {
  min-height: 82vh;
  padding: 48rpx 32rpx 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.loading-card {
  width: 100%;
  max-width: 650rpx;
  padding: 46rpx 34rpx 36rpx;
  border-radius: 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.loading-mark {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mark-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 6rpx solid rgba(37, 99, 235, 0.18);
  border-top-color: var(--brand);
  border-right-color: var(--teal);
  animation: loadingSpin 1.2s linear infinite;
}

.mark-core {
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, var(--brand), var(--teal));
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.22);
  font-size: 27rpx;
  font-weight: 950;
}

@keyframes loadingSpin {
  to { transform: rotate(360deg); }
}

.loading-eyebrow {
  margin-top: 30rpx;
  color: var(--brand);
  font-size: 21rpx;
  font-weight: 950;
}

.loading-tip {
  margin-top: 12rpx;
  color: var(--text-main);
  font-size: 34rpx;
  line-height: 1.32;
  font-weight: 950;
  text-align: center;
}

.loading-desc {
  margin-top: 14rpx;
  max-width: 540rpx;
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 1.65;
  text-align: center;
}

.loading-progress {
  width: 100%;
  height: 12rpx;
  margin-top: 30rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #eef2f7;
}

.loading-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--brand), var(--teal));
  transition: width 0.35s ease;
}

.loading-steps {
  width: 100%;
  margin-top: 26rpx;
  display: flex;
  gap: 12rpx;
}

.lstep {
  flex: 1;
  min-height: 100rpx;
  padding: 16rpx 12rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-light);
  background: #f8fafc;
  border: 1rpx solid rgba(230, 235, 242, 0.95);
  box-sizing: border-box;
}

.lstep.done {
  color: #175cd3;
  background: #eef4ff;
  border-color: rgba(37, 99, 235, 0.16);
}

.lstep-index {
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 950;
}

.lstep-title {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 900;
}

.loading-note {
  margin-top: 24rpx;
  color: var(--text-light);
  font-size: 23rpx;
  line-height: 1.4;
  text-align: center;
}

.result-page {
  padding: 18rpx 22rpx 0;
}

.result-header {
  margin-bottom: 18rpx;
  padding: 30rpx 28rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.result-header-left {
  flex: 1;
  min-width: 0;
}

.result-title {
  display: block;
  color: var(--text-main);
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 950;
}

.result-meta {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: var(--text-body);
  background: #f2f4f7;
  font-size: 24rpx;
}

.result-regen {
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #175cd3;
  background: #eef4ff;
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  flex-shrink: 0;
}

.regen-icon {
  font-size: 28rpx;
}

.regen-txt {
  font-size: 24rpx;
  font-weight: 850;
}

.sec-card {
  margin-bottom: 18rpx;
  padding: 30rpx 28rpx;
  border-radius: 30rpx;
}

.sec-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 26rpx;
}

.sec-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef4ff;
  font-size: 30rpx;
  flex-shrink: 0;
}

.sec-title {
  flex: 1;
  min-width: 0;
  color: var(--text-main);
  font-size: 34rpx;
  line-height: 1.28;
  font-weight: 950;
}

.two-col {
  display: flex;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.col-box {
  flex: 1;
  min-width: 0;
  padding: 22rpx;
  border-radius: 24rpx;
  background: var(--panel-soft);
  border: 1rpx solid rgba(37, 99, 235, 0.10);
  box-sizing: border-box;
}

.col-sep {
  display: none;
}

.col-title {
  display: block;
  margin-bottom: 14rpx;
  color: var(--text-body);
  font-size: 25rpx;
  line-height: 1.35;
  font-weight: 900;
}

.col-title.blue { color: #175cd3; }
.col-title.green { color: #027a48; }

.tag-wrap,
.pill-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag,
.pill {
  max-width: 100%;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 750;
  box-sizing: border-box;
  word-break: break-word;
}

.blue-tag,
.pill {
  color: #175cd3;
  background: #eef4ff;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
}

.green-tag {
  color: #027a48;
  background: #ecfdf3;
  border: 1rpx solid rgba(2, 122, 72, 0.12);
}

.gap-block {
  margin-top: 8rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff7ed;
  border: 1rpx solid rgba(249, 115, 22, 0.14);
  border-left: 8rpx solid var(--orange);
}

.gap-label {
  display: block;
  color: #9a3412;
  font-size: 27rpx;
  font-weight: 950;
  margin-bottom: 14rpx;
}

.gap-row {
  display: flex;
  gap: 12rpx;
  margin-top: 10rpx;
}

.gap-dot {
  color: var(--orange);
  line-height: 1.55;
}

.gap-txt {
  flex: 1;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.62;
}

.phase-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.phase-tab {
  min-width: 140rpx;
  height: 72rpx;
  padding: 0 14rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475467;
  background: #f8fafc;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  font-size: 25rpx;
  line-height: 1.15;
  font-weight: 900;
  box-sizing: border-box;
}

.phase-tab.active,
.phase-tab.milestone-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, var(--brand), var(--teal));
  border-color: transparent;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.20);
}

.phase-body {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.phase-goal {
  padding: 24rpx 24rpx 24rpx 30rpx;
  border-radius: 24rpx;
  color: var(--text-main);
  background: linear-gradient(180deg, #eef4ff, var(--panel-soft));
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  border-left: 8rpx solid var(--brand);
  font-size: 29rpx;
  line-height: 1.52;
  font-weight: 900;
}

.detail-block {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.04);
}

.db-title {
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 950;
}

.arrow-item {
  display: flex;
  gap: 12rpx;
  padding: 10rpx 0;
}

.arrow {
  color: var(--brand);
  font-size: 28rpx;
  line-height: 1.5;
}

.arrow-txt,
.db-text {
  flex: 1;
  color: #475467;
  font-size: 26rpx;
  line-height: 1.68;
}

.milestone-body {
  padding-top: 6rpx;
}

.ms-item {
  display: flex;
  min-height: 100rpx;
}

.ms-axis {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 44rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.ms-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--brand);
  border: 6rpx solid #eef4ff;
  flex-shrink: 0;
}

.ms-line {
  flex: 1;
  width: 4rpx;
  min-height: 40rpx;
  margin-top: 4rpx;
  background: linear-gradient(to bottom, var(--brand), rgba(37, 99, 235, 0.10));
}

.ms-content {
  flex: 1;
  min-width: 0;
  padding: 0 0 26rpx 18rpx;
}

.ms-header-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.ms-month {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  color: #175cd3;
  background: #eef4ff;
  font-size: 23rpx;
  font-weight: 950;
  flex-shrink: 0;
}

.ms-focus {
  flex: 1;
  min-width: 0;
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 950;
}

.ms-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ms-action-row {
  display: flex;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: #f8fafc;
}

.ms-action-dot {
  color: var(--green);
  font-size: 22rpx;
  line-height: 1.55;
}

.ms-action-txt {
  flex: 1;
  color: #475467;
  font-size: 25rpx;
  line-height: 1.62;
}

.res-group {
  margin-bottom: 24rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: var(--panel-soft);
  border: 1rpx solid rgba(37, 99, 235, 0.08);
}

.res-group:last-child {
  margin-bottom: 0;
}

.res-cat {
  display: block;
  margin-bottom: 14rpx;
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 950;
}

.res-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.res-row:last-child {
  margin-bottom: 0;
}

.res-txt {
  flex: 1;
  color: #475467;
  font-size: 25rpx;
  line-height: 1.58;
}

.res-copy {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #175cd3;
  background: #eef4ff;
  font-size: 22rpx;
  font-weight: 850;
}
