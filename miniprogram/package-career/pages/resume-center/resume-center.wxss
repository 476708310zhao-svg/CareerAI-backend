.page { min-height: 100vh; padding: 24rpx 28rpx 80rpx; background: #f5f7fb; color: #101828; box-sizing: border-box; }
.hero { padding: 38rpx; border-radius: 28rpx; color: #fff; background: linear-gradient(135deg,#111827,#1d4ed8); box-shadow: 0 20rpx 50rpx rgba(29,78,216,.2); }
.eyebrow { display:block; font-size:20rpx; letter-spacing:3rpx; opacity:.7; }.title{display:block;font-size:48rpx;font-weight:800;margin-top:12rpx}.subtitle{display:block;font-size:26rpx;line-height:1.7;opacity:.82;margin-top:12rpx}
.hero-actions,.sheet-actions{display:flex;gap:18rpx;margin-top:28rpx;align-items:center}.primary,.secondary{padding:20rpx 28rpx;border-radius:16rpx;font-size:26rpx;font-weight:700}.primary{background:#2563eb;color:#fff}.hero .primary{background:#fff;color:#1d4ed8}.secondary{border:1rpx solid rgba(255,255,255,.3)}
.tabs{display:flex;background:#fff;border-radius:18rpx;padding:8rpx;margin:28rpx 0 18rpx}.tab{flex:1;text-align:center;padding:18rpx 8rpx;color:#667085;font-size:26rpx}.tab.active{background:#eef4ff;color:#1d4ed8;border-radius:14rpx;font-weight:700}
.card,.version-card{display:flex;align-items:center;gap:20rpx;background:#fff;border:2rpx solid transparent;border-radius:22rpx;padding:26rpx;margin-bottom:16rpx}.card.selected{border-color:#93b4ff}.card-main{flex:1;min-width:0}.card-title{font-size:30rpx;font-weight:750}.meta{display:block;color:#98a2b3;font-size:23rpx;margin-top:10rpx}.badge,.type{display:inline-block;margin-left:12rpx;padding:5rpx 12rpx;border-radius:999rpx;background:#eef4ff;color:#2563eb;font-size:20rpx}.type{margin:0 12rpx 8rpx 0}.more{padding:20rpx;color:#667085}.archive,.restore{font-size:24rpx;color:#2563eb}.optimize{margin:24rpx 0;padding:26rpx;text-align:center;border-radius:18rpx;background:#101828;color:#fff;font-weight:700}.empty{text-align:center;color:#98a2b3;padding:100rpx 20rpx}
.mask{position:fixed;inset:0;background:rgba(16,24,40,.5);z-index:20}.sheet{position:fixed;z-index:21;left:0;right:0;bottom:0;background:#fff;border-radius:32rpx 32rpx 0 0;padding:32rpx;max-height:82vh}.sheet-title{display:block;font-size:34rpx;font-weight:800}.sheet-note{display:block;color:#98a2b3;font-size:22rpx;margin-top:8rpx}.suggestions{height:52vh;margin-top:20rpx}.suggestion{padding:22rpx;background:#f8fafc;border-radius:18rpx;margin-bottom:16rpx}.reason,.before,.after{display:block;font-size:25rpx;line-height:1.6}.reason{font-weight:700}.before{color:#667085;margin-top:12rpx}.after{color:#1d4ed8;margin-top:8rpx}.decision{margin-top:14rpx;padding:14rpx;text-align:center;border-radius:12rpx;background:#fee2e2;color:#b42318}.decision.accepted{background:#dcfae6;color:#067647}.sheet-actions{justify-content:flex-end}.manual-switch{margin:18rpx 0;padding:18rpx;text-align:center;border-radius:14rpx;background:#eef4ff;color:#1d4ed8;font-size:24rpx}.manual-editor{box-sizing:border-box;width:100%;height:420rpx;padding:20rpx;border-radius:14rpx;background:#101828;color:#e5e7eb;font-family:monospace;font-size:22rpx}
.dialog{position:fixed;z-index:21;left:40rpx;right:40rpx;top:50%;transform:translateY(-50%);background:#fff;border-radius:28rpx;padding:34rpx}.input,.textarea{box-sizing:border-box;width:100%;background:#f5f7fb;border-radius:14rpx;padding:22rpx;margin-top:20rpx;font-size:26rpx}.textarea{height:180rpx}.wide{text-align:center;margin-top:24rpx}
