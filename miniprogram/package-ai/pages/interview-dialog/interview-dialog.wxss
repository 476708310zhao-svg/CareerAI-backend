.score-bar-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
}

.score-stars {
  margin-top: 16rpx;
  display: flex;
  gap: 8rpx;
}

.star {
  color: #cbd5e1;
  font-size: 28rpx;
}

.star.lit {
  color: #f59e0b;
}

.section-body {
  margin-top: 16rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.7;
}

.record-card {
  margin-top: 20rpx;
  margin-bottom: 0;
  padding: 22rpx;
  border: 1rpx solid #edf2f7;
  border-radius: 22rpx;
  background: #f8fafc;
}

.record-card + .record-card {
  margin-top: 18rpx;
}

.record-row {
  margin-bottom: 14rpx;
  display: flex;
  align-items: flex-start;
}

.label {
  min-width: 42rpx;
  margin-top: 2rpx;
  margin-right: 14rpx;
  padding: 5rpx 0;
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
}

.q-label {
  background: #2563eb;
}

.a-label {
  background: #14b8a6;
}

.f-label {
  background: #f59e0b;
}

.text-content {
  flex: 1;
  min-width: 0;
  color: #334155;
  font-size: 27rpx;
  line-height: 1.62;
}

.strong {
  color: #101828;
  font-weight: 900;
}

.feedback-box {
  margin-top: 6rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fff7ed;
}

.feedback-text {
  color: #92400e;
  font-size: 26rpx;
}

.modal-footer {
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(226, 232, 240, 0.9);
}
