/* pages/interview-dialog/interview-dialog.wxss */
page {
  height: 100vh;
  background-color: #ededed; /* 微信聊天背景灰 */
  display: flex;
  flex-direction: column;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* --- 1. 聊天列表 --- */
.chat-list {
  flex: 1;
  width: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.padding-top { height: 20rpx; }
.padding-bottom { height: 40rpx; }

/* 消息组通用 */
.message-group {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.content-wrapper {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.bubble {
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
  position: relative;
}

/* AI 样式 */
.ai-group { flex-direction: row; }
.ai-avatar { background-color: #fff; margin-right: 20rpx; }
.ai-bubble { background-color: #fff; color: #333; border: 1rpx solid #e0e0e0; }
/* 小三角 */
.ai-bubble::before {
  content: ''; position: absolute; left: -12rpx; top: 30rpx;
  border-top: 12rpx solid transparent; border-bottom: 12rpx solid transparent;
  border-right: 12rpx solid #fff;
}

/* 用户 样式 */
.user-group { flex-direction: row; justify-content: flex-end; }
.user-avatar { background-color: #95ec69; margin-left: 20rpx; font-size: 28rpx; color: #000; font-weight: bold;}
.user-bubble { background-color: #95ec69; color: #000; }
/* 小三角 */
.user-bubble::before {
  content: ''; position: absolute; right: -12rpx; top: 30rpx;
  border-top: 12rpx solid transparent; border-bottom: 12rpx solid transparent;
  border-left: 12rpx solid #95ec69;
}

/* 系统消息 */
.system-message {
  text-align: center;
  margin: 40rpx 0;
  color: #888;
  font-size: 26rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.check-report-btn {
  margin-top: 20rpx;
  background-color: #fff;
  color: #576b95;
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
  border: 1rpx solid #e0e0e0;
}

/* Loading 动画 */
.loading-wrap { display: flex; justify-content: flex-start; padding-left: 100rpx; margin-bottom: 20rpx; }
.loading-dots { display: flex; gap: 8rpx; background: #fff; padding: 15rpx 20rpx; border-radius: 10rpx; }
.dot { width: 12rpx; height: 12rpx; background: #ccc; border-radius: 50%; animation: blink 1.4s infinite both; }
.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes blink { 0%, 80%, 100% { opacity: 0; } 40% { opacity: 1; } }

/* 底部栏：改为底部对齐，这样输入框变高时，按钮会停留在底部 */
.footer-bar {
  background-color: #f7f7f7;
  padding: 20rpx;
  /* ⚠️ 关键：适配 iPhone X 等底部安全区 */
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: flex-end; /* ⚠️ 关键：让按钮和输入框底部对齐 */
  border-top: 1rpx solid #dcdcdc;
  min-height: 100rpx;
  box-sizing: content-box; /* 防止高度计算塌陷 */
}

/* 输入框样式调整 */
.input-box {
  flex: 1;
  background-color: #fff;
  border-radius: 10rpx; /* 改为圆角矩形，更适合多行文本 */
  padding: 20rpx;       /* 增加内边距 */
  font-size: 30rpx;
  margin-right: 20rpx;

  /* ⚠️ 关键：设置最小高度和最大高度 */
  min-height: 40rpx;
  max-height: 200rpx;   /* 超过这个高度后，输入框内部滚动 */
  width: auto;          /* 修复 textarea 宽度问题 */
  line-height: 1.4;
}

/* 发送按钮微调 */
.send-btn {
  background-color: #07c160;
  color: #fff;
  padding: 0 30rpx;
  height: 76rpx;       /* 保持按钮高度固定 */
  line-height: 76rpx;
  border-radius: 10rpx;
  font-size: 30rpx;
  font-weight: bold;
  flex-shrink: 0;      /* 防止按钮被挤压 */
  margin-bottom: 2rpx; /* 微调对齐 */
}
.send-btn.disabled { background-color: #b2e2c3; color: #e9fdf0; }

.finished-bar { display: flex; width: 100%; justify-content: space-around; }
.action-btn { width: 45%; font-size: 30rpx; border-radius: 10rpx; }
.restart { background: #fff; color: #333; }
.report { background: #07c160; color: #fff; }

/* --- 3. 报告弹窗 (修复滚动问题) --- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: flex-end; /* 从底部弹出 */

  /* 防止点击穿透滚动背景 */
  touch-action: none;
}

.modal-content {
  width: 100%;
  height: 85vh; /* 弹窗高度占屏幕 85% */
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;

  /* ✅ 关键布局：让头部和底部固定，中间自适应 */
  display: flex;
  flex-direction: column;
  overflow: hidden; /* 防止外层溢出 */
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
  position: relative;
  flex-shrink: 0; /* 防止头部被压缩 */
}
.modal-title { font-size: 34rpx; font-weight: bold; }
.close-icon { position: absolute; right: 30rpx; top: 30rpx; font-size: 40rpx; color: #999; padding: 0 20rpx; }

/* ✅ 关键修复：滚动区域 */
.report-scroll {
  flex: 1;            /* 占据剩余所有空间 */
  height: 0;          /* ⚠️ 必须设为0，配合 flex:1 才能触发内部滚动 */
  background: #f5f5f5;
  width: 100%;
}

/* 内部 padding 转移到 view 上，不要直接加在 scroll-view 上 */
.report-inner {
  padding: 20rpx;
  box-sizing: border-box;
  padding-bottom: 50rpx; /* 底部多留点白 */
}

.report-section { background: #fff; padding: 30rpx; border-radius: 16rpx; margin-bottom: 30rpx; }
.section-head { font-size: 32rpx; font-weight: bold; margin-bottom: 20rpx; color: #333; border-left: 8rpx solid #07c160; padding-left: 16rpx; }

.record-card { margin-bottom: 30rpx; border-bottom: 1rpx dashed #eee; padding-bottom: 30rpx; }
.record-card:last-child { border-bottom: none; }

.record-row { display: flex; margin-bottom: 12rpx; align-items: flex-start; }
.label { font-size: 22rpx; color: #fff; padding: 4rpx 10rpx; border-radius: 6rpx; margin-right: 15rpx; margin-top: 6rpx; flex-shrink: 0;}
.q-label { background: #ff9c6e; }
.a-label { background: #69c0ff; }
.f-label { background: #ffc069; }

.text-content { font-size: 28rpx; color: #333; line-height: 1.5; }
.strong { font-weight: bold; }
.feedback-box { background: #fffbe6; padding: 15rpx; border-radius: 8rpx; }
.feedback-text { color: #8a6d3b; font-size: 26rpx; }

.modal-footer {
  padding: 20rpx;
  border-top: 1rpx solid #eee;
  background: #fff;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  flex-shrink: 0; /* 防止底部被压缩 */
}
.close-btn { background: #f2f2f2; color: #666; width: 100%; border-radius: 10rpx; }
/* Unified homepage background */
