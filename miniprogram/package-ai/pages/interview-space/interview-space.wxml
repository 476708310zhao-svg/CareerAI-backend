<view class="page"><c-ai-disclosure text="模拟评分用于训练反馈，不代表真实招聘结果。" />
<view wx:if="{{!current}}"><view class="hero"><text class="title">岗位专属面试空间</text><text class="sub">申请进入面试状态后自动创建</text></view><view wx:for="{{spaces}}" wx:key="id" class="space" data-id="{{item.id}}" bindtap="selectSpace"><view><text class="name">{{item.company}} · {{item.jobTitle}}</text><text class="meta">{{item.round}} · {{item.interviewTime||'待安排'}}</text></view><text class="progress">{{item.preparationCompletion}}%</text></view>
<text class="section">能力趋势</text><view wx:for="{{trends}}" wx:key="date" class="trend"><text>{{item.date}}</text><text>{{item.overallScore}} 分</text></view><text class="section">Today 补强任务</text><view wx:for="{{tasks}}" wx:key="id" class="task" data-id="{{item.id}}" bindtap="toggleTask"><text>{{item.title}}</text><text>{{item.status}}</text></view></view>
<view wx:else><view class="back" bindtap="backList">← 返回空间列表</view><view class="hero"><text class="title">{{current.company}}</text><text class="sub">{{current.jobTitle}} · {{current.round}} · 准备 {{current.preparationCompletion}}%</text></view>
<view class="grid"><view><text>{{current.companyExperiences.length}}</text><text>历史面经</text></view><view><text>{{current.frequentQuestions.length}}</text><text>高频题</text></view><view><text>{{current.algorithmQuestions.length}}</text><text>算法题</text></view><view><text>{{current.behaviorQuestions.length}}</text><text>行为题</text></view></view>
<view wx:if="{{!session&&!report}}" class="actions"><view bindtap="startMock">开始模拟面试</view><view bindtap="startStar">STAR 案例训练</view></view>
<view wx:if="{{session}}" class="practice"><textarea class="question" value="{{question}}" bindinput="onQuestion"/><textarea class="answer" placeholder="输入你的回答" value="{{answer}}" bindinput="onAnswer"/><view class="submit" bindtap="submitAnswer">提交单题</view><view wx:if="{{feedback}}" class="feedback"><text>内容 {{feedback.content}} · 结构 {{feedback.structure}} · 表达 {{feedback.expression}} · 匹配 {{feedback.jobMatch}}</text><text>{{feedback.feedback}}</text><view bindtap="complete">完成并生成报告</view></view></view>
<view wx:if="{{report}}" class="report"><text class="score">{{report.overallScore}}</text><text>{{report.summary}}</text><view wx:for="{{report.weaknesses}}" wx:key="key">短板：{{item.name}} {{item.score}} 分</view></view></view></view>
