.page{min-height:100vh;background:#f5f7fb;padding:24rpx 28rpx 80rpx;box-sizing:border-box;color:#101828}.hero{padding:34rpx;border-radius:26rpx;background:#101828;color:#fff}.title{display:block;font-size:42rpx;font-weight:800}.sub{display:block;opacity:.75;margin-top:10rpx}.space,.task,.trend{display:flex;justify-content:space-between;align-items:center;background:#fff;border-radius:20rpx;padding:24rpx;margin-top:16rpx}.name{display:block;font-weight:750}.meta{display:block;color:#98a2b3;font-size:22rpx;margin-top:8rpx}.progress{font-size:34rpx;color:#4338ca;font-weight:800}.section{display:block;margin:30rpx 0 10rpx;font-size:30rpx;font-weight:800}.back{margin-bottom:20rpx;color:#4338ca}.grid{display:grid;grid-template-columns:1fr 1fr;gap:14rpx;margin:20rpx 0}.grid view{display:flex;flex-direction:column;padding:24rpx;background:#fff;border-radius:18rpx}.grid view text:first-child{font-size:34rpx;font-weight:800}.actions{display:flex;gap:16rpx}.actions view,.submit{flex:1;text-align:center;padding:22rpx;border-radius:16rpx;background:#4338ca;color:#fff}.practice,.report{margin-top:22rpx;padding:24rpx;border-radius:22rpx;background:#fff}.question,.answer{box-sizing:border-box;width:100%;padding:18rpx;border-radius:14rpx;background:#f5f7fb}.question{height:120rpx}.answer{height:260rpx;margin:14rpx 0}.feedback{display:flex;flex-direction:column;gap:12rpx;margin-top:18rpx;color:#344054}.score{display:block;font-size:72rpx;font-weight:900;color:#4338ca}
