/* pages/ai-history/ai-history.wxss — White-based premium redesign */
page {
  background: var(--bg-page);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container {
  min-height: 100vh;
  padding: 0 24rpx 48rpx;
}

/* ─── Top Action Bar — clean white strip ──────────────────────── */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0 20rpx;
  border-bottom: 1.5rpx solid #F1F5F9;
  margin-bottom: 8rpx;
}

.record-count {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.clear-btn {
  font-size: 24rpx;
  color: #EF4444;
  background: #FEF2F2;
  padding: 8rpx 22rpx;
  border-radius: var(--r-lg);
  border: 1.5rpx solid #FECACA;
  font-weight: 500;
}

/* ─── Loading ──────────────────────────────────────────────────── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 20rpx;
}

.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border: 5rpx solid var(--border-light);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* ─── Record Card ─────────────────────────────────────────────── */
.record-card {
  background: var(--bg-panel);
  border-radius: var(--r-lg);
  padding: 24rpx 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  overflow: hidden;
  transition: transform 0.12s;
}

.record-card:active {
  transform: scale(0.984);
  background: #FAFBFF;
}

/* ─── Card Header ─────────────────────────────────────────────── */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.job-role {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 5rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.company-name {
  font-size: 25rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 5rpx;
}

.time {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* ─── Score Badge ─────────────────────────────────────────────── */
.score-badge {
  display: flex;
  align-items: baseline;
  padding: 10rpx 20rpx;
  border-radius: var(--r-md);
  flex-shrink: 0;
  margin-left: 20rpx;
}

.score-badge.high { color: #059669; background: #ECFDF5; }
.score-badge.mid  { color: #F59E0B; background: #FFFBEB; }
.score-badge.low  { color: #EF4444; background: #FEF2F2; }
.score-badge.none { color: var(--text-muted); background: var(--bg-page); }

.score-num {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.score-unit {
  font-size: 22rpx;
  margin-left: 4rpx;
  font-weight: 600;
}

/* ─── Tags Row ────────────────────────────────────────────────── */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg-page);
  padding: 5rpx 14rpx;
  border-radius: 8rpx;
}

.record-review-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 0 0 18rpx;
}

.record-review-item {
  min-width: 168rpx;
  padding: 12rpx 14rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #eef2f7;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.record-review-item.next {
  flex: 1;
  min-width: 260rpx;
  background: #eef4ff;
  border-color: rgba(37, 99, 235, 0.14);
}

.review-label,
.review-value {
  display: block;
}

.review-label {
  color: #98a2b3;
  font-size: 20rpx;
  line-height: 1.25;
  font-weight: 800;
}

.review-value {
  margin-top: 6rpx;
  color: #111827;
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ─── Card Footer ─────────────────────────────────────────────── */
.card-footer {
  border-top: 1.5rpx solid #F1F5F9;
  padding-top: 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.duration {
  font-size: 23rpx;
  color: var(--text-muted);
}

.btn {
  font-size: 26rpx;
  color: var(--brand);
  font-weight: 700;
  background: #EEF2FF;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}


/* ── 页面 Tab 切换 ───────────────────────────── */
.page-tabs {
  display: flex;
  background: var(--bg-panel);
  border-bottom: 1rpx solid #EFEFEF;
  margin-bottom: 4rpx;
}
.ptab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.ptab.active {
  color: var(--brand);
  font-weight: bold;
}
.ptab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: var(--brand);
  border-radius: 3rpx;
}
.ptab-badge {
  background: #EF4444;
  color: #fff;
  font-size: 18rpx;
  font-weight: bold;
  padding: 2rpx 10rpx;
  border-radius: var(--r-lg);
  min-width: 32rpx;
  text-align: center;
}

/* ── 错题本卡片 ───────────────────────────────── */
.bq-card {
  background: var(--bg-panel);
  border-radius: var(--r-md);
  margin: 0 24rpx 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.bq-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}
.bq-source {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: #F3F4F6;
  padding: 4rpx 14rpx;
  border-radius: var(--r-lg);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bq-score-badge {
  font-size: 22rpx;
  font-weight: bold;
  padding: 4rpx 14rpx;
  border-radius: var(--r-lg);
  flex-shrink: 0;
}
.bq-score-badge.high { background: #f6ffed; color: #52c41a; }
.bq-score-badge.mid  { background: #fffbe6; color: #faad14; }
.bq-score-badge.low  { background: #fff2f0; color: #f5222d; }
.bq-del {
  font-size: 36rpx;
  color: var(--text-muted);
  flex-shrink: 0;
  padding: 0 8rpx;
  line-height: 1;
}
.bq-q {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  line-height: 1.5;
  display: block;
  margin-bottom: 16rpx;
}
.bq-section {
  background: #F9FAFB;
  border-radius: 10rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}
.bq-fb-section {
  background: #FFFBE6;
  margin-bottom: 0;
}
.bq-label {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 6rpx;
}
.bq-fb-section .bq-label {
  color: #fa8c16;
  font-weight: bold;
}
.bq-a {
  font-size: 26rpx;
  color: var(--text-body);
  line-height: 1.6;
}
.bq-fb {
  font-size: 26rpx;
  color: #d48806;
  line-height: 1.6;
}
.bq-empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* ── 复习计划 ─────────────────────────────────────── */
.review-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFFBEB;
  border: 1.5rpx solid #FCD34D;
  border-radius: var(--r-md);
  margin: 16rpx 0 8rpx;
  padding: 20rpx 24rpx;
}

.review-banner-icon {
  font-size: 36rpx;
  line-height: 1;
  flex-shrink: 0;
}

.review-banner-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.review-banner-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #92400E;
}

.review-banner-desc {
  font-size: 22rpx;
  color: #B45309;
}

.bq-card.bq-due {
  border: 1.5rpx solid #FCD34D;
  box-shadow: 0 2rpx 12rpx rgba(245, 158, 11, 0.15);
}

.bq-review-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1.5rpx solid #F1F5F9;
}

.bq-due-tag {
  font-size: 22rpx;
  font-weight: 700;
  color: #D97706;
  background: #FEF3C7;
  padding: 4rpx 16rpx;
  border-radius: var(--r-lg);
  border: 1rpx solid #FCD34D;
}

.bq-next-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

.bq-review-btn {
  font-size: 22rpx;
  font-weight: 600;
  color: #059669;
  background: #ECFDF5;
  border: 1.5rpx solid #A7F3D0;
  padding: 6rpx 20rpx;
  border-radius: var(--r-lg);
}
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Profile entry page polish */
.container {
  padding: 18rpx 24rpx 48rpx;
}

.history-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 4rpx 0 16rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 58%, #ecfffb 100%);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.08);
}

.hero-kicker,
.hero-title,
.hero-sub,
.score-main,
.score-label,
.stat-num,
.stat-label,
.empty-title,
.empty-desc {
  display: block;
}

.hero-kicker {
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 8rpx;
  color: #101828;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 950;
}

.hero-sub {
  width: 430rpx;
  max-width: 100%;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.hero-score {
  width: 122rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(145deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 18rpx 34rpx rgba(37,99,235,0.22);
  flex-shrink: 0;
}

.score-main {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 950;
}

.score-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 800;
  opacity: 0.88;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.stat-card {
  min-height: 106rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.055);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-num {
  color: #111827;
  font-size: 32rpx;
  font-weight: 950;
}

.stat-label {
  margin-top: 8rpx;
  color: #718096;
  font-size: 22rpx;
  font-weight: 800;
}

.page-tabs {
  margin: 0 0 16rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.ptab {
  border-radius: 18rpx;
  color: #64748b;
  font-weight: 850;
}

.ptab.active {
  color: #1d4ed8;
  background: #eef4ff;
}

.ptab.active::after {
  display: none;
}

.ptab-badge {
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #fff;
  font-size: 18rpx;
  line-height: 30rpx;
  font-weight: 900;
}

.ptab-badge.soft {
  color: #2563eb;
  background: #dbeafe;
}

.top-bar {
  padding: 18rpx 0;
  border-bottom: 0;
}

.record-card,
.bq-card,
.review-banner {
  border-radius: 24rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.record-card,
.bq-card {
  margin-left: 0;
  margin-right: 0;
}

.job-role,
.bq-title {
  color: #111827;
  font-weight: 900;
}

.company-name,
.time,
.duration {
  color: #667085;
}

.score-badge.high,
.bq-score-badge.high {
  color: #047857;
  background: #ecfdf5;
}

.btn {
  color: #2563eb;
  background: #eef4ff;
}

.history-empty {
  margin: 72rpx 0 0;
  padding: 76rpx 36rpx 38rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 18rpx 42rpx rgba(32,48,70,0.07);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f7ff;
  font-size: 52rpx;
  box-shadow: inset 0 0 0 1rpx rgba(37,99,235,0.08);
}

.empty-title {
  margin-top: 24rpx;
  color: #111827;
  font-size: 31rpx;
  font-weight: 950;
}

.empty-desc {
  width: 540rpx;
  max-width: 100%;
  margin-top: 14rpx;
  color: #718096;
  font-size: 25rpx;
  line-height: 1.62;
  text-align: center;
}

.empty-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 34rpx;
}

.empty-primary,
.empty-secondary {
  min-width: 176rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
}

.empty-primary {
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #18b6b0 100%);
  box-shadow: 0 12rpx 26rpx rgba(37,99,235,0.22);
}

.empty-secondary {
  color: #2563eb;
  background: #f3f7ff;
  border: 1rpx solid rgba(37,99,235,0.12);
}

.empty-tips {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 34rpx;
}

.tip-item {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #667085;
  background: #f8fbff;
  font-size: 22rpx;
  font-weight: 750;
}

.audio-review-entry {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 0 0 18rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.audio-entry-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f7ff;
  font-size: 38rpx;
  flex-shrink: 0;
}

.audio-entry-copy {
  flex: 1;
  min-width: 0;
}

.audio-entry-title,
.audio-entry-desc {
  display: block;
}

.audio-entry-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 900;
}

.audio-entry-desc {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
}

.audio-entry-btn {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #18b6b0);
  font-size: 23rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.audio-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.96);
  border: 1rpx solid rgba(220,229,240,0.96);
  box-shadow: 0 12rpx 30rpx rgba(32,48,70,0.06);
}

.audio-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.audio-card-title,
.audio-card-date,
.audio-summary {
  display: block;
}

.audio-card-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.audio-card-date {
  margin-top: 6rpx;
  color: #98a2b3;
  font-size: 22rpx;
  font-weight: 700;
}

.audio-score {
  min-width: 66rpx;
  height: 58rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 950;
  flex-shrink: 0;
}

.audio-score.high { color: #047857; background: #ecfdf5; }
.audio-score.mid { color: #b45309; background: #fffbeb; }
.audio-score.low { color: #dc2626; background: #fef2f2; }

.audio-summary {
  margin-top: 16rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}

.audio-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.audio-metrics text {
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  color: #2563eb;
  background: #eef4ff;
  font-size: 21rpx;
  font-weight: 850;
}
