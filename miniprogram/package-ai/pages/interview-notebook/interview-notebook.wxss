page {
  background: #f6f8fc;
  color: #101828;
}

.page {
  min-height: 100vh;
  padding: 22rpx 24rpx 0;
  box-sizing: border-box;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 12rpx;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffffff, #f0fdfa);
  border: 1rpx solid #e6ebf2;
  box-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.06);
}

.hero-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.kicker {
  color: #0f766e;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 900;
}

.title {
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 950;
}

.subtitle {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
  font-weight: 650;
}

.hero-stat {
  width: 122rpx;
  height: 122rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.20);
}

.hero-num {
  font-size: 40rpx;
  line-height: 1;
  font-weight: 950;
}

.hero-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.stat-card {
  min-height: 94rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid #e6ebf2;
}

.stat-card.warn {
  background: #fff7ed;
  border-color: #fed7aa;
}

.stat-card.ok {
  background: #ecfdf3;
  border-color: #abefc6;
}

.stat-num {
  color: #101828;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 950;
}

.stat-label {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 750;
}

.search-bar {
  margin-top: 18rpx;
  height: 78rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #e6ebf2;
}

.search-input {
  flex: 1;
  height: 78rpx;
  color: #101828;
  font-size: 26rpx;
}

.search-clear {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  background: #f1f5f9;
  font-size: 34rpx;
  line-height: 1;
}

.tab-scroll {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.tab-row {
  display: flex;
  gap: 12rpx;
  padding-bottom: 6rpx;
}

.tab {
  min-width: 140rpx;
  height: 62rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #475467;
  background: #ffffff;
  border: 1rpx solid #e6ebf2;
  font-size: 23rpx;
  font-weight: 850;
}

.tab.active {
  color: #175cd3;
  background: #eef4ff;
  border-color: rgba(37, 99, 235, 0.24);
}

.tab-count {
  color: inherit;
  opacity: 0.72;
  font-size: 20rpx;
}

.question-card,
.empty-card {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf2;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.045);
}

.question-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.question-tags {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  color: #344054;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 850;
}

.tag.unknown {
  color: #b42318;
  background: #fff1f0;
  border-color: #fecdca;
}

.tag.mastered {
  color: #067647;
  background: #ecfdf3;
  border-color: #abefc6;
}

.tag.daily {
  color: #175cd3;
  background: #eef4ff;
  border-color: #b2ccff;
}

.tag.soft {
  color: #64748b;
}

.question-date {
  flex-shrink: 0;
  color: #98a2b3;
  font-size: 21rpx;
  font-weight: 750;
}

.question-title {
  display: block;
  margin-top: 18rpx;
  color: #101828;
  font-size: 31rpx;
  line-height: 1.45;
  font-weight: 900;
}

.question-answer {
  display: -webkit-box;
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  color: #475467;
  background: #f8fafc;
  border: 1rpx solid #eef2f7;
  font-size: 25rpx;
  line-height: 1.6;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.question-actions {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.q-btn {
  min-height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #344054;
  background: #f8fafc;
  border: 1rpx solid #e6ebf2;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 850;
  text-align: center;
}

.q-btn.primary {
  color: #ffffff;
  background: #101828;
  border-color: #101828;
}

.q-btn.warn {
  color: #b42318;
  background: #fff1f0;
  border-color: #fecdca;
}

.q-btn.ok {
  color: #067647;
  background: #ecfdf3;
  border-color: #abefc6;
}

.question-footer {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eef2f7;
}

.footer-link {
  color: #175cd3;
  font-size: 24rpx;
  font-weight: 850;
}

.footer-link.danger {
  color: #b42318;
}

.empty-card {
  min-height: 330rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-title {
  color: #101828;
  font-size: 31rpx;
  font-weight: 900;
}

.empty-desc {
  max-width: 580rpx;
  margin-top: 12rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.55;
}

.empty-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.empty-btn {
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  color: #175cd3;
  background: #eef4ff;
  font-size: 25rpx;
  font-weight: 900;
}

.empty-btn.primary {
  color: #ffffff;
  background: #101828;
}

.bottom-space {
  height: 90rpx;
}

.reference-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(15, 23, 42, 0.24);
}

.reference-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  max-height: 82vh;
  padding: 24rpx 24rpx calc(26rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -24rpx 60rpx rgba(15, 23, 42, 0.16);
  transform: translateY(104%);
  transition: transform 220ms ease;
}

.reference-panel.show {
  transform: translateY(0);
}

.reference-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.reference-kicker,
.reference-title,
.reference-question,
.reference-content {
  display: block;
}

.reference-kicker {
  color: #0f766e;
  font-size: 20rpx;
  font-weight: 900;
}

.reference-title {
  margin-top: 4rpx;
  color: #101828;
  font-size: 32rpx;
  font-weight: 950;
}

.reference-close {
  width: 62rpx;
  height: 62rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475467;
  background: #f8fafc;
  border: 1rpx solid #e6ebf2;
  font-size: 40rpx;
}

.reference-body {
  max-height: calc(82vh - 190rpx);
}

.reference-question {
  padding: 18rpx;
  border-radius: 18rpx;
  color: #101828;
  background: #f8fafc;
  border: 1rpx solid #eef2f7;
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 850;
}

.reference-content {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  color: #334155;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  font-size: 27rpx;
  line-height: 1.72;
}

.reference-done {
  height: 78rpx;
  margin-top: 16rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  font-size: 27rpx;
  font-weight: 900;
}
