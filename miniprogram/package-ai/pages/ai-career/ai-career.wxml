<view class="page"><c-ai-disclosure text="AI 会读取你的求职画像和当前申请；敏感信息会脱敏，写操作必须再次确认。" />
<view class="hero"><text class="kicker">FOUR SPECIALIST AGENTS</text><text class="title">AI Career</text><text class="sub">岗位、申请、面试与职业规划统一入口</text><view class="interview-link" bindtap="openInterviews">进入岗位面试空间 →</view></view>
<scroll-view scroll-x class="agents"><view class="agent-row"><view wx:for="{{agents}}" wx:key="code" class="agent {{selectedAgent===item.code?'active':''}}" data-code="{{item.code}}" bindtap="selectAgent">{{item.name}}</view></view></scroll-view>
<view class="composer"><picker range="{{applications}}" range-key="jobTitle" bindchange="onApplicationChange"><view class="field">当前申请：{{applications[applicationIndex].company || '未选择'}} · {{applications[applicationIndex].jobTitle || ''}}</view></picker>
<textarea class="query" placeholder="描述你希望 Agent 帮你完成的任务" value="{{query}}" bindinput="onQuery" />
<view class="write-toggle {{requestWrite?'on':''}}" bindtap="toggleWrite">{{requestWrite?'✓ ':''}}允许提出待确认的写操作</view><view class="run" bindtap="runAgent">{{loading?'处理中…':'运行 Agent'}}</view></view>
<text class="section-title">任务历史</text><view wx:for="{{tasks}}" wx:key="id" class="task" data-id="{{item.id}}" bindtap="openTask"><view><text class="task-name">{{item.agentName}}</text><text class="task-time">{{item.createdAt}}</text></view><text class="status">{{item.status}}</text></view>
<view wx:if="{{currentTask}}" class="mask" bindtap="closeTask"></view><view wx:if="{{currentTask}}" class="sheet"><text class="sheet-title">{{currentTask.agentName}}</text><text class="meta">{{currentTask.aiModel}} · {{currentTask.promptVersion}}</text><text class="answer">{{currentTask.output.message || currentTask.error.message}}</text>
<view class="actions"><view wx:if="{{currentTask.status==='failed'}}" bindtap="retryTask">重试</view><view wx:if="{{currentTask.status==='awaiting_confirmation'}}" bindtap="cancelTask">取消</view><view wx:if="{{currentTask.status==='awaiting_confirmation'}}" class="confirm" bindtap="confirmWrite">确认执行写操作</view></view></view></view>
