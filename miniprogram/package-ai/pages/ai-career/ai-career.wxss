.page{min-height:100vh;background:#f5f7fb;padding:24rpx 28rpx 80rpx;box-sizing:border-box;color:#101828}.hero{padding:38rpx;border-radius:28rpx;background:linear-gradient(135deg,#101828,#4338ca);color:#fff}.kicker{display:block;font-size:20rpx;letter-spacing:3rpx;opacity:.65}.title{display:block;font-size:52rpx;font-weight:800;margin-top:12rpx}.sub{display:block;font-size:25rpx;opacity:.8;margin-top:10rpx}.interview-link{margin-top:28rpx;font-size:25rpx;font-weight:700}.agents{margin:26rpx 0}.agent-row{display:flex;gap:14rpx}.agent{white-space:nowrap;padding:18rpx 24rpx;border-radius:999rpx;background:#fff;color:#667085}.agent.active{background:#101828;color:#fff}.composer,.task{background:#fff;border-radius:22rpx;padding:24rpx;margin-bottom:16rpx}.field,.query{box-sizing:border-box;width:100%;padding:20rpx;border-radius:14rpx;background:#f5f7fb;font-size:25rpx}.query{height:220rpx;margin-top:16rpx}.write-toggle{margin:16rpx 0;color:#667085;font-size:24rpx}.write-toggle.on{color:#4338ca}.run{padding:22rpx;border-radius:14rpx;background:#4338ca;color:#fff;text-align:center;font-weight:700}.section-title{display:block;font-size:30rpx;font-weight:800;margin:28rpx 0 16rpx}.task{display:flex;justify-content:space-between}.task-name{display:block;font-weight:700}.task-time,.meta{display:block;color:#98a2b3;font-size:21rpx;margin-top:8rpx}.status{color:#4338ca;font-size:23rpx}.mask{position:fixed;inset:0;background:rgba(16,24,40,.5);z-index:20}.sheet{position:fixed;z-index:21;left:0;right:0;bottom:0;padding:34rpx;background:#fff;border-radius:30rpx 30rpx 0 0}.sheet-title{font-size:34rpx;font-weight:800}.answer{display:block;line-height:1.8;margin:26rpx 0}.actions{display:flex;justify-content:flex-end;gap:24rpx;align-items:center}.confirm{padding:18rpx 24rpx;background:#4338ca;color:#fff;border-radius:14rpx}
