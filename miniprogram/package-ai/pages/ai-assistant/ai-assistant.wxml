<!-- pages/ai-assistant/ai-assistant.wxml -->
<view class="page">

  <!-- 顶部栏（自定义导航，含状态栏占位） -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-left">
      <view class="nav-back-btn" bindtap="goBack" hover-class="btn-hover">
        <text class="nav-back-icon">‹</text>
      </view>
      <view class="menu-btn" bindtap="toggleSidebar" hover-class="btn-hover">
        <view class="menu-line"></view>
        <view class="menu-line short"></view>
      </view>
    </view>
    <view class="top-title">
      <text class="top-icon">AI</text>
      <view class="top-copy">
        <text class="top-name">AI 求职助手</text>
        <text class="top-sub">AI生成内容 · 仅供参考</text>
      </view>
    </view>
    <view class="new-chat-btn" bindtap="onNewChat" hover-class="btn-hover">
      <text class="new-chat-icon">+</text>
    </view>
  </view>

  <view wx:if="{{sidebarOpen}}" class="drawer-mask" bindtap="toggleSidebar"></view>
  <view class="drawer {{sidebarOpen ? 'open' : ''}}" style="padding-top: {{statusBarHeight}}px;">
    <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="drawer-scroll">
      <view class="drawer-brand">
        <view class="drawer-logo">AI</view>
        <view class="drawer-title-wrap">
          <text class="drawer-title">求职助手</text>
        </view>
      </view>
      <view class="drawer-new" bindtap="onNewChat" hover-class="card-hover">
        <text class="drawer-new-icon">+</text>
        <text>新对话</text>
      </view>
      <view class="drawer-search">
        <text class="drawer-search-icon">⌕</text>
        <text class="drawer-search-placeholder">搜索聊天</text>
      </view>
      <view class="drawer-section-title">AI 功能套件</view>
      <block wx:for="{{assistantTools}}" wx:key="title">
        <view
          wx:if="{{index < 4 || showMoreTools}}"
          class="drawer-tool"
          bindtap="onToolAction"
          data-action="{{item.action}}"
          data-text="{{item.prompt}}"
          data-url="{{item.url}}"
          hover-class="card-hover"
        >
          <view class="drawer-tool-icon">{{item.icon}}</view>
          <view class="drawer-tool-copy">
            <text class="drawer-tool-title">{{item.title}}</text>
            <text class="drawer-tool-desc">{{item.desc}}</text>
          </view>
        </view>
      </block>
      <view wx:if="{{assistantTools.length > 4}}" class="drawer-more" bindtap="toggleMoreTools" hover-class="card-hover">
        <text>{{showMoreTools ? '收起' : '更多'}}</text>
        <text class="drawer-more-count" wx:if="{{!showMoreTools}}">其余 {{assistantTools.length - 4}} 个功能</text>
      </view>
      <view class="drawer-section-title recent-title">最近对话</view>
      <block wx:for="{{recentChats}}" wx:key="id">
        <view class="recent-chat" bindtap="toggleSidebar" hover-class="card-hover">
          <view class="recent-dot"></view>
          <view class="recent-copy">
            <text class="recent-name">{{item.title}}</text>
            <text class="recent-preview">{{item.preview}}</text>
          </view>
          <text class="recent-time">{{item.time}}</text>
        </view>
      </block>
    </scroll-view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="msg-scroll"
    scroll-y
    scroll-into-view="{{scrollId}}"
    scroll-with-animation
    style="margin-bottom: {{keyboardHeight > 0 ? keyboardHeight + 'px' : '0'}};"
  >
    <view class="msg-list">
      <c-ai-disclosure text="本页 AI 问答回复由人工智能生成，仅供求职参考，请核验后使用。" />
      <block wx:for="{{messages}}" wx:key="id">

        <!-- 时间分隔 -->
        <view wx:if="{{item.showTime}}" class="time-stamp">{{item.timeLabel}}</view>

        <view class="msg-row {{item.role === 'user' ? 'user-row' : 'ai-row'}}">

          <!-- AI 头像 -->
          <view wx:if="{{item.role === 'ai'}}" class="ai-avatar">
            <text class="ai-avatar-icon">✦</text>
          </view>

          <view class="bubble-wrap">

            <view wx:if="{{item.role === 'ai' && !item.isError}}" class="ai-generated-label">AI生成</view>

            <!-- 气泡主体 -->
            <view
              wx:if="{{item.role === 'ai' && item.isStreaming && loading && !streaming && !item.displayText}}"
              class="bubble ai-bubble loading-bubble"
            >
              <view class="thinking-head">
                <text class="thinking-title">CareerGPT 正在思考</text>
                <view class="dot-wrap">
                  <view class="dot"></view>
                  <view class="dot"></view>
                  <view class="dot"></view>
                </view>
              </view>
              <view class="thinking-steps">
                <text>理解你的目标</text>
                <text>匹配求职策略</text>
                <text>生成可执行建议</text>
              </view>
            </view>
            <view
              wx:else
              class="bubble {{item.role === 'user' ? 'user-bubble' : item.isError ? 'error-bubble' : 'ai-bubble'}}"
            >

              <!-- 用户消息、streaming 中、error：plain text -->
              <text
                wx:if="{{item.role === 'user' || item.isStreaming || item.isError}}"
                class="bubble-text"
                user-select
              >{{item.displayText}}</text>

              <!-- 完成的 AI 消息：rich-text 渲染 Markdown -->
              <rich-text
                wx:else
                class="bubble-text bubble-rich"
                nodes="{{item.htmlContent}}"
              ></rich-text>

            </view>

            <view
              wx:if="{{item.role === 'ai' && !item.isWelcome && !item.isStreaming && !item.isError && (item.content || item.displayText || item.htmlContent)}}"
              class="answer-action-card ux-ai-result-card"
            >
              <view class="answer-action-head">
                <view class="answer-action-mark">AI</view>
                <view class="answer-action-copy">
                  <text class="answer-action-title">下一步操作</text>
                  <text class="answer-action-sub">保存答案，或继续细化面试准备</text>
                </view>
              </view>
              <view class="answer-action-grid">
                <view class="answer-action-btn ux-result-action" bindtap="onCopyAnswer" data-index="{{index}}" hover-class="card-hover">
                  <text class="answer-action-icon">⧉</text>
                  <text>复制</text>
                </view>
                <view class="answer-action-btn ux-result-action" bindtap="onSaveAnswer" data-index="{{index}}" hover-class="card-hover">
                  <text class="answer-action-icon">✓</text>
                  <text>保存</text>
                </view>
                <view class="answer-action-btn ux-result-action primary" bindtap="onContinueAsk" data-type="follow" hover-class="card-hover">
                  <text class="answer-action-icon">↳</text>
                  <text>继续追问</text>
                </view>
                <view class="answer-action-btn ux-result-action" bindtap="onContinueAsk" data-type="plan" hover-class="card-hover">
                  <text class="answer-action-icon">▦</text>
                  <text>拆成清单</text>
                </view>
              </view>
              <view
                wx:if="{{item.suggestions && item.suggestions.length && index === latestAiIdx && !loading && !streaming}}"
                class="answer-suggestions"
              >
                <text class="answer-suggestions-title">推荐追问</text>
                <view class="answer-suggestion-list">
                  <view
                    wx:for="{{item.suggestions}}"
                    wx:for-item="sug"
                    wx:key="*this"
                    class="sug-chip"
                    bindtap="onSuggestion"
                    data-text="{{sug}}"
                    hover-class="chip-hover"
                  >{{sug}}</view>
                </view>
              </view>
            </view>

            <!-- 错误重试按钮 -->
            <view wx:if="{{item.isError && item.retryText}}" class="retry-row">
              <view
                class="retry-btn"
                bindtap="onRetry"
                data-text="{{item.retryText}}"
                hover-class="btn-hover"
              >
                <text class="retry-txt">↻ 重新发送</text>
              </view>
            </view>

            <!-- 首条欢迎消息：核心功能入口 -->
            <view wx:if="{{item.isWelcome && index === 0}}" class="suite-grid">
              <view
                wx:for="{{aiSuites}}"
                wx:for-item="suite"
                wx:key="title"
                class="suite-card {{(loading || streaming) ? 'quick-disabled' : ''}}"
                bindtap="onToolAction"
                data-action="{{suite.action}}"
                data-url="{{suite.url}}"
                data-text="{{suite.prompt}}"
                hover-class="card-hover"
              >
                <view class="suite-icon">{{suite.icon}}</view>
                <view class="suite-copy">
                  <text class="suite-title">{{suite.title}}</text>
                  <text class="suite-desc">{{suite.desc}}</text>
                </view>
              </view>
            </view>

          </view>
        </view>
      </block>

      <!-- Perf fix: 底部固定锚点，scroll-into-view 永远定位到此 -->
      <view id="scroll-anchor" style="height: 24rpx;"></view>
    </view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar" style="padding-bottom: calc(24rpx + {{safeBottom}}px);">
    <view class="input-wrap">
      <text class="input-leading">AI</text>
      <input
        class="input"
        placeholder="输入求职问题或具体目标"
        placeholder-class="input-ph"
        value="{{inputText}}"
        bindinput="onInputChange"
        bindconfirm="onSend"
        bindkeyboardheightchange="onKeyboardHeight"
        confirm-type="send"
        maxlength="300"
        adjust-position="{{false}}"
      />
    </view>
    <view class="input-right">
      <text wx:if="{{inputLen > 260}}" class="char-count {{inputLen >= 285 ? 'char-warn' : ''}}">{{inputLen}}/300</text>
      <!-- 停止/发送统一按钮 -->
      <view
        class="send-btn {{streaming ? 'stop-btn' : (inputText && !loading ? 'active' : 'inactive')}}"
        bindtap="onSendOrStop"
        hover-class="btn-hover"
      >
        <text class="send-icon">{{streaming ? '■' : '↑'}}</text>
      </view>
    </view>
  </view>

  <view
    class="application-mask"
    wx:if="{{showApplicationPanel}}"
    bindtap="closeApplicationAssistant"
  ></view>
  <view class="application-panel {{showApplicationPanel ? 'show' : ''}}">
    <view class="application-header">
      <view class="application-heading">
        <text class="application-kicker">APPLICATION</text>
        <text class="application-title">网申助手</text>
      </view>
      <view class="application-close" bindtap="closeApplicationAssistant">×</view>
    </view>
    <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="application-body">
      <view class="application-section">
        <text class="application-label">选择岗位</text>
        <scroll-view wx:if="{{applicationJobs.length}}" scroll-x enhanced show-scrollbar="{{false}}" class="application-job-scroll">
          <view class="application-choice-row">
            <view
              wx:for="{{applicationJobs}}"
              wx:key="id"
              class="application-choice {{selectedApplicationJobId == item.id ? 'active' : ''}}"
              bindtap="selectApplicationJob"
              data-id="{{item.id}}"
            >
              <text class="application-choice-title">{{item.company || '目标公司'}}</text>
              <text class="application-choice-sub">{{item.jobTitle || item.title || '目标岗位'}}</text>
            </view>
          </view>
        </scroll-view>
        <view wx:else class="application-empty">
          <text>先在职位详情或求职进度中添加一个岗位，再生成定制化网申草稿。</text>
        </view>
      </view>

      <view class="application-section">
        <text class="application-label">选择简历</text>
        <picker
          wx:if="{{hasApplicationResume}}"
          mode="selector"
          range="{{applicationResumeVersionLabels}}"
          value="{{selectedApplicationResumeIndex}}"
          disabled="{{applicationResumeLoading || applicationResumeVersions.length <= 1}}"
          bindchange="onApplicationResumeChange"
        >
          <view class="application-resume-picker">
            <view class="application-resume-copy">
              <text class="application-resume-title">{{selectedApplicationResumeName}}</text>
              <text class="application-resume-sub">{{selectedApplicationResumeTargetRole || '将结合这份简历生成回答'}}</text>
            </view>
            <text class="application-resume-action">{{applicationResumeVersions.length > 1 ? '切换 ›' : '默认'}}</text>
          </view>
        </picker>
        <view wx:else class="application-empty" bindtap="goApplicationResume">
          <text>{{applicationResumeLoading ? '正在读取简历...' : '先完善在线简历，再生成更贴合的网申草稿。'}}</text>
        </view>
      </view>

      <view class="application-section">
        <text class="application-label">问题类型</text>
        <view class="application-jd-block">
          <text class="application-label small">JD / 网申题干</text>
          <textarea
            class="application-jd-input"
            value="{{applicationJdText}}"
            maxlength="5000"
            auto-height
            placeholder="粘贴岗位 JD 或网申题干，AI 会结合简历与岗位生成更贴合的回答"
            bindinput="onApplicationJdInput"
          />
        </view>
        <view class="question-type-grid">
          <view
            wx:for="{{applicationQuestionTypes}}"
            wx:key="code"
            class="question-type {{selectedQuestionType === item.code ? 'active' : ''}}"
            bindtap="selectApplicationQuestion"
            data-type="{{item.code}}"
          >{{item.label}}</view>
        </view>
      </view>

      <view class="application-generate {{applicationJobs.length && hasApplicationResume && !applicationGenerating ? '' : 'disabled'}}" bindtap="generateApplicationDraft">
        {{applicationGenerating ? '生成中...' : '生成回答草稿'}}
      </view>

      <view class="application-draft" wx:if="{{applicationDraft}}">
        <text class="application-draft-title">{{applicationDraft.questionLabel}}</text>
        <text class="application-draft-meta">{{applicationDraft.company}} · {{applicationDraft.jobTitle}}</text>
        <text class="application-draft-resume" wx:if="{{applicationDraft.resumeName}}">基于：{{applicationDraft.resumeName}}</text>
        <text class="application-draft-content" user-select>{{applicationDraft.content}}</text>
        <view class="application-draft-actions">
          <view class="application-draft-btn" bindtap="copyApplicationDraft">复制</view>
          <view class="application-draft-btn primary" bindtap="saveApplicationDraft">保存到材料库</view>
        </view>
      </view>

      <view class="application-section saved-section" wx:if="{{applicationSavedMaterials.length}}">
        <view class="application-label-row">
          <text class="application-label inline">最近保存</text>
          <text class="application-label-link" bindtap="goApplicationMaterials">查看全部 ›</text>
        </view>
        <view
          wx:for="{{applicationSavedMaterials}}"
          wx:key="id"
          class="saved-material"
        >
          <view class="saved-material-head">
            <text class="saved-material-title">{{item.questionLabel}}</text>
            <text class="saved-material-meta">{{item.company}}</text>
          </view>
          <text class="saved-material-content" user-select>{{item.content}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <c-login-popup
    show="{{showLoginPopup}}"
    subtitle="{{loginSubtitle}}"
    bind:close="onLoginPopupClose"
    bind:success="onLoginSuccess"
  />

</view>
