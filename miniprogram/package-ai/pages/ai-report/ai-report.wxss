/* pages/ai-report/ai-report.wxss */
page { background: var(--bg-raised); padding-bottom: 40rpx; }

/* 头部总分 */
.score-card {
  background: linear-gradient(135deg, #0D1B3E, var(--brand));
  padding: 50rpx 40rpx;
  display: flex;
  align-items: center;
  color: #fff;
}
.score-circle {
  width: 160rpx; height: 160rpx;
  border: 8rpx solid rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  margin-right: 30rpx;
  background: rgba(255,255,255,0.15);
  flex-shrink: 0;
}
.score-val { font-size: 56rpx; font-weight: 800; line-height: 1; }
.score-label { font-size: 20rpx; opacity: 0.8; margin-top: 4rpx; }
.role-info { flex: 1; }
.role-title { font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 6rpx; }
.company-name { font-size: 26rpx; opacity: 0.9; display: block; margin-bottom: 10rpx; }
.score-badge {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--r-lg);
  font-weight: bold;
  margin-bottom: 8rpx;
}
.score-desc { font-size: 22rpx; opacity: 0.85; display: block; line-height: 1.4; }

/* Tab 切换 */
.report-tabs {
  display: flex;
  background: var(--bg-panel);
  border-bottom: 1rpx solid #eee;
}
.rtab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}
.rtab.active {
  color: var(--brand);
  font-weight: bold;
}
.rtab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: var(--brand);
  border-radius: 3rpx;
}

/* 通用板块 */
.section { background: var(--bg-panel); padding: 30rpx; margin-top: 20rpx; }
.section-title { font-size: 32rpx; font-weight: bold; margin-bottom: 30rpx; border-left: 8rpx solid var(--brand); padding-left: 16rpx; line-height: 1; }

/* 维度分析 - 增强版 */
.dim-item {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  justify-content: space-between;
}
.dim-left {
  width: 160rpx;
  flex-shrink: 0;
}
.dim-name { font-size: 26rpx; color: var(--text-body); display: block; font-weight: 500; }
.dim-level { font-size: 20rpx; display: block; margin-top: 4rpx; }
.dim-right {
  flex: 1;
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}
.progress-bg {
  flex: 1;
  height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.8s ease-out;
}
.dim-score { font-size: 28rpx; font-weight: bold; width: 60rpx; text-align: right; margin-left: 12rpx; }

/* 雷达图Canvas版 */
.radar-wrap {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}
.radar-canvas {
  width: 560rpx;
  height: 560rpx;
  border-radius: 16rpx;
}

/* 优劣势分析卡 */
.analysis-card {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-radius: var(--r-md);
  margin-bottom: 20rpx;
}
.analysis-card.good { background: #f6ffed; border: 1rpx solid #b7eb8f; }
.analysis-card.bad { background: #fff2e8; border: 1rpx solid #ffbb96; }
.analysis-card.tip { background: #e6f7ff; border: 1rpx solid #91d5ff; }
.analysis-icon {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.analysis-card.good .analysis-icon { background: #52c41a; color: #fff; }
.analysis-card.bad .analysis-icon { background: #fa8c16; color: #fff; }
.analysis-card.tip .analysis-icon { background: var(--brand); color: #fff; }
.analysis-body { flex: 1; }
.analysis-label { font-size: 28rpx; font-weight: bold; color: var(--text-body); display: block; margin-bottom: 8rpx; }
.analysis-text { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }

/* 综合评语 */
.summary-box { background: #F9FAFB; padding: 24rpx; border-radius: var(--r-sm); color: var(--text-body); line-height: 1.6; font-size: 28rpx; border: 1rpx solid #E6F4FF; }

/* 问答复盘 */
.qa-item { margin-bottom: 40rpx; border-bottom: 1rpx dashed #eee; padding-bottom: 30rpx; }
.qa-item:last-child { border-bottom: none; margin-bottom: 0; }
.qa-header { display: flex; align-items: flex-start; margin-bottom: 16rpx; }
.q-tag { background: var(--brand); color: #fff; font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; margin-right: 12rpx; height: fit-content; flex-shrink: 0; }
.q-text { font-size: 30rpx; font-weight: bold; color: var(--text-body); line-height: 1.4; flex: 1; }
.q-score {
  font-size: 22rpx;
  color: #fff;
  padding: 4rpx 14rpx;
  border-radius: var(--r-lg);
  margin-left: 12rpx;
  flex-shrink: 0;
  font-weight: bold;
}
.a-box { margin-bottom: 16rpx; background: #fafafa; padding: 16rpx; border-radius: 8rpx; }
.a-label { color: var(--text-muted); font-size: 24rpx; display: block; margin-bottom: 6rpx; }
.a-text { color: var(--text-secondary); font-size: 28rpx; line-height: 1.5; }
.feedback-box { background: #fffbe6; padding: 16rpx; border-radius: 8rpx; }
.fb-label { color: #fa8c16; font-size: 24rpx; font-weight: bold; display: block; margin-bottom: 4rpx; }
.fb-text { color: #d48806; font-size: 26rpx; line-height: 1.5; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: var(--bg-panel);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.btn-secondary {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border: 2rpx solid var(--brand);
  color: var(--brand);
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}
.btn-primary {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: linear-gradient(90deg, var(--brand), var(--brand-dark));
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* Loading */
.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}
.loading-spinner {
  width: 60rpx; height: 60rpx;
  border: 6rpx solid #f0f0f0;
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 30rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: var(--text-muted); }

/* ── 重点提升方向 ──────────────────────────── */
.improve-list {}
.improve-item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.improve-item:last-child { border-bottom: none; }
.improve-rank {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.improve-body { flex: 1; }
.improve-name { font-size: 28rpx; font-weight: 600; color: var(--text-body); display: block; }
.improve-tip { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 6rpx; }
.improve-score { font-size: 38rpx; font-weight: 800; flex-shrink: 0; margin-left: 20rpx; }

/* ── 复盘行动清单 ──────────────────────────── */
.action-plan {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.action-item {
  min-height: 104rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 1.5rpx solid #eef2f7;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
}

.action-item.high {
  background: #eef4ff;
  border-color: rgba(37, 99, 235, 0.18);
}

.action-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 23rpx;
  font-weight: 900;
}

.action-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.action-title {
  color: #111827;
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 900;
}

.action-detail {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
  font-weight: 650;
}

.action-priority {
  flex-shrink: 0;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  color: #175cd3;
  background: #ffffff;
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  font-size: 21rpx;
  font-weight: 900;
}

.practice-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.practice-chip {
  max-width: 100%;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #175cd3;
  background: #eef4ff;
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  font-size: 23rpx;
  line-height: 1.3;
  font-weight: 850;
}

.red-flags {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.red-flag-title {
  color: #9a3412;
  font-size: 23rpx;
  font-weight: 900;
}

.red-flag {
  color: #c2410c;
  font-size: 24rpx;
  line-height: 1.45;
}

/* ── 薄弱题摘要 ──────────────────────────── */
.weak-section {
  background: linear-gradient(180deg, #ffffff 0%, #fffaf0 100%);
  border-color: #fed7aa;
}

.weak-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.weak-title,
.weak-sub {
  display: block;
}

.weak-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.weak-sub {
  margin-top: 7rpx;
  color: #9a3412;
  font-size: 23rpx;
  line-height: 1.4;
}

.weak-save {
  flex-shrink: 0;
  height: 62rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.weak-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.weak-card {
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid #fde68a;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.weak-score {
  flex-shrink: 0;
  color: #b45309;
  background: #fffbeb;
  border-radius: 999rpx;
  padding: 5rpx 10rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.weak-question {
  flex: 1;
  min-width: 0;
  color: #334155;
  font-size: 24rpx;
  line-height: 1.45;
}

/* ── 改进建议高亮 ──────────────────────────── */
.fb-text-wrap { display: block; }
.fb-seg { font-size: 26rpx; color: #d48806; line-height: 1.7; }
.fb-highlight { color: #d4380d; font-weight: bold; }

/* ── 题目收藏按钮 ───────────────────────────────── */
.q-bookmark {
  font-size: 34rpx;
  color: #D1D5DB;
  margin-left: 10rpx;
  flex-shrink: 0;
  line-height: 1;
  padding: 4rpx 8rpx;
}
.q-bookmark.saved { color: #FBBF24; }

/* ── 对标分析 ──────────────────────────────────── */
.percentile-card {
  background: linear-gradient(135deg, #EEF2FF, #F0F4FF);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1.5rpx solid #C7D2FE;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  align-items: center;
}

.pct-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.pct-big {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--brand);
  line-height: 1;
}

.pct-sub {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
  text-align: center;
}

.pct-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.pct-avg-label {
  font-size: 20rpx;
  color: var(--text-muted);
}

.pct-avg-val {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-body);
  line-height: 1.2;
}

.pct-bar-wrap {
  width: 100%;
  margin-top: 4rpx;
}

.pct-bar-track {
  position: relative;
  height: 14rpx;
  background: #DBEAFE;
  border-radius: 7rpx;
  margin-bottom: 8rpx;
}

.pct-bar-avg {
  position: absolute;
  top: -6rpx;
  transform: translateX(-50%);
  width: 4rpx;
  height: 26rpx;
  background: var(--text-muted);
  border-radius: 2rpx;
}

.pct-bar-me {
  position: absolute;
  top: -8rpx;
  transform: translateX(-50%);
  width: 6rpx;
  height: 30rpx;
  background: var(--brand);
  border-radius: 3rpx;
}

.pct-bar-labels {
  position: relative;
  height: 32rpx;
  margin-top: 6rpx;
}
.pct-bar-label-avg {
  position: absolute;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: var(--text-muted);
  white-space: nowrap;
}
.pct-bar-label-me {
  position: absolute;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: var(--brand);
  font-weight: bold;
  white-space: nowrap;
}

/* 维度对比表 */
.bench-list {
  background: var(--bg-panel);
  border-radius: var(--r-md);
  overflow: hidden;
  border: 1.5rpx solid #F1F5F9;
}

.bench-head {
  display: flex;
  background: #F8F9FC;
  padding: 16rpx 0;
  border-bottom: 1.5rpx solid #F1F5F9;
}

.bench-row {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F8F9FC;
}

.bench-row:last-child { border-bottom: none; }

.bench-col-name {
  flex: 2;
  font-size: 24rpx;
  color: var(--text-body);
  padding-left: 20rpx;
}

.bench-head .bench-col-name {
  font-weight: 700;
  color: var(--text-primary);
}

.bench-col {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

.bench-head .bench-col {
  font-weight: 700;
  color: var(--text-body);
}

.bench-me { font-weight: 700; }
.bench-avg { color: var(--text-muted); }
.bench-diff.pos { color: #059669; font-weight: 700; }
.bench-diff.neg { color: #DC2626; font-weight: 700; }
/* Unified homepage background */
page,
.page,
.container {
  --app-page-bg: radial-gradient(circle at 18% 0%, rgba(43, 92, 230, 0.08) 0%, rgba(43, 92, 230, 0) 34%), linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
  background: var(--app-page-bg);
  background-color: #ffffff;
}

/* Polished AI interview report */
page {
  --report-bg: #f6f8fb;
  --report-panel: #ffffff;
  --report-text: #111827;
  --report-sub: #667085;
  --report-line: #e6ebf2;
  --report-blue: #2563eb;
  --report-teal: #14b8a6;
  --report-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.07);
  min-height: 100vh;
  padding-bottom: 0;
  background:
    radial-gradient(circle at 18% 0%, rgba(37, 99, 235, 0.09) 0%, rgba(37, 99, 235, 0) 34%),
    linear-gradient(180deg, #f8fbff 0%, var(--report-bg) 52%, #ffffff 100%);
}

.container {
  min-height: 100vh;
  padding: 22rpx 24rpx 0;
  box-sizing: border-box;
  background: transparent;
}

.score-card {
  margin: 0 0 18rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  color: var(--report-text);
  background:
    linear-gradient(135deg, rgba(37, 99, 235, 0.08), rgba(20, 184, 166, 0.08)),
    var(--report-panel);
  border: 1.5rpx solid rgba(230, 235, 242, 0.95);
  box-shadow: var(--report-shadow);
}

.score-circle {
  width: 154rpx;
  height: 154rpx;
  margin-right: 28rpx;
  border-width: 8rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 14rpx rgba(37, 99, 235, 0.045);
}

.score-val {
  font-size: 58rpx;
  font-weight: 900;
}

.score-label {
  margin-top: 8rpx;
  color: var(--report-sub);
  opacity: 1;
  font-size: 22rpx;
  font-weight: 700;
}

.role-title {
  margin-bottom: 8rpx;
  color: var(--report-text);
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 900;
}

.company-name {
  margin-bottom: 12rpx;
  color: var(--report-sub);
  opacity: 1;
  font-size: 25rpx;
}

.score-badge {
  margin-bottom: 12rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef4ff !important;
  font-size: 22rpx;
}

.score-desc {
  color: #475467;
  opacity: 1;
  font-size: 24rpx;
  line-height: 1.5;
}

.report-tabs {
  margin: 0 0 18rpx;
  padding: 8rpx;
  border: 1.5rpx solid var(--report-line);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.035);
}

.rtab {
  padding: 18rpx 0;
  border-radius: 16rpx;
  color: #667085;
  font-size: 27rpx;
  font-weight: 800;
}

.rtab.active {
  color: #ffffff;
  background: linear-gradient(135deg, var(--report-blue), var(--report-teal));
  box-shadow: 0 10rpx 22rpx rgba(37, 99, 235, 0.18);
}

.rtab.active::after {
  display: none;
}

.section {
  margin: 18rpx 0 0;
  padding: 30rpx;
  border-radius: 28rpx;
  background: var(--report-panel);
  border: 1.5rpx solid rgba(230, 235, 242, 0.95);
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.045);
}

.section-title {
  margin-bottom: 28rpx;
  padding-left: 0;
  border-left: 0;
  color: var(--report-text);
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
}

.dim-item {
  margin-bottom: 30rpx;
}

.dim-left {
  width: 164rpx;
}

.dim-name {
  color: var(--report-text);
  font-size: 27rpx;
  font-weight: 850;
}

.dim-level {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.progress-bg {
  height: 18rpx;
  background: #eef2f7;
  border-radius: 999rpx;
}

.progress-bar {
  border-radius: 999rpx;
}

.dim-score {
  width: 64rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.radar-wrap {
  padding: 8rpx 0 2rpx;
  overflow: hidden;
}

.radar-canvas {
  width: 640rpx;
  height: 560rpx;
  max-width: 100%;
  border-radius: 22rpx;
  background: #fbfcff;
}

.analysis-card,
.percentile-card,
.summary-box,
.a-box,
.feedback-box,
.bench-list {
  border-radius: 22rpx;
}

.analysis-card {
  padding: 24rpx;
  border-width: 1.5rpx;
}

.summary-box {
  background: #f8fafc;
  border-color: var(--report-line);
}

.bottom-bar {
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  gap: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1.5rpx solid rgba(230, 235, 242, 0.95);
  box-shadow: 0 -16rpx 34rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.btn-secondary,
.btn-primary {
  height: 86rpx;
  padding: 0;
  margin: 0;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.btn-secondary {
  color: #344054;
  background: #f8fafc;
  border: 1.5rpx solid var(--report-line);
}

.btn-primary {
  color: #ffffff;
  background: linear-gradient(135deg, var(--report-blue), var(--report-teal));
  border: 0;
  box-shadow: 0 14rpx 26rpx rgba(37, 99, 235, 0.2);
}

.bottom-spacer {
  height: calc(152rpx + env(safe-area-inset-bottom));
}

.report-empty {
  min-height: 100vh;
  padding: 220rpx 54rpx 80rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 0%, rgba(37, 99, 235, 0.08) 0%, rgba(37, 99, 235, 0) 34%),
    linear-gradient(180deg, #f8fbff 0%, #ffffff 56%);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.report-empty-title {
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 950;
  line-height: 1.2;
}

.report-empty-sub {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
}

.report-empty-btn {
  margin-top: 34rpx;
  height: 76rpx;
  padding: 0 32rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, var(--report-blue), var(--report-teal));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 26rpx rgba(37, 99, 235, 0.2);
}

.ai-generated-notice {
  margin: 20rpx 0 24rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border: 1.5rpx solid #bfdbfe;
  border-radius: 20rpx;
  background: #eff6ff;
  box-sizing: border-box;
}

.ai-generated-badge {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  color: #ffffff;
  background: #2563eb;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.2;
}

.ai-generated-text {
  color: #1e3a8a;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 1.5;
}
