<!-- pages/daily-brief/daily-brief.wxml -->
<view class="page">

  <c-ai-disclosure text="求职总结与行动建议由人工智能生成，仅供规划参考。" />

  <!-- 顶部日期 Header -->
  <view class="date-header">
    <view class="date-left">
      <text class="greeting">{{greeting}}！</text>
      <text class="today-date">{{todayStr}}</text>
    </view>
    <view class="header-icon-box">
      <text class="header-icon">☀️</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-card" wx:if="{{phase === 'loading'}}">
    <view class="loading-rings">
      <view class="ring r1"></view>
      <view class="ring r2"></view>
      <view class="ring-icon">📋</view>
    </view>
    <text class="loading-tip">{{loadingTip}}</text>
  </view>

  <!-- 空态：手动触发 -->
  <view class="idle-card" wx:if="{{phase === 'idle'}}">
    <text class="idle-emoji">📋</text>
    <text class="idle-title">今日求职日报</text>
    <text class="idle-desc">AI 分析你的求职进展，生成今日总结和明日行动计划</text>
    <view class="gen-btn" bindtap="retryGenerate">生成今日日报</view>
  </view>

  <!-- 结果 -->
  <view wx:if="{{phase === 'done' && result}}">

    <view class="brief-module" wx:if="{{brief && brief.tasks && brief.tasks.length}}">
      <view class="module-head">
        <text class="module-title">今日任务队列</text>
      </view>
      <block wx:for="{{brief.tasks}}" wx:key="id">
        <view wx:if="{{index < 4}}" class="task-card {{item.done ? 'done' : ''}}" bindtap="goDailyTask" data-url="{{item.url}}" hover-class="card-press">
          <text class="task-title">{{item.done ? '已完成 · ' : ''}}{{item.title}}</text>
          <text class="task-sub">{{item.desc}}</text>
        </view>
      </block>
    </view>

    <view class="brief-module" wx:if="{{brief && brief.recommendedJobs.length}}">
      <view class="module-head">
        <text class="module-title">今日推荐岗位</text>
        <text class="module-link" bindtap="goJobs">更多 ›</text>
      </view>
      <block wx:for="{{brief.recommendedJobs}}" wx:key="id">
        <view class="brief-job-card" bindtap="goJobDetail" data-id="{{item.id}}" hover-class="card-press">
          <view>
            <text class="brief-job-title">{{item.title}}</text>
            <text class="brief-job-company">{{item.company}}{{item.city ? ' · ' + item.city : ''}}</text>
          </view>
          <text class="brief-job-salary">{{item.salary || '查看'}}</text>
        </view>
      </block>
    </view>

    <view class="brief-module">
      <view class="module-head">
        <text class="module-title">即将截止</text>
        <text class="module-link" bindtap="goProgress">管理 ›</text>
      </view>
      <block wx:if="{{brief && brief.deadlines.length}}">
        <view wx:for="{{brief.deadlines}}" wx:key="id" class="deadline-brief-card" bindtap="goProgress" hover-class="card-press">
          <view>
            <text class="deadline-company">{{item.company}}</text>
            <text class="deadline-role">{{item.jobTitle}}</text>
          </view>
          <text class="deadline-badge">{{item.deadlineLabel}}</text>
        </view>
      </block>
      <view wx:else class="soft-empty">暂无 7 天内截止岗位，今天可以补充目标岗位的截止时间。</view>
    </view>

    <view class="brief-module">
      <view class="module-head">
        <text class="module-title">我的投递进度</text>
        <text class="module-link" bindtap="goProgress">查看 ›</text>
      </view>
      <view class="mini-stat-grid">
        <view class="mini-stat">
          <text class="mini-num">{{stats.totalApps}}</text>
          <text class="mini-label">全部记录</text>
        </view>
        <view class="mini-stat">
          <text class="mini-num">{{stats.pendingApps}}</text>
          <text class="mini-label">网申/OA</text>
        </view>
        <view class="mini-stat">
          <text class="mini-num">{{stats.interviewApps}}</text>
          <text class="mini-label">面试中</text>
        </view>
        <view class="mini-stat">
          <text class="mini-num offer">{{stats.offerApps}}</text>
          <text class="mini-label">Offer</text>
        </view>
      </view>
    </view>

    <view class="brief-module">
      <view class="module-head">
        <text class="module-title">今日面试任务</text>
        <text class="module-link" bindtap="goInterview">练习 ›</text>
      </view>
      <block wx:if="{{brief && brief.todayInterviews.length}}">
        <view wx:for="{{brief.todayInterviews}}" wx:key="id" class="task-card" bindtap="goProgress">
          <text class="task-title">{{item.company}} · {{item.jobTitle}}</text>
          <text class="task-sub">{{item.interviewTime}}</text>
        </view>
      </block>
      <view wx:else class="soft-empty">今天暂无面试安排，可以练一道高频行为题保持手感。</view>
    </view>

    <view class="brief-module">
      <view class="module-head">
        <text class="module-title">今日必练题</text>
        <text class="module-link" bindtap="goNotebook">题本 ›</text>
      </view>
      <block wx:for="{{brief.dailyQuestions}}" wx:key="*this">
        <view class="question-row" bindtap="goInterview" data-question="{{item}}" hover-class="card-press">
          <text class="question-index">{{index + 1}}</text>
          <text class="question-text">{{item}}</text>
        </view>
      </block>
    </view>

    <view class="brief-module" wx:if="{{brief && brief.news.length}}">
      <view class="module-head">
        <text class="module-title">热门求职快讯</text>
      </view>
      <block wx:for="{{brief.news}}" wx:key="id">
        <view class="news-brief-row">
          <text class="news-brief-title">{{item.title}}</text>
          <text class="news-brief-time">{{item.time}}</text>
        </view>
      </block>
    </view>

    <!-- 今日总结 -->
    <view class="summary-banner">
      <view class="summary-banner-head">
        <text class="summary-banner-title">今日求职总结</text>
        <view class="refresh-btn" bindtap="refresh">刷新</view>
      </view>
      <text class="summary-txt">{{result.todaySummary}}</text>
    </view>

    <!-- 数据亮点 -->
    <view class="section" wx:if="{{result.highlights && result.highlights.length > 0}}">
      <view class="section-title">📊 今日数据</view>
      <view class="highlights-row">
        <block wx:for="{{result.highlights}}" wx:key="label">
          <view class="highlight-card">
            <text class="hl-icon">{{item.icon}}</text>
            <text class="hl-value">{{item.value}}</text>
            <text class="hl-label">{{item.label}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 今日聚焦 -->
    <view class="section">
      <view class="section-title">🎯 今日聚焦</view>
      <view class="focus-card">
        <view class="focus-icon-wrap">
          <text class="focus-icon">⚡</text>
        </view>
        <text class="focus-txt">{{result.focusArea}}</text>
      </view>
    </view>

    <!-- 明日计划 -->
    <view class="section">
      <view class="section-title">📅 明日行动计划</view>
      <block wx:for="{{result.tomorrowPlan}}" wx:key="task">
        <view class="plan-item">
          <view class="plan-time-wrap">
            <text class="plan-time">{{item.time}}</text>
          </view>
          <view class="plan-body">
            <text class="plan-task">{{item.task}}</text>
            <view class="plan-priority {{item.priority}}">
              <text wx:if="{{item.priority === 'high'}}">高优先</text>
              <text wx:elif="{{item.priority === 'medium'}}">中优先</text>
              <text wx:else>低优先</text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- AI 建议 -->
    <view class="section">
      <view class="section-title">🤖 AI 专属建议</view>
      <view class="advice-card">
        <view class="advice-ai-tag">AI</view>
        <text class="advice-txt">{{result.aiAdvice}}</text>
      </view>
    </view>

    <!-- 激励语 -->
    <view class="motivation-card" wx:if="{{result.motivation}}">
      <text class="motivation-txt">💬 {{result.motivation}}</text>
    </view>

    <!-- 统计摘要 -->
    <view class="stats-summary" wx:if="{{stats}}">
      <view class="stats-title">求职状态总览</view>
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-num">{{stats.totalApps}}</text>
          <text class="stat-label">总投递</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.pendingApps}}</text>
          <text class="stat-label">待回复</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.interviewApps}}</text>
          <text class="stat-label">面试中</text>
        </view>
        <view class="stat-item">
          <text class="stat-num {{stats.offerApps > 0 ? 'offer' : ''}}">{{stats.offerApps}}</text>
          <text class="stat-label">Offer</text>
        </view>
      </view>
    </view>

  </view>

  <view style="height: 80rpx;"></view>
</view>
