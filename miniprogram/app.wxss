/* app.wxss — Linear Design System (Dark) */

/* ── Design Tokens ── */
page {
  /* Backgrounds */
  --bg-page:    #FFFFFF;
  --bg-panel:   #FFFFFF;
  --bg-surface: #FFFFFF;
  --bg-raised:  #F4F6F9;

  /* Text */
  --text-primary:   #111827;
  --text-body:      #374151;
  --text-secondary: #6B7280;
  --text-muted:     #9CA3AF;
  --text-subtle:    #9CA3AF;

  /* Brand */
  --brand:       #2B5CE6;
  --brand-dark:  #1A3CC9;
  --brand-shadow: rgba(43, 92, 230, 0.3);
  --accent:      #2B5CE6;
  --accent-hover:#4F7BFF;

  /* Status */
  --success: #10b981;
  --warning: #f59e0b;
  --danger:  #ef4444;
  --info:    #2B5CE6;

  /* Borders */
  --border:        rgba(0,0,0,0.06);
  --border-subtle: rgba(0,0,0,0.04);
  --border-light:  #E5E7EB;
  --border-solid:  #23252a;

  /* Radius */
  --r-xs:   4rpx;
  --r-sm:   12rpx;
  --r-md:   16rpx;
  --r-lg:   24rpx;
  --r-xl:   32rpx;
  --r-pill: 9999rpx;

  /* Button */
  --btn-height:    88rpx;
  --btn-height-sm: 64rpx;
  --btn-font-size: 30rpx;
  --btn-font-size-sm: 26rpx;

  /* Skeleton */
  --skeleton-base: #F4F6F9;
  --skeleton-shine: #FFFFFF;

  /* 状态色背景（浅色 tint，用于 badge/tag 背景） */
  --success-bg: rgba(16, 185, 129, 0.10);
  --warning-bg: rgba(245, 158, 11, 0.10);
  --danger-bg:  rgba(239, 68, 68, 0.10);
  --info-bg:    rgba(43, 92, 230, 0.08);

  /* 品牌色浅背景（替代页面中散落的 #EEF2FF） */
  --brand-bg:   #EEF2FF;
  --brand-border: #A5B4FC;

  /* 成功色（替代 #059669 / #ECFDF5 / #D1FAE5） */
  --success-text: #059669;
  --success-bg-solid: #ECFDF5;

  /* 分隔线（替代 resume.wxss 中未定义的 var(--divider)） */
  --divider: rgba(0, 0, 0, 0.05);

  /* 超浅边框（替代 #F1F5F9） */
  --border-faint: #F1F5F9;

  /* 阴影系统 */
  --shadow-sm:  0 2rpx 8rpx  rgba(0, 0, 0, 0.05);
  --shadow-md:  0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  --shadow-lg:  0 8rpx 32rpx rgba(0, 0, 0, 0.10);
  --shadow-up:  0 -4rpx 24rpx rgba(0, 0, 0, 0.08);

  /* 过渡时长 */
  --trans-fast:   0.12s ease;
  --trans-normal: 0.20s ease;
  --trans-slow:   0.30s cubic-bezier(0.32, 0.72, 0, 1);

  font-family: -apple-system, 'PingFang SC', 'SF Pro Display', sans-serif;
  background-color: #FFFFFF !important; /* 强制覆盖，彻底封杀底层灰色 */
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
  /* 💡 新增：消除移动端点击默认的灰色闪烁 */
  -webkit-tap-highlight-color: transparent; 
  overflow-x: hidden;
  width: 100%;
  box-sizing: border-box;
}

/* 💡 优化：覆盖更多常用组件，防止表单或按钮宽度溢出 */
view, text, image, scroll-view, button, input, textarea, navigator { 
  box-sizing: border-box; 
}

/* ── Layout & Safe Area ── */
.safe-bottom { 
  /* 💡 优化：增加 constant fallback，兼容老版 iOS */
  height: calc(30rpx + constant(safe-area-inset-bottom));
  height: calc(30rpx + env(safe-area-inset-bottom)); 
}

/* ── Flex Utilities (💡 新增：极大减少页面布局代码) ── */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-between { display: flex; flex-direction: row; align-items: center; justify-content: space-between; }
.flex-center { display: flex; align-items: center; justify-content: center; }

/* ── Text Utilities (💡 新增：处理职位描述、题目长文本) ── */
.text-ellipsis { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.text-ellipsis-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

/* ── Interaction ── */
.hover-active { opacity: 0.72; transform: scale(0.982); transition: all var(--trans-fast); }
.hover-bg { background: var(--bg-raised) !important; transition: background var(--trans-fast); }
/* 卡片点击态（含 scale + opacity，比纯 opacity 精致） */
.card-tap { transition: transform var(--trans-fast), opacity var(--trans-fast); }
.card-tap:active { transform: scale(0.984); opacity: 0.88; }

/* ── Cards ── */
.card {
  background: var(--bg-surface);
  border-radius: var(--r-lg);
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1.5rpx solid var(--border);
  box-shadow: var(--shadow-sm);
}
.card:active { transform: scale(0.984); opacity: 0.88; }

/* ── Buttons ── */
.btn-primary {
  background: var(--brand);
  color: #fff;
  border-radius: var(--r-pill);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  height: var(--btn-height);
  line-height: var(--btn-height);
  text-align: center;
  /* 💡 新增：稍微加一点主色阴影，质感更好 */
  box-shadow: 0 8rpx 16rpx var(--brand-shadow);
}
.btn-ghost {
  background: rgba(255,255,255,0.03);
  color: var(--text-secondary);
  border: 1.5rpx solid var(--border);
  border-radius: var(--r-pill);
  font-size: 28rpx;
  height: var(--btn-height);
  line-height: calc(var(--btn-height) - 3rpx); /* 减去 border 高度防止文字偏移 */
  text-align: center;
}

/* ── Tags ── */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--r-xs);
  background: rgba(0,0,0,0.04);
  color: var(--text-muted);
  border: 1rpx solid var(--border-subtle);
}
.tag-blue   { background: rgba(43,92,230,0.08); color: var(--accent);  border-color: rgba(43,92,230,0.15); }
.tag-green  { background: rgba(16,185,129,0.08); color: var(--success); border-color: rgba(16,185,129,0.15); }
.tag-amber  { background: rgba(245,158,11,0.08); color: var(--warning); border-color: rgba(245,158,11,0.15); }
.tag-red    { background: rgba(239,68,68,0.08);  color: var(--danger);  border-color: rgba(239,68,68,0.15); }

/* ── Loading / Empty ── */
.loading { text-align: center; padding: 60rpx 0; color: var(--text-subtle); font-size: 26rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 100rpx 40rpx; color: var(--text-muted); font-size: 28rpx; }

/* ── Section title ── */
.section-title-bar {
  font-size: 32rpx; /* 稍微调大一点点更有层级感 */
  font-weight: 700;
  color: var(--text-primary);
  padding-left: 16rpx;
  border-left: 6rpx solid var(--brand); /* 加粗一点点边线 */
  line-height: 1.1;
}

/* ── Skeleton ── */
.skeleton {
  /* 💡 优化：使用变量，解决暗色模式闪白问题 */
  background: linear-gradient(90deg, var(--skeleton-base) 25%, var(--skeleton-shine) 50%, var(--skeleton-base) 75%);
  background-size: 400% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--r-sm);
}
@keyframes shimmer {
  0%   { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

/* ── Divider ── */
.divider { height: 1rpx; background: var(--border-subtle); width: 100%; }

/* ── Spinner ── */
.spinner {
  border: 4rpx solid var(--border-subtle);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ══════════════════════════════════════════════════════════════════
 * 暗色主题（Dark Mode）
 * ══════════════════════════════════════════════════════════════════ */

@media (prefers-color-scheme: dark) {
  page {
    /* Backgrounds */
    --bg-page:    #0F1117;
    --bg-panel:   #1A1D27;
    --bg-surface: #1A1D27;
    --bg-raised:  #252833;

    /* Text */
    --text-primary:   #F9FAFB;
    --text-body:      #E5E7EB;
    --text-secondary: #9CA3AF;
    --text-muted:     #6B7280;
    --text-subtle:    #6B7280;

    /* Brand */
    --brand:        #4F7BFF;
    --brand-dark:   #2B5CE6;
    --brand-shadow: rgba(79, 123, 255, 0.22);

    /* Status */
    --success: #34d399;
    --warning: #fbbf24;
    --danger:  #f87171;

    /* Borders */
    --border:        rgba(255,255,255,0.08);
    --border-subtle: rgba(255,255,255,0.04);
    --border-light:  #2D3141;
    --border-solid:  #3D4160;

    --skeleton-base: #252833;
    --skeleton-shine: #2D3141;

    /* 状态色背景（暗色） */
    --success-bg: rgba(52, 211, 153, 0.12);
    --warning-bg: rgba(251, 191, 36, 0.12);
    --danger-bg:  rgba(248, 113, 113, 0.12);
    --info-bg:    rgba(79, 123, 255, 0.10);

    --brand-bg:   rgba(79, 123, 255, 0.12);
    --brand-border: rgba(79, 123, 255, 0.40);

    --success-text: #34d399;
    --success-bg-solid: rgba(52, 211, 153, 0.12);

    --divider: rgba(255, 255, 255, 0.06);
    --border-faint: rgba(255, 255, 255, 0.06);

    --shadow-sm:  0 2rpx 8rpx  rgba(0, 0, 0, 0.25);
    --shadow-md:  0 4rpx 16rpx rgba(0, 0, 0, 0.30);
    --shadow-lg:  0 8rpx 32rpx rgba(0, 0, 0, 0.40);
    --shadow-up:  0 -4rpx 24rpx rgba(0, 0, 0, 0.30);
  }
}

/* 2026 Product Design System
 * Direction: clean AI SaaS, mobile first, white surface, restrained depth.
 */
page {
  --color-bg: #ffffff;
  --color-bg-soft: #f7f8fb;
  --color-bg-elevated: #ffffff;
  --color-ink: #101828;
  --color-ink-2: #344054;
  --color-ink-3: #667085;
  --color-ink-4: #98a2b3;
  --color-line: rgba(16, 24, 40, 0.08);
  --color-line-soft: rgba(16, 24, 40, 0.05);
  --color-brand: #2563eb;
  --color-brand-strong: #1d4ed8;
  --color-brand-soft: #eff6ff;
  --color-ai: #111827;
  --color-success: #059669;
  --color-success-soft: #ecfdf3;
  --color-warning: #d97706;
  --color-warning-soft: #fffbeb;
  --color-danger: #dc2626;
  --color-danger-soft: #fef2f2;

  --font-xs: 20rpx;
  --font-sm: 23rpx;
  --font-md: 26rpx;
  --font-lg: 30rpx;
  --font-xl: 36rpx;
  --font-2xl: 44rpx;

  --space-1: 8rpx;
  --space-2: 12rpx;
  --space-3: 16rpx;
  --space-4: 20rpx;
  --space-5: 24rpx;
  --space-6: 32rpx;
  --space-7: 40rpx;

  --radius-sm: 14rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-full: 999rpx;

  --shadow-card: 0 12rpx 34rpx rgba(16, 24, 40, 0.06);
  --shadow-pop: 0 20rpx 54rpx rgba(16, 24, 40, 0.10);
  --shadow-action: 0 12rpx 26rpx rgba(37, 99, 235, 0.18);
  --motion-fast: 0.16s ease;
  --motion-normal: 0.22s cubic-bezier(0.2, 0.8, 0.2, 1);

  --bg-page: var(--color-bg);
  --bg-panel: var(--color-bg-elevated);
  --bg-surface: var(--color-bg-elevated);
  --bg-raised: var(--color-bg-soft);
  --text-primary: var(--color-ink);
  --text-body: var(--color-ink-2);
  --text-secondary: var(--color-ink-3);
  --text-muted: var(--color-ink-4);
  --brand: var(--color-brand);
  --brand-dark: var(--color-brand-strong);
  --brand-shadow: rgba(37, 99, 235, 0.18);
  --border: var(--color-line);
  --border-subtle: var(--color-line-soft);
  --border-light: #eaecf0;
  --r-sm: var(--radius-sm);
  --r-md: var(--radius-md);
  --r-lg: var(--radius-lg);
  --r-xl: var(--radius-xl);
  --r-pill: var(--radius-full);
  --btn-height: 84rpx;
  --btn-height-sm: 60rpx;
  --btn-font-size: 28rpx;
  --btn-font-size-sm: 24rpx;
  --shadow-sm: var(--shadow-card);
  --shadow-md: var(--shadow-card);
  --shadow-lg: var(--shadow-pop);
  --shadow-up: 0 -14rpx 36rpx rgba(16, 24, 40, 0.08);

  background: var(--color-bg);
}

.page,
.container {
  background: var(--color-bg);
  color: var(--color-ink);
}

.ux-page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: var(--color-bg);
}

.ux-card {
  background: var(--color-bg-elevated);
  border: 1rpx solid var(--color-line-soft);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.ux-card:active,
.card:active {
  transform: scale(0.988);
  opacity: 0.92;
}

.ux-section-title {
  color: var(--color-ink);
  font-size: var(--font-lg);
  font-weight: 800;
  letter-spacing: -0.4rpx;
}

.ux-section-subtitle {
  color: var(--color-ink-3);
  font-size: var(--font-sm);
  line-height: 1.55;
}

.ux-pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-full);
  color: var(--color-ink-3);
  background: var(--color-bg-soft);
  border: 1rpx solid var(--color-line-soft);
  font-size: var(--font-sm);
  font-weight: 650;
}

.ux-primary-action,
.ux-secondary-action {
  height: 84rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-md);
  font-weight: 800;
}

.ux-primary-action {
  color: #ffffff;
  background: var(--color-brand);
  box-shadow: var(--shadow-action);
}

.ux-secondary-action {
  color: var(--color-ink-2);
  background: var(--color-bg-soft);
  border: 1rpx solid var(--color-line-soft);
}

.ux-input {
  min-height: 76rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: var(--color-bg-soft);
  border: 1rpx solid transparent;
  color: var(--color-ink);
  font-size: var(--font-md);
}

.ux-skeleton {
  overflow: hidden;
  position: relative;
  background: #f2f4f7;
  border-radius: var(--radius-md);
}

.ux-skeleton::after {
  content: '';
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.72), transparent);
  animation: ux-shimmer 1.4s infinite;
}

@keyframes ux-shimmer {
  100% { transform: translateX(100%); }
}

.ux-fade-in {
  animation: ux-fade-in 0.28s ease both;
}

@keyframes ux-fade-in {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.ux-ai-surface {
  background: #ffffff;
  border: 1rpx solid var(--color-line-soft);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.ux-ai-mark {
  background: var(--color-ai);
  color: #ffffff;
  border-radius: 16rpx;
  font-weight: 900;
}

.safe-tail {
  height: calc(24rpx + env(safe-area-inset-bottom));
}

button,
.c-btn,
.ux-primary-action,
.ux-secondary-action,
.card,
.ux-card {
  transition: transform var(--motion-fast), opacity var(--motion-fast), background var(--motion-fast), box-shadow var(--motion-normal);
  will-change: transform;
}

button:active,
.c-btn:active,
.ux-primary-action:active,
.ux-secondary-action:active {
  transform: scale(0.975);
  opacity: 0.88;
}

/* 手动暗色模式（已废弃 — 当前无 WXML 使用 theme-dark 类名，
   暗色模式完全通过 @media (prefers-color-scheme: dark) 自动生效。
   如需手动切换，请在页面 WXML 根节点绑定 class，并取消下方注释） */
