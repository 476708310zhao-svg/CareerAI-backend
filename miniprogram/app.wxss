/* app.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
}

/* 页面标题样式 */
.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 按钮样式 */
.btn-primary {
  background: #007aff;
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

/* 列表项样式 */
.list-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.list-item:last-child {
  border-bottom: none;
}

/* 标签样式 */
.tag {
  display: inline-block;
  font-size: 22rpx;
  color: #999;
  border: 1rpx solid #ddd;
  border-radius: 4rpx;
  padding: 4rpx 12rpx;
  margin-right: 10rpx;
}

/* 加载动画 */
.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* Global dark AI marks: keep AI icons visible on pale cards. */
.ai-icon-box,
.ai-avatar,
.ai-intro-badge,
.ai-badge,
.answer-action-mark,
.brand-mark,
.top-icon,
.drawer-logo,
.ai-tag,
.q-ai-tag,
.fab-text {
  background: linear-gradient(135deg, #111827 0%, #1e293b 100%) !important;
  color: #ffffff !important;
  border-color: rgba(15, 23, 42, 0.16) !important;
}

.ai-icon-txt,
.ai-avatar-icon,
.ai-avatar-text,
.ai-badge-txt {
  color: #ffffff !important;
}
