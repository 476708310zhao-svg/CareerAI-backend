/* app.wxss — Linear Design System (Dark) */

/* ── Design Tokens ── */
page {
  /* Backgrounds */
  --bg-page:    #FFFFFF;
  --bg-panel:   #FFFFFF;
  --bg-surface: #FFFFFF;
  --bg-raised:  #F4F6F9;

  /* Text */
  --text-primary:   #111827;
  --text-body:      #374151;
  --text-secondary: #6B7280;
  --text-muted:     #9CA3AF;
  --text-subtle:    #9CA3AF;

  /* Brand */
  --brand:       #2B5CE6;
  --brand-dark:  #1A3CC9;
  --brand-shadow: rgba(43, 92, 230, 0.3);
  --accent:      #2B5CE6;
  --accent-hover:#4F7BFF;

  /* Status */
  --success: #10b981;
  --warning: #f59e0b;
  --danger:  #ef4444;
  --info:    #2B5CE6;

  /* Borders */
  --border:        rgba(0,0,0,0.06);
  --border-subtle: rgba(0,0,0,0.04);
  --border-light:  #E5E7EB;
  --border-solid:  #23252a;

  /* Radius */
  --r-xs:   4rpx;
  --r-sm:   12rpx;
  --r-md:   16rpx;
  --r-lg:   24rpx;
  --r-xl:   32rpx;
  --r-pill: 9999rpx;

  /* Button */
  --btn-height:    88rpx;
  --btn-height-sm: 64rpx;
  --btn-font-size: 30rpx;
  --btn-font-size-sm: 26rpx;

  /* Skeleton */
  --skeleton-base: #F4F6F9;
  --skeleton-shine: #FFFFFF;

  /* 状态色背景（浅色 tint，用于 badge/tag 背景） */
  --success-bg: rgba(16, 185, 129, 0.10);
  --warning-bg: rgba(245, 158, 11, 0.10);
  --danger-bg:  rgba(239, 68, 68, 0.10);
  --info-bg:    rgba(43, 92, 230, 0.08);

  /* 品牌色浅背景（替代页面中散落的 #EEF2FF） */
  --brand-bg:   #EEF2FF;
  --brand-border: #A5B4FC;

  /* 成功色（替代 #059669 / #ECFDF5 / #D1FAE5） */
  --success-text: #059669;
  --success-bg-solid: #ECFDF5;

  /* 分隔线（替代 resume.wxss 中未定义的 var(--divider)） */
  --divider: rgba(0, 0, 0, 0.05);

  /* 超浅边框（替代 #F1F5F9） */
  --border-faint: #F1F5F9;

  /* 阴影系统 */
  --shadow-sm:  0 2rpx 8rpx  rgba(0, 0, 0, 0.05);
  --shadow-md:  0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  --shadow-lg:  0 8rpx 32rpx rgba(0, 0, 0, 0.10);
  --shadow-up:  0 -4rpx 24rpx rgba(0, 0, 0, 0.08);

  /* 过渡时长 */
  --trans-fast:   0.12s ease;
  --trans-normal: 0.20s ease;
  --trans-slow:   0.30s cubic-bezier(0.32, 0.72, 0, 1);

  font-family: -apple-system, 'PingFang SC', 'SF Pro Display', sans-serif;
  background-color: #FFFFFF !important; /* 强制覆盖，彻底封杀底层灰色 */
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
  /* 💡 新增：消除移动端点击默认的灰色闪烁 */
  -webkit-tap-highlight-color: transparent; 
  overflow-x: hidden;
  width: 100%;
  box-sizing: border-box;
}

/* 💡 优化：覆盖更多常用组件，防止表单或按钮宽度溢出 */
view, text, image, scroll-view, button, input, textarea, navigator { 
  box-sizing: border-box; 
}

/* ── Layout & Safe Area ── */
.safe-bottom { 
  /* 💡 优化：增加 constant fallback，兼容老版 iOS */
  height: calc(30rpx + constant(safe-area-inset-bottom));
  height: calc(30rpx + env(safe-area-inset-bottom)); 
}

/* ── Flex Utilities (💡 新增：极大减少页面布局代码) ── */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-between { display: flex; flex-direction: row; align-items: center; justify-content: space-between; }
.flex-center { display: flex; align-items: center; justify-content: center; }

/* ── Text Utilities (💡 新增：处理职位描述、题目长文本) ── */
.text-ellipsis { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.text-ellipsis-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

/* ── Interaction ── */
.hover-active { opacity: 0.72; transform: scale(0.982); transition: all var(--trans-fast); }
.hover-bg { background: var(--bg-raised) !important; transition: background var(--trans-fast); }
/* 卡片点击态（含 scale + opacity，比纯 opacity 精致） */
.card-tap { transition: transform var(--trans-fast), opacity var(--trans-fast); }
.card-tap:active { transform: scale(0.984); opacity: 0.88; }

/* ── Cards ── */
.card {
  background: var(--bg-surface);
  border-radius: var(--r-lg);
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1.5rpx solid var(--border);
  box-shadow: var(--shadow-sm);
}
.card:active { transform: scale(0.984); opacity: 0.88; }

/* ── Buttons ── */
.btn-primary {
  background: var(--brand);
  color: #fff;
  border-radius: var(--r-pill);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  height: var(--btn-height);
  line-height: var(--btn-height);
  text-align: center;
  /* 💡 新增：稍微加一点主色阴影，质感更好 */
  box-shadow: 0 8rpx 16rpx var(--brand-shadow);
}
.btn-ghost {
  background: rgba(255,255,255,0.03);
  color: var(--text-secondary);
  border: 1.5rpx solid var(--border);
  border-radius: var(--r-pill);
  font-size: 28rpx;
  height: var(--btn-height);
  line-height: calc(var(--btn-height) - 3rpx); /* 减去 border 高度防止文字偏移 */
  text-align: center;
}

/* ── Tags ── */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--r-xs);
  background: rgba(0,0,0,0.04);
  color: var(--text-muted);
  border: 1rpx solid var(--border-subtle);
}
.tag-blue   { background: rgba(43,92,230,0.08); color: var(--accent);  border-color: rgba(43,92,230,0.15); }
.tag-green  { background: rgba(16,185,129,0.08); color: var(--success); border-color: rgba(16,185,129,0.15); }
.tag-amber  { background: rgba(245,158,11,0.08); color: var(--warning); border-color: rgba(245,158,11,0.15); }
.tag-red    { background: rgba(239,68,68,0.08);  color: var(--danger);  border-color: rgba(239,68,68,0.15); }

/* ── Loading / Empty ── */
.loading { text-align: center; padding: 60rpx 0; color: var(--text-subtle); font-size: 26rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 100rpx 40rpx; color: var(--text-muted); font-size: 28rpx; }

/* ── Section title ── */
.section-title-bar {
  font-size: 32rpx; /* 稍微调大一点点更有层级感 */
  font-weight: 700;
  color: var(--text-primary);
  padding-left: 16rpx;
  border-left: 6rpx solid var(--brand); /* 加粗一点点边线 */
  line-height: 1.1;
}

/* ── Skeleton ── */
.skeleton {
  /* 💡 优化：使用变量，解决暗色模式闪白问题 */
  background: linear-gradient(90deg, var(--skeleton-base) 25%, var(--skeleton-shine) 50%, var(--skeleton-base) 75%);
  background-size: 400% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--r-sm);
}
@keyframes shimmer {
  0%   { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

/* ── Divider ── */
.divider { height: 1rpx; background: var(--border-subtle); width: 100%; }

/* ── Spinner ── */
.spinner {
  border: 4rpx solid var(--border-subtle);
  border-top-color: var(--brand);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ══════════════════════════════════════════════════════════════════
 * 暗色主题（Dark Mode）
 * ══════════════════════════════════════════════════════════════════ */

@media (prefers-color-scheme: dark) {
  page {
    /* Backgrounds */
    --bg-page:    #0F1117;
    --bg-panel:   #1A1D27;
    --bg-surface: #1A1D27;
    --bg-raised:  #252833;

    /* Text */
    --text-primary:   #F9FAFB;
    --text-body:      #E5E7EB;
    --text-secondary: #9CA3AF;
    --text-muted:     #6B7280;
    --text-subtle:    #6B7280;

    /* Brand */
    --brand:        #4F7BFF;
    --brand-dark:   #2B5CE6;
    --brand-shadow: rgba(79, 123, 255, 0.22);

    /* Status */
    --success: #34d399;
    --warning: #fbbf24;
    --danger:  #f87171;

    /* Borders */
    --border:        rgba(255,255,255,0.08);
    --border-subtle: rgba(255,255,255,0.04);
    --border-light:  #2D3141;
    --border-solid:  #3D4160;

    --skeleton-base: #252833;
    --skeleton-shine: #2D3141;

    /* 状态色背景（暗色） */
    --success-bg: rgba(52, 211, 153, 0.12);
    --warning-bg: rgba(251, 191, 36, 0.12);
    --danger-bg:  rgba(248, 113, 113, 0.12);
    --info-bg:    rgba(79, 123, 255, 0.10);

    --brand-bg:   rgba(79, 123, 255, 0.12);
    --brand-border: rgba(79, 123, 255, 0.40);

    --success-text: #34d399;
    --success-bg-solid: rgba(52, 211, 153, 0.12);

    --divider: rgba(255, 255, 255, 0.06);
    --border-faint: rgba(255, 255, 255, 0.06);

    --shadow-sm:  0 2rpx 8rpx  rgba(0, 0, 0, 0.25);
    --shadow-md:  0 4rpx 16rpx rgba(0, 0, 0, 0.30);
    --shadow-lg:  0 8rpx 32rpx rgba(0, 0, 0, 0.40);
    --shadow-up:  0 -4rpx 24rpx rgba(0, 0, 0, 0.30);
  }
}

/* 手动暗色模式（已废弃 — 当前无 WXML 使用 theme-dark 类名，
   暗色模式完全通过 @media (prefers-color-scheme: dark) 自动生效。
   如需手动切换，请在页面 WXML 根节点绑定 class，并取消下方注释） */