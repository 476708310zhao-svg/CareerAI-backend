# 复制此文件为 .env，填入真实密钥
# cp .env.example .env

# RapidAPI (JSearch 真实职位搜索)
RAPID_API_KEY=你的RapidAPI密钥
RAPID_API_HOST=jsearch.p.rapidapi.com
RAPID_API_URL=https://jsearch.p.rapidapi.com

# DeepSeek AI（面试对话/题库生成）
DEEPSEEK_API_KEY=你的DeepSeek密钥
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# 服务端口
PORT=3000

# 微信小程序（登录鉴权必填）
# 在 https://mp.weixin.qq.com → 开发 → 开发管理 → 开发设置 中获取
WX_APP_ID=你的小程序AppID
WX_APP_SECRET=你的小程序AppSecret

# JWT 签名密钥（生产环境请改为随机长字符串）
JWT_SECRET=jobapp_super_secret_key_change_in_production
JWT_EXPIRES_IN=30d

# 微信订阅消息模板 ID（在微信公众平台 → 订阅消息 → 我的模板 中获取）
WX_TPL_APPLICATION=  # 申请状态更新
WX_TPL_INTERVIEW=    # AI面试完成提醒
WX_TPL_SYSTEM=       # 系统通知

# 允许跨域的来源（小程序不需要，保留给本地调试用）
ALLOWED_ORIGIN=*
