# 复制此文件为 .env，填入真实密钥
# cp .env.example .env

# ── 职位搜索（多源，按优先级降级）────────────────────────────────────────────

# 1. RapidAPI JSearch（主力：北美职位搜索）
# 申请：https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPID_API_KEY=你的RapidAPI密钥
RAPID_API_HOST=jsearch.p.rapidapi.com
RAPID_API_URL=https://jsearch.p.rapidapi.com

# 2. Adzuna（备用：覆盖美/英/加/澳/新加坡等多国，免费 100次/天）
# 申请：https://developer.adzuna.com/  → Create App → 获取 App ID 和 App Key
ADZUNA_APP_ID=你的AdzunaAppID
ADZUNA_APP_KEY=你的AdzunaAppKey

# 3. RemoteOK（远程职位专区，完全免费无需 Key，自动生效）
# 4. The Muse（精选科技/创业公司职位，完全免费无需 Key，自动生效）
# 职位功能总开关。设为 false 后，职位列表/详情、职位搜索、一键申请及聚合接口统一关闭。
RECRUITMENT_FEATURE_ENABLED=false
# 会员权益展示开关。微信支付/正式权益内容上线前保持 false，隐藏会员页入口和权益跳转。
MEMBERSHIP_FEATURE_ENABLED=false

# 5. LinkedIn Jobs（RapidAPI，需单独订阅）
# 订阅地址：https://rapidapi.com/jaypat87/api/linkedin-jobs-search
# 订阅后无需新 Key，复用 RAPID_API_KEY，只需配置 Host：
LINKEDIN_RAPID_HOST=linkedin-job-search-api.p.rapidapi.com

# 6. Indeed（RapidAPI，需单独订阅）
# 订阅地址：https://rapidapi.com/hris1533/api/indeed12
# 订阅后无需新 Key，复用 RAPID_API_KEY，只需配置 Host：
INDEED_RAPID_HOST=indeed12.p.rapidapi.com

# 7. Glassdoor 公司评价（RapidAPI，需单独订阅）
# 订阅地址：https://rapidapi.com/Search?term=glassdoor
# 订阅后无需新 Key，复用 RAPID_API_KEY，只需配置 Host：
GLASSDOOR_RAPID_HOST=glassdoor.p.rapidapi.com

# AI model provider. Default recommendation: Volcengine Ark / Doubao.
AI_PROVIDER=ark
ARK_API_KEY=YOUR_ARK_API_KEY_HERE
ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_MODEL=doubao-seed-2-1-pro-260628
AI_API_KEY=
AI_API_URL=
AI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 服务端口
PORT=3001

# Runtime environment: production deployments must set NODE_ENV=production.
NODE_ENV=development

# ── 生产持久化路径 ───────────────────────────────────────────────────────────
# 生产建议把数据库、上传文件、后台职位数据放到代码目录之外，避免 git pull/重新部署误删。
# Linux 示例：
# DATA_DIR=/var/lib/jobapp-server/data
# UPLOAD_DIR=/var/lib/jobapp-server/uploads
# DB_PATH=/var/lib/jobapp-server/db/jobapp.db
DATA_DIR=
UPLOAD_DIR=
DB_PATH=

# Feishu / Lark data sync. Use module-specific credentials when different
# Feishu apps own different Bases.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Campus calendar Base sync.
FEISHU_CAMPUS_APP_ID=
FEISHU_CAMPUS_APP_SECRET=
FEISHU_CAMPUS_BASE_TOKEN=
FEISHU_CAMPUS_TABLE_ID=

# Company profile Base sync. The wiki token is resolved to the real Base token
# automatically. Set FEISHU_COMPANY_TABLE_ID when the Base contains multiple
# tables and auto-detection cannot identify the company table.
FEISHU_COMPANY_APP_ID=
FEISHU_COMPANY_APP_SECRET=
FEISHU_COMPANY_WIKI_TOKEN=
FEISHU_COMPANY_BASE_TOKEN=
FEISHU_COMPANY_TABLE_ID=
FEISHU_COMPANY_TABLE_NAME=
FEISHU_COMPANY_IMPORT_API_BASE_URL=https://feishu-bitable-action-api.onrender.com
FEISHU_COMPANY_IMPORT_MAX=1000

# ── 邮箱验证码（官网邮箱登录）──────────────────────────────────────────────────
# 推荐用 QQ 邮箱：登录 mail.qq.com → 设置 → 账户 → 开启 SMTP → 获取授权码
# 也可用 163 邮箱：smtp.163.com:465，授权码在 163 邮箱设置中生成
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ号@qq.com
SMTP_PASS=你的QQ邮箱授权码（不是登录密码）
# 可选，不填则自动用 SMTP_USER
SMTP_FROM=职引 <你的QQ号@qq.com>

# ── 官网资讯同步（同步到小程序“求职快讯/资讯”）──────────────────────────────
# 支持 RSS/Atom：多个地址用英文逗号分隔，如 https://www.example.com/feed.xml
OFFICIAL_NEWS_FEEDS=
# 支持 JSON API：返回数组，或 {articles/items/list/data:[...]}；多个地址用英文逗号分隔
OFFICIAL_NEWS_API_URLS=
# 小程序中展示的官网来源名称
OFFICIAL_NEWS_SOURCE_NAME=职引官网

# 腾讯云语音识别 / 短信：生产环境如启用对应功能需完整配置；缺失时生产环境会拒绝 mock/dev 成功
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_ASR_APPID=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# 微信小程序（登录鉴权必填）
# 在 https://mp.weixin.qq.com → 开发 → 开发管理 → 开发设置 中获取
# Production requires WX_APP_ID/WX_APP_SECRET. Missing values are only tolerated in local development.
WX_APP_ID=你的小程序AppID
WX_APP_SECRET=你的小程序AppSecret

# JWT 签名密钥（生产环境请改为随机长字符串）
JWT_SECRET=jobapp_super_secret_key_change_in_production
JWT_EXPIRES_IN=30d

# Admin console login. Production requires both values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password

# GitHub Webhook 签名密钥（必须配置，否则 /webhook/deploy 会拒绝执行）
WEBHOOK_SECRET=请填写GitHubWebhookSecret

# 内部定时任务密钥（保护职位聚合刷新、投递状态轮询等内部接口）
# 生产环境必须配置为 32 位以上随机字符串，例如：openssl rand -hex 32
CRON_SECRET=请填写内部任务密钥

# 微信订阅消息模板 ID（在微信公众平台 → 订阅消息 → 我的模板 中获取）
WX_TPL_APPLICATION=  # 申请状态更新
WX_TPL_INTERVIEW=    # AI面试完成提醒
WX_TPL_SYSTEM=       # 系统通知
WX_TPL_PAYMENT_SUCCESS=   # 订单支付成功通知
WX_TPL_PAYMENT_REMINDER=  # 订单支付提醒

# ── 会员支付 ───────────────────────────────────────────────────────────────
# PAYMENT_PROVIDER=virtual 使用小程序虚拟支付；PAYMENT_PROVIDER=wxpay 使用普通微信支付 JSAPI。
# 支付正式开放时，也要把 MEMBERSHIP_FEATURE_ENABLED=true 打开小程序会员入口。
PAYMENT_ENABLED=false
PAYMENT_PROVIDER=virtual

# 小程序虚拟支付（道具直购）
# 在微信公众平台 → 虚拟支付 → 基础配置 / 道具配置 中获取。
# env=0 使用现网 AppKey；env=1 使用沙箱 AppKey。正式版小程序只能使用 env=0。
VIRTUAL_PAY_ENV=0
VIRTUAL_PAY_OFFER_ID=
VIRTUAL_PAY_APP_KEY=
VIRTUAL_PAY_SANDBOX_APP_KEY=
VIRTUAL_PAY_CURRENCY=CNY
VIRTUAL_PAY_MODE=short_series_goods
VIRTUAL_PAY_MONTH_PRODUCT_ID=
VIRTUAL_PAY_QUARTER_PRODUCT_ID=
VIRTUAL_PAY_YEAR_PRODUCT_ID=
# 可选：一周体验会员道具。微信后台道具价格要求整数元，建议配置为 viptrial7d / 10 元。
VIRTUAL_PAY_TRIAL_PRODUCT_ID=
# 配置微信消息与事件推送时填写的 Token，用于校验虚拟支付发货通知。
VIRTUAL_PAY_NOTIFY_TOKEN=

# 普通微信支付（WXPAY v2 JSAPI，保留兼容）
# 申请地址：https://pay.weixin.qq.com → 产品中心 → 小程序支付
# WXPAY_APP_ID 通常与 WX_APP_ID 相同
WXPAY_MCH_ID=         # 商户号（10位数字）
WXPAY_API_KEY=        # API 密钥（32位字符，v2签名密钥）
WXPAY_APP_ID=         # 小程序 AppID（与 WX_APP_ID 相同）
WXPAY_NOTIFY_URL=     # 异步回调地址，如 https://yourdomain.com/api/payment/notify
                      # ⚠️ 非生产环境未配置以上4项时自动进入 Mock 模式（开发测试用）

# 允许跨域的来源（小程序不需要；浏览器管理后台需要精确来源，多个用逗号分隔）
ALLOWED_ORIGIN=https://api.zhiyincareer.com,https://mp.weixin.qq.com,http://localhost:3001,http://127.0.0.1:3001
