# 复制此文件为 .env，填入真实密钥
# cp .env.example .env

# ── 职位搜索（多源，按优先级降级）────────────────────────────────────────────

# 1. RapidAPI JSearch（主力：北美职位搜索）
# 申请：https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPID_API_KEY=你的RapidAPI密钥
RAPID_API_HOST=jsearch.p.rapidapi.com
RAPID_API_URL=https://jsearch.p.rapidapi.com

# 2. Adzuna（备用：覆盖美/英/加/澳/新加坡等多国，免费 100次/天）
# 申请：https://developer.adzuna.com/  → Create App → 获取 App ID 和 App Key
ADZUNA_APP_ID=你的AdzunaAppID
ADZUNA_APP_KEY=你的AdzunaAppKey

# 3. RemoteOK（远程职位专区，完全免费无需 Key，自动生效）

# DeepSeek AI（面试对话/题库生成）
DEEPSEEK_API_KEY=你的DeepSeek密钥
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# 服务端口
PORT=3000

# 微信小程序（登录鉴权必填）
# 在 https://mp.weixin.qq.com → 开发 → 开发管理 → 开发设置 中获取
WX_APP_ID=你的小程序AppID
WX_APP_SECRET=你的小程序AppSecret

# JWT 签名密钥（生产环境请改为随机长字符串）
JWT_SECRET=jobapp_super_secret_key_change_in_production
JWT_EXPIRES_IN=30d

# GitHub Webhook 签名密钥（必须配置，否则 /webhook/deploy 会拒绝执行）
WEBHOOK_SECRET=请填写GitHubWebhookSecret

# 微信订阅消息模板 ID（在微信公众平台 → 订阅消息 → 我的模板 中获取）
WX_TPL_APPLICATION=  # 申请状态更新
WX_TPL_INTERVIEW=    # AI面试完成提醒
WX_TPL_SYSTEM=       # 系统通知

# ── 微信支付（WXPAY v2 JSAPI）──────────────────────────────────────
# 申请地址：https://pay.weixin.qq.com → 产品中心 → 小程序支付
# WXPAY_APP_ID 通常与 WX_APP_ID 相同
WXPAY_MCH_ID=         # 商户号（10位数字）
WXPAY_API_KEY=        # API 密钥（32位字符，v2签名密钥）
WXPAY_APP_ID=         # 小程序 AppID（与 WX_APP_ID 相同）
WXPAY_NOTIFY_URL=     # 异步回调地址，如 https://yourdomain.com/api/payment/notify
                      # ⚠️ 未配置以上4项时自动进入 Mock 模式（开发测试用）

# 允许跨域的来源（小程序不需要；浏览器管理后台需要精确来源，多个用逗号分隔）
ALLOWED_ORIGIN=http://localhost:3001
