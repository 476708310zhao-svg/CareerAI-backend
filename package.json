{
  "name": "overseas-student-job-backend",
  "version": "1.0.0",
  "description": "留学生求职小程序后端服务",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node tests/all.test.js",
    "bot:acceptance": "node scripts/acceptance-bot.js",
    "bot:career-line": "node scripts/acceptance-bot.js --full-static",
    "bot:e2e-3.0": "node scripts/e2e-3.0-bot.js",
    "check:e2e-3.0": "node scripts/e2e-3.0-bot.js --dry-run",
    "check:acceptance": "node scripts/acceptance-bot.js --full-static",
    "check:miniprogram": "node scripts/check-miniprogram.js",
    "check:data": "node scripts/check-data-content.js",
    "check:release": "npm test && npm run check:miniprogram && npm run check:data",
    "seed:ops-content": "node scripts/seed_ops_content.js",
    "sync:campus": "node scripts/sync_feishu_server.js",
    "sync:companies": "node scripts/sync_feishu_companies.js",
    "dispatch:reminders": "node scripts/dispatch_reminders.js",
    "refresh:aggregate": "node scripts/refresh_aggregate_jobs.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^12.8.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^1.1.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "miniprogram-automator": "^0.12.1",
    "nodemon": "^3.1.4"
  }
}
